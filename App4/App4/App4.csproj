  <!--
    GoPxL SDK native DLL referansları — YEREL klasöre bağlı (taşınabilir).
    Bu sayede repo başka bir PC'ye klonlandığında HintPath dosya sistemine
    dayanmadan derleme başarılı olur. DLL'ler repo içinde:
      App4\Utilities\14630-1.3.7.26_SOFTWARE_GoPxL_SDK\GoPxL_SDK_dotNet\bin\win64\
  -->
  <ItemGroup>
    <Reference Include="GoPxLSdkNet">
      <HintPath>Utilities\14630-1.3.7.26_SOFTWARE_GoPxL_SDK\GoPxL_SDK_dotNet\bin\win64\GoPxLSdkNet.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="MessagePack">
      <HintPath>Utilities\14630-1.3.7.26_SOFTWARE_GoPxL_SDK\GoPxL_SDK_dotNet\bin\win64\MessagePack.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="MessagePack.Annotations">
      <HintPath>Utilities\14630-1.3.7.26_SOFTWARE_GoPxL_SDK\GoPxL_SDK_dotNet\bin\win64\MessagePack.Annotations.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="Microsoft.Bcl.AsyncInterfaces">
      <HintPath>Utilities\14630-1.3.7.26_SOFTWARE_GoPxL_SDK\GoPxL_SDK_dotNet\bin\win64\Microsoft.Bcl.AsyncInterfaces.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="Microsoft.NET.StringTools">
      <HintPath>Utilities\14630-1.3.7.26_SOFTWARE_GoPxL_SDK\GoPxL_SDK_dotNet\bin\win64\Microsoft.NET.StringTools.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="Newtonsoft.Json">
      <HintPath>Utilities\14630-1.3.7.26_SOFTWARE_GoPxL_SDK\GoPxL_SDK_dotNet\bin\win64\Newtonsoft.Json.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="System.Collections.Immutable">
      <HintPath>Utilities\14630-1.3.7.26_SOFTWARE_GoPxL_SDK\GoPxL_SDK_dotNet\bin\win64\System.Collections.Immutable.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
