	<ItemGroup>
		<Content Include="Assets\PointCloud3DViewer.html">
		  <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
		<Content Include="Assets\HandEyeVisualizer.html">
		  <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
		<Content Include="Assets\RobotArmViewer.html">
		  <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
		<!-- UI logosu (MainWindow sol ust kose + login overlay).
		     Unpackaged WinUI 3'te ms-appx:// URI'si publish klasorunde
		     fiziken dosya arar. Explicit Content olmadan publish'e kopyalanmiyor. -->
		<Content Include="Assets\SBS_Logo.png">
		  <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
		<Content Include="Assets\SBS_Logo.ico">
		  <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
		<!-- Kacak haritasi diyagramlari + nokta koordinat JSON'u (Trend kacak gosterimi).
		     ms-appx:///Assets/LeakMaps/... ile yuklenir; publish'e kopyalanmali. -->
		<Content Include="Assets\LeakMaps\**\*.*">
		  <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
		<!-- 3D modeller (.glb) artik installer/seed/Models/ altindan
		     C:\Simbiosis\SimbiosisLeakTestApp\Models'e seed ediliyor.
		     Publish klasorune kopyalamaya gerek yok - bu ~100MB tasarruf
		     ve duplikasyonu onler. ModelsPathHelper C:\Simbiosis...
		     lokasyonunu kullanir. -->
	</ItemGroup>
	
	<ItemGroup>
	  <None Update="PAGES\Trend_Page.xaml">
	    <Generator>MSBuild:Compile</Generator>
	  </None>
	</ItemGroup>
	
	<ItemGroup>
	  <Page Update="PAGES\MultiRobot_Page.xaml">
		<Generator>MSBuild:Compile</Generator>
	  </Page>
	</ItemGroup>
	
	<ItemGroup>
	  <Page Update="PAGES\PLC_Page.xaml">
	    <Generator>MSBuild:Compile</Generator>
	  </Page>
	</ItemGroup>
    <!-- ═══════════════════════════════════════════════════════════════════
         Publish Properties (SETUP üretimi için)
         - PublishTrimmed = False: WinUI 3'te XAML reflection'ı kırar, KAPALI!
         - PublishSingleFile = False: XAML resource paketleme sorunu yaratır
         - PublishReadyToRun = True: Release'de hızlı başlatma için OK
         - WindowsPackageType = None: Unpackaged mod (MSIX değil)
         - SelfContained = True: Hedef PC'de .NET 8 Runtime gerekmez (Inno kurar)
    ═══════════════════════════════════════════════════════════════════ -->
  <PropertyGroup>
    <PublishReadyToRun Condition="'$(Configuration)' == 'Debug'">False</PublishReadyToRun>
    <PublishReadyToRun Condition="'$(Configuration)' != 'Debug'">True</PublishReadyToRun>
    <PublishTrimmed>False</PublishTrimmed>
    <PublishSingleFile>False</PublishSingleFile>
    <WindowsPackageType>None</WindowsPackageType>
    <SelfContained Condition="'$(Configuration)' != 'Debug'">true</SelfContained>
    <WindowsAppSDKSelfContained Condition="'$(Configuration)' != 'Debug'">true</WindowsAppSDKSelfContained>
  </PropertyGroup>

  <!-- ═══════════════════════════════════════════════════════════════════
       UNPACKAGED WinUI 3 için App4.pri publish kopyalama düzeltmesi.
       `dotnet publish` WindowsPackageType=None modunda uygulamanın kendi
       resources.pri dosyasını (App4.pri) publish klasörüne taşımıyor.
       Bu dosya olmadan MainWindow.xaml yüklenemiyor ve başlangıçta
       XamlParseException (0x802B000A) atıyor. Aşağıdaki hedef bu bug'ı
       telafi ediyor — bin klasöründen publish klasörüne kopyalıyor.
       Referans: https://github.com/microsoft/WindowsAppSDK/issues/
  ═══════════════════════════════════════════════════════════════════ -->
  <Target Name="_CopyAppPriToPublishDir"
          AfterTargets="Publish"
          Condition="'$(WindowsPackageType)' == 'None'">
    <ItemGroup>
      <_AppPriToPublish Include="$(OutputPath)$(AssemblyName).pri" />
    </ItemGroup>
    <Message Importance="high"
             Text="[App4.pri FIX] Kopyalaniyor: %(_AppPriToPublish.FullPath) -> $(PublishDir)"
             Condition="Exists('%(_AppPriToPublish.FullPath)')" />
    <Copy SourceFiles="@(_AppPriToPublish)"
          DestinationFolder="$(PublishDir)"
          Condition="Exists('%(_AppPriToPublish.FullPath)')"
          SkipUnchangedFiles="true" />
    <Warning Text="[App4.pri FIX] $(OutputPath)$(AssemblyName).pri bulunamadi - publish eksik olabilir!"
             Condition="!Exists('$(OutputPath)$(AssemblyName).pri')" />
  </Target>
</Project>