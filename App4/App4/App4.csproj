    <None Remove="Models\cad04778-stylish-bml-h-outdoor-top.glb" />
    <None Remove="Models\cad04811-mini-skyair-bml-h-outdoor-top.glb" />
    <None Remove="Models\cad05046-sensira50-all-assy-piping.glb" />
    <None Remove="Models\RXM71A5V1B.glb" />
    <None Remove="PAGES\Klima_Editor_Page.xaml" />
    <None Remove="PAGES\PLC_Page.xaml" />
    <None Remove="PAGES\Recipes_Page.xaml" />
    <None Remove="PAGES\Robot_Page.xaml" />
    <None Remove="Settings_Page.xaml" />
  </ItemGroup>
  <ItemGroup>
  </ItemGroup>

  <ItemGroup>
