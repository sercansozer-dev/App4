<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="App4.MainWindow"
    xmlns:utils="using:App4.Utilities"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Simbiosis Mekatronik - Kontrol Merkezi">

    <Grid x:Name="RootGrid" Background="#1C1C1C">
        <NavigationView x:Name="MainNav" 
                PaneDisplayMode="Left" 
                ItemInvoked="MainNav_ItemInvoked"
                Background="#1C1C1C"
                IsSettingsVisible="True"
                IsBackButtonVisible="Collapsed" 
                OpenPaneLength="280">

            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="#161616" />
                <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#161616" />

                <SolidColorBrush x:Key="NavigationViewItemForeground" Color="White" />
                <SolidColorBrush x:Key="NavigationViewItemForegroundPointerOver" Color="White" />
                <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="#00A2FF" />

                <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver" Color="#2D2D2D" />

                <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected" Color="#252526" />
            </NavigationView.Resources>

            <NavigationView.PaneHeader>
                <StackPanel Padding="12,20,12,10">
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="50" Height="50" Background="#252526" CornerRadius="8" BorderBrush="#333333" BorderThickness="1">
                            <Image Source="Assets/SBS_Logo.png" Margin="5"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="SİMBİOSİS" FontSize="14" FontWeight="Black" Foreground="White" CharacterSpacing="80"/>
                            <TextBlock Text="MEKATRONİK" FontSize="9" FontWeight="SemiBold" Foreground="#00A2FF"/>
                        </StackPanel>
                    </Grid>

                    <Button x:Name="LoginTriggerBtn" Click="LoginTrigger_Click" HorizontalAlignment="Stretch" 
                            Background="#1A1A1C" BorderBrush="#333333" BorderThickness="1" CornerRadius="10" Padding="12,10">
                        <Grid HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <FontIcon Glyph="&#xE77B;" FontSize="20" Foreground="#00A2FF"/>
                                <Ellipse x:Name="UserStatusLed" Width="8" Height="8" Fill="Gray" 
                                         HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-2,-2"/>
                            </Grid>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="CurrentUserText" Text="Giriş Yapılmadı" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                <TextBlock x:Name="CurrentRoleText" Text="Sınırlı Erişim" FontSize="9" Foreground="Gray"/>
                            </StackPanel>
                            <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="10" Foreground="Gray"/>
                        </Grid>
                    </Button>
                    <Rectangle Height="1" Fill="#333333" Margin="5,15,5,5"/>
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Otomatik Mod" Tag="auto" Icon="Target" Margin="0,5,0,0"/>
                <!-- Manuel Mod sayfası gösterimden kaldırıldı (istek üzerine). Geri açmak için yorumdan çıkar. -->
                <!--<NavigationViewItem Content="Manuel Mod" Tag="manuel" Icon="Edit" Margin="0,5,0,0"/>-->
                <NavigationViewItem Icon="Camera" Content="Kamera Görüntüsü" Tag="camera" Margin="0,5,0,0"/>
                <NavigationViewItem Content="PLC Kontrol" Tag="plc">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!--<NavigationViewItem Content="Reçete Yönetimi" Tag="recipes" Icon="Library" Margin="0,5,0,0"/>-->
                <NavigationViewItem Content="Robot Entegrasyonu" Tag="robot" Icon="Remote" Margin="0,5,0,0"/>
                <NavigationViewItem Content="Çoklu Robot" Tag="multirobot" Margin="0,5,0,0">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE99A;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Trend ve Rapor" Tag="trend" Margin="0,5,0,0">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Alarm Kayıtları" Tag="faultlog" Margin="0,5,0,0">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7BA;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!-- Helyum Kaçak sayfası geçici olarak gizlendi (uygulama crash nedeniyle).
                     Sayfa stabil hale getirildikten sonra tekrar açılacak.
                <NavigationViewItem Content="Helyum Kaçak" Tag="inficon" Margin="0,5,0,0">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9CE;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                -->
                <!-- NOT: Page routing (inficon → InficonPage) MainWindow.xaml.cs içinde hala aktif olabilir —
                     ama nav öğesi olmadığı için kullanıcı oraya ulaşamaz. İleride açarken buradaki comment'i
                     kaldırmak yeterli. -->
                <NavigationViewItem x:Name="NavItem_KlimaEditor" Content="Klima Editörü" Tag="Klima_Editor_Page" Margin="0,5,0,0" Visibility="Collapsed">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE70F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItemSeparator/>
                <NavigationViewItem Content="Uygulamayı Kapat" Tag="exit" FontWeight="Bold" Margin="0,0,0,10" Foreground="#FF5252">
                    <NavigationViewItem.Icon>
                        <PathIcon Data="M12,2 A10,10 0 1,0 22,12 A10,10 0 0,0 12,2 M12,4 A8,8 0 0,1 19,12 A8,8 0 0,1 12,20 A8,8 0 0,1 5,12 A8,8 0 0,1 12,4 M11,7 V13 H13 V7 H11 Z" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <NavigationView.PaneFooter>
                <Border Margin="12,10,12,20" Padding="12" Background="#1A1A1C" CornerRadius="10" BorderThickness="1" BorderBrush="#2D2D2D">
                    <StackPanel Spacing="8">
                        <TextBlock Text="SİSTEM DURUMU" FontSize="9" Foreground="Gray" FontWeight="Bold"/>
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse x:Name="GocatorStatusLed" Width="8" Height="8" Fill="#4CAF50" VerticalAlignment="Center"/>
                                <TextBlock x:Name="GocatorStatusText" Text="Gocator 3D" FontSize="11" Foreground="White"/>
                            </StackPanel>
                            <TextBlock Text="v1.2.4" HorizontalAlignment="Right" FontSize="9" Foreground="#444444" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse x:Name="PlcStatusLed" Width="8" Height="8" Fill="Gray" VerticalAlignment="Center"/>
                                <TextBlock x:Name="PlcStatusText" Text="PLC Bağlantısı" FontSize="11" Foreground="White"/>
                            </StackPanel>
                            <TextBlock x:Name="PlcStatusDetail" Text="---" HorizontalAlignment="Right" FontSize="9" Foreground="#444444" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse x:Name="RobotStatusLed" Width="8" Height="8" Fill="Gray" VerticalAlignment="Center"/>
                                <TextBlock x:Name="RobotStatusText" Text="Robot" FontSize="11" Foreground="White"/>
                            </StackPanel>
                            <TextBlock x:Name="RobotStatusDetail" Text="---" HorizontalAlignment="Right" FontSize="9" Foreground="#444444" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame" Padding="0"/>
        </NavigationView>

        <Grid x:Name="LoginOverlay" Visibility="Collapsed" Background="#CC000000" Canvas.ZIndex="2000">
            <Viewbox MaxWidth="900" MaxHeight="750">
                <Border Background="#1E1E1E" CornerRadius="24" Width="820" Height="700" 
                        HorizontalAlignment="Center" VerticalAlignment="Center" 
                        BorderBrush="#333333" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Background="#252526" CornerRadius="24,0,0,24" Padding="30">
                            <Image Source="Assets/SBS_Logo.png" Height="100" Margin="0,20,0,40"/>
                            <TextBlock Text="GÜVENLİ ERİŞİM" FontSize="18" FontWeight="Black" Foreground="#00A2FF" HorizontalAlignment="Center"/>
                            <FontIcon Glyph="&#xE72E;" FontSize="70" Foreground="#121212" Margin="0,120,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Padding="40" Spacing="15">
                            <ComboBox x:Name="UserRoleCombo" Header="Yetki Seviyesi" HorizontalAlignment="Stretch" SelectedIndex="0" MaxDropDownHeight="200" Canvas.ZIndex="999">
                                <ComboBoxItem Content="Operatör"/>
                                <ComboBoxItem Content="Expert"/>
                                <ComboBoxItem Content="Admin"/>
                            </ComboBox>
                            <PasswordBox x:Name="PasswordInput" Header="PIN KODU" RequestedTheme="Dark" FontSize="42" Foreground="White" PasswordRevealMode="Peek" 
                                         HorizontalAlignment="Stretch" Height="110" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                         Background="#1A1A1B" BorderThickness="0,0,0,3" BorderBrush="#00A2FF" SelectionHighlightColor="#00A2FF" CornerRadius="8"
                                         KeyDown="PasswordInput_KeyDown"/>
                            <TextBlock x:Name="LoginStatusText" Text="" Foreground="#FF5252" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Height="24" Margin="0,-10,0,0"/>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="75"/>
                                    <RowDefinition Height="75"/>
                                    <RowDefinition Height="75"/>
                                    <RowDefinition Height="75"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.Resources>
                                    <Style TargetType="Button">
                                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                        <Setter Property="VerticalAlignment" Value="Stretch"/>
                                        <Setter Property="Margin" Value="4"/>
                                        <Setter Property="FontSize" Value="26"/>
                                        <Setter Property="Background" Value="#2D2D2D"/>
                                        <Setter Property="CornerRadius" Value="12"/>
                                    </Style>
                                </Grid.Resources>

                                <Button Grid.Row="0" Grid.Column="0" Content="1" Click="Numpad_Click"/>
                                <Button Grid.Row="0" Grid.Column="1" Content="2" Click="Numpad_Click"/>
                                <Button Grid.Row="0" Grid.Column="2" Content="3" Click="Numpad_Click"/>
                                <Button Grid.Row="1" Grid.Column="0" Content="4" Click="Numpad_Click"/>
                                <Button Grid.Row="1" Grid.Column="1" Content="5" Click="Numpad_Click"/>
                                <Button Grid.Row="1" Grid.Column="2" Content="6" Click="Numpad_Click"/>
                                <Button Grid.Row="2" Grid.Column="0" Content="7" Click="Numpad_Click"/>
                                <Button Grid.Row="2" Grid.Column="1" Content="8" Click="Numpad_Click"/>
                                <Button Grid.Row="2" Grid.Column="2" Content="9" Click="Numpad_Click"/>
                                <Button Grid.Row="3" Grid.Column="0" Content="C" Click="Numpad_Clear_Click" Background="#442D2D"/>
                                <Button Grid.Row="3" Grid.Column="1" Content="0" Click="Numpad_Click"/>
                                <Button Grid.Row="3" Grid.Column="2" Click="Numpad_Backspace_Click">
                                    <FontIcon Glyph="&#xE94F;" FontFamily="Segoe MDL2 Assets" FontSize="22"/>
                                </Button>
                            </Grid>

                            <Grid ColumnDefinitions="*,*" Margin="0,10,0,0">
                                <Button x:Name="CancelBtn" Content="Vazgeç" Click="LoginCancel_Click" Grid.Column="0" Margin="5" HorizontalAlignment="Stretch" Height="55" Background="#333333"/>
                                <Button x:Name="ConfirmBtn" Content="Sisteme Giriş" Click="LoginConfirm_Click" Grid.Column="1" Margin="5" HorizontalAlignment="Stretch" Height="55" Background="#00A2FF" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </Viewbox>
        </Grid>

        <Grid x:Name="AppSplashScreen" Canvas.ZIndex="9999" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <!-- Background -->
            <Grid>
                <Grid.Background>
                    <RadialGradientBrush Center="0.5,0.45" GradientOrigin="0.5,0.45" RadiusX="0.7" RadiusY="0.7">
                        <GradientStop Color="#0B1220" Offset="0"/>
                        <GradientStop Color="#050810" Offset="0.5"/>
                        <GradientStop Color="#020304" Offset="1"/>
                    </RadialGradientBrush>
                </Grid.Background>
            </Grid>

            <StackPanel x:Name="SplashContent" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">

                <!-- Logo + Spinner -->
                <Grid Width="250" Height="250" HorizontalAlignment="Center">
                    <Grid.Resources>
                        <Storyboard x:Name="PulseLogoAnim" RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetName="GlowEffect" Storyboard.TargetProperty="Opacity"
                                             From="0.05" To="0.2" Duration="0:0:2.5"/>
                            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             From="1" To="1.15" Duration="0:0:2.5"/>
                            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             From="1" To="1.15" Duration="0:0:2.5"/>
                        </Storyboard>
                        <Storyboard x:Name="SpinnerAnim" RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="SpinnerRing"
                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                             From="0" To="360" Duration="0:0:2.8"/>
                        </Storyboard>
                    </Grid.Resources>

                    <!-- Glow -->
                    <Ellipse x:Name="GlowEffect" Width="190" Height="190" Fill="#00A2FF"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             RenderTransformOrigin="0.5,0.5" Opacity="0.05">
                        <Ellipse.RenderTransform>
                            <ScaleTransform/>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- Outer static ring -->
                    <Ellipse Width="238" Height="238" Stroke="#0D1E35" StrokeThickness="1"
                             Fill="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- Spinner ring -->
                    <Grid x:Name="SpinnerRing" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <RotateTransform/>
                        </Grid.RenderTransform>
                        <!-- Primary arc -->
                        <Path Data="M125,10 A115,115 0 0 1 224,68"
                              Stroke="#00A2FF" StrokeThickness="2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.7"/>
                        <!-- Counter arc -->
                        <Path Data="M125,240 A115,115 0 0 1 26,68"
                              Stroke="#00A2FF" StrokeThickness="1.2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.2"/>
                        <!-- Endpoint dot -->
                        <Ellipse Width="7" Height="7" Fill="#00A2FF"
                                 HorizontalAlignment="Center" VerticalAlignment="Top"
                                 Margin="0,6,0,0" Opacity="0.9"/>
                    </Grid>

                    <!-- Logo card -->
                    <Border Background="#0A0F1A" CornerRadius="26" BorderBrush="#1A2540" BorderThickness="1"
                            Padding="26" Translation="0,0,32" Width="150" Height="150"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>
                        <Image Source="Assets/SBS_Logo.png"/>
                    </Border>
                </Grid>

                <!-- Brand -->
                <StackPanel Spacing="6" HorizontalAlignment="Center">
                    <TextBlock Text="SİMBİOSİS" FontSize="34" FontWeight="Black" Foreground="White"
                               HorizontalAlignment="Center" CharacterSpacing="200"/>
                    <TextBlock Text="MEKATRONİK" FontSize="11" FontWeight="SemiBold" Foreground="#00A2FF"
                               HorizontalAlignment="Center" CharacterSpacing="500"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" Margin="0,8,0,0">
                        <Rectangle Width="45" Height="1" VerticalAlignment="Center" Opacity="0.6">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#00A2FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <TextBlock Text="LEAK TEST &amp; VISION SYSTEM" FontSize="9" FontWeight="SemiBold"
                                   Foreground="#6A8DAD" CharacterSpacing="350" VerticalAlignment="Center"/>
                        <Rectangle Width="45" Height="1" VerticalAlignment="Center" Opacity="0.6">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00A2FF" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </StackPanel>
                </StackPanel>

                <!-- Loading Steps -->
                <StackPanel Width="340" Spacing="7" HorizontalAlignment="Center">
                    <Grid x:Name="Step1Panel" Opacity="0.5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="Step1Icon" Text="○" FontSize="12" Foreground="#4A7090" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock x:Name="Step1Text" Text="Sistem yapılandırması" FontSize="11" Foreground="#7A9AB8" Grid.Column="1" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid x:Name="Step2Panel" Opacity="0.5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="Step2Icon" Text="○" FontSize="12" Foreground="#4A7090" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock x:Name="Step2Text" Text="PLC bağlantısı" FontSize="11" Foreground="#7A9AB8" Grid.Column="1" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid x:Name="Step3Panel" Opacity="0.5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="Step3Icon" Text="○" FontSize="12" Foreground="#4A7090" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock x:Name="Step3Text" Text="Gocator 3D sensör" FontSize="11" Foreground="#7A9AB8" Grid.Column="1" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid x:Name="Step4Panel" Opacity="0.5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="Step4Icon" Text="○" FontSize="12" Foreground="#4A7090" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock x:Name="Step4Text" Text="KUKA robot arayüzü" FontSize="11" Foreground="#7A9AB8" Grid.Column="1" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid x:Name="Step5Panel" Opacity="0.5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="Step5Icon" Text="○" FontSize="12" Foreground="#4A7090" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock x:Name="Step5Text" Text="Arayüz hazırlanıyor" FontSize="11" Foreground="#7A9AB8" Grid.Column="1" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Thin progress bar -->
                    <ProgressBar IsIndeterminate="True" Height="2" Foreground="#00A2FF" Background="#0A1525" CornerRadius="1" Margin="0,5,0,0"/>
                    <TextBlock x:Name="SplashStatusText" Text="Sistem başlatılıyor..." FontSize="10"
                               Foreground="#7090AA" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Footer -->
                <StackPanel HorizontalAlignment="Center" Opacity="0.5" Spacing="3">
                    <TextBlock Text="v2.0  •  GOCATOR  •  KUKA  •  WinUI 3" FontSize="9"
                               Foreground="#5A7A98" HorizontalAlignment="Center" CharacterSpacing="150"/>
                    <TextBlock Text="© 2025 Simbiosis Mekatronik" FontSize="8"
                               Foreground="#3A5A78" HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>