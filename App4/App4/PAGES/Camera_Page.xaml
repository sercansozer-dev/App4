<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App4.PAGES.Camera_Page"
    xmlns:local="using:App4.PAGES"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:utils="using:App4.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    NavigationCacheMode="Required">
    <Page.Resources>
        <utils:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <local:BoolToPlayPauseIconConverter x:Key="BoolToPlayPauseIconConverter"/>
    </Page.Resources>
    <Grid Background="#0D0D0D">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- BAŞLIK BÖLÜMÜ - Header -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1A1A1C" BorderThickness="0,0,0,2" BorderBrush="#00A4EF" Padding="25,0">
            <Grid VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="KAMERA KONTROL PANELİ" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Gocator Sensör | Point Cloud 3D Analiz" FontSize="11" Foreground="#00A4EF" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="20" VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center" Spacing="5">
                        <TextBlock Text="SİSTEM DURUMU" FontSize="9" Foreground="#888888" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="StatusLabel" Text="HAZIR" FontSize="13" FontWeight="Bold" Foreground="#4CAF50"/>
                    </StackPanel>
                    <FontIcon Glyph="&#xE957;" Foreground="#4CAF50" FontSize="24"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- İKİ PANEL: FOTO ÇEKIMI (SOL) + 3D POINT CLOUD (SAĞ) -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="20" Padding="0,20,0,20">

                <Grid Height="550" Padding="20,0" ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1A1A1C" CornerRadius="12" BorderThickness="2" BorderBrush="#00A4EF" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="45"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#252526" CornerRadius="10,10,0,0" Padding="15,0" BorderThickness="0,0,0,2" BorderBrush="#00A4EF">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                    <FontIcon Glyph="&#xE722;" Foreground="#00A4EF" FontSize="20"/>
                                    <TextBlock Text="FOTOGRAF ÇEKIMI" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="1" Background="#0D0D0D">
                                <Canvas Opacity="0.03">
                                    <Path Stroke="White" StrokeThickness="0.5" Data="M0,50 H2000 M0,100 H2000 M50,0 V2000 M100,0 V2000"/>
                                </Canvas>
                                <TextBlock x:Name="NoDataText" Text="🖼️ GÖRÜNTÜ BEKLENİYOR" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#555555" FontWeight="Bold" Opacity="0.6" FontSize="13" TextAlignment="Center"/>
                                <Image x:Name="SensorDisplay" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="25,25,25,25" RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <TransformGroup>
                                            <RotateTransform Angle="90"/>
                                            <ScaleTransform ScaleX="-0.75" ScaleY="0.75"/>
                                        </TransformGroup>
                                    </Image.RenderTransform>
                                </Image>
                                <ProgressRing x:Name="LoadingRing" IsActive="False" Width="70" Height="70" Foreground="#00A4EF" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>

                            <Border Grid.Row="2" Background="#1A1A1C" CornerRadius="0,0,10,10" Padding="15,0" BorderThickness="0,2,0,0" BorderBrush="#00A4EF">
                                <Grid VerticalAlignment="Center">
                                    <StackPanel>
                                        <TextBlock Text="Durum:" FontSize="10" Foreground="#888888"/>
                                        <TextBlock x:Name="PhotoStatus" Text="Hazırlanıyor..." FontSize="12" Foreground="#4CAF50" FontWeight="Bold" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="PhotoButton" Click="RunButton_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Width="110" Height="40" Background="#00A4EF" CornerRadius="8" FontWeight="Bold" FontSize="12" Foreground="White">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE722;" FontSize="14"/>
                                            <TextBlock Text="ÇEK"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="#1A1A1C" CornerRadius="12" BorderThickness="2" BorderBrush="#00A4EF" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="45"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#252526" CornerRadius="10,10,0,0" Padding="15,0" BorderThickness="0,0,0,2" BorderBrush="#00A4EF">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                    <FontIcon Glyph="&#xE71D;" Foreground="#00A4EF" FontSize="20"/>
                                    <TextBlock Text="3D POINT CLOUD" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="1" Background="#0D0D0D" x:Name="WebViewContainer">
                                <controls:WebView2 x:Name="PointCloudWebView"/>
                            </Grid>

                            <Border Grid.Row="2" Background="#1A1A1C" CornerRadius="0,0,10,10" Padding="15,0" BorderThickness="0,2,0,0" BorderBrush="#00A4EF">
                                <Grid VerticalAlignment="Center">
                                    <StackPanel>
                                        <TextBlock Text="Durum:" FontSize="10" Foreground="#888888"/>
                                        <TextBlock x:Name="Cloud3DStatus" Text="Hazırlanıyor..." FontSize="12" Foreground="#4CAF50" FontWeight="Bold" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="SurfaceButton" Click="SurfaceButton_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Width="130" Height="40" Background="#00A4EF" CornerRadius="8" FontWeight="Bold" FontSize="12" Foreground="White">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE71D;" FontSize="14"/>
                                            <TextBlock Text="SURFACE"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Border Background="#1A1A1C" Height="150" Margin="20,0" BorderThickness="2" BorderBrush="#00A4EF" CornerRadius="10" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="15,0" BorderThickness="0,0,0,2" BorderBrush="#00A4EF">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                                <FontIcon Glyph="&#xE7C3;" Foreground="#00A4EF" FontSize="16"/>
                                <TextBlock Text="LOG KONSOLU" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                            <TextBlock x:Name="LogOutput" Text="[00:00:00] ► Uygulama başlatıldı..." Foreground="#00FF88" FontFamily="Cascadia Mono" FontSize="10" Padding="15,10" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Grid Margin="20,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#0F2940" CornerRadius="10" BorderBrush="#00A4EF" BorderThickness="2" Padding="15" MinHeight="240">
                        <Grid RowSpacing="10" Padding="0,5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header Section -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <Border Background="#00A4EF" CornerRadius="6" Padding="10" MinWidth="40" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE964;" Foreground="White" FontSize="18"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="OTOMASYON KONTROL" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="PLC Tag Bağlantısı ve Tetikleme" FontSize="9" Foreground="#AAA"/>
                                </StackPanel>
                                <Rectangle Width="1" Height="30" Fill="#00A4EF" Opacity="0.3" Margin="10,0"/>
                                <StackPanel Spacing="5" VerticalAlignment="Center">
                                    <TextBlock Text="MOD:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <RadioButton GroupName="AutomationMode" Content="Otomatik" 
                                                     IsChecked="{x:Bind IsAutomationMode, Mode=TwoWay}"
                                                     Foreground="White" FontSize="10"/>
                                        <RadioButton GroupName="AutomationMode" Content="Manuel" 
                                                     IsChecked="{x:Bind IsManualMode, Mode=TwoWay}"
                                                     Foreground="White" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- Tags and Button Section -->
                            <Grid Grid.Row="1" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>

                                <!-- RFID TAG SECTION -->
                                <Border Grid.Column="0" Background="#1A2A3A" CornerRadius="8" BorderBrush="#2A4A5A" BorderThickness="1" Padding="12">
                                    <StackPanel Spacing="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="RFID TAG" FontSize="10" FontWeight="Bold" Foreground="#00A4EF"/>
                                            <TextBlock Text="Kart Tanımlama" FontSize="8" Foreground="#666"/>
                                        </StackPanel>
                                        
                                        <Border Background="#0F1F2F" CornerRadius="6" BorderBrush="#00A4EF" BorderThickness="1" Padding="8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="SEÇİM:" FontSize="8" Foreground="#888" Visibility="{x:Bind IsAutomationMode, Mode=OneWay}"/>
                                                <TextBlock Text="{x:Bind SelectedRfidTag, Mode=OneWay}" 
                                                           Foreground="#00FF88" FontSize="12" FontWeight="Bold" FontFamily="Cascadia Mono"
                                                           Visibility="{x:Bind IsAutomationMode, Mode=OneWay}"/>
                                                <TextBlock Text="DEĞER:" FontSize="8" Foreground="#888" Margin="0,4,0,0"/>
                                                <Border Background="#1A3A4A" CornerRadius="4" Padding="0" BorderBrush="#FFB81C" BorderThickness="1"
                                                        Visibility="{x:Bind IsAutomationMode, Mode=OneWay}">
                                                    <TextBlock Text="{x:Bind RfidTagValue, Mode=OneWay}" 
                                                               Foreground="#FFB81C" FontSize="13" FontWeight="Bold" FontFamily="Cascadia Mono" Padding="6,3"/>
                                                </Border>
                                                <TextBox x:Name="TxtManualRfid" PlaceholderText="Değer girin..."
                                                         Text="{x:Bind ManualRfidValue, Mode=TwoWay}"
                                                         Visibility="{x:Bind IsManualMode, Mode=OneWay}"
                                                         Background="#1A3A4A" Foreground="#FFB81C" BorderBrush="#FFB81C"
                                                         FontSize="13" FontWeight="Bold" FontFamily="Cascadia Mono"
                                                         Padding="6,3" Height="32" CornerRadius="4"/>
                                            </StackPanel>
                                        </Border>
                                        
                                        <ComboBox x:Name="CmbRfidTag" 
                                            ItemsSource="{x:Bind PlcInputTags, Mode=OneWay}" 
                                            SelectedItem="{x:Bind SelectedRfidTag, Mode=TwoWay}"
                                            SelectionChanged="AutomationComboBox_SelectionChanged"
                                            PlaceholderText="Tag Seçiniz..." 
                                            HorizontalAlignment="Stretch" FontSize="11" Height="34" VerticalAlignment="Center"
                                            Foreground="White" Background="#0F1F2F" BorderBrush="#00A4EF" BorderThickness="2" CornerRadius="6">
                                            <ComboBox.Resources>
                                                <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#1A2A3A"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#E0E0E0"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="White"/>
                                                <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#00A4EF"/>
                                                <SolidColorBrush x:Key="ComboBoxPlaceHolderForeground" Color="#666"/>
                                            </ComboBox.Resources>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <!-- JOB INDEX TAG SECTION -->
                                <Border Grid.Column="1" Background="#1A2A3A" CornerRadius="8" BorderBrush="#2A4A5A" BorderThickness="1" Padding="12">
                                    <StackPanel Spacing="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="JOB INDEX TAG" FontSize="10" FontWeight="Bold" Foreground="#00A4EF"/>
                                            <TextBlock Text="İş Indeksi" FontSize="8" Foreground="#666"/>
                                        </StackPanel>
                                        
                                        <Border Background="#0F1F2F" CornerRadius="6" BorderBrush="#00A4EF" BorderThickness="1" Padding="8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="SEÇİM:" FontSize="8" Foreground="#888" Visibility="{x:Bind IsAutomationMode, Mode=OneWay}"/>
                                                <TextBlock Text="{x:Bind SelectedIndexTag, Mode=OneWay}" 
                                                           Foreground="#00FF88" FontSize="12" FontWeight="Bold" FontFamily="Cascadia Mono"
                                                           Visibility="{x:Bind IsAutomationMode, Mode=OneWay}"/>
                                                <TextBlock Text="DEĞER:" FontSize="8" Foreground="#888" Margin="0,4,0,0"/>
                                                <Border Background="#1A3A4A" CornerRadius="4" Padding="0" BorderBrush="#00FF88" BorderThickness="1"
                                                        Visibility="{x:Bind IsAutomationMode, Mode=OneWay}">
                                                    <TextBlock Text="{x:Bind IndexTagValue, Mode=OneWay}" 
                                                               Foreground="#00FF88" FontSize="13" FontWeight="Bold" FontFamily="Cascadia Mono" Padding="6,3"/>
                                                </Border>
                                                <TextBox x:Name="TxtManualIndex" PlaceholderText="Değer girin..."
                                                         Text="{x:Bind ManualIndexValue, Mode=TwoWay}"
                                                         Visibility="{x:Bind IsManualMode, Mode=OneWay}"
                                                         Background="#1A3A4A" Foreground="#00FF88" BorderBrush="#00FF88"
                                                         FontSize="13" FontWeight="Bold" FontFamily="Cascadia Mono"
                                                         Padding="6,3" Height="32" CornerRadius="4"/>
                                            </StackPanel>
                                        </Border>
                                        
                                        <ComboBox x:Name="CmbIndexTag" 
                                            ItemsSource="{x:Bind PlcInputTags, Mode=OneWay}" 
                                            SelectedItem="{x:Bind SelectedIndexTag, Mode=TwoWay}"
                                            SelectionChanged="AutomationComboBox_SelectionChanged"
                                            PlaceholderText="Tag Seçiniz..."
                                            HorizontalAlignment="Stretch" FontSize="11" Height="34" VerticalAlignment="Center"
                                            Foreground="White" Background="#0F1F2F" BorderBrush="#00A4EF" BorderThickness="2" CornerRadius="6">
                                            <ComboBox.Resources>
                                                <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#1A2A3A"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#E0E0E0"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="White"/>
                                                <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#00A4EF"/>
                                                <SolidColorBrush x:Key="ComboBoxPlaceHolderForeground" Color="#666"/>
                                            </ComboBox.Resources>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <!-- TRIGGER TAG SECTION -->
                                <Border Grid.Column="2" Background="#1A2A3A" CornerRadius="8" BorderBrush="#2A4A5A" BorderThickness="1" Padding="12">
                                    <StackPanel Spacing="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="TETİK (TRIGGER)" FontSize="10" FontWeight="Bold" Foreground="#00A4EF"/>
                                            <TextBlock Text="Tetikleme Sinyali" FontSize="8" Foreground="#666"/>
                                        </StackPanel>
                                        
                                        <Border Background="#0F1F2F" CornerRadius="6" BorderBrush="#00A4EF" BorderThickness="1" Padding="8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="SEÇİM:" FontSize="8" Foreground="#888" Visibility="{x:Bind IsAutomationMode, Mode=OneWay}"/>
                                                <TextBlock Text="{x:Bind SelectedTriggerTag, Mode=OneWay}" 
                                                           Foreground="#00FF88" FontSize="12" FontWeight="Bold" FontFamily="Cascadia Mono"
                                                           Visibility="{x:Bind IsAutomationMode, Mode=OneWay}"/>
                                                <TextBlock Text="DURUM:" FontSize="8" Foreground="#888" Margin="0,4,0,0"
                                                           Visibility="{x:Bind IsAutomationMode, Mode=OneWay}"/>
                                                <Border Background="#1A3A2A" CornerRadius="4" Padding="6,3" BorderBrush="#00BFFF" BorderThickness="1"
                                                        Visibility="{x:Bind IsAutomationMode, Mode=OneWay}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                        <FontIcon Glyph="{x:Bind utils:GlobalData.IsProcessRunning, Mode=OneWay, Converter={StaticResource BoolToPlayPauseIconConverter}}" FontSize="10" Foreground="#00FF88"/>
                                                        <TextBlock Text="{x:Bind utils:GlobalData.ProcessStatus, Mode=OneWay}" Foreground="#00BFFF" FontSize="11" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                        
                                        <ComboBox x:Name="CmbTriggerTag" 
                                            ItemsSource="{x:Bind PlcInputTags, Mode=OneWay}" 
                                            SelectedItem="{x:Bind SelectedTriggerTag, Mode=TwoWay}"
                                            SelectionChanged="AutomationComboBox_SelectionChanged"
                                            PlaceholderText="Tag Seçiniz..."
                                            HorizontalAlignment="Stretch" FontSize="11" Height="34" VerticalAlignment="Center"
                                            Foreground="White" Background="#0F1F2F" BorderBrush="#00A4EF" BorderThickness="2" CornerRadius="6">
                                            <ComboBox.Resources>
                                                <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#1A2A3A"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#E0E0E0"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="White"/>
                                                <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#00A4EF"/>
                                                <SolidColorBrush x:Key="ComboBoxPlaceHolderForeground" Color="#666"/>
                                            </ComboBox.Resources>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <!-- OUTPUT SIGNAL TAG SECTION -->
                                <Border Grid.Column="3" Background="#1A2A3A" CornerRadius="8" BorderBrush="#2A4A5A" BorderThickness="1" Padding="12">
                                    <StackPanel Spacing="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="ÖLÇÜM SONUCU (OUTPUT)" FontSize="10" FontWeight="Bold" Foreground="#00A4EF"/>
                                            <TextBlock Text="Tamamlandı Sinyali" FontSize="8" Foreground="#666"/>
                                        </StackPanel>
                                        
                                        <Border Background="#0F1F2F" CornerRadius="6" BorderBrush="#00A4EF" BorderThickness="1" Padding="8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="SİNYAL DURUMU:" FontSize="8" Foreground="#888"/>
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <TextBlock Text="{x:Bind MeasurementOutputStatusText, Mode=OneWay}" Foreground="{x:Bind MeasurementOutputStatusColor, Mode=OneWay}" FontSize="11" FontWeight="Bold"/> 
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        
                                        <ComboBox x:Name="CmbMeasurementOutputTag" 
                                            ItemsSource="{x:Bind PlcOutputTags, Mode=OneWay}" 
                                            SelectedItem="{x:Bind SelectedMeasurementOutputTag, Mode=TwoWay}"
                                            SelectionChanged="AutomationComboBox_SelectionChanged"
                                            PlaceholderText="Tag Seçiniz..."
                                            HorizontalAlignment="Stretch" FontSize="11" Height="34" VerticalAlignment="Center"
                                            Foreground="White" Background="#0F1F2F" BorderBrush="#00A4EF" BorderThickness="2" CornerRadius="6">
                                            <ComboBox.Resources>
                                                <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#1A2A3A"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#E0E0E0"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="White"/>
                                                <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#00A4EF"/>
                                                <SolidColorBrush x:Key="ComboBoxPlaceHolderForeground" Color="#666"/>
                                            </ComboBox.Resources>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <!-- MANUEL START BUTTON -->
                                <Border Grid.Column="4" Background="#27AE60" CornerRadius="8" BorderBrush="#2ECC71" BorderThickness="2" Padding="0">
                                    <Button Click="BtnManualTrigger_Click" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" BorderThickness="0" Padding="0">
                                        <StackPanel Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE768;" Foreground="#2ECC71" FontSize="28"/>
                                            <TextBlock Text="MANUEL" FontSize="8" Foreground="#DDD" HorizontalAlignment="Center"/>
                                            <TextBlock Text="BAŞLAT" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" ColumnSpacing="20" RowSpacing="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#1A1A1C" BorderThickness="2" BorderBrush="#00A4EF" CornerRadius="10" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="40"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="15,0" BorderThickness="0,0,0,2" BorderBrush="#00A4EF">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                                        <FontIcon Glyph="&#xE8F4;" Foreground="#00A4EF" FontSize="16"/>
                                        <TextBlock Text="GOCATOR ALINANLAR (ÖLÇÜMLER)" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
                                    <StackPanel Spacing="5">
                                        <Grid Background="#2A2A2C" Height="35" CornerRadius="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="#" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Text="ÖLÇÜM ADI" Foreground="#AAA" VerticalAlignment="Center" Margin="10,0" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="2" Text="DEĞER" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="3" Text="DURUM" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                                        </Grid>

                                        <ItemsControl ItemsSource="{x:Bind utils:GlobalData.LastMeasurements, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="utils:GocatorMeasurement">
                                                    <Grid Height="40" Margin="0,0,0,2" Background="#0F0F0F" CornerRadius="4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="40"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="60"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{x:Bind Id}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" Opacity="0.5"/>
                                                        <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center" Margin="10,0" Foreground="White"/>
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind Value}" Foreground="#00A4EF" FontWeight="Bold"/>
                                                            <TextBlock Text="{x:Bind Unit}" Foreground="#00A4EF" Margin="4,0,0,0" FontSize="10" VerticalAlignment="Bottom"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="3" Background="{x:Bind StatusColor}" CornerRadius="4" Height="20" Width="50">
                                                            <TextBlock Text="{x:Bind Decision}" FontSize="10" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="Henüz ölçüm alınmadı." Foreground="#444" HorizontalAlignment="Center" Margin="0,20,0,0"
                                   Visibility="{x:Bind utils:GlobalData.LastMeasurements.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=Inverse, Mode=OneWay}"/>
                                    </StackPanel>
                                </ScrollViewer>

                                <Button Grid.Row="2" Click="BtnGetMeasurement_Click" Margin="10,0,10,10" HorizontalAlignment="Stretch" Background="#222" BorderBrush="#444" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE916;" FontSize="12" Foreground="Orange"/>
                                        <TextBlock Text="SENSÖRDEN YENİ ÖLÇÜM AL" FontSize="11" Foreground="White"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Background="#1A1A1C" BorderThickness="2" BorderBrush="#00A4EF" CornerRadius="10" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="45"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="10,0" BorderThickness="0,0,0,2" BorderBrush="#00A4EF">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                            <FontIcon Glyph="&#xE975;" Foreground="#00A4EF" FontSize="16"/>
                                            <TextBlock Text="PLC AKTARIM" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <Button Click="BtnBackup_Click" Height="26" Padding="8,0" CornerRadius="4" Background="#D35400" BorderThickness="0" ToolTipService.ToolTip="Uygulama Verilerini Yedekle">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xE753;" Foreground="White" FontSize="10"/>
                                                    <TextBlock Text="APP YEDEK" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Click="BtnBackupGocator_Click" Height="26" Padding="8,0" CornerRadius="4" Background="#00A4EF" BorderThickness="0" ToolTipService.ToolTip="Sensör Yedeğini İndir">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xE964;" Foreground="White" FontSize="10"/>
                                                    <TextBlock Text="GOCATOR" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
                                    <StackPanel x:Name="PlcTransferContainer" Spacing="5">
                                        <Grid Background="#2A2A2C" Height="35" CornerRadius="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="#" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Text="PLC TAG SEÇİMİ" Foreground="#AAA" VerticalAlignment="Center" Margin="10,0" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="2" Text="DEĞER" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="3" Text="SİL" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="9"/>
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding PlcTransferRows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Background="{Binding BackgroundColor}" Height="40" CornerRadius="4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="40"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="40"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Index}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontWeight="SemiBold" Opacity="0.5"/>
                                                        <ComboBox Grid.Column="1" 
                                                            ItemsSource="{Binding ElementName=PageRoot, Path=PlcOutputTags}"
                                                            SelectedItem="{Binding SelectedTag, Mode=TwoWay}"
                                                            Margin="5,0" Background="#252526" BorderThickness="1" BorderBrush="#444" CornerRadius="4" 
                                                            Foreground="White" PlaceholderText="Tag Seçiniz..." FontSize="11"
                                                            VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Value}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{Binding StatusColor}" FontWeight="Bold"/>
                                                        <Button Grid.Column="3" Click="BtnDeletePlcRow_Click" Background="Transparent" BorderThickness="0" Padding="0" HorizontalAlignment="Center">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="#E74C3C"/>
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="3"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>

                                <Button Grid.Row="2" Click="BtnAddPlcRow_Click" Margin="10,0,10,10" HorizontalAlignment="Stretch" Background="#222" BorderBrush="#444" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="#00FF88"/>
                                        <TextBlock Text="YENİ SATIR EKLE" FontSize="11" Foreground="White" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Border Grid.Row="3" Background="#1A1A1C" Margin="20,10,20,10" CornerRadius="10" BorderThickness="2" BorderBrush="#FFB81C">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="250"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,5" Background="#151515">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="45"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#252526" Padding="15,0" CornerRadius="8,8,0,0">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE8F1;" Foreground="#FFB81C" FontSize="16"/>
                                        <TextBlock Text="SENSÖR İŞ DOSYALARI (JOBS)" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Click="BtnRefreshJobs_Click" Background="#333" CornerRadius="4" Height="28" ToolTipService.ToolTip="Listeyi Yenile">
                                            <FontIcon Glyph="&#xE72C;" Foreground="White" FontSize="12"/>
                                        </Button>
                                        <Button Content="YÜKLE (LOAD)" Click="BtnLoadSelectedJob_Click" Background="#4CAF50" Foreground="White" FontSize="10" FontWeight="Bold" CornerRadius="4" Height="28"/>
                                        <Button Content="İNDİR" Click="BtnDownloadSelectedJob_Click" Background="#00A4EF" Foreground="White" FontSize="10" FontWeight="Bold" CornerRadius="4" Height="28"/>
                                        <Button Click="BtnUploadNewJob_Click" Background="#FF9800" CornerRadius="4" Height="28" ToolTipService.ToolTip="PC'den Job Yükle">
                                            <FontIcon Glyph="&#xE896;" Foreground="White" FontSize="12"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <ListView x:Name="SensorJobListView" Grid.Row="1" SelectionMode="Single" Background="#111">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="10" BorderBrush="#222" BorderThickness="0,0,0,1">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <FontIcon Glyph="&#xF133;" FontSize="12" Foreground="#888"/>
                                                <TextBlock Text="{Binding}" Foreground="White" FontSize="13" FontFamily="Cascadia Mono"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>

                        <Grid Grid.Row="1" Background="#1A1A1C" Margin="0,5,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="45"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#252526" Padding="15,0" BorderThickness="0,1,0,1" BorderBrush="#333">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE9D5;" Foreground="#00FF88" FontSize="16"/>
                                    <TextBlock Text="REÇETE YÖNETİMİ (KART GÖRÜNÜMÜ)" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Klima tipleri ve işlem adımları." FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <GridView Grid.Row="1" Padding="10" 
                      ItemsSource="{x:Bind utils:GlobalData.KnownRfids, Mode=OneWay}" 
                      SelectionMode="None">

                                <GridView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="-1" HorizontalAlignment="Left"/>
                                    </ItemsPanelTemplate>
                                </GridView.ItemsPanel>

                                <GridView.ItemContainerStyle>
                                    <Style TargetType="GridViewItem">
                                        <Setter Property="Margin" Value="0,0,10,10"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="VerticalAlignment" Value="Top"/>
                                    </Style>
                                </GridView.ItemContainerStyle>

                                <GridView.ItemTemplate>
                                    <DataTemplate x:DataType="utils:RfidDef">
                                        <Border Width="360" Background="#202020" BorderBrush="#444" BorderThickness="1" CornerRadius="6" Padding="10">
                                            <StackPanel Spacing="10">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Background="#00A4EF" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind Id}" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{x:Bind Description}" Foreground="#DDD" VerticalAlignment="Center" FontWeight="SemiBold" Margin="10,0,0,0" TextTrimming="CharacterEllipsis"/>
                                                </Grid>

                                                <Rectangle Height="1" Fill="#333"/>

                                                <TextBlock Text="İşlem Sırası:" FontSize="10" Foreground="#888"/>
                                                <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemsSource="{x:Bind IndexedJobSequence, Mode=OneWay}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="utils:IndexedJobItem">
                                                                <Grid Margin="0,0,0,4" Background="#2A2A2C" CornerRadius="4" Height="28">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="30"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="24"/>
                                                                        <ColumnDefinition Width="24"/>
                                                                        <ColumnDefinition Width="28"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Background="#00A4EF" CornerRadius="4" Width="22" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                        <TextBlock Text="{x:Bind Index}" Foreground="White" FontWeight="Bold" FontSize="10" 
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <TextBlock Grid.Column="1" Text="{x:Bind JobName}" Foreground="White" VerticalAlignment="Center" FontSize="11" Margin="5,0" TextTrimming="CharacterEllipsis"/>
                                                                    <!-- Yukarı Taşı Butonu -->
                                                                    <Button Grid.Column="2" 
                                                                            Click="MoveJobUp"
                                                                            Tag="{x:Bind Index}"
                                                                            Background="Transparent" Padding="0" BorderThickness="0" 
                                                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                            Width="22" Height="22" ToolTipService.ToolTip="Yukarı Taşı">
                                                                        <FontIcon Glyph="&#xE70E;" Foreground="#888" FontSize="10"/>
                                                                    </Button>
                                                                    <!-- Aşağı Taşı Butonu -->
                                                                    <Button Grid.Column="3" 
                                                                            Click="MoveJobDown"
                                                                            Tag="{x:Bind Index}"
                                                                            Background="Transparent" Padding="0" BorderThickness="0" 
                                                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                            Width="22" Height="22" ToolTipService.ToolTip="Aşağı Taşı">
                                                                        <FontIcon Glyph="&#xE70D;" Foreground="#888" FontSize="10"/>
                                                                    </Button>
                                                                    <!-- Sil Butonu -->
                                                                    <Button Grid.Column="4" 
                                                                            Click="RemoveJobFromSequence"
                                                                            Tag="{x:Bind JobName}"
                                                                            Background="Transparent" Padding="0" BorderThickness="0" HorizontalAlignment="Center">
                                                                        <FontIcon Glyph="&#xE74D;" Foreground="#E74C3C" FontSize="10"/>
                                                                    </Button>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="70"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox x:Name="CmbAddJob" 
                                              PlaceholderText="Job Seç..." 
                                              HorizontalAlignment="Stretch" 
                                              FontSize="11" Height="28"
                                              ItemsSource="{Binding ElementName=SensorJobListView, Path=DataContext.AvailableJobs}"
                                              Loaded="JobCombo_Loaded"/>
                                                    <Button Grid.Column="1" Content="+ EKLE" Click="BtnAddJobToSequence_Click" 
                                            Background="#27AE60" Foreground="White" FontSize="10" FontWeight="Bold" 
                                            Height="28" Margin="5,0,0,0" HorizontalAlignment="Stretch"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                        </Grid>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ALT DURUM ÇUBUĞU - Footer -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#252526" BorderThickness="0,2,0,0" BorderBrush="#00A4EF" Padding="25,0">
            <Grid VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Left">
                    <Ellipse Width="10" Height="10" Fill="#4CAF50" VerticalAlignment="Center"/>
                    <TextBlock Text="Çalışma Durumu:" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock Text="AKTIF" FontSize="11" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="© 2025 Simbiosis Mekatronik | Gocator 3D Sensor" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Right" 
                           FontSize="10" 
                           Foreground="#555555"/>
            </Grid>
        </Border>
    </Grid>
</Page>