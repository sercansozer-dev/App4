<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App4.PAGES.Camera_Page"
    xmlns:local="using:App4.PAGES"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:utils="using:App4.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    NavigationCacheMode="Required">
    <Page.Resources>
        <utils:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <local:BoolToPlayPauseIconConverter x:Key="BoolToPlayPauseIconConverter"/>
    </Page.Resources>
    <Grid Background="#0D0D0D">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- BAŞLIK BÖLÜMÜ - Header -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1A1A1C" BorderThickness="0,0,0,1" BorderBrush="#333" Padding="20,0">
            <Grid VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                    <Border Background="#00A4EF" CornerRadius="8" Width="40" Height="40">
                        <FontIcon Glyph="&#xE722;" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Kamera Kontrol Paneli" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Gocator Sensör | Point Cloud 3D Analiz" FontSize="11" Foreground="#888"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" VerticalAlignment="Center">
                    <Border Background="#1E1E20" CornerRadius="6" Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="#4CAF50"/>
                            <TextBlock x:Name="StatusLabel" Text="HAZIR" FontSize="11" Foreground="#888"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- İKİ PANEL: FOTO ÇEKIMI (SOL) + 3D POINT CLOUD (SAĞ) -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="20" Padding="0,20,0,20">

                <Grid Height="550" Padding="20,0" ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1A1A1C" CornerRadius="12" BorderThickness="1" BorderBrush="#333" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="45"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#252526" CornerRadius="10,10,0,0" Padding="15,0" BorderThickness="0,0,0,1" BorderBrush="#333">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                    <FontIcon Glyph="&#xE722;" Foreground="#00A4EF" FontSize="20"/>
                                    <TextBlock Text="FOTOGRAF ÇEKIMI" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="1" Background="#0D0D0D">
                                <Canvas Opacity="0.03">
                                    <Path Stroke="White" StrokeThickness="0.5" Data="M0,50 H2000 M0,100 H2000 M50,0 V2000 M100,0 V2000"/>
                                </Canvas>
                                <TextBlock x:Name="NoDataText" Text="🖼️ GÖRÜNTÜ BEKLENİYOR" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#555555" FontWeight="Bold" Opacity="0.6" FontSize="13" TextAlignment="Center"/>
                                <Image x:Name="SensorDisplay" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="25,25,25,25" RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <TransformGroup>
                                            <RotateTransform Angle="90"/>
                                            <ScaleTransform ScaleX="-0.75" ScaleY="0.75"/>
                                        </TransformGroup>
                                    </Image.RenderTransform>
                                </Image>
                                <ProgressRing x:Name="LoadingRing" IsActive="False" Width="70" Height="70" Foreground="#00A4EF" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>

                            <Border Grid.Row="2" Background="#1A1A1C" CornerRadius="0,0,10,10" Padding="15,0" BorderThickness="0,1,0,0" BorderBrush="#333">
                                <Grid VerticalAlignment="Center">
                                    <StackPanel>
                                        <TextBlock Text="Durum:" FontSize="10" Foreground="#888888"/>
                                        <TextBlock x:Name="PhotoStatus" Text="Hazırlanıyor..." FontSize="12" Foreground="#4CAF50" FontWeight="Bold" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="PhotoButton" Click="RunButton_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Width="110" Height="40" Background="#00A4EF" CornerRadius="8" FontWeight="Bold" FontSize="12" Foreground="White">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE722;" FontSize="14"/>
                                            <TextBlock Text="ÇEK"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="#1A1A1C" CornerRadius="12" BorderThickness="1" BorderBrush="#333" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="45"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#252526" CornerRadius="10,10,0,0" Padding="15,0" BorderThickness="0,0,0,1" BorderBrush="#333">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                    <FontIcon Glyph="&#xE71D;" Foreground="#00A4EF" FontSize="20"/>
                                    <TextBlock Text="3D POINT CLOUD" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="1" Background="#0D0D0D" x:Name="WebViewContainer">
                                <controls:WebView2 x:Name="PointCloudWebView"/>
                            </Grid>

                            <Border Grid.Row="2" Background="#1A1A1C" CornerRadius="0,0,10,10" Padding="15,0" BorderThickness="0,1,0,0" BorderBrush="#333">
                                <Grid VerticalAlignment="Center">
                                    <StackPanel>
                                        <TextBlock Text="Durum:" FontSize="10" Foreground="#888888"/>
                                        <TextBlock x:Name="Cloud3DStatus" Text="Hazırlanıyor..." FontSize="12" Foreground="#4CAF50" FontWeight="Bold" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="SurfaceButton" Click="SurfaceButton_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Width="130" Height="40" Background="#00A4EF" CornerRadius="8" FontWeight="Bold" FontSize="12" Foreground="White">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE71D;" FontSize="14"/>
                                            <TextBlock Text="SURFACE"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Border Background="#1A1A1C" Height="150" Margin="20,0" BorderThickness="1" BorderBrush="#333" CornerRadius="10" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="15,0" BorderThickness="0,0,0,1" BorderBrush="#333">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                                <FontIcon Glyph="&#xE7C3;" Foreground="#00A4EF" FontSize="16"/>
                                <TextBlock Text="LOG KONSOLU" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                            <TextBlock x:Name="LogOutput" Text="[00:00:00] ► Uygulama başlatıldı..." Foreground="#00FF88" FontFamily="Cascadia Mono" FontSize="10" Padding="15,10" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ═══════════════════════════════════════════════════════════════════ -->
                <!-- KAMERA KALİBRASYON - Eye-on-Hand Kalibrasyon Alanı -->
                <!-- ═══════════════════════════════════════════════════════════════════ -->
                <Border Background="#1A1A1C" Margin="20,0" CornerRadius="10" BorderThickness="1" BorderBrush="#333" Padding="15">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0">
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <Border Background="#FF6F00" CornerRadius="6" Padding="10" MinWidth="40" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE81E;" Foreground="White" FontSize="18"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="KAMERA KALİBRASYON" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Eye-on-Hand | Gocator - Robot TCP Eşleştirme" FontSize="9" Foreground="#AAA"/>
                                </StackPanel>
                                <Rectangle Width="1" Height="30" Fill="#FF6F00" Opacity="0.3" Margin="10,0"/>
                                <!-- Kalibrasyon Durumu -->
                                <Border x:Name="CalibStatusBorder" Background="#1E2D1E" CornerRadius="6" Padding="12,6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Ellipse x:Name="CalibStatusDot" Width="8" Height="8" Fill="#888"/>
                                        <TextBlock x:Name="CalibStatusText" Text="Kalibrasyon yapılmamış" FontSize="11" Foreground="#888"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Sag taraf: Butonlar -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <Button x:Name="BtnCalibLoad" Click="BtnCalibLoad_Click"
                                        Background="#2A2A2E" CornerRadius="6" Height="36" Padding="12,0"
                                        ToolTipService.ToolTip="Kaydedilmiş kalibrasyonu yükle">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE8E5;" FontSize="12" Foreground="#00A4EF"/>
                                        <TextBlock Text="YÜKLE" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnCalibSave" Click="BtnCalibSave_Click"
                                        Background="#2A2A2E" CornerRadius="6" Height="36" Padding="12,0"
                                        ToolTipService.ToolTip="Kalibrasyonu kaydet">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE74E;" FontSize="12" Foreground="#4CAF50"/>
                                        <TextBlock Text="KAYDET" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnCalibClear" Click="BtnCalibClear_Click"
                                        Background="#2A2A2E" CornerRadius="6" Height="36" Padding="12,0"
                                        ToolTipService.ToolTip="Toplanan pozları temizle">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="#E74C3C"/>
                                        <TextBlock Text="TEMİZLE" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- BallBar Parametreleri -->
                        <Border Grid.Row="1" Background="#141418" CornerRadius="8" Padding="10,8" BorderBrush="#333" BorderThickness="1">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Baslik -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xECAD;" Foreground="#FF6F00" FontSize="14"/>
                                    <TextBlock Text="BALLBAR" FontSize="10" FontWeight="Bold" Foreground="#FF6F00" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Top 1 Yaricap -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Text="Top 1 R:" FontSize="10" Foreground="#AAA" VerticalAlignment="Center"/>
                                    <controls:NumberBox x:Name="NbCalibSphere1Radius" Value="12.5" Minimum="1" Maximum="100"
                                              SpinButtonPlacementMode="Compact" SmallChange="0.1"
                                              FontSize="11" Width="100" Height="30"
                                              ValueChanged="CalibBallBarParam_ValueChanged"/>
                                    <TextBlock Text="mm" FontSize="9" Foreground="#666" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Top 2 Yaricap -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Text="Top 2 R:" FontSize="10" Foreground="#AAA" VerticalAlignment="Center"/>
                                    <controls:NumberBox x:Name="NbCalibSphere2Radius" Value="12.5" Minimum="1" Maximum="100"
                                              SpinButtonPlacementMode="Compact" SmallChange="0.1"
                                              FontSize="11" Width="100" Height="30"
                                              ValueChanged="CalibBallBarParam_ValueChanged"/>
                                    <TextBlock Text="mm" FontSize="9" Foreground="#666" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Cubuk Uzunlugu (merkez-merkez) -->
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Text="Cubuk:" FontSize="10" Foreground="#AAA" VerticalAlignment="Center"/>
                                    <controls:NumberBox x:Name="NbCalibBarLength" Value="50" Minimum="10" Maximum="500"
                                              SpinButtonPlacementMode="Compact" SmallChange="1"
                                              FontSize="11" Width="100" Height="30"
                                              ValueChanged="CalibBallBarParam_ValueChanged"/>
                                    <TextBlock Text="mm" FontSize="9" Foreground="#666" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Ozet -->
                                <TextBlock Grid.Column="4" x:Name="CalibBallBarSummary"
                                           Text="Top R=12.5mm | Cubuk=50mm (merkez-merkez)"
                                           FontSize="9" Foreground="#555" VerticalAlignment="Center" HorizontalAlignment="Right"
                                           FontFamily="Cascadia Mono"/>
                            </Grid>
                        </Border>

                        <!-- Aktif Robot Pozisyonu (canli) -->
                        <Border Grid.Row="2" Background="#141418" CornerRadius="8" Padding="12" BorderBrush="#333" BorderThickness="1">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Robot Secimi -->
                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center" MinWidth="100">
                                    <TextBlock Text="ROBOT" FontSize="9" FontWeight="Bold" Foreground="#FF6F00"/>
                                    <ComboBox x:Name="CmbCalibRobot" PlaceholderText="Robot Sec" FontSize="10" Height="30" MinWidth="100"
                                              SelectionChanged="CmbCalibRobot_SelectionChanged"/>
                                </StackPanel>

                                <!-- Job Secimi -->
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center" MinWidth="140">
                                    <TextBlock Text="GOCATOR JOB" FontSize="9" FontWeight="Bold" Foreground="#FFB81C"/>
                                    <ComboBox x:Name="CmbCalibJob" PlaceholderText="Job Sec..." FontSize="10" Height="30" MinWidth="140"/>
                                </StackPanel>

                                <!-- X -->
                                <StackPanel Grid.Column="2" Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="X (mm)" FontSize="9" FontWeight="Bold" Foreground="#00A4EF" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="CalibPosX" Text="---" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" FontFamily="Cascadia Mono"/>
                                </StackPanel>
                                <!-- Y -->
                                <StackPanel Grid.Column="3" Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Y (mm)" FontSize="9" FontWeight="Bold" Foreground="#00A4EF" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="CalibPosY" Text="---" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" FontFamily="Cascadia Mono"/>
                                </StackPanel>
                                <!-- Z -->
                                <StackPanel Grid.Column="4" Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Z (mm)" FontSize="9" FontWeight="Bold" Foreground="#00A4EF" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="CalibPosZ" Text="---" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" FontFamily="Cascadia Mono"/>
                                </StackPanel>
                                <!-- A -->
                                <StackPanel Grid.Column="5" Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="A (deg)" FontSize="9" FontWeight="Bold" Foreground="#FFB81C" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="CalibPosA" Text="---" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" FontFamily="Cascadia Mono"/>
                                </StackPanel>
                                <!-- B -->
                                <StackPanel Grid.Column="6" Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="B (deg)" FontSize="9" FontWeight="Bold" Foreground="#FFB81C" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="CalibPosB" Text="---" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" FontFamily="Cascadia Mono"/>
                                </StackPanel>
                                <!-- C -->
                                <StackPanel Grid.Column="7" Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="C (deg)" FontSize="9" FontWeight="Bold" Foreground="#FFB81C" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="CalibPosC" Text="---" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" FontFamily="Cascadia Mono"/>
                                </StackPanel>

                                <!-- POZ YAKALA Butonu -->
                                <Button Grid.Column="8" x:Name="BtnCalibCapture" Click="BtnCalibCapture_Click"
                                        Background="#FF6F00" CornerRadius="8" Height="40" Padding="16,0"
                                        ToolTipService.ToolTip="Secili job'i yukleyip olcum alir, robot pozu ile eslestirir">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE710;" FontSize="14" Foreground="White"/>
                                        <TextBlock Text="POZ YAKALA" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Toplanan Pozlar Tablosu -->
                        <Border Grid.Row="3" Background="#141418" CornerRadius="8" BorderBrush="#333" BorderThickness="1" MinHeight="120" MaxHeight="250">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Tablo Header -->
                                <Border Grid.Row="0" Background="#1E1E22" CornerRadius="8,8,0,0" Padding="12,0">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE8EF;" Foreground="#FF6F00" FontSize="14"/>
                                            <TextBlock Text="TOPLANAN KALİBRASYON POZLARI" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                            <Border Background="#FF6F00" CornerRadius="10" Padding="8,2" Margin="5,0">
                                                <TextBlock x:Name="CalibPoseCountBadge" Text="0" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock x:Name="CalibMinPoseHint" Text="(Min. 3 poz gerekli, 5+ önerilir)"
                                                   FontSize="9" Foreground="#888" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Tablo İçerik -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                                    <StackPanel x:Name="CalibPoseListPanel" Spacing="4">
                                        <!-- Poz satırları code-behind'dan dinamik eklenir -->
                                        <TextBlock x:Name="CalibNoPoseText" Text="Henüz poz toplanmadı. Robotu farklı pozisyonlara götürüp 'POZ YAKALA' butonuna basın."
                                                   FontSize="10" Foreground="#555" TextWrapping="Wrap" Padding="10" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Kalibrasyon Calistir + Sonuc -->
                        <Grid Grid.Row="4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Kalibrasyon Çalıştır Butonu -->
                            <Button Grid.Column="0" x:Name="BtnCalibRun" Click="BtnCalibRun_Click"
                                    Background="#4CAF50" CornerRadius="8" Height="44" Padding="20,0"
                                    ToolTipService.ToolTip="Tsai-Lenz kalibrasyonu çalıştır">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE768;" FontSize="16" Foreground="White"/>
                                    <TextBlock Text="KALİBRASYONU ÇALIŞTIR" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Button>

                            <!-- Sonuç Bilgisi -->
                            <Border Grid.Column="1" Background="#141418" CornerRadius="8" Padding="12" BorderBrush="#333" BorderThickness="1">
                                <Grid ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="HAND-EYE MATRİS" FontSize="9" FontWeight="Bold" Foreground="#FF6F00"/>
                                        <TextBlock x:Name="CalibResultText" Text="Kalibrasyon yapılmadı" FontSize="10" Foreground="#888" FontFamily="Cascadia Mono" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center" MinWidth="100">
                                        <TextBlock Text="POZ. HASSASIYET" FontSize="9" FontWeight="Bold" Foreground="#4CAF50"/>
                                        <TextBlock x:Name="CalibAccuracyPos" Text="--- mm" FontSize="12" FontWeight="Bold" Foreground="White" FontFamily="Cascadia Mono"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center" MinWidth="100">
                                        <TextBlock Text="AÇI HASSASIYET" FontSize="9" FontWeight="Bold" Foreground="#FFB81C"/>
                                        <TextBlock x:Name="CalibAccuracyAng" Text="--- °" FontSize="12" FontWeight="Bold" Foreground="White" FontFamily="Cascadia Mono"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                    </Grid>
                </Border>

                <Grid Margin="20,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1A1A1C" CornerRadius="10" BorderBrush="#333" BorderThickness="1" Padding="15" MinHeight="240">
                        <Grid RowSpacing="10" Padding="0,5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header Section -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <Border Background="#00A4EF" CornerRadius="6" Padding="10" MinWidth="40" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE964;" Foreground="White" FontSize="18"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="OTOMASYON KONTROL" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="PLC Tag Bağlantısı ve Tetikleme" FontSize="9" Foreground="#AAA"/>
                                </StackPanel>
                                <Rectangle Width="1" Height="30" Fill="#00A4EF" Opacity="0.3" Margin="10,0"/>
                                <StackPanel Spacing="5" VerticalAlignment="Center">
                                    <TextBlock Text="MOD:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <RadioButton GroupName="AutomationMode" Content="Otomatik" 
                                                     IsChecked="{x:Bind IsAutomationMode, Mode=TwoWay}"
                                                     Foreground="White" FontSize="10"/>
                                        <RadioButton GroupName="AutomationMode" Content="Manuel" 
                                                     IsChecked="{x:Bind IsManualMode, Mode=TwoWay}"
                                                     Foreground="White" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- Tags and Button Section -->
                            <Grid Grid.Row="1" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>

                                <!-- RFID TAG SECTION -->
                                <Border Grid.Column="0" Background="#1A2A3A" CornerRadius="8" BorderBrush="#2A4A5A" BorderThickness="1" Padding="12">
                                    <StackPanel Spacing="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="RFID TAG" FontSize="10" FontWeight="Bold" Foreground="#00A4EF"/>
                                            <TextBlock Text="Kart Tanımlama" FontSize="8" Foreground="#666"/>
                                        </StackPanel>
                                        
                                        <Border Background="#0F1F2F" CornerRadius="6" BorderBrush="#00A4EF" BorderThickness="1" Padding="8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="SEÇİM:" FontSize="8" Foreground="#888" Visibility="{x:Bind IsAutomationMode, Mode=OneWay}"/>
                                                <TextBlock Text="{x:Bind SelectedRfidTag, Mode=OneWay}" 
                                                           Foreground="#00FF88" FontSize="12" FontWeight="Bold" FontFamily="Cascadia Mono"
                                                           Visibility="{x:Bind IsAutomationMode, Mode=OneWay}"/>
                                                <TextBlock Text="DEĞER:" FontSize="8" Foreground="#888" Margin="0,4,0,0"/>
                                                <Border Background="#1A3A4A" CornerRadius="4" Padding="0" BorderBrush="#FFB81C" BorderThickness="1"
                                                        Visibility="{x:Bind IsAutomationMode, Mode=OneWay}">
                                                    <TextBlock Text="{x:Bind RfidTagValue, Mode=OneWay}" 
                                                               Foreground="#FFB81C" FontSize="13" FontWeight="Bold" FontFamily="Cascadia Mono" Padding="6,3"/>
                                                </Border>
                                                <TextBox x:Name="TxtManualRfid" PlaceholderText="Değer girin..."
                                                         Text="{x:Bind ManualRfidValue, Mode=TwoWay}"
                                                         Visibility="{x:Bind IsManualMode, Mode=OneWay}"
                                                         Background="#1A3A4A" Foreground="#FFB81C" BorderBrush="#FFB81C"
                                                         FontSize="13" FontWeight="Bold" FontFamily="Cascadia Mono"
                                                         Padding="6,3" Height="32" CornerRadius="4"/>
                                            </StackPanel>
                                        </Border>
                                        
                                        <ComboBox x:Name="CmbRfidTag"
                                            ItemsSource="{x:Bind PlcAllTags, Mode=OneWay}"
                                            SelectedItem="{x:Bind SelectedRfidTag, Mode=TwoWay}"
                                            SelectionChanged="AutomationComboBox_SelectionChanged"
                                            PlaceholderText="Tag Seçiniz..." 
                                            HorizontalAlignment="Stretch" FontSize="11" Height="34" VerticalAlignment="Center"
                                            Foreground="White" Background="#0F1F2F" BorderBrush="#00A4EF" BorderThickness="2" CornerRadius="6">
                                            <ComboBox.Resources>
                                                <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#1A2A3A"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#E0E0E0"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="White"/>
                                                <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#00A4EF"/>
                                                <SolidColorBrush x:Key="ComboBoxPlaceHolderForeground" Color="#666"/>
                                            </ComboBox.Resources>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <!-- JOB INDEX TAG SECTION -->
                                <Border Grid.Column="1" Background="#1A2A3A" CornerRadius="8" BorderBrush="#2A4A5A" BorderThickness="1" Padding="12">
                                    <StackPanel Spacing="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="JOB INDEX TAG" FontSize="10" FontWeight="Bold" Foreground="#00A4EF"/>
                                            <TextBlock Text="İş Indeksi" FontSize="8" Foreground="#666"/>
                                        </StackPanel>
                                        
                                        <Border Background="#0F1F2F" CornerRadius="6" BorderBrush="#00A4EF" BorderThickness="1" Padding="8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="SEÇİM:" FontSize="8" Foreground="#888" Visibility="{x:Bind IsAutomationMode, Mode=OneWay}"/>
                                                <TextBlock Text="{x:Bind SelectedIndexTag, Mode=OneWay}" 
                                                           Foreground="#00FF88" FontSize="12" FontWeight="Bold" FontFamily="Cascadia Mono"
                                                           Visibility="{x:Bind IsAutomationMode, Mode=OneWay}"/>
                                                <TextBlock Text="DEĞER:" FontSize="8" Foreground="#888" Margin="0,4,0,0"/>
                                                <Border Background="#1A3A4A" CornerRadius="4" Padding="0" BorderBrush="#00FF88" BorderThickness="1"
                                                        Visibility="{x:Bind IsAutomationMode, Mode=OneWay}">
                                                    <TextBlock Text="{x:Bind IndexTagValue, Mode=OneWay}" 
                                                               Foreground="#00FF88" FontSize="13" FontWeight="Bold" FontFamily="Cascadia Mono" Padding="6,3"/>
                                                </Border>
                                                <TextBox x:Name="TxtManualIndex" PlaceholderText="Değer girin..."
                                                         Text="{x:Bind ManualIndexValue, Mode=TwoWay}"
                                                         Visibility="{x:Bind IsManualMode, Mode=OneWay}"
                                                         Background="#1A3A4A" Foreground="#00FF88" BorderBrush="#00FF88"
                                                         FontSize="13" FontWeight="Bold" FontFamily="Cascadia Mono"
                                                         Padding="6,3" Height="32" CornerRadius="4"/>
                                            </StackPanel>
                                        </Border>
                                        
                                        <AutoSuggestBox x:Name="CmbIndexTag"
                                            PlaceholderText="&#xE721; Tag ara ve sec..."
                                            Text="{x:Bind SelectedIndexTag, Mode=TwoWay}"
                                            TextChanged="CmbIndexTag_TextChanged"
                                            SuggestionChosen="CmbIndexTag_SuggestionChosen"
                                            QuerySubmitted="CmbIndexTag_QuerySubmitted"
                                            HorizontalAlignment="Stretch" FontSize="11"
                                            Foreground="White" Background="#0F1F2F" BorderBrush="#00A4EF" BorderThickness="2" CornerRadius="6">
                                            <AutoSuggestBox.QueryIcon>
                                                <SymbolIcon Symbol="Find"/>
                                            </AutoSuggestBox.QueryIcon>
                                            <AutoSuggestBox.Resources>
                                                <SolidColorBrush x:Key="AutoSuggestBoxSuggestionsListBackground" Color="#1A2A3A"/>
                                                <SolidColorBrush x:Key="AutoSuggestBoxSuggestionsListBorderBrush" Color="#00A4EF"/>
                                            </AutoSuggestBox.Resources>
                                        </AutoSuggestBox>
                                    </StackPanel>
                                </Border>

                                <!-- TRIGGER TAG SECTION (Çift Tetik: Boru + Tabla) -->
                                <Border Grid.Column="2" Background="#1A2A3A" CornerRadius="8" BorderBrush="#2A4A5A" BorderThickness="1" Padding="12">
                                    <StackPanel Spacing="6">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="TETİK (TRIGGER)" FontSize="10" FontWeight="Bold" Foreground="#00A4EF"/>
                                            <TextBlock Text="Herhangi biri gelirse ölçüm tetiklenir" FontSize="8" Foreground="#666"/>
                                        </StackPanel>

                                        <!-- BORU ÖLÇÜM TETİK -->
                                        <Border Background="#0F1F2F" CornerRadius="6" BorderBrush="#FF9800" BorderThickness="1" Padding="6">
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="BORU ÖLÇÜM" FontSize="8" FontWeight="Bold" Foreground="#FF9800"/>
                                                    <TextBlock Text="{x:Bind SelectedTriggerTag, Mode=OneWay}"
                                                               Foreground="#00FF88" FontSize="10" FontWeight="Bold" FontFamily="Cascadia Mono"
                                                               Visibility="{x:Bind IsAutomationMode, Mode=OneWay}"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="#1A3A4A" CornerRadius="4" Padding="6,2" BorderBrush="#00FF88" BorderThickness="1"
                                                        Visibility="{x:Bind IsAutomationMode, Mode=OneWay}" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind TriggerTagValue, Mode=OneWay}"
                                                               Foreground="#00FF88" FontSize="11" FontWeight="Bold" FontFamily="Cascadia Mono"/>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <ComboBox x:Name="CmbTriggerTag"
                                            ItemsSource="{x:Bind Robot1InputTags, Mode=OneWay}"
                                            SelectedItem="{x:Bind SelectedTriggerTag, Mode=TwoWay}"
                                            SelectionChanged="AutomationComboBox_SelectionChanged"
                                            PlaceholderText="Boru Tetik Seçiniz..."
                                            HorizontalAlignment="Stretch" FontSize="10" Height="30" VerticalAlignment="Center"
                                            Foreground="White" Background="#0F1F2F" BorderBrush="#FF9800" BorderThickness="2" CornerRadius="6">
                                            <ComboBox.Resources>
                                                <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#1A2A3A"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#E0E0E0"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="White"/>
                                                <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#FF9800"/>
                                                <SolidColorBrush x:Key="ComboBoxPlaceHolderForeground" Color="#666"/>
                                            </ComboBox.Resources>
                                        </ComboBox>

                                        <!-- TABLA KAÇIKLIK TETİK -->
                                        <Border Background="#0F1F2F" CornerRadius="6" BorderBrush="#4CAF50" BorderThickness="1" Padding="6">
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="TABLA KAÇIKLIK" FontSize="8" FontWeight="Bold" Foreground="#4CAF50"/>
                                                    <TextBlock Text="{x:Bind SelectedTriggerTag2, Mode=OneWay}"
                                                               Foreground="#00FF88" FontSize="10" FontWeight="Bold" FontFamily="Cascadia Mono"
                                                               Visibility="{x:Bind IsAutomationMode, Mode=OneWay}"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="#1A3A4A" CornerRadius="4" Padding="6,2" BorderBrush="#00FF88" BorderThickness="1"
                                                        Visibility="{x:Bind IsAutomationMode, Mode=OneWay}" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind TriggerTag2Value, Mode=OneWay}"
                                                               Foreground="#00FF88" FontSize="11" FontWeight="Bold" FontFamily="Cascadia Mono"/>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <ComboBox x:Name="CmbTriggerTag2"
                                            ItemsSource="{x:Bind Robot1InputTags, Mode=OneWay}"
                                            SelectedItem="{x:Bind SelectedTriggerTag2, Mode=TwoWay}"
                                            SelectionChanged="AutomationComboBox_SelectionChanged"
                                            PlaceholderText="Tabla Tetik Seçiniz..."
                                            HorizontalAlignment="Stretch" FontSize="10" Height="30" VerticalAlignment="Center"
                                            Foreground="White" Background="#0F1F2F" BorderBrush="#4CAF50" BorderThickness="2" CornerRadius="6">
                                            <ComboBox.Resources>
                                                <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#1A2A3A"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#E0E0E0"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="White"/>
                                                <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#4CAF50"/>
                                                <SolidColorBrush x:Key="ComboBoxPlaceHolderForeground" Color="#666"/>
                                            </ComboBox.Resources>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <!-- BORU ÖLÇÜM ÇIKTISI -->
                                <Border Grid.Column="3" Background="#1A2A1A" CornerRadius="8" BorderBrush="#3A5A2A" BorderThickness="1" Padding="10">
                                    <StackPanel Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Ellipse Width="8" Height="8" Fill="#FF9800"/>
                                            <TextBlock Text="BORU ÇIKTI" FontSize="9" FontWeight="Bold" Foreground="#FF9800"/>
                                        </StackPanel>

                                        <Border Background="#0F1F0F" CornerRadius="6" BorderBrush="#FF9800" BorderThickness="1" Padding="6">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="SİNYAL:" FontSize="7" Foreground="#888"/>
                                                <TextBlock Text="{x:Bind MeasurementOutputStatusText, Mode=OneWay}" Foreground="{x:Bind MeasurementOutputStatusColor, Mode=OneWay}" FontSize="11" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Border>

                                        <ComboBox x:Name="CmbMeasurementOutputTag"
                                            ItemsSource="{x:Bind Robot1OutputTags, Mode=OneWay}"
                                            SelectedItem="{x:Bind SelectedMeasurementOutputTag, Mode=TwoWay}"
                                            SelectionChanged="AutomationComboBox_SelectionChanged"
                                            PlaceholderText="Tag Seçiniz..."
                                            HorizontalAlignment="Stretch" FontSize="10" Height="32" VerticalAlignment="Center"
                                            Foreground="White" Background="#0F1F0F" BorderBrush="#FF9800" BorderThickness="1.5" CornerRadius="5">
                                            <ComboBox.Resources>
                                                <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#1A2A1A"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#E0E0E0"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="White"/>
                                                <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#FF9800"/>
                                                <SolidColorBrush x:Key="ComboBoxPlaceHolderForeground" Color="#666"/>
                                            </ComboBox.Resources>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <!-- TABLA ÖLÇÜM ÇIKTISI -->
                                <Border Grid.Column="4" Background="#1A2A1A" CornerRadius="8" BorderBrush="#2A5A3A" BorderThickness="1" Padding="10">
                                    <StackPanel Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Ellipse Width="8" Height="8" Fill="#4CAF50"/>
                                            <TextBlock Text="TABLA ÇIKTI" FontSize="9" FontWeight="Bold" Foreground="#4CAF50"/>
                                        </StackPanel>

                                        <Border Background="#0F1F0F" CornerRadius="6" BorderBrush="#4CAF50" BorderThickness="1" Padding="6">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="SİNYAL:" FontSize="7" Foreground="#888"/>
                                                <TextBlock Text="{x:Bind TablaOutputStatusText, Mode=OneWay}" Foreground="{x:Bind TablaOutputStatusColor, Mode=OneWay}" FontSize="11" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Border>

                                        <ComboBox x:Name="CmbTablaOutputTag"
                                            ItemsSource="{x:Bind Robot1OutputTags, Mode=OneWay}"
                                            SelectedItem="{x:Bind SelectedTablaOutputTag, Mode=TwoWay}"
                                            SelectionChanged="AutomationComboBox_SelectionChanged"
                                            PlaceholderText="Tag Seçiniz..."
                                            HorizontalAlignment="Stretch" FontSize="10" Height="32" VerticalAlignment="Center"
                                            Foreground="White" Background="#0F1F0F" BorderBrush="#4CAF50" BorderThickness="1.5" CornerRadius="5">
                                            <ComboBox.Resources>
                                                <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#1A2A1A"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#E0E0E0"/>
                                                <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="White"/>
                                                <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#4CAF50"/>
                                                <SolidColorBrush x:Key="ComboBoxPlaceHolderForeground" Color="#666"/>
                                            </ComboBox.Resources>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <!-- MANUEL START BUTTON -->
                                <Border Grid.Column="5" Background="#27AE60" CornerRadius="8" BorderBrush="#2ECC71" BorderThickness="2" Padding="0">
                                    <Button Click="BtnManualTrigger_Click" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" BorderThickness="0" Padding="0">
                                        <StackPanel Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE768;" Foreground="#2ECC71" FontSize="28"/>
                                            <TextBlock Text="MANUEL" FontSize="8" Foreground="#DDD" HorizontalAlignment="Center"/>
                                            <TextBlock Text="BAŞLAT" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ═══ AKTİF KALİBRASYON MATRİSİ PANELİ ═══ -->
                    <Border Grid.Row="2" Background="#141418" CornerRadius="8" Padding="12" BorderBrush="#333" BorderThickness="1">
                        <Grid ColumnSpacing="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Durum ikonu + baslik -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Ellipse x:Name="CalibActiveStatusDot" Width="10" Height="10" Fill="#888"/>
                                <TextBlock Text="AKTİF KALİBRASYON" FontSize="10" FontWeight="Bold" Foreground="#FF6F00" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Hand-Eye Matris XYZABC -->
                            <Border Grid.Column="1" Background="#1E1E22" CornerRadius="6" Padding="10,6">
                                <Grid ColumnSpacing="15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="HAND-EYE:" FontSize="9" FontWeight="Bold" Foreground="#FF6F00" VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="3">
                                        <TextBlock Text="X:" FontSize="9" Foreground="#00A4EF" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="CalibMatX" Text="---" FontSize="10" FontWeight="Bold" Foreground="White" FontFamily="Cascadia Mono" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="3">
                                        <TextBlock Text="Y:" FontSize="9" Foreground="#00A4EF" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="CalibMatY" Text="---" FontSize="10" FontWeight="Bold" Foreground="White" FontFamily="Cascadia Mono" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="3">
                                        <TextBlock Text="Z:" FontSize="9" Foreground="#00A4EF" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="CalibMatZ" Text="---" FontSize="10" FontWeight="Bold" Foreground="White" FontFamily="Cascadia Mono" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="3">
                                        <TextBlock Text="A:" FontSize="9" Foreground="#FFB81C" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="CalibMatA" Text="---" FontSize="10" FontWeight="Bold" Foreground="White" FontFamily="Cascadia Mono" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="3">
                                        <TextBlock Text="B:" FontSize="9" Foreground="#FFB81C" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="CalibMatB" Text="---" FontSize="10" FontWeight="Bold" Foreground="White" FontFamily="Cascadia Mono" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="3">
                                        <TextBlock Text="C:" FontSize="9" Foreground="#FFB81C" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="CalibMatC" Text="---" FontSize="10" FontWeight="Bold" Foreground="White" FontFamily="Cascadia Mono" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="7" Orientation="Horizontal" Spacing="6" Margin="10,0,0,0">
                                        <TextBlock Text="Hassasiyet:" FontSize="9" Foreground="#4CAF50" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="CalibMatAccuracy" Text="--- mm" FontSize="10" FontWeight="Bold" Foreground="#4CAF50" FontFamily="Cascadia Mono" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Tarih -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE787;" FontSize="11" Foreground="#888"/>
                                <TextBlock x:Name="CalibMatDate" Text="---" FontSize="9" Foreground="#888" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Robot -->
                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE99A;" FontSize="11" Foreground="#888"/>
                                <TextBlock x:Name="CalibMatRobot" Text="---" FontSize="9" Foreground="#888" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="4" ColumnSpacing="15" RowSpacing="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ═══ SÜTUN 0: GOCATOR HAM VERİ ═══ -->
                        <Border Grid.Column="0" Background="#1A1A1C" BorderThickness="1" BorderBrush="#333" CornerRadius="10" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="40"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="15,0" BorderThickness="0,0,0,1" BorderBrush="#333">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                            <FontIcon Glyph="&#xE8F4;" Foreground="#FF9800" FontSize="16"/>
                                            <TextBlock Text="GOCATOR HAM VERİ" FontSize="11" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                            <Border Background="#FF9800" CornerRadius="4" Padding="6,2"><TextBlock Text="SENSOR" FontSize="9" FontWeight="Bold" Foreground="White"/></Border>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkSourceSensor" Grid.Column="1" Checked="ChkSourceSensor_Checked" IsChecked="True" VerticalAlignment="Center" MinWidth="0" Padding="0" ToolTipService.ToolTip="Bu veriyi Boru Ölçüm Aktarım tablosuna ilet"/>
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                                    <StackPanel Spacing="4">
                                        <Grid Background="#2A2A2C" Height="30" CornerRadius="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="#" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="10"/>
                                            <TextBlock Grid.Column="1" Text="ÖLÇÜM ADI" Foreground="#AAA" VerticalAlignment="Center" Margin="8,0" FontWeight="Bold" FontSize="10"/>
                                            <TextBlock Grid.Column="2" Text="DEĞER" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="Bold" FontSize="10"/>
                                            <TextBlock Grid.Column="3" Text="DURUM" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="9"/>
                                        </Grid>

                                        <ItemsControl ItemsSource="{x:Bind utils:GlobalData.LastMeasurements, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="utils:GocatorMeasurement">
                                                    <Grid Height="36" Margin="0,0,0,2" Background="#0F0F0F" CornerRadius="4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="70"/>
                                                            <ColumnDefinition Width="50"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{x:Bind Id}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" Opacity="0.5" FontSize="10"/>
                                                        <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center" Margin="8,0" Foreground="White" FontSize="11"/>
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind Value}" Foreground="#00A4EF" FontWeight="Bold" FontSize="11"/>
                                                            <TextBlock Text="{x:Bind Unit}" Foreground="#00A4EF" Margin="3,0,0,0" FontSize="9" VerticalAlignment="Bottom"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="3" Background="{x:Bind StatusColor}" CornerRadius="4" Height="18" Width="40">
                                                            <TextBlock Text="{x:Bind Decision}" FontSize="9" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="Henüz ölçüm alınmadı." Foreground="#444" HorizontalAlignment="Center" Margin="0,20,0,0" FontSize="10"
                                   Visibility="{x:Bind utils:GlobalData.LastMeasurements.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=Inverse, Mode=OneWay}"/>
                                    </StackPanel>
                                </ScrollViewer>

                                <Button Grid.Row="2" Click="BtnGetMeasurement_Click" Margin="8,0,8,8" HorizontalAlignment="Stretch" Background="#222" BorderBrush="#444" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE916;" FontSize="11" Foreground="Orange"/>
                                        <TextBlock Text="YENİ ÖLÇÜM AL" FontSize="10" Foreground="White"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- ═══ SÜTUN 1: DÖNÜŞTÜRÜLMÜŞ VERİ (BASE KOORDİNAT) ═══ -->
                        <Border Grid.Column="1" Background="#1A1A1C" BorderThickness="1" BorderBrush="#333" CornerRadius="10" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#1E2D1E" CornerRadius="8,8,0,0" Padding="15,0" BorderThickness="0,0,0,1" BorderBrush="#333">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                            <FontIcon Glyph="&#xE81E;" Foreground="#4CAF50" FontSize="16"/>
                                            <TextBlock Text="BASE KOORDİNAT" FontSize="11" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                                            <Border Background="#4CAF50" CornerRadius="4" Padding="6,2"><TextBlock Text="HAND-EYE" FontSize="8" FontWeight="Bold" Foreground="White"/></Border>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkSourceHandEye" Grid.Column="1" Checked="ChkSourceHandEye_Checked" IsChecked="False" VerticalAlignment="Center" MinWidth="0" Padding="0" ToolTipService.ToolTip="Bu veriyi Boru Ölçüm Aktarım tablosuna ilet"/>
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                                    <StackPanel Spacing="4">
                                        <Grid Background="#2A2A2C" Height="30" CornerRadius="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="#" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="10"/>
                                            <TextBlock Grid.Column="1" Text="ÖLÇÜM ADI" Foreground="#AAA" VerticalAlignment="Center" Margin="8,0" FontWeight="Bold" FontSize="10"/>
                                            <TextBlock Grid.Column="2" Text="DEĞER" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="Bold" FontSize="10"/>
                                            <TextBlock Grid.Column="3" Text="DURUM" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="9"/>
                                        </Grid>

                                        <ItemsControl ItemsSource="{x:Bind utils:GlobalData.TransformedMeasurements, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="utils:GocatorMeasurement">
                                                    <Grid Height="36" Margin="0,0,0,2" Background="#0F150F" CornerRadius="4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="50"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{x:Bind Id}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" Opacity="0.5" FontSize="10"/>
                                                        <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center" Margin="8,0" Foreground="#4CAF50" FontSize="11" FontWeight="SemiBold"/>
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind Value}" Foreground="#4CAF50" FontWeight="Bold" FontSize="11"/>
                                                            <TextBlock Text="{x:Bind Unit}" Foreground="#4CAF50" Margin="3,0,0,0" FontSize="9" VerticalAlignment="Bottom"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="3" Background="{x:Bind StatusColor}" CornerRadius="4" Height="18" Width="40">
                                                            <TextBlock Text="{x:Bind Decision}" FontSize="9" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="Kalibrasyon dönüşümü bekleniyor..." Foreground="#444" HorizontalAlignment="Center" Margin="0,20,0,0" FontSize="10"
                                   Visibility="{x:Bind utils:GlobalData.TransformedMeasurements.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=Inverse, Mode=OneWay}"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- ═══ SÜTUN 2: BORU ÖLÇÜM AKTARIM ═══ -->
                        <Border Grid.Column="2" Background="#1A1A1C" BorderThickness="1" BorderBrush="#333" CornerRadius="10" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="45"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="10,0" BorderThickness="0,0,0,1" BorderBrush="#333">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                                            <FontIcon Glyph="&#xE975;" Foreground="#FF9800" FontSize="16"/>
                                            <TextBlock Text="BORU ÖLÇÜM AKTARIM" FontSize="11" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <Button Click="BtnBackup_Click" Height="26" Padding="8,0" CornerRadius="4" Background="#D35400" BorderThickness="0" ToolTipService.ToolTip="Uygulama Verilerini Yedekle">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xE753;" Foreground="White" FontSize="10"/>
                                                    <TextBlock Text="YEDEK" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Click="BtnBackupGocator_Click" Height="26" Padding="8,0" CornerRadius="4" Background="#00A4EF" BorderThickness="0" ToolTipService.ToolTip="Sensör Yedeğini İndir">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xE964;" Foreground="White" FontSize="10"/>
                                                    <TextBlock Text="GOCATOR" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                                    <StackPanel x:Name="PlcTransferContainer" Spacing="4">
                                        <Grid Background="#2A2A2C" Height="30" CornerRadius="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="35"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="#" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="10"/>
                                            <TextBlock Grid.Column="1" Text="TAG SEÇİMİ" Foreground="#AAA" VerticalAlignment="Center" Margin="8,0" FontWeight="Bold" FontSize="10"/>
                                            <TextBlock Grid.Column="2" Text="DEĞER" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="10"/>
                                            <TextBlock Grid.Column="3" Text="SİL" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="8"/>
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding PlcTransferRows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Background="{Binding BackgroundColor}" Height="36" CornerRadius="4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="70"/>
                                                            <ColumnDefinition Width="35"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Index}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontWeight="SemiBold" Opacity="0.5" FontSize="10"/>
                                                        <ComboBox Grid.Column="1"
                                                            ItemsSource="{Binding ElementName=PageRoot, Path=Robot1OutputTags}"
                                                            SelectedItem="{Binding SelectedTag, Mode=TwoWay}"
                                                            Margin="4,0" Background="#252526" BorderThickness="1" BorderBrush="#444" CornerRadius="4"
                                                            Foreground="White" PlaceholderText="Tag Seç..." FontSize="10"
                                                            VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Value}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{Binding StatusColor}" FontWeight="Bold" FontSize="10"/>
                                                        <Button Grid.Column="3" Click="BtnDeletePlcRow_Click" Background="Transparent" BorderThickness="0" Padding="0" HorizontalAlignment="Center">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="11" Foreground="#E74C3C"/>
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="3"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>

                                <Button Grid.Row="2" Click="BtnAddPlcRow_Click" Margin="8,0,8,8" HorizontalAlignment="Stretch" Background="#222" BorderBrush="#444" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE710;" FontSize="11" Foreground="#00FF88"/>
                                        <TextBlock Text="YENİ SATIR EKLE" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ═══════════════════════════════════════════════════════════════ -->
                <!-- TABLA KAÇIKLIK: ÖLÇÜM SONUÇLARI + PLC AKTARIM -->
                <!-- ═══════════════════════════════════════════════════════════════ -->
                <Grid Margin="20,0" ColumnSpacing="20" RowSpacing="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- TABLA KAÇIKLIK ÖLÇÜM SONUÇLARI (JOB 0) -->
                    <Border Grid.Column="0" Background="#1A1A1C" BorderThickness="1" BorderBrush="#333" CornerRadius="10" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="45"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="15,0" BorderThickness="0,0,0,1" BorderBrush="#333">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                                    <FontIcon Glyph="&#xE8F4;" Foreground="#4CAF50" FontSize="16"/>
                                    <TextBlock Text="TABLA KAÇIKLIK SONUÇLARI" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                    <Border Background="#4CAF50" CornerRadius="4" Padding="6,2"><TextBlock Text="JOB 0" FontSize="9" FontWeight="Bold" Foreground="White"/></Border>
                                </StackPanel>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
                                <StackPanel Spacing="5">
                                    <Grid Background="#2A2A2C" Height="35" CornerRadius="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="#" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="ÖLÇÜM ADI" Foreground="#AAA" VerticalAlignment="Center" Margin="10,0" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="2" Text="DEĞER" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="3" Text="DURUM" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{x:Bind utils:GlobalData.TablaLastMeasurements, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="utils:GocatorMeasurement">
                                                <Grid Height="40" Margin="0,0,0,2" Background="#0F0F0F" CornerRadius="4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="40"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="60"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{x:Bind Id}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" Opacity="0.5"/>
                                                    <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center" Margin="10,0" Foreground="White"/>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind Value}" Foreground="#4CAF50" FontWeight="Bold"/>
                                                        <TextBlock Text="{x:Bind Unit}" Foreground="#4CAF50" Margin="4,0,0,0" FontSize="10" VerticalAlignment="Bottom"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="3" Background="{x:Bind StatusColor}" CornerRadius="4" Height="20" Width="50">
                                                        <TextBlock Text="{x:Bind Decision}" FontSize="10" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="Henüz tabla ölçümü alınmadı." Foreground="#444" HorizontalAlignment="Center" Margin="0,20,0,0"
                                               Visibility="{x:Bind utils:GlobalData.TablaLastMeasurements.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=Inverse, Mode=OneWay}"/>
                                </StackPanel>
                            </ScrollViewer>

                            <Button Grid.Row="2" Click="BtnGetTablaMeasurement_Click" Margin="10,0,10,10" HorizontalAlignment="Stretch" Background="#222" BorderBrush="#444" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE916;" FontSize="12" Foreground="#4CAF50"/>
                                    <TextBlock Text="TABLA ÖLÇÜMÜ AL (JOB 0)" FontSize="11" Foreground="White"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- TABLA PLC AKTARIM -->
                    <Border Grid.Column="1" Background="#1A1A1C" BorderThickness="1" BorderBrush="#333" CornerRadius="10" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="45"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="45"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="10,0" BorderThickness="0,0,0,1" BorderBrush="#333">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                    <FontIcon Glyph="&#xE975;" Foreground="#4CAF50" FontSize="16"/>
                                    <TextBlock Text="TABLA PLC AKTARIM" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
                                <StackPanel x:Name="TablaTransferContainer" Spacing="5">
                                    <Grid Background="#2A2A2C" Height="35" CornerRadius="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="#" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="PLC TAG SEÇİMİ" Foreground="#AAA" VerticalAlignment="Center" Margin="10,0" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="2" Text="DEĞER" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="3" Text="SİL" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="9"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding TablaTransferRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Background="{Binding BackgroundColor}" Height="40" CornerRadius="4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="40"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="40"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Index}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontWeight="SemiBold" Opacity="0.5"/>
                                                    <ComboBox Grid.Column="1"
                                                        ItemsSource="{Binding ElementName=PageRoot, Path=Robot1OutputTags}"
                                                        SelectedItem="{Binding SelectedTag, Mode=TwoWay}"
                                                        Margin="5,0" Background="#252526" BorderThickness="1" BorderBrush="#444" CornerRadius="4"
                                                        Foreground="White" PlaceholderText="Tag Seçiniz..." FontSize="11"
                                                        VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{Binding StatusColor}" FontWeight="Bold"/>
                                                    <Button Grid.Column="3" Click="BtnDeleteTablaPlcRow_Click" Background="Transparent" BorderThickness="0" Padding="0" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="#E74C3C"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Spacing="3"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>

                            <Button Grid.Row="2" Click="BtnAddTablaPlcRow_Click" Margin="10,0,10,10" HorizontalAlignment="Stretch" Background="#222" BorderBrush="#444" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="#4CAF50"/>
                                    <TextBlock Text="YENİ SATIR EKLE" FontSize="11" Foreground="White" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="3" Background="#1A1A1C" Margin="20,10,20,10" CornerRadius="10" BorderThickness="1" BorderBrush="#333">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="250"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,5" Background="#151515">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="45"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#252526" Padding="15,0" CornerRadius="8,8,0,0">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE8F1;" Foreground="#FFB81C" FontSize="16"/>
                                        <TextBlock Text="SENSÖR İŞ DOSYALARI (JOBS)" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Click="BtnRefreshJobs_Click" Background="#333" CornerRadius="4" Height="28" ToolTipService.ToolTip="Listeyi Yenile">
                                            <FontIcon Glyph="&#xE72C;" Foreground="White" FontSize="12"/>
                                        </Button>
                                        <Button Content="YÜKLE (LOAD)" Click="BtnLoadSelectedJob_Click" Background="#4CAF50" Foreground="White" FontSize="10" FontWeight="Bold" CornerRadius="4" Height="28"/>
                                        <Button Content="İNDİR" Click="BtnDownloadSelectedJob_Click" Background="#00A4EF" Foreground="White" FontSize="10" FontWeight="Bold" CornerRadius="4" Height="28"/>
                                        <Button Click="BtnUploadNewJob_Click" Background="#FF9800" CornerRadius="4" Height="28" ToolTipService.ToolTip="PC'den Job Yükle">
                                            <FontIcon Glyph="&#xE896;" Foreground="White" FontSize="12"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <ListView x:Name="SensorJobListView" Grid.Row="1" SelectionMode="Single" Background="#111">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="10" BorderBrush="#222" BorderThickness="0,0,0,1">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <FontIcon Glyph="&#xF133;" FontSize="12" Foreground="#888"/>
                                                <TextBlock Text="{Binding}" Foreground="White" FontSize="13" FontFamily="Cascadia Mono"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>

                        <Grid Grid.Row="1" Background="#1A1A1C" Margin="0,5,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="45"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#252526" Padding="15,0" BorderThickness="0,1,0,1" BorderBrush="#333">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE9D5;" Foreground="#00FF88" FontSize="16"/>
                                    <TextBlock Text="REÇETE YÖNETİMİ (KART GÖRÜNÜMÜ)" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Klima tipleri ve işlem adımları." FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <GridView Grid.Row="1" Padding="10" 
                      ItemsSource="{x:Bind utils:GlobalData.KnownRfids, Mode=OneWay}" 
                      SelectionMode="None">

                                <GridView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="-1" HorizontalAlignment="Left"/>
                                    </ItemsPanelTemplate>
                                </GridView.ItemsPanel>

                                <GridView.ItemContainerStyle>
                                    <Style TargetType="GridViewItem">
                                        <Setter Property="Margin" Value="0,0,10,10"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="VerticalAlignment" Value="Top"/>
                                    </Style>
                                </GridView.ItemContainerStyle>

                                <GridView.ItemTemplate>
                                    <DataTemplate x:DataType="utils:RfidDef">
                                        <Border Width="420" Height="300"
                                                Background="{x:Bind ActiveCardBackground, Mode=OneWay}"
                                                BorderBrush="{x:Bind ActiveBorderBrush, Mode=OneWay}"
                                                BorderThickness="{x:Bind ActiveBorderThickness, Mode=OneWay}"
                                                CornerRadius="6" Padding="0">
                                            <!-- Ic glow efekti: aktifse yesil ic border -->
                                            <Border CornerRadius="5" Padding="10"
                                                    BorderBrush="{x:Bind ActiveBorderBrush, Mode=OneWay}"
                                                    BorderThickness="0"
                                                    Opacity="1">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Header: RFID Badge + Aciklama + AKTİF etiketi -->
                                                <Border Grid.Row="0" Background="{x:Bind ActiveHeaderBackground, Mode=OneWay}"
                                                        CornerRadius="4" Padding="6,5" Margin="-6,-6,-6,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="{x:Bind ActiveIdBadgeBrush, Mode=OneWay}" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind Id}" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="{x:Bind Description}" Foreground="#DDD" VerticalAlignment="Center" FontWeight="SemiBold" Margin="10,0,0,0" TextTrimming="CharacterEllipsis"/>
                                                        <!-- AKTİF Etiketi -->
                                                        <Border Grid.Column="2" Background="#2ECC71" CornerRadius="4" Padding="8,3"
                                                                VerticalAlignment="Center"
                                                                Visibility="{x:Bind ActiveLabelVisibility, Mode=OneWay}">
                                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                                <Ellipse Width="6" Height="6" Fill="White"/>
                                                                <TextBlock Text="AKTİF" Foreground="White" FontWeight="Bold" FontSize="9"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <Rectangle Grid.Row="1" Height="1" Fill="{x:Bind ActiveSeparatorBrush, Mode=OneWay}" Margin="0,0,0,10"/>

                                                <Grid Grid.Row="2" Margin="0,0,0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="14"/>
                                                        <ColumnDefinition Width="26"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="75"/>
                                                        <ColumnDefinition Width="76"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="İşlem Sırası:" FontSize="10" Foreground="#888" Grid.ColumnSpan="3"/>
                                                    <TextBlock Grid.Column="3" Text="Sniffer (ms)" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                                                </Grid>
                                                
                                                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                                                    <ItemsControl ItemsSource="{x:Bind IndexedJobSequence, Mode=OneWay}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="utils:IndexedJobItem">
                                                                <Grid Margin="0,0,0,4" Background="{x:Bind RowBackground, Mode=OneWay}" CornerRadius="4" Height="28">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="14"/>
                                                                        <ColumnDefinition Width="26"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="75"/>
                                                                        <ColumnDefinition Width="24"/>
                                                                        <ColumnDefinition Width="24"/>
                                                                        <ColumnDefinition Width="28"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <!-- Anlik Index Gostergesi (▶) -->
                                                                    <TextBlock Text="{x:Bind CurrentIndicator, Mode=OneWay}"
                                                                               Foreground="#FF9800" FontSize="8" FontWeight="Bold"
                                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    <!-- Index Badge (renk: gri/yesil/kirmizi) -->
                                                                    <Border Grid.Column="1" Background="{x:Bind StatusColor, Mode=OneWay}" CornerRadius="4" Width="22" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                        <TextBlock Text="{x:Bind Index}" Foreground="White" FontWeight="Bold" FontSize="10"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <TextBlock Grid.Column="2" Text="{x:Bind JobName}" Foreground="White" VerticalAlignment="Center" FontSize="11" Margin="5,0" TextTrimming="CharacterEllipsis"/>
                                                                    <!-- Sniffer Suresi (ms) -->
                                                                    <controls:NumberBox Grid.Column="3"
                                                                                        Value="{x:Bind SnifferDuration, Mode=TwoWay}"
                                                                                        Minimum="0" Maximum="120000"
                                                                                        SpinButtonPlacementMode="Compact"
                                                                                        Width="70" Height="24" FontSize="10"
                                                                                        VerticalAlignment="Center"
                                                                                        ValueChanged="SnifferDuration_ValueChanged"/>
                                                                    <!-- Yukari Tasi Butonu -->
                                                                    <Button Grid.Column="4"
                                                                            Click="MoveJobUp"
                                                                            Tag="{x:Bind Index}"
                                                                            Background="Transparent" Padding="0" BorderThickness="0"
                                                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                            Width="22" Height="22" ToolTipService.ToolTip="Yukarı Taşı">
                                                                        <FontIcon Glyph="&#xE70E;" Foreground="#888" FontSize="10"/>
                                                                    </Button>
                                                                    <!-- Asagi Tasi Butonu -->
                                                                    <Button Grid.Column="5"
                                                                            Click="MoveJobDown"
                                                                            Tag="{x:Bind Index}"
                                                                            Background="Transparent" Padding="0" BorderThickness="0"
                                                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                            Width="22" Height="22" ToolTipService.ToolTip="Aşağı Taşı">
                                                                        <FontIcon Glyph="&#xE70D;" Foreground="#888" FontSize="10"/>
                                                                    </Button>
                                                                    <!-- Sil Butonu -->
                                                                    <Button Grid.Column="6"
                                                                            Click="RemoveJobFromSequence"
                                                                            Tag="{x:Bind JobName}"
                                                                            Background="Transparent" Padding="0" BorderThickness="0" HorizontalAlignment="Center">
                                                                        <FontIcon Glyph="&#xE74D;" Foreground="#E74C3C" FontSize="10"/>
                                                                    </Button>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>

                                                <Grid Grid.Row="4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="70"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox x:Name="CmbAddJob" 
                                              PlaceholderText="Job Seç..." 
                                              HorizontalAlignment="Stretch" 
                                              FontSize="11" Height="28"
                                              ItemsSource="{Binding ElementName=SensorJobListView, Path=DataContext.AvailableJobs}"
                                              Loaded="JobCombo_Loaded"/>
                                                    <Button Grid.Column="1" Content="+ EKLE" Click="BtnAddJobToSequence_Click" 
                                            Background="#27AE60" Foreground="White" FontSize="10" FontWeight="Bold" 
                                            Height="28" Margin="5,0,0,0" HorizontalAlignment="Stretch"/>
                                                </Grid>
                                            </Grid>
                                            </Border>
                                        </Border>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                        </Grid>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ALT DURUM ÇUBUĞU - Footer -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#1A1A1C" BorderThickness="0,1,0,0" BorderBrush="#333" Padding="20,0">
            <Grid VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Left">
                    <Ellipse Width="10" Height="10" Fill="#4CAF50" VerticalAlignment="Center"/>
                    <TextBlock Text="Çalışma Durumu:" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock Text="AKTIF" FontSize="11" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="© 2025 Simbiosis Mekatronik | Gocator 3D Sensor" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Right" 
                           FontSize="10" 
                           Foreground="#555555"/>
            </Grid>
        </Border>
    </Grid>
</Page>