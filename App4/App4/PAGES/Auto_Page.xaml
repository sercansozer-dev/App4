                                <Grid Padding="0,8" BorderBrush="#222" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="3" Foreground="#0078D4" FontWeight="Bold" Margin="15,0"/>
                                    <TextBlock Grid.Column="1" Text="TEST TAMAMLANDI" Foreground="White" Margin="15,0"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" Margin="15,0">
                                        <Ellipse Width="10" Height="10" Fill="#0078D4"/>
                                        <TextBlock Text="MAVİ (PROCESS)" Foreground="#CCC" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="3" Text="Ölçüm ve test işlemleri bitti, sonuç bekleniyor." Foreground="#888" Margin="15,0"/>
                                </Grid>
                                <Grid Padding="0,8" BorderBrush="#222" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="4" Foreground="#4CAF50" FontWeight="Bold" Margin="15,0"/>
                                    <TextBlock Grid.Column="1" Text="OK ÜRÜN" Foreground="White" Margin="15,0"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" Margin="15,0">
                                        <Ellipse Width="10" Height="10" Fill="#4CAF50"/>
                                        <TextBlock Text="YEŞİL (BAŞARILI)" Foreground="#CCC" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="3" Text="Ürün tüm testlerden başarıyla geçti." Foreground="#888" Margin="15,0"/>
                                </Grid>
                                <Grid Padding="0,8" BorderBrush="#222" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="5" Foreground="#E74C3C" FontWeight="Bold" Margin="15,0"/>
                                    <TextBlock Grid.Column="1" Text="NOK ÜRÜN" Foreground="White" Margin="15,0"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" Margin="15,0">
                                        <Ellipse Width="10" Height="10" Fill="#E74C3C"/>
                                        <TextBlock Text="KIRMIZI (HATALI)" Foreground="#CCC" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="3" Text="Ürün testlerden geçemedi, hatalı." Foreground="#888" Margin="15,0"/>
                                </Grid>
                                <Grid Padding="0,8" BorderBrush="#222" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="6" Foreground="#F1C40F" FontWeight="Bold" Margin="15,0"/>
                                    <TextBlock Grid.Column="1" Text="HAZIRLANIYOR" Foreground="White" Margin="15,0"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" Margin="15,0">
                                        <Ellipse Width="10" Height="10" Fill="#F1C40F"/>
                                        <TextBlock Text="SARI (BEKLİYOR)" Foreground="#CCC" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="3" Text="İstasyon giriş/çıkış yapıyor veya hazırlanıyor." Foreground="#888" Margin="15,0"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#1A1A1C" CornerRadius="8" BorderThickness="1" BorderBrush="#333" Padding="0" VerticalAlignment="Top">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="300"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#252526" Padding="15,8" BorderThickness="0,0,0,1" BorderBrush="#333" CornerRadius="8,8,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE8F1;" Foreground="#FFF" FontSize="14"/>
                                        <TextBlock Text="RFID TANIMLAMA LİSTESİ" FontSize="12" FontWeight="Bold" Foreground="#DDD"/>
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Row="1" Background="#222" Padding="10" ColumnSpacing="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtNewRfidId" Grid.Column="0" PlaceholderText="ID Gr" FontSize="11"/>
                                    <TextBox x:Name="TxtNewRfidDesc" Grid.Column="1" PlaceholderText="Açıklama" FontSize="11"/>
                                    <Button Grid.Column="2" Content="Ekle" Click="BtnAddRfid_Click" FontSize="11" Background="#0078D4" Foreground="White"/>
                                </Grid>

                                <ListView Grid.Row="2" ItemsSource="{x:Bind KnownRfids}" SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="utils:RfidDef">
                                            <Grid Padding="10,5" BorderBrush="#333" BorderThickness="0,0,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{x:Bind Id}" FontWeight="Bold" Foreground="#0078D4" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{x:Bind Description}" Foreground="#BBB" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="2" Click="BtnDeleteRfid_Click" Background="Transparent" BorderThickness="0" Padding="5" Margin="5,0,0,0" ToolTipService.ToolTip="Listeden Sil">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#E74C3C"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="#1A1A1C" CornerRadius="8" BorderThickness="1" BorderBrush="#333" Padding="0" VerticalAlignment="Top">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="300"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#252526" Padding="15,8" BorderThickness="0,0,0,1" BorderBrush="#333" CornerRadius="8,8,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE9D9;" Foreground="#E74C3C" FontSize="14"/>
                                        <TextBlock Text="SİSTEM START KOŞULLARI" FontSize="12" FontWeight="Bold" Foreground="#DDD"/>
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Row="1" Background="#222" Padding="10" RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox x:Name="ComboCheckTag" Grid.Row="0" Grid.ColumnSpan="2"
                          ItemsSource="{Binding AvailableInputPlcTags, ElementName=AutoPageRoot, Mode=OneWay}" 
                          PlaceholderText="PLC Input Seçiniz..." 
                          HorizontalAlignment="Stretch" FontSize="11"/>

                                    <TextBox x:Name="TxtCheckMessage" Grid.Row="1" Grid.Column="0" 
                         PlaceholderText="Hata Mesajı (Örn: HAVA DÜŞÜK)" 
                         FontSize="11" Margin="0,0,5,0"/>

                                    <Button Grid.Row="1" Grid.Column="1" Content="Ekle" Click="BtnAddCheck_Click" 
                        FontSize="11" FontWeight="Bold" Background="#27AE60" Foreground="White"/>
                                </Grid>

                                <ListView Grid.Row="2" ItemsSource="{x:Bind SystemCheckList}" SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="utils:SystemCheckItem">
                                            <Grid Padding="10,8" BorderBrush="#333" BorderThickness="0,0,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock Text="{x:Bind TagName}" Foreground="#0078D4" FontSize="10" Opacity="0.8"/>
                                                    <TextBlock Text="{x:Bind ErrorMessage}" Foreground="#E74C3C" FontWeight="Bold" FontSize="11" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Click="BtnDeleteCheck_Click" Background="Transparent" BorderThickness="0" Padding="8" VerticalAlignment="Center">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#666"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>