<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App4.Auto_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App4"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#101010">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1F1F1F" BorderThickness="0,0,0,1" BorderBrush="#333333" Padding="20,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <FontIcon Glyph="&#xE72A;" Foreground="#0078D4" FontSize="20"/>
                    <TextBlock Text="OTOMATİK ÜRETİM KONTROLÜ" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="20">
                <Grid Height="650">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>
            <!-- 4 Column Layout -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Station 1 -->
            <Grid Grid.Column="0" Grid.Row="0" Margin="5">
                <ContentControl Content="{x:Bind Stations[0], Mode=OneWay}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="local:StationViewModel">
                            <Border Background="#1A1A1C" CornerRadius="8" BorderThickness="2" BorderBrush="{x:Bind BorderColor, Mode=OneWay}" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="50"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="60"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <Border Grid.Row="0" Background="#252526" CornerRadius="6,6,0,0" Padding="15,0" BorderThickness="0,0,0,1" BorderBrush="#333333">
                                        <Grid>
                                             <StackPanel VerticalAlignment="Center">
                                                 <TextBlock Text="{x:Bind Name}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                                 <TextBlock Text="{x:Bind Description}" FontSize="10" Foreground="#888888"/>
                                             </StackPanel>
                                            <Ellipse Width="12" Height="12" Fill="{x:Bind ModeColor, Mode=OneWay}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Status / Visual -->
                                    <Grid Grid.Row="1" Background="#151515">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="15">
                                            <!-- Mode Badge -->
                                            <Border Background="#252526" CornerRadius="15" Padding="15,5" HorizontalAlignment="Center" BorderThickness="1" BorderBrush="#444">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xE90C;" FontSize="12" Foreground="{x:Bind ModeColor, Mode=OneWay}"/>
                                                    <TextBlock Text="{x:Bind ModeText, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                                </StackPanel>
                                            </Border>
                                            
                                            <!-- State Large Icon -->
                                            <FontIcon Glyph="&#xE9F5;" FontSize="50" Foreground="{x:Bind StateColor, Mode=OneWay}"/>
                                            
                                            <!-- State Text -->
                                            <TextBlock Text="{x:Bind StateText, Mode=OneWay}" FontSize="16" FontWeight="Bold" Foreground="{x:Bind StateColor, Mode=OneWay}" TextAlignment="Center"/>

                                            <!-- Alarm Warning -->
                                            <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind AlarmVisibility, Mode=OneWay}" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xE7BA;" Foreground="Red" FontSize="16"/>
                                                <TextBlock Text="{x:Bind AlarmText, Mode=OneWay}" Foreground="Red" FontSize="12" FontWeight="Bold"/>
                                            </StackPanel>

                                            <!-- BYPASS BUTTON -->
                                            <Button Click="{x:Bind ToggleBypass}" Background="{x:Bind BypassButtonColor, Mode=OneWay}" CornerRadius="15" Padding="20,5" HorizontalAlignment="Center" Margin="0,10,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xE7E8;" FontSize="12" Foreground="White"/>
                                                    <TextBlock Text="{x:Bind BypassButtonText, Mode=OneWay}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Footer Stats -->
                                    <Border Grid.Row="2" Background="#202020" CornerRadius="0,0,6,6" Padding="15,0">
                                        <Grid VerticalAlignment="Center">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Üretim Adedi" FontSize="10" Foreground="#888888"/>
                                                <TextBlock Text="1,245" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                            </StackPanel>
                                            <StackPanel Spacing="2" HorizontalAlignment="Right">
                                                <TextBlock Text="Verimlilik" FontSize="10" Foreground="#888888" HorizontalAlignment="Right"/>
                                                <TextBlock Text="%92" FontSize="14" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Grid>

            <!-- Station 2 -->
            <Grid Grid.Column="1" Grid.Row="0" Margin="5">
                <ContentControl Content="{x:Bind Stations[1], Mode=OneWay}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                     <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="local:StationViewModel">
                            <Border Background="#1A1A1C" CornerRadius="8" BorderThickness="2" BorderBrush="{x:Bind BorderColor, Mode=OneWay}" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="50"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="60"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#252526" CornerRadius="6,6,0,0" Padding="15,0" BorderThickness="0,0,0,1" BorderBrush="#333333">
                                        <Grid>
                                             <StackPanel VerticalAlignment="Center">
                                                 <TextBlock Text="{x:Bind Name}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                                 <TextBlock Text="{x:Bind Description}" FontSize="10" Foreground="#888888"/>
                                             </StackPanel>
                                            <Ellipse Width="12" Height="12" Fill="{x:Bind ModeColor, Mode=OneWay}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <Grid Grid.Row="1" Background="#151515">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="15">
                                            <Border Background="#252526" CornerRadius="15" Padding="15,5" HorizontalAlignment="Center" BorderThickness="1" BorderBrush="#444">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xE90C;" FontSize="12" Foreground="{x:Bind ModeColor, Mode=OneWay}"/>
                                                    <TextBlock Text="{x:Bind ModeText, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                                </StackPanel>
                                            </Border>
                                            <FontIcon Glyph="&#xE9F5;" FontSize="50" Foreground="{x:Bind StateColor, Mode=OneWay}"/>
                                            <TextBlock Text="{x:Bind StateText, Mode=OneWay}" FontSize="16" FontWeight="Bold" Foreground="{x:Bind StateColor, Mode=OneWay}" TextAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind AlarmVisibility, Mode=OneWay}" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xE7BA;" Foreground="Red" FontSize="16"/>
                                                <TextBlock Text="{x:Bind AlarmText, Mode=OneWay}" Foreground="Red" FontSize="12" FontWeight="Bold"/>
                                            </StackPanel>
                                            <!-- BYPASS BUTTON -->
                                            <Button Click="{x:Bind ToggleBypass}" Background="{x:Bind BypassButtonColor, Mode=OneWay}" CornerRadius="15" Padding="20,5" HorizontalAlignment="Center" Margin="0,10,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xE7E8;" FontSize="12" Foreground="White"/>
                                                    <TextBlock Text="{x:Bind BypassButtonText, Mode=OneWay}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <Border Grid.Row="2" Background="#202020" CornerRadius="0,0,6,6" Padding="15,0">
                                        <Grid VerticalAlignment="Center">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Üretim Adedi" FontSize="10" Foreground="#888888"/>
                                                <TextBlock Text="845" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                            </StackPanel>
                                            <StackPanel Spacing="2" HorizontalAlignment="Right">
                                                <TextBlock Text="Verimlilik" FontSize="10" Foreground="#888888" HorizontalAlignment="Right"/>
                                                <TextBlock Text="%95" FontSize="14" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Grid>

            <!-- Station 3 -->
            <Grid Grid.Column="2" Grid.Row="0" Margin="5">
                <ContentControl Content="{x:Bind Stations[2], Mode=OneWay}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                     <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="local:StationViewModel">
                            <Border Background="#1A1A1C" CornerRadius="8" BorderThickness="2" BorderBrush="{x:Bind BorderColor, Mode=OneWay}" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="50"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="60"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#252526" CornerRadius="6,6,0,0" Padding="15,0" BorderThickness="0,0,0,1" BorderBrush="#333333">
                                        <Grid>
                                             <StackPanel VerticalAlignment="Center">
                                                 <TextBlock Text="{x:Bind Name}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                                 <TextBlock Text="{x:Bind Description}" FontSize="10" Foreground="#888888"/>
                                             </StackPanel>
                                            <Ellipse Width="12" Height="12" Fill="{x:Bind ModeColor, Mode=OneWay}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <Grid Grid.Row="1" Background="#151515">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="15">
                                            <Border Background="#252526" CornerRadius="15" Padding="15,5" HorizontalAlignment="Center" BorderThickness="1" BorderBrush="#444">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xE90C;" FontSize="12" Foreground="{x:Bind ModeColor, Mode=OneWay}"/>
                                                    <TextBlock Text="{x:Bind ModeText, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                                </StackPanel>
                                            </Border>
                                            <FontIcon Glyph="&#xE9F5;" FontSize="50" Foreground="{x:Bind StateColor, Mode=OneWay}"/>
                                            <TextBlock Text="{x:Bind StateText, Mode=OneWay}" FontSize="16" FontWeight="Bold" Foreground="{x:Bind StateColor, Mode=OneWay}" TextAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind AlarmVisibility, Mode=OneWay}" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xE7BA;" Foreground="Red" FontSize="16"/>
                                                <TextBlock Text="{x:Bind AlarmText, Mode=OneWay}" Foreground="Red" FontSize="12" FontWeight="Bold"/>
                                            </StackPanel>
                                            <!-- BYPASS BUTTON -->
                                            <Button Click="{x:Bind ToggleBypass}" Background="{x:Bind BypassButtonColor, Mode=OneWay}" CornerRadius="15" Padding="20,5" HorizontalAlignment="Center" Margin="0,10,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xE7E8;" FontSize="12" Foreground="White"/>
                                                    <TextBlock Text="{x:Bind BypassButtonText, Mode=OneWay}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <Border Grid.Row="2" Background="#202020" CornerRadius="0,0,6,6" Padding="15,0">
                                        <Grid VerticalAlignment="Center">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Üretim Adedi" FontSize="10" Foreground="#888888"/>
                                                <TextBlock Text="0" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                            </StackPanel>
                                            <StackPanel Spacing="2" HorizontalAlignment="Right">
                                                <TextBlock Text="Verimlilik" FontSize="10" Foreground="#888888" HorizontalAlignment="Right"/>
                                                <TextBlock Text="-" FontSize="14" FontWeight="Bold" Foreground="Gray" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Grid>

            <!-- Station 4 -->
            <Grid Grid.Column="3" Grid.Row="0" Margin="5">
                <ContentControl Content="{x:Bind Stations[3], Mode=OneWay}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                     <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="local:StationViewModel">
                            <Border Background="#1A1A1C" CornerRadius="8" BorderThickness="2" BorderBrush="{x:Bind BorderColor, Mode=OneWay}" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="50"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="60"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#252526" CornerRadius="6,6,0,0" Padding="15,0" BorderThickness="0,0,0,1" BorderBrush="#333333">
                                        <Grid>
                                             <StackPanel VerticalAlignment="Center">
                                                 <TextBlock Text="{x:Bind Name}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                                 <TextBlock Text="{x:Bind Description}" FontSize="10" Foreground="#888888"/>
                                             </StackPanel>
                                            <Ellipse Width="12" Height="12" Fill="{x:Bind ModeColor, Mode=OneWay}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <Grid Grid.Row="1" Background="#151515">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="15">
                                            <Border Background="#252526" CornerRadius="15" Padding="15,5" HorizontalAlignment="Center" BorderThickness="1" BorderBrush="#444">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xE90C;" FontSize="12" Foreground="{x:Bind ModeColor, Mode=OneWay}"/>
                                                    <TextBlock Text="{x:Bind ModeText, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                                </StackPanel>
                                            </Border>
                                            <FontIcon Glyph="&#xE9F5;" FontSize="50" Foreground="{x:Bind StateColor, Mode=OneWay}"/>
                                            <TextBlock Text="{x:Bind StateText, Mode=OneWay}" FontSize="16" FontWeight="Bold" Foreground="{x:Bind StateColor, Mode=OneWay}" TextAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind AlarmVisibility, Mode=OneWay}" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xE7BA;" Foreground="Red" FontSize="16"/>
                                                <TextBlock Text="{x:Bind AlarmText, Mode=OneWay}" Foreground="Red" FontSize="12" FontWeight="Bold"/>
                                            </StackPanel>
                                            <!-- BYPASS BUTTON -->
                                            <Button Click="{x:Bind ToggleBypass}" Background="{x:Bind BypassButtonColor, Mode=OneWay}" CornerRadius="15" Padding="20,5" HorizontalAlignment="Center" Margin="0,10,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xE7E8;" FontSize="12" Foreground="White"/>
                                                    <TextBlock Text="{x:Bind BypassButtonText, Mode=OneWay}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <Border Grid.Row="2" Background="#202020" CornerRadius="0,0,6,6" Padding="15,0">
                                        <Grid VerticalAlignment="Center">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Üretim Adedi" FontSize="10" Foreground="#888888"/>
                                                <TextBlock Text="0" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                            </StackPanel>
                                            <StackPanel Spacing="2" HorizontalAlignment="Right">
                                                <TextBlock Text="Verimlilik" FontSize="10" Foreground="#888888" HorizontalAlignment="Right"/>
                                                <TextBlock Text="STOP" FontSize="14" FontWeight="Bold" Foreground="Red" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Grid>
        
            <!-- TRACK & ROBOT VISUALIZATION -->
            <Border Grid.Row="1" Grid.ColumnSpan="4" Height="4" Background="#333333" VerticalAlignment="Center" Margin="10,0" CornerRadius="2"/>

            <!-- Robot Visuals Per Column -->
            <Grid Grid.Row="1" Grid.Column="0" Visibility="{x:Bind Stations[0].RobotVisibility, Mode=OneWay}" Opacity="{x:Bind Stations[0].RobotOpacity, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-20,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Robot Cart Icon -->
                    <Grid Grid.Row="0" HorizontalAlignment="Center">
                        <Ellipse Width="50" Height="50" Fill="#1F1F1F" Stroke="#0078D4" StrokeThickness="2"/>
                        <FontIcon Glyph="&#xE81D;" FontSize="24" Foreground="#0078D4"/>
                    </Grid>
                    
                    <!-- Connector Line -->
                    <Rectangle Grid.Row="1" Width="2" Height="15" Fill="#0078D4" HorizontalAlignment="Center"/>
                    
                    <!-- Wheel Base -->
                    <Border Grid.Row="1" Width="40" Height="8" Background="#0078D4" CornerRadius="4" VerticalAlignment="Bottom" Margin="0,0,0,-4"/>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Grid.Column="1" Visibility="{x:Bind Stations[1].RobotVisibility, Mode=OneWay}" Opacity="{x:Bind Stations[1].RobotOpacity, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-20,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" HorizontalAlignment="Center">
                        <Ellipse Width="50" Height="50" Fill="#1F1F1F" Stroke="#0078D4" StrokeThickness="2"/>
                        <FontIcon Glyph="&#xE81D;" FontSize="24" Foreground="#0078D4"/>
                    </Grid>
                    <Rectangle Grid.Row="1" Width="2" Height="15" Fill="#0078D4" HorizontalAlignment="Center"/>
                    <Border Grid.Row="1" Width="40" Height="8" Background="#0078D4" CornerRadius="4" VerticalAlignment="Bottom" Margin="0,0,0,-4"/>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Grid.Column="2" Visibility="{x:Bind Stations[2].RobotVisibility, Mode=OneWay}" Opacity="{x:Bind Stations[2].RobotOpacity, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-20,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" HorizontalAlignment="Center">
                        <Ellipse Width="50" Height="50" Fill="#1F1F1F" Stroke="#0078D4" StrokeThickness="2"/>
                        <FontIcon Glyph="&#xE81D;" FontSize="24" Foreground="#0078D4"/>
                    </Grid>
                    <Rectangle Grid.Row="1" Width="2" Height="15" Fill="#0078D4" HorizontalAlignment="Center"/>
                    <Border Grid.Row="1" Width="40" Height="8" Background="#0078D4" CornerRadius="4" VerticalAlignment="Bottom" Margin="0,0,0,-4"/>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Grid.Column="3" Visibility="{x:Bind Stations[3].RobotVisibility, Mode=OneWay}" Opacity="{x:Bind Stations[3].RobotOpacity, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-20,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" HorizontalAlignment="Center">
                        <Ellipse Width="50" Height="50" Fill="#1F1F1F" Stroke="#0078D4" StrokeThickness="2"/>
                        <FontIcon Glyph="&#xE81D;" FontSize="24" Foreground="#0078D4"/>
                    </Grid>
                    <Rectangle Grid.Row="1" Width="2" Height="15" Fill="#0078D4" HorizontalAlignment="Center"/>
                    <Border Grid.Row="1" Width="40" Height="8" Background="#0078D4" CornerRadius="4" VerticalAlignment="Bottom" Margin="0,0,0,-4"/>
                </Grid>
            </Grid>
            </Grid>

            <!-- PLC Variables Table -->
            <StackPanel Spacing="10" Margin="0,30,0,20">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE8FD;" Foreground="#E67E22" FontSize="20"/>
                    <TextBlock Text="PLC KONFİGÜRASYON &amp; SİMÜLASYON" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Aşağıdaki tablodan simülasyon veya manual ayar değerleri girebilirsiniz." FontSize="12" Foreground="#888888"/>

                <Border Background="#1A1A1C" CornerRadius="8" BorderThickness="1" BorderBrush="#333333" Margin="0,10,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Table Header -->
                        <Grid Grid.Row="0" Background="#252526" BorderThickness="0,0,0,1" BorderBrush="#333333">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="3*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="DEĞİŞKEN ADI" VerticalAlignment="Center" Margin="15,0" Foreground="#AAAAAA" FontWeight="SemiBold" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="DEĞER" VerticalAlignment="Center" Margin="15,0" Foreground="#AAAAAA" FontWeight="SemiBold" FontSize="11"/>
                            <TextBlock Grid.Column="2" Text="AÇIKLAMA" VerticalAlignment="Center" Margin="15,0" Foreground="#AAAAAA" FontWeight="SemiBold" FontSize="11"/>
                        </Grid>

                        <!-- Table Items -->
                        <ListView Grid.Row="1" ItemsSource="{x:Bind PlcVariables}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:PlcVariable">
                                    <Grid Padding="0,8" BorderBrush="#222" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="3*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Name -->
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" Margin="15,0">
                                            <FontIcon Glyph="&#xE9D2;" FontSize="12" Foreground="#0078D4"/>
                                            <TextBlock Text="{x:Bind Name}" Foreground="White" FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <!-- Value -->
                                        <TextBox Grid.Column="1" Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                 IsEnabled="{x:Bind IsEditable}"
                                                 Margin="5,0,20,0"/>

                                        <!-- Description -->
                                        <TextBlock Grid.Column="2" Text="{x:Bind Description}" VerticalAlignment="Center" Margin="15,0" Foreground="#888888"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
    </Grid>
</Page>
