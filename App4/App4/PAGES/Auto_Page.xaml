<Page
    x:Class="App4.Auto_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App4"
    xmlns:utils="using:App4.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="AutoPageRoot"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- StationCardTemplate removed as we are inlining it to support WebViews -->

        <DataTemplate x:Key="StationVarTemplate" x:DataType="utils:PlcVariable">
            <StackPanel Spacing="5" Padding="10" BorderBrush="#222" BorderThickness="0,0,0,1">
                <TextBlock Text="{x:Bind Name}" Foreground="#0078D4" FontWeight="Bold" FontSize="11"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableInputPlcTags, ElementName=AutoPageRoot, Mode=OneWay}" 
                              SelectedItem="{x:Bind PlcTag, Mode=OneWay}" 
                              PlaceholderText="Tag Seç..." Background="#202020" BorderBrush="#333" Foreground="White" FontSize="11" Margin="0,0,5,0" Height="28"
                              SelectionChanged="PlcTagComboBox_SelectionChanged"/>
                    <TextBox Grid.Column="1" Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Val" Background="#202020" BorderBrush="#333" Foreground="White" FontSize="11"/>
                </Grid>
                <TextBlock Text="{x:Bind Description}" Foreground="#666" FontSize="10" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="StationOutputVarTemplate" x:DataType="utils:PlcVariable">
            <StackPanel Spacing="5" Padding="10" BorderBrush="#222" BorderThickness="0,0,0,1">
                <TextBlock Text="{x:Bind Name}" Foreground="#0078D4" FontWeight="Bold" FontSize="11"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableOutputPlcTags, ElementName=AutoPageRoot, Mode=OneWay}" 
                              SelectedItem="{x:Bind PlcTag, Mode=OneWay}" 
                              PlaceholderText="Tag Seç..." Background="#202020" BorderBrush="#333" Foreground="White" FontSize="11" Margin="0,0,5,0" Height="28"
                              SelectionChanged="PlcTagComboBox_SelectionChanged"/>
                    <TextBox Grid.Column="1" Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Val" Background="#202020" BorderBrush="#333" Foreground="White" FontSize="11"/>
                </Grid>
                <TextBlock Text="{x:Bind Description}" Foreground="#666" FontSize="10" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid Background="#101010">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F1F1F" BorderThickness="0,0,0,1" BorderBrush="#333333" Padding="20,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <FontIcon Glyph="&#xE72A;" Foreground="#0078D4" FontSize="20"/>
                    <TextBlock Text="OTOMATİK ÜRETİM KONTROLÜ" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="20">
                <Border Background="#1A1A1C" CornerRadius="8" BorderThickness="1" BorderBrush="#333" Margin="0,0,0,20">
                    <Grid Padding="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="5">
                            <TextBlock Text="HAT KONTROL MERKEZİ" FontSize="14" FontWeight="Bold" Foreground="White"/>

                            <Border x:Name="LineStatusCard" Background="#333" CornerRadius="4" Padding="10,5" HorizontalAlignment="Left" BorderThickness="1" BorderBrush="#555">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon x:Name="LineStatusIcon" Glyph="&#xE71A;" FontSize="14" Foreground="#CCC"/>
                                    <TextBlock x:Name="LineStatusText" Text="SİSTEM KAPALI" FontSize="12" FontWeight="Bold" Foreground="#CCC"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center" Margin="0,0,30,0">

                            <StackPanel Orientation="Vertical" Spacing="2">
                                <TextBlock Text="SAFETY" FontSize="9" Foreground="#888" HorizontalAlignment="Center"/>
                                <Border x:Name="CheckSafetyBorder" Background="#333" CornerRadius="10" Padding="8,4" BorderThickness="1" BorderBrush="#555">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon x:Name="CheckSafetyIcon" Glyph="&#xE7BA;" FontSize="12" Foreground="#999"/>
                                        <TextBlock x:Name="CheckSafetyText" Text="BEKLİYOR" FontSize="10" FontWeight="Bold" Foreground="#999"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Spacing="2">
                                <TextBlock Text="ALARM" FontSize="9" Foreground="#888" HorizontalAlignment="Center"/>
                                <Border x:Name="CheckAlarmBorder" Background="#333" CornerRadius="10" Padding="8,4" BorderThickness="1" BorderBrush="#555">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon x:Name="CheckAlarmIcon" Glyph="&#xE7BA;" FontSize="12" Foreground="#999"/>
                                        <TextBlock x:Name="CheckAlarmText" Text="KONTROL" FontSize="10" FontWeight="Bold" Foreground="#999"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                        </StackPanel>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Button x:Name="BtnStart" Click="BtnStart_Click" CornerRadius="6" Padding="0" Width="110" Height="45" Background="#1E5631" BorderBrush="#27AE60" BorderThickness="1" Opacity="0.5" IsEnabled="False">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE768;" FontSize="16" Foreground="#2ECC71"/>
                                    <TextBlock Text="BAŞLAT" FontWeight="Bold" Foreground="White" FontSize="12"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnStop" Click="BtnStop_Click" CornerRadius="6" Padding="0" Width="110" Height="45" Background="#641E16" BorderBrush="#C0392B" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE71A;" FontSize="16" Foreground="#E74C3C"/>
                                    <TextBlock Text="DURDUR" FontWeight="Bold" Foreground="White" FontSize="12"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnReset" Click="BtnReset_Click" CornerRadius="6" Padding="0" Width="110" Height="45" Background="#7E5109" BorderBrush="#F39C12" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE72C;" FontSize="16" Foreground="#F1C40F"/>
                                    <TextBlock Text="RESET" FontWeight="Bold" Foreground="White" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Height="650">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="80"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Grid.Row="0" Margin="5">
                        <Border Background="#1A1A1C" CornerRadius="8" BorderThickness="2" BorderBrush="{x:Bind Stations[0].BorderColor, Mode=OneWay}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="50"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="60"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#252526" CornerRadius="6,6,0,0" Padding="15,0" BorderThickness="0,0,0,1" BorderBrush="#333333">
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Stations[0].Name}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                            <TextBlock Text="{x:Bind Stations[0].Description}" FontSize="10" Foreground="#888888"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="10">
                                            <Ellipse Width="12" Height="12" Fill="{x:Bind Stations[0].ModeColor, Mode=OneWay}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Grid Grid.Row="1" Background="#151515">
                                    <Grid Margin="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- 1. Auto/Manual Buttons -->
                                        <Border Grid.Row="0" CornerRadius="15" Background="#202020" BorderBrush="#333" BorderThickness="1" HorizontalAlignment="Center" Padding="2" Margin="0,0,0,10">
                                            <StackPanel Orientation="Horizontal">
                                                <ToggleButton IsChecked="{Binding Stations[0].IsAutoMode, Mode=TwoWay}" Content="OTOMATİK" FontSize="11" FontWeight="Bold" Width="90" CornerRadius="13" Height="26" Background="{Binding Stations[0].AutoBtnBg}" Foreground="{Binding Stations[0].AutoBtnFg}"/>
                                                <ToggleButton IsChecked="{Binding Stations[0].IsManualMode, Mode=TwoWay}" Content="MANUEL" FontSize="11" FontWeight="Bold" Width="90" CornerRadius="13" Height="26" Background="{Binding Stations[0].ManualBtnBg}" Foreground="{Binding Stations[0].ManualBtnFg}"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- 2. Model View (Middle) -->
                                        <Border Grid.Row="1" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Background="#101010" Margin="0,0,0,10">
                                             <WebView2 x:Name="Viewer_Station1" DefaultBackgroundColor="Transparent"/>
                                        </Border>

                                        <!-- 3. Bottom Area (Status Left | RFID Right) -->
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Status Notifications -->
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,5,0">
                                                <FontIcon Glyph="&#xE9F5;" FontSize="36" Foreground="{x:Bind Stations[0].StateColor, Mode=OneWay}" Margin="0,0,0,5"/>
                                                <TextBlock Text="{x:Bind Stations[0].StateText, Mode=OneWay}" FontSize="12" FontWeight="Bold" Foreground="{x:Bind Stations[0].StateColor, Mode=OneWay}" TextAlignment="Center" TextWrapping="Wrap"/>
                                                
                                                <StackPanel Orientation="Horizontal" Spacing="5" Visibility="{x:Bind Stations[0].AlarmVisibility, Mode=OneWay}" HorizontalAlignment="Center" Margin="0,5,0,0">
                                                    <FontIcon Glyph="&#xE7BA;" Foreground="Red" FontSize="14"/>
                                                    <TextBlock Text="{x:Bind Stations[0].AlarmText, Mode=OneWay}" Foreground="Red" FontSize="10" FontWeight="Bold"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- RFID Control Box -->
                                            <Border Grid.Column="1" Background="#202020" CornerRadius="6" Padding="8" BorderBrush="#333" BorderThickness="1">
                                                <StackPanel Spacing="5">
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <FontIcon Glyph="&#xEFA9;" Foreground="#0078D4" FontSize="12"/>
                                                        <TextBlock Text="RFID KONTROL" FontSize="10" FontWeight="Bold" Foreground="#DDD"/>
                                                    </StackPanel>
                                                    <ComboBox ItemsSource="{Binding Stations[0].RfidOpModes}" SelectedItem="{Binding Stations[0].RfidOpMode, Mode=TwoWay}" Foreground="White" FontSize="10" HorizontalAlignment="Stretch" BorderThickness="1" Background="#151515" Height="24"/>
                                                    
                                                    <StackPanel Visibility="{Binding Stations[0].IsSpecificRfidVisible}">
                                                        <TextBlock Text="Beklenen ID :" FontSize="9" Foreground="#888" Margin="0,0,0,2"/>
                                                        <ComboBox ItemsSource="{Binding Stations[0].RefRfids}" SelectedValue="{Binding Stations[0].TargetRfid, Mode=TwoWay}" SelectedValuePath="Id" DisplayMemberPath="Id" Foreground="White" PlaceholderText="..." FontSize="10" HorizontalAlignment="Stretch" BorderThickness="1" Background="#151515" Height="24"/>
                                                    </StackPanel>

                                                    <Grid ColumnSpacing="5" Margin="0,2,0,0" Background="#151515" Padding="4" CornerRadius="4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="Okunan:" FontSize="8" Foreground="#888"/>
                                                            <TextBlock Text="{x:Bind Stations[0].CurrentRfid, Mode=OneWay}" FontSize="11" Foreground="{x:Bind Stations[0].RfidMatchColor, Mode=OneWay}" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <FontIcon Grid.Column="1" Glyph="{x:Bind Stations[0].RfidMatchIcon, Mode=OneWay}" Foreground="{x:Bind Stations[0].RfidMatchColor, Mode=OneWay}" FontSize="14" VerticalAlignment="Center" Margin="2,0"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>
                                <Border Grid.Row="2" Background="#202020" CornerRadius="0,0,6,6" Padding="15,0">
                                    <Grid VerticalAlignment="Center">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Üretim Adedi" FontSize="10" Foreground="#888888"/>
                                            <TextBlock Text="{x:Bind Stations[0].ProductionCount, Mode=OneWay}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                        </StackPanel>
                                        <StackPanel Spacing="2" HorizontalAlignment="Right">
                                            <TextBlock Text="Verimlilik" FontSize="10" Foreground="#888888" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{x:Bind Stations[0].Efficiency, Mode=OneWay}" FontSize="14" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                    <Grid Grid.Column="1" Grid.Row="0" Margin="5">
                        <Border Background="#1A1A1C" CornerRadius="8" BorderThickness="2" BorderBrush="{x:Bind Stations[1].BorderColor, Mode=OneWay}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="50"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="60"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#252526" CornerRadius="6,6,0,0" Padding="15,0" BorderThickness="0,0,0,1" BorderBrush="#333333">
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Stations[1].Name}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                            <TextBlock Text="{x:Bind Stations[1].Description}" FontSize="10" Foreground="#888888"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="10">
                                            <Ellipse Width="12" Height="12" Fill="{x:Bind Stations[1].ModeColor, Mode=OneWay}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Grid Grid.Row="1" Background="#151515">
                                    <Grid Margin="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- 1. Auto/Manual Buttons -->
                                        <Border Grid.Row="0" CornerRadius="15" Background="#202020" BorderBrush="#333" BorderThickness="1" HorizontalAlignment="Center" Padding="2" Margin="0,0,0,10">
                                            <StackPanel Orientation="Horizontal">
                                                <ToggleButton IsChecked="{Binding Stations[1].IsAutoMode, Mode=TwoWay}" Content="OTOMATİK" FontSize="11" FontWeight="Bold" Width="90" CornerRadius="13" Height="26" Background="{Binding Stations[1].AutoBtnBg}" Foreground="{Binding Stations[1].AutoBtnFg}"/>
                                                <ToggleButton IsChecked="{Binding Stations[1].IsManualMode, Mode=TwoWay}" Content="MANUEL" FontSize="11" FontWeight="Bold" Width="90" CornerRadius="13" Height="26" Background="{Binding Stations[1].ManualBtnBg}" Foreground="{Binding Stations[1].ManualBtnFg}"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- 2. Model View (Middle) -->
                                        <Border Grid.Row="1" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Background="#101010" Margin="0,0,0,10">
                                             <WebView2 x:Name="Viewer_Station2" DefaultBackgroundColor="Transparent"/>
                                        </Border>

                                        <!-- 3. Bottom Area (Status Left | RFID Right) -->
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Status Notifications -->
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,5,0">
                                                <FontIcon Glyph="&#xE9F5;" FontSize="36" Foreground="{x:Bind Stations[1].StateColor, Mode=OneWay}" Margin="0,0,0,5"/>
                                                <TextBlock Text="{x:Bind Stations[1].StateText, Mode=OneWay}" FontSize="12" FontWeight="Bold" Foreground="{x:Bind Stations[1].StateColor, Mode=OneWay}" TextAlignment="Center" TextWrapping="Wrap"/>
                                                
                                                <StackPanel Orientation="Horizontal" Spacing="5" Visibility="{x:Bind Stations[1].AlarmVisibility, Mode=OneWay}" HorizontalAlignment="Center" Margin="0,5,0,0">
                                                    <FontIcon Glyph="&#xE7BA;" Foreground="Red" FontSize="14"/>
                                                    <TextBlock Text="{x:Bind Stations[1].AlarmText, Mode=OneWay}" Foreground="Red" FontSize="10" FontWeight="Bold"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- RFID Control Box -->
                                            <Border Grid.Column="1" Background="#202020" CornerRadius="6" Padding="8" BorderBrush="#333" BorderThickness="1">
                                                <StackPanel Spacing="5">
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <FontIcon Glyph="&#xEFA9;" Foreground="#0078D4" FontSize="12"/>
                                                        <TextBlock Text="RFID KONTROL" FontSize="10" FontWeight="Bold" Foreground="#DDD"/>
                                                    </StackPanel>
                                                    <ComboBox ItemsSource="{Binding Stations[1].RfidOpModes}" SelectedItem="{Binding Stations[1].RfidOpMode, Mode=TwoWay}" Foreground="White" FontSize="10" HorizontalAlignment="Stretch" BorderThickness="1" Background="#151515" Height="24"/>
                                                    
                                                    <StackPanel Visibility="{Binding Stations[1].IsSpecificRfidVisible}">
                                                        <TextBlock Text="Beklenen ID :" FontSize="9" Foreground="#888" Margin="0,0,0,2"/>
                                                        <ComboBox ItemsSource="{Binding Stations[1].RefRfids}" SelectedValue="{Binding Stations[1].TargetRfid, Mode=TwoWay}" SelectedValuePath="Id" DisplayMemberPath="Id" Foreground="White" PlaceholderText="..." FontSize="10" HorizontalAlignment="Stretch" BorderThickness="1" Background="#151515" Height="24"/>
                                                    </StackPanel>

                                                    <Grid ColumnSpacing="5" Margin="0,2,0,0" Background="#151515" Padding="4" CornerRadius="4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="Okunan:" FontSize="8" Foreground="#888"/>
                                                            <TextBlock Text="{x:Bind Stations[1].CurrentRfid, Mode=OneWay}" FontSize="11" Foreground="{x:Bind Stations[1].RfidMatchColor, Mode=OneWay}" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <FontIcon Grid.Column="1" Glyph="{x:Bind Stations[1].RfidMatchIcon, Mode=OneWay}" Foreground="{x:Bind Stations[1].RfidMatchColor, Mode=OneWay}" FontSize="14" VerticalAlignment="Center" Margin="2,0"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>
                                <Border Grid.Row="2" Background="#202020" CornerRadius="0,0,6,6" Padding="15,0">
                                    <Grid VerticalAlignment="Center">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Üretim Adedi" FontSize="10" Foreground="#888888"/>
                                            <TextBlock Text="{x:Bind Stations[1].ProductionCount, Mode=OneWay}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                        </StackPanel>
                                        <StackPanel Spacing="2" HorizontalAlignment="Right">
                                            <TextBlock Text="Verimlilik" FontSize="10" Foreground="#888888" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{x:Bind Stations[1].Efficiency, Mode=OneWay}" FontSize="14" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                    <Grid Grid.Column="2" Grid.Row="0" Margin="5">
                        <Border Background="#1A1A1C" CornerRadius="8" BorderThickness="2" BorderBrush="{x:Bind Stations[2].BorderColor, Mode=OneWay}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="50"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="60"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#252526" CornerRadius="6,6,0,0" Padding="15,0" BorderThickness="0,0,0,1" BorderBrush="#333333">
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Stations[2].Name}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                            <TextBlock Text="{x:Bind Stations[2].Description}" FontSize="10" Foreground="#888888"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="10">
                                            <Ellipse Width="12" Height="12" Fill="{x:Bind Stations[2].ModeColor, Mode=OneWay}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Grid Grid.Row="1" Background="#151515">
                                    <Grid Margin="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- 1. Auto/Manual Buttons -->
                                        <Border Grid.Row="0" CornerRadius="15" Background="#202020" BorderBrush="#333" BorderThickness="1" HorizontalAlignment="Center" Padding="2" Margin="0,0,0,10">
                                            <StackPanel Orientation="Horizontal">
                                                <ToggleButton IsChecked="{Binding Stations[2].IsAutoMode, Mode=TwoWay}" Content="OTOMATİK" FontSize="11" FontWeight="Bold" Width="90" CornerRadius="13" Height="26" Background="{Binding Stations[2].AutoBtnBg}" Foreground="{Binding Stations[2].AutoBtnFg}"/>
                                                <ToggleButton IsChecked="{Binding Stations[2].IsManualMode, Mode=TwoWay}" Content="MANUEL" FontSize="11" FontWeight="Bold" Width="90" CornerRadius="13" Height="26" Background="{Binding Stations[2].ManualBtnBg}" Foreground="{Binding Stations[2].ManualBtnFg}"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- 2. Model View (Middle) -->
                                        <Border Grid.Row="1" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Background="#101010" Margin="0,0,0,10">
                                             <WebView2 x:Name="Viewer_Station3" DefaultBackgroundColor="Transparent"/>
                                        </Border>

                                        <!-- 3. Bottom Area (Status Left | RFID Right) -->
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Status Notifications -->
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,5,0">
                                                <FontIcon Glyph="&#xE9F5;" FontSize="36" Foreground="{x:Bind Stations[2].StateColor, Mode=OneWay}" Margin="0,0,0,5"/>
                                                <TextBlock Text="{x:Bind Stations[2].StateText, Mode=OneWay}" FontSize="12" FontWeight="Bold" Foreground="{x:Bind Stations[2].StateColor, Mode=OneWay}" TextAlignment="Center" TextWrapping="Wrap"/>
                                                
                                                <StackPanel Orientation="Horizontal" Spacing="5" Visibility="{x:Bind Stations[2].AlarmVisibility, Mode=OneWay}" HorizontalAlignment="Center" Margin="0,5,0,0">
                                                    <FontIcon Glyph="&#xE7BA;" Foreground="Red" FontSize="14"/>
                                                    <TextBlock Text="{x:Bind Stations[2].AlarmText, Mode=OneWay}" Foreground="Red" FontSize="10" FontWeight="Bold"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- RFID Control Box -->
                                            <Border Grid.Column="1" Background="#202020" CornerRadius="6" Padding="8" BorderBrush="#333" BorderThickness="1">
                                                <StackPanel Spacing="5">
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <FontIcon Glyph="&#xEFA9;" Foreground="#0078D4" FontSize="12"/>
                                                        <TextBlock Text="RFID KONTROL" FontSize="10" FontWeight="Bold" Foreground="#DDD"/>
