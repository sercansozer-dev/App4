<Page
    x:Class="App4.Auto_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App4"
    xmlns:utils="using:App4.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="AutoPageRoot"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="StationCardTemplate" x:DataType="utils:StationViewModel">
            <Border Background="#1A1A1C" CornerRadius="8" BorderThickness="2" BorderBrush="{x:Bind BorderColor, Mode=OneWay}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="60"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#252526" CornerRadius="6,6,0,0" Padding="15,0" BorderThickness="0,0,0,1" BorderBrush="#333333">
                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Name}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{x:Bind Description}" FontSize="10" Foreground="#888888"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="10">
                                <Ellipse Width="12" Height="12" Fill="{x:Bind ModeColor, Mode=OneWay}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Background="#151515">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="15">
                            <Border CornerRadius="15" Background="#202020" BorderBrush="#333" BorderThickness="1" HorizontalAlignment="Center" Padding="2">
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton IsChecked="{Binding IsAutoMode, Mode=TwoWay}" 
                                                  Content="OTOMATİK" FontSize="11" FontWeight="Bold" Width="90" CornerRadius="13" Height="26"
                                                  Background="{Binding AutoBtnBg}" 
                                                  Foreground="{Binding AutoBtnFg}"/>

                                    <ToggleButton IsChecked="{Binding IsManualMode, Mode=TwoWay}"
                                                  Content="MANUEL" FontSize="11" FontWeight="Bold" Width="90" CornerRadius="13" Height="26"
                                                  Background="{Binding ManualBtnBg}"
                                                  Foreground="{Binding ManualBtnFg}"/>
                                </StackPanel>
                            </Border>

                            <FontIcon Glyph="&#xE9F5;" FontSize="50" Foreground="{x:Bind StateColor, Mode=OneWay}"/>

                            <TextBlock Text="{x:Bind StateText, Mode=OneWay}" FontSize="16" FontWeight="Bold" Foreground="{x:Bind StateColor, Mode=OneWay}" TextAlignment="Center"/>

                            <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind AlarmVisibility, Mode=OneWay}" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE7BA;" Foreground="Red" FontSize="16"/>
                                <TextBlock Text="{x:Bind AlarmText, Mode=OneWay}" Foreground="Red" FontSize="12" FontWeight="Bold"/>
                            </StackPanel>

                            <Border Background="#202020" CornerRadius="6" Padding="10" Margin="0,5,0,0" BorderBrush="#333" BorderThickness="1" HorizontalAlignment="Stretch" Width="220">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon Glyph="&#xEFA9;" Foreground="#0078D4" FontSize="12"/>
                                        <TextBlock Text="RFID KONTROL" FontSize="11" FontWeight="Bold" Foreground="#DDD"/>
                                    </StackPanel>

                                    <ComboBox ItemsSource="{Binding RfidOpModes}" SelectedItem="{Binding RfidOpMode, Mode=TwoWay}" Foreground="White"
                                                FontSize="11" HorizontalAlignment="Stretch" BorderThickness="1" Background="#151515"/>

                                    <StackPanel Visibility="{Binding IsSpecificRfidVisible}">
                                        <TextBlock Text="Beklenen ID :" FontSize="10" Foreground="#888" Margin="0,0,0,2"/>
                                        <ComboBox ItemsSource="{Binding RefRfids}" SelectedValue="{Binding TargetRfid, Mode=TwoWay}"
                                                    SelectedValuePath="Id" DisplayMemberPath="Id" Foreground="White"
                                                    PlaceholderText="Seçiniz..."
                                                    FontSize="11" HorizontalAlignment="Stretch" BorderThickness="1" Background="#151515"/>
                                    </StackPanel>

                                    <Grid ColumnSpacing="5" Margin="0,5,0,0" Background="#151515" Padding="5" CornerRadius="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Okunan:" FontSize="9" Foreground="#888"/>
                                            <TextBlock Text="{x:Bind CurrentRfid, Mode=OneWay}" FontSize="14" Foreground="{x:Bind RfidMatchColor, Mode=OneWay}" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <FontIcon Grid.Column="1" Glyph="{x:Bind RfidMatchIcon, Mode=OneWay}" Foreground="{x:Bind RfidMatchColor, Mode=OneWay}" FontSize="16" VerticalAlignment="Center" Margin="5,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Button Click="{x:Bind ToggleBypass}" Background="{x:Bind BypassButtonColor, Mode=OneWay}" CornerRadius="15" Padding="20,5" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <FontIcon Glyph="&#xE7E8;" FontSize="12" Foreground="White"/>
                                    <TextBlock Text="{x:Bind BypassButtonText, Mode=OneWay}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2" Background="#202020" CornerRadius="0,0,6,6" Padding="15,0">
                        <Grid VerticalAlignment="Center">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Üretim Adedi" FontSize="10" Foreground="#888888"/>
                                <TextBlock Text="{x:Bind ProductionCount, Mode=OneWay}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Spacing="2" HorizontalAlignment="Right">
                                <TextBlock Text="Verimlilik" FontSize="10" Foreground="#888888" HorizontalAlignment="Right"/>
                                <TextBlock Text="{x:Bind Efficiency, Mode=OneWay}" FontSize="14" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="StationVarTemplate" x:DataType="utils:PlcVariable">
            <StackPanel Spacing="5" Padding="10" BorderBrush="#222" BorderThickness="0,0,0,1">
                <TextBlock Text="{x:Bind Name}" Foreground="#0078D4" FontWeight="Bold" FontSize="11"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableInputPlcTags, ElementName=AutoPageRoot, Mode=OneWay}" 
                              SelectedItem="{x:Bind PlcTag, Mode=OneWay}" 
                              PlaceholderText="Tag Seç..." Background="#202020" BorderBrush="#333" Foreground="White" FontSize="11" Margin="0,0,5,0" Height="28"
                              SelectionChanged="PlcTagComboBox_SelectionChanged"/>
                    <TextBox Grid.Column="1" Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Val" Background="#202020" BorderBrush="#333" Foreground="White" FontSize="11"/>
                </Grid>
                <TextBlock Text="{x:Bind Description}" Foreground="#666" FontSize="10" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="StationOutputVarTemplate" x:DataType="utils:PlcVariable">
            <StackPanel Spacing="5" Padding="10" BorderBrush="#222" BorderThickness="0,0,0,1">
                <TextBlock Text="{x:Bind Name}" Foreground="#0078D4" FontWeight="Bold" FontSize="11"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableOutputPlcTags, ElementName=AutoPageRoot, Mode=OneWay}" 
                              SelectedItem="{x:Bind PlcTag, Mode=OneWay}" 
                              PlaceholderText="Tag Seç..." Background="#202020" BorderBrush="#333" Foreground="White" FontSize="11" Margin="0,0,5,0" Height="28"
                              SelectionChanged="PlcTagComboBox_SelectionChanged"/>
                    <TextBox Grid.Column="1" Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Val" Background="#202020" BorderBrush="#333" Foreground="White" FontSize="11"/>
                </Grid>
                <TextBlock Text="{x:Bind Description}" Foreground="#666" FontSize="10" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid Background="#101010">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F1F1F" BorderThickness="0,0,0,1" BorderBrush="#333333" Padding="20,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <FontIcon Glyph="&#xE72A;" Foreground="#0078D4" FontSize="20"/>
                    <TextBlock Text="OTOMATİK ÜRETİM KONTROLÜ" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="20">
                <Grid Height="650">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="80"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Grid.Row="0" Margin="5">
                        <ContentControl Content="{x:Bind Stations[0], Mode=OneWay}" ContentTemplate="{StaticResource StationCardTemplate}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                    </Grid>
                    <Grid Grid.Column="1" Grid.Row="0" Margin="5">
                        <ContentControl Content="{x:Bind Stations[1], Mode=OneWay}" ContentTemplate="{StaticResource StationCardTemplate}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                    </Grid>
                    <Grid Grid.Column="2" Grid.Row="0" Margin="5">
                        <ContentControl Content="{x:Bind Stations[2], Mode=OneWay}" ContentTemplate="{StaticResource StationCardTemplate}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                    </Grid>
                    <Grid Grid.Column="3" Grid.Row="0" Margin="5">
                        <ContentControl Content="{x:Bind Stations[3], Mode=OneWay}" ContentTemplate="{StaticResource StationCardTemplate}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                    </Grid>

                    <Border Grid.Row="1" Grid.ColumnSpan="4" Height="4" Background="#333333" VerticalAlignment="Center" Margin="10,0" CornerRadius="2"/>

                    <Grid Grid.Row="1" Grid.Column="0" Visibility="{x:Bind Stations[0].RobotVisibility, Mode=OneWay}" Opacity="{x:Bind Stations[0].RobotOpacity, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-20,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" HorizontalAlignment="Center">
                                <Ellipse Width="50" Height="50" Fill="#1F1F1F" Stroke="#0078D4" StrokeThickness="2"/>
                                <FontIcon Glyph="&#xE81D;" FontSize="24" Foreground="#0078D4"/>
                            </Grid>
                            <Rectangle Grid.Row="1" Width="2" Height="15" Fill="#0078D4" HorizontalAlignment="Center"/>
                            <Border Grid.Row="1" Width="40" Height="8" Background="#0078D4" CornerRadius="4" VerticalAlignment="Bottom" Margin="0,0,0,-4"/>
                        </Grid>
                    </Grid>
                    <Grid Grid.Row="1" Grid.Column="1" Visibility="{x:Bind Stations[1].RobotVisibility, Mode=OneWay}" Opacity="{x:Bind Stations[1].RobotOpacity, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-20,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" HorizontalAlignment="Center">
                                <Ellipse Width="50" Height="50" Fill="#1F1F1F" Stroke="#0078D4" StrokeThickness="2"/>
                                <FontIcon Glyph="&#xE81D;" FontSize="24" Foreground="#0078D4"/>
                            </Grid>
                            <Rectangle Grid.Row="1" Width="2" Height="15" Fill="#0078D4" HorizontalAlignment="Center"/>
                            <Border Grid.Row="1" Width="40" Height="8" Background="#0078D4" CornerRadius="4" VerticalAlignment="Bottom" Margin="0,0,0,-4"/>
                        </Grid>
                    </Grid>
                    <Grid Grid.Row="1" Grid.Column="2" Visibility="{x:Bind Stations[2].RobotVisibility, Mode=OneWay}" Opacity="{x:Bind Stations[2].RobotOpacity, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-20,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" HorizontalAlignment="Center">
                                <Ellipse Width="50" Height="50" Fill="#1F1F1F" Stroke="#0078D4" StrokeThickness="2"/>
                                <FontIcon Glyph="&#xE81D;" FontSize="24" Foreground="#0078D4"/>
                            </Grid>
                            <Rectangle Grid.Row="1" Width="2" Height="15" Fill="#0078D4" HorizontalAlignment="Center"/>
                            <Border Grid.Row="1" Width="40" Height="8" Background="#0078D4" CornerRadius="4" VerticalAlignment="Bottom" Margin="0,0,0,-4"/>
                        </Grid>
                    </Grid>
                    <Grid Grid.Row="1" Grid.Column="3" Visibility="{x:Bind Stations[3].RobotVisibility, Mode=OneWay}" Opacity="{x:Bind Stations[3].RobotOpacity, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-20,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" HorizontalAlignment="Center">
                                <Ellipse Width="50" Height="50" Fill="#1F1F1F" Stroke="#0078D4" StrokeThickness="2"/>
                                <FontIcon Glyph="&#xE81D;" FontSize="24" Foreground="#0078D4"/>
                            </Grid>
                            <Rectangle Grid.Row="1" Width="2" Height="15" Fill="#0078D4" HorizontalAlignment="Center"/>
                            <Border Grid.Row="1" Width="40" Height="8" Background="#0078D4" CornerRadius="4" VerticalAlignment="Bottom" Margin="0,0,0,-4"/>
                        </Grid>
                    </Grid>
                </Grid>

                <StackPanel Spacing="10" Margin="0,30,0,20">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE8FD;" Foreground="#E67E22" FontSize="20"/>
                        <TextBlock Text="PLC KONFİGÜRASYON &amp; SİMÜLASYON" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Aşağıdaki tablodan simülasyon veya manual ayar değerleri girebilirsiniz." FontSize="12" Foreground="#888888"/>

                    <Border Background="#1A1A1C" CornerRadius="8" BorderThickness="1" BorderBrush="#333333" Margin="0,10,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#252526" Padding="15,8" BorderThickness="0,0,0,1" BorderBrush="#333">
                                <TextBlock Text="GENEL ROBOT &amp; HAT VARIABLES" FontSize="12" FontWeight="Bold" Foreground="#DDD"/>
                            </Border>
                            <Grid Grid.Row="1" Background="#202020" BorderThickness="0,0,0,1" BorderBrush="#333" Height="30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="3*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="DEĞİŞKEN ADI" VerticalAlignment="Center" Margin="15,0" Foreground="#888" FontWeight="SemiBold" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="PLC TAG" VerticalAlignment="Center" Margin="15,0" Foreground="#888" FontWeight="SemiBold" FontSize="10"/>
                                <TextBlock Grid.Column="2" Text="DEĞER" VerticalAlignment="Center" Margin="15,0" Foreground="#888" FontWeight="SemiBold" FontSize="10"/>
                                <TextBlock Grid.Column="3" Text="AÇIKLAMA" VerticalAlignment="Center" Margin="15,0" Foreground="#888" FontWeight="SemiBold" FontSize="10"/>
                            </Grid>
                            <ListView Grid.Row="2" ItemsSource="{x:Bind GeneralVars}" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="utils:PlcVariable">
                                        <Grid Padding="0,5" BorderBrush="#222" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="3*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" Margin="15,0">
                                                <FontIcon Glyph="&#xE9D2;" FontSize="12" Foreground="#0078D4"/>
                                                <TextBlock Text="{x:Bind Name}" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                                            </StackPanel>
                                            <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableInputPlcTags, ElementName=AutoPageRoot, Mode=OneWay}" 
                                                      SelectedItem="{x:Bind PlcTag, Mode=OneWay}" 
                                                      Background="#202020" BorderBrush="#333" Foreground="White" Margin="5,0,20,0" FontSize="12" PlaceholderText="Tag Seç..." Height="28"
                                                      SelectionChanged="PlcTagComboBox_SelectionChanged"/>
                                            <TextBox Grid.Column="2" Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{x:Bind IsEditable}" Background="#202020" BorderBrush="#333" Foreground="White" Margin="5,0,20,0" FontSize="12" Padding="5"/>
                                            <TextBlock Grid.Column="3" Text="{x:Bind Description}" VerticalAlignment="Center" Margin="15,0" Foreground="#888888" FontSize="11"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <Grid Margin="0,15,0,0" ColumnSpacing="15" RowSpacing="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Background="#1A1A1C" CornerRadius="8" BorderThickness="2" BorderBrush="#666">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#252526" Padding="10,8" BorderThickness="0,0,0,1" BorderBrush="#333">
                                    <TextBlock Text="İSTASYON 1" FontSize="12" FontWeight="Bold" Foreground="#DDD"/>
                                </Border>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" BorderBrush="#333" BorderThickness="0,0,1,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="GELEN VERİ (INPUT)" Foreground="#888" FontSize="10" Margin="10,5" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <ListView Grid.Row="1" ItemsSource="{x:Bind Station1Vars}" SelectionMode="None" ItemTemplate="{StaticResource StationVarTemplate}"/>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="AKTARILAN VERİ (OUTPUT)" Foreground="#888" FontSize="10" Margin="10,5" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <ListView Grid.Row="1" ItemsSource="{x:Bind Station1Outputs, Mode=OneWay}" SelectionMode="None" ItemTemplate="{StaticResource StationOutputVarTemplate}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1" Background="#1A1A1C" CornerRadius="8" BorderThickness="2" BorderBrush="#666">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#252526" Padding="10,8" BorderThickness="0,0,0,1" BorderBrush="#333">
                                    <TextBlock Text="İSTASYON 2" FontSize="12" FontWeight="Bold" Foreground="#DDD"/>
                                </Border>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" BorderBrush="#333" BorderThickness="0,0,1,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="GELEN VERİ (INPUT)" Foreground="#888" FontSize="10" Margin="10,5" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <ListView Grid.Row="1" ItemsSource="{x:Bind Station2Vars}" SelectionMode="None" ItemTemplate="{StaticResource StationVarTemplate}"/>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="AKTARILAN VERİ (OUTPUT)" Foreground="#888" FontSize="10" Margin="10,5" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <ListView Grid.Row="1" ItemsSource="{x:Bind Station2Outputs, Mode=OneWay}" SelectionMode="None" ItemTemplate="{StaticResource StationOutputVarTemplate}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0" Background="#1A1A1C" CornerRadius="8" BorderThickness="2" BorderBrush="#666">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#252526" Padding="10,8" BorderThickness="0,0,0,1" BorderBrush="#333">
                                    <TextBlock Text="İSTASYON 3" FontSize="12" FontWeight="Bold" Foreground="#DDD"/>
                                </Border>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" BorderBrush="#333" BorderThickness="0,0,1,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="GELEN VERİ (INPUT)" Foreground="#888" FontSize="10" Margin="10,5" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <ListView Grid.Row="1" ItemsSource="{x:Bind Station3Vars}" SelectionMode="None" ItemTemplate="{StaticResource StationVarTemplate}"/>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="AKTARILAN VERİ (OUTPUT)" Foreground="#888" FontSize="10" Margin="10,5" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <ListView Grid.Row="1" ItemsSource="{x:Bind Station3Outputs, Mode=OneWay}" SelectionMode="None" ItemTemplate="{StaticResource StationOutputVarTemplate}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" Background="#1A1A1C" CornerRadius="8" BorderThickness="2" BorderBrush="#666">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#252526" Padding="10,8" BorderThickness="0,0,0,1" BorderBrush="#333">
                                    <TextBlock Text="İSTASYON 4" FontSize="12" FontWeight="Bold" Foreground="#DDD"/>
                                </Border>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" BorderBrush="#333" BorderThickness="0,0,1,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="GELEN VERİ (INPUT)" Foreground="#888" FontSize="10" Margin="10,5" FontWeight="Bold" HorizontalAlignment="Center"/>
