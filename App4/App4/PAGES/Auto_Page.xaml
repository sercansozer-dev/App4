                <!-- ═══════════════════════════════════════════════════════════════════════════ -->
                <Expander Header="Slider Pozisyon Eşleştirme" IsExpanded="True" Margin="0,15,0,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="#1A1A1C" BorderBrush="#333">
                    <StackPanel Padding="15" Spacing="12">

                        <!-- Robot Seçimi -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Kaynak Robot:" FontSize="11" Foreground="#AAA" VerticalAlignment="Center"/>
                            <ComboBox x:Name="SliderRobotCombo" Grid.Column="1" FontSize="11" Height="32" HorizontalAlignment="Stretch" Background="#252528" BorderBrush="#333" PlaceholderText="Robot seç..."/>
                        </Grid>

                        <!-- İstasyon Sinyali (1, 2, 3 → görsel pozisyon) -->
                        <Border Background="#151515" CornerRadius="6" Padding="12,8">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="İstasyon Sinyali:" FontSize="11" Foreground="#FF9800" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <ComboBox x:Name="SliderSignalCombo" Grid.Column="1" FontSize="11" Height="32" HorizontalAlignment="Stretch" Background="#252528" BorderBrush="#333" PlaceholderText="Sinyal seç..."/>
                                <TextBlock Grid.Column="2" Text="Değer:" FontSize="10" Foreground="#888" VerticalAlignment="Center"/>
                                <TextBlock x:Name="SliderLiveValue" Grid.Column="3" Text="---" FontSize="14" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="Robot 1,2 veya 3 gönderir → slider görseli o istasyona hareket eder" FontSize="10" Foreground="#666" Margin="0,-6,0,0"/>

                        <!-- Aktüel Pozisyon Sinyali (mm → sadece gösterim) -->
                        <Border Background="#151515" CornerRadius="6" Padding="12,8">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Aktüel Pozisyon:" FontSize="11" Foreground="#0078D4" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <ComboBox x:Name="SliderActualPosCombo" Grid.Column="1" FontSize="11" Height="32" HorizontalAlignment="Stretch" Background="#252528" BorderBrush="#333" PlaceholderText="Sinyal seç..."/>
                                <TextBlock Grid.Column="2" Text="Değer:" FontSize="10" Foreground="#888" VerticalAlignment="Center"/>
                                <TextBlock x:Name="SliderActualPosLive" Grid.Column="3" Text="---" FontSize="14" FontWeight="Bold" Foreground="#FF9800" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="Slider'ın gerçek mm pozisyonunu gösterir (görseli etkilemez)" FontSize="10" Foreground="#666" Margin="0,-6,0,0"/>

                        <!-- İstasyon E1 Pozisyonları -->
                        <Border Background="#151515" CornerRadius="6" Padding="12,10" Margin="0,4,0,0">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE707;" FontSize="12" Foreground="#FF9800"/>
                                    <TextBlock Text="İSTASYON E1 POZİSYONLARI (mm)" FontSize="11" FontWeight="Bold" Foreground="#FF9800"/>
                                </StackPanel>
                                <Grid ColumnSpacing="10" RowSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="BAKIM:" FontSize="11" Foreground="#AAA" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBox x:Name="TxtAutoStBakimPos" Grid.Row="0" Grid.Column="1" PlaceholderText="0.0"
                                             FontSize="11" Height="30" Background="#1A1A1C" BorderBrush="#333" Foreground="White"
                                             LostFocus="AutoStationPos_LostFocus"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="İSTASYON 1:" FontSize="11" Foreground="#AAA" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBox x:Name="TxtAutoSt1Pos" Grid.Row="0" Grid.Column="3" PlaceholderText="0.0"
                                             FontSize="11" Height="30" Background="#1A1A1C" BorderBrush="#333" Foreground="White"
                                             LostFocus="AutoStationPos_LostFocus"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="İSTASYON 2:" FontSize="11" Foreground="#AAA" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBox x:Name="TxtAutoSt2Pos" Grid.Row="1" Grid.Column="1" PlaceholderText="0.0"
                                             FontSize="11" Height="30" Background="#1A1A1C" BorderBrush="#333" Foreground="White"
                                             LostFocus="AutoStationPos_LostFocus"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="İSTASYON 3:" FontSize="11" Foreground="#AAA" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBox x:Name="TxtAutoSt3Pos" Grid.Row="1" Grid.Column="3" PlaceholderText="0.0"
                                             FontSize="11" Height="30" Background="#1A1A1C" BorderBrush="#333" Foreground="White"
                                             LostFocus="AutoStationPos_LostFocus"/>
                                </Grid>
                                <TextBlock Text="Değerleri değiştirip dışına tıkladığınızda otomatik kaydedilir" FontSize="9" Foreground="#555"/>
                            </StackPanel>
                        </Border>

                        <!-- Robot Bağlantı Durumu -->
                        <Grid ColumnSpacing="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#151515" CornerRadius="6" Padding="10,8">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE99A;" FontSize="14" Foreground="#4CAF50"/>
                                        <TextBlock Text="Robot 1" FontSize="11" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border x:Name="Robot1ConnStatus" Background="#64211E" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right">
                                        <TextBlock x:Name="Robot1ConnText" Text="BAĞLI DEĞİL" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Grid.Column="1" Background="#151515" CornerRadius="6" Padding="10,8">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE99A;" FontSize="14" Foreground="#0078D4"/>
                                        <TextBlock Text="Robot 2" FontSize="11" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border x:Name="Robot2ConnStatus" Background="#64211E" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right">
                                        <TextBlock x:Name="Robot2ConnText" Text="BAĞLI DEĞİL" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Expander>


                <Expander Header="RFID ve Model Eşleştirme" IsExpanded="True" Margin="0,5,0,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="#1A1A1C" BorderBrush="#333">
                    <Grid Height="250" Padding="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- HEADER ROW -->
                        <Grid Grid.Row="0" Margin="0,0,0,5">
                           <Grid.ColumnDefinitions>
                               <ColumnDefinition Width="150"/>
                               <ColumnDefinition Width="*"/>
                               <ColumnDefinition Width="250"/>
                           </Grid.ColumnDefinitions>
                           <Border Grid.Column="0" Background="#333" CornerRadius="4" Margin="0,0,5,0" Padding="10,6">
                                <TextBlock Text="RFID ID" Foreground="#AAA" FontSize="11" FontWeight="Bold"/>
                           </Border>
                           <Border Grid.Column="1" Background="#333" CornerRadius="4" Margin="0,0,5,0" Padding="10,6">
                                <TextBlock Text="AÇIKLAMA" Foreground="#AAA" FontSize="11" FontWeight="Bold"/>
                           </Border>
                           <Border Grid.Column="2" Background="#333" CornerRadius="4" Padding="10,6">
                                <TextBlock Text="MODEL DOSYASI" Foreground="#AAA" FontSize="11" FontWeight="Bold"/>
                           </Border>
                        </Grid>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind utils:GlobalData.KnownRfids, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="utils:RfidDef">
                                    <Border Background="#1F1F1F" CornerRadius="4" Margin="0,2" BorderBrush="#2A2A2A" BorderThickness="1">
                                        <Grid Padding="10,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="250"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" Text="{x:Bind Id}" Foreground="#3498DB" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="5,0"/>
                                            
                                            <TextBox Grid.Column="1" Text="{x:Bind Description, Mode=TwoWay}" 
                                                     Background="Transparent" BorderThickness="0" Foreground="White" FontSize="12"
                                                     PlaceholderText="Açıklama giriniz..." VerticalAlignment="Center" Margin="0,0,10,0"/>

                                            <ComboBox Grid.Column="2" 
                                                      ItemsSource="{Binding ElementName=AutoPageRoot, Path=AvailableModels}"
                                                      SelectedItem="{x:Bind ModelFileName, Mode=OneWay}"
                                                      SelectionChanged="RfidModel_SelectionChanged"
                                                      Background="#252526" BorderBrush="#444" Foreground="White" FontSize="11"
                                                      HorizontalAlignment="Stretch" VerticalAlignment="Center" Height="28"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Expander>

                <!-- (Robot durum bilgisi slider bölümüne taşındı) -->

                <Border Background="#1A1A1C" CornerRadius="8" BorderThickness="1" BorderBrush="#333" Margin="0,20,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="200"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#252526" Padding="15,8" BorderThickness="0,0,0,1" BorderBrush="#333" CornerRadius="8,8,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Stretch">
                                <FontIcon Glyph="&#xE9F5;" Foreground="#E74C3C" FontSize="14"/>
                                <TextBlock Text="SİSTEM VE ARIZA KAYITLARI (LOG)" FontSize="12" FontWeight="Bold" Foreground="#DDD"/>
                                <Button Click="BtnClearLogs_Click" Content="Temizle" FontSize="10" Height="24" Padding="10,0" Margin="20,0,0,0" Background="#333" Foreground="White" BorderThickness="0" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Border>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind SystemLogs}" SelectionMode="None" Background="#111">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="utils:LogEntry">
                                    <Grid Padding="10,4" BorderThickness="0,0,0,1" BorderBrush="#222">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind TimeStr}" Foreground="#666" FontSize="11" FontFamily="Consolas"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Message}" Foreground="{x:Bind ColorBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <StackPanel Spacing="10" Margin="0,30,0,20">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE8FD;" Foreground="#E67E22" FontSize="20"/>
                        <TextBlock Text="PLC KONFİGÜRASYON &amp; SİMÜLASYON" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Aşağıdaki tablodan simülasyon veya manual ayar değerleri girebilirsiniz." FontSize="12" Foreground="#888888"/>

                    <Border Background="#1A1A1C" CornerRadius="8" BorderThickness="1" BorderBrush="#333333" Margin="0,10,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#252526" Padding="15,8" BorderThickness="0,0,0,1" BorderBrush="#333">
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="GENEL ROBOT &amp; HAT VARIABLES" FontSize="12" FontWeight="Bold" Foreground="#DDD"/>
                                    <TextBlock Text="Config: C:\Simbiosis\SimbiosisLeakTestApp\Config\Auto_Page_Variables.json" FontSize="8" Foreground="#444" FontFamily="Consolas"/>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="1" Padding="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" BorderBrush="#333" BorderThickness="0,0,1,0" Padding="0,0,10,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="GELEN VERİ (INPUT)" Foreground="#888" FontSize="10" Margin="10,5" FontWeight="Bold" HorizontalAlignment="Center"/>

                                        <ListView Grid.Row="1" ItemsSource="{x:Bind FilteredGeneralInputVars}" SelectionMode="None">
                                            <ListView.ItemTemplate>
                                                <DataTemplate x:DataType="utils:PlcVariable">
                                                    <StackPanel Spacing="5" Padding="10" BorderBrush="#222" BorderThickness="0,0,0,1">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <FontIcon Glyph="&#xE9D2;" FontSize="11" Foreground="#0078D4"/>
                                                            <TextBlock Text="{x:Bind Name}" Foreground="#0078D4" FontWeight="Bold" FontSize="11"/>
                                                        </StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="80"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableInputPlcTags, ElementName=AutoPageRoot, Mode=OneWay}"
                                                                      SelectedItem="{x:Bind PlcTag, Mode=OneWay}"
                                                                      IsEditable="True" PlaceholderText="Tag Ara..." Background="#202020" BorderBrush="#333" Foreground="White" FontSize="11" Margin="0,0,5,0" Height="28"
                                                                      SelectionChanged="PlcTagComboBox_SelectionChanged"/>
                                                            <TextBox Grid.Column="1" Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Val" Background="#202020" BorderBrush="#333" Foreground="White" FontSize="11"/>
                                                        </Grid>
                                                        <TextBlock Text="{x:Bind Description}" Foreground="#666" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1" Padding="10,0,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="AKTARILAN VERİ (OUTPUT)" Foreground="#888" FontSize="10" Margin="10,5" FontWeight="Bold" HorizontalAlignment="Center"/>

                                        <ListView Grid.Row="1" ItemsSource="{x:Bind FilteredGeneralOutputVars}" SelectionMode="None">
                                            <ListView.ItemTemplate>
                                                <DataTemplate x:DataType="utils:PlcVariable">
                                                    <StackPanel Spacing="5" Padding="10" BorderBrush="#222" BorderThickness="0,0,0,1">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <FontIcon Glyph="&#xE9D2;" FontSize="11" Foreground="#E67E22"/>
                                                            <TextBlock Text="{x:Bind Name}" Foreground="#E67E22" FontWeight="Bold" FontSize="11"/>
                                                        </StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="80"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableOutputPlcTags, ElementName=AutoPageRoot, Mode=OneWay}"
                                                                      SelectedItem="{x:Bind PlcTag, Mode=OneWay}"
                                                                      IsEditable="True" PlaceholderText="Tag 1 Ara..." Background="#202020" BorderBrush="#333" Foreground="White" FontSize="11" Margin="0,0,5,0" Height="28"
                                                                      SelectionChanged="PlcTagComboBox_SelectionChanged"/>
                                                            <TextBox Grid.Column="1" Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Val" Background="#202020" BorderBrush="#333" Foreground="White" FontSize="11"/>
                                                        </Grid>
                                                        <ComboBox ItemsSource="{Binding AvailableOutputPlcTags, ElementName=AutoPageRoot, Mode=OneWay}"
                                                                  SelectedItem="{x:Bind PlcTag2, Mode=OneWay}"
                                                                  IsEditable="True" PlaceholderText="Tag 2 Ara..." Background="#1A1A1C" BorderBrush="#2A2A2A" Foreground="#AAA" FontSize="10" Height="26"
                                                                  SelectionChanged="PlcTag2ComboBox_SelectionChanged"/>
                                                        <TextBlock Text="{x:Bind Description}" Foreground="#666" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Grid>
                                </Border>

                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Margin="0,15,0,0" ColumnSpacing="15" RowSpacing="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Background="#1A1A1C" CornerRadius="8" BorderThickness="2" BorderBrush="#666">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#252526" Padding="10,8" BorderThickness="0,0,0,1" BorderBrush="#333">
                                    <TextBlock Text="İSTASYON 1" FontSize="12" FontWeight="Bold" Foreground="#DDD"/>
                                </Border>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" BorderBrush="#333" BorderThickness="0,0,1,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="GELEN VERİ (INPUT)" Foreground="#888" FontSize="10" Margin="10,5" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <ListView Grid.Row="1" ItemsSource="{x:Bind Station1Vars}" SelectionMode="None" ItemTemplate="{StaticResource StationVarTemplate}"/>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="AKTARILAN VERİ (OUTPUT)" Foreground="#888" FontSize="10" Margin="10,5" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <ListView Grid.Row="1" ItemsSource="{x:Bind Station1Outputs, Mode=OneWay}" SelectionMode="None" ItemTemplate="{StaticResource StationOutputVarTemplate}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1" Background="#1A1A1C" CornerRadius="8" BorderThickness="2" BorderBrush="#666">
