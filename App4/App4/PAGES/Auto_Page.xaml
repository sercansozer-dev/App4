                                                    </ListView.ItemTemplate>
                                                </ListView>

                                                <!-- Alarm Çıkış Sinyalleri (Alarm tetiklendiğinde TRUE yazılır) -->
                                                <Border Background="#2A1515" Padding="8,6" BorderBrush="#F44336" BorderThickness="0,1,0,0">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="ALARM ÇIKIŞI (Alarm → Robot TRUE)" FontSize="8" FontWeight="Bold" Foreground="#F44336" Opacity="0.8"/>
                                                        <Grid ColumnSpacing="4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="30"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="R1:" FontSize="9" Foreground="#0078D4" FontWeight="Bold" VerticalAlignment="Center"/>
                                                            <ComboBox x:Name="ComboSafetyAlarmR1Output"
                                                                Grid.Row="0" Grid.Column="1"
                                                                ItemsSource="{Binding AvailableOutputPlcTags, ElementName=AutoPageRoot, Mode=OneWay}"
                                                                SelectedItem="{x:Bind SafetyAlarmR1OutputTag, Mode=TwoWay}"
                                                                PlaceholderText="R1 Çıkış Seç..."
                                                                HorizontalAlignment="Stretch" FontSize="9" Height="30"
                                                                SelectionChanged="ComboSafetyAlarmOutput_SelectionChanged"/>
                                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="R2:" FontSize="9" Foreground="#FF9800" FontWeight="Bold" VerticalAlignment="Center"/>
                                                            <ComboBox x:Name="ComboSafetyAlarmR2Output"
                                                                Grid.Row="1" Grid.Column="1"
                                                                ItemsSource="{Binding AvailableOutputPlcTags, ElementName=AutoPageRoot, Mode=OneWay}"
                                                                SelectedItem="{x:Bind SafetyAlarmR2OutputTag, Mode=TwoWay}"
                                                                PlaceholderText="R2 Çıkış Seç..."
                                                                HorizontalAlignment="Stretch" FontSize="9" Height="30"
                                                                SelectionChanged="ComboSafetyAlarmOutput_SelectionChanged"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Alarm Ekleme -->
                                                <StackPanel Background="#222" Padding="8" Spacing="4">
                                                    <ComboBox x:Name="ComboSafetyAlarmTag"
                                                        ItemsSource="{Binding AvailableInputPlcTags, ElementName=AutoPageRoot, Mode=OneWay}"
                                                        PlaceholderText="Sinyal Seçiniz..."
                                                        HorizontalAlignment="Stretch" FontSize="10"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox x:Name="TxtSafetyAlarmMsg" Grid.Column="0" PlaceholderText="Alarm Mesajı" FontSize="10" Margin="0,0,4,0"/>
                                                        <Button Grid.Column="1" Content="Ekle" Click="BtnAddSafetyAlarm_Click" FontSize="10" FontWeight="Bold" Background="#F44336" Foreground="White" Padding="10,4"/>
                                                    </Grid>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- ═══ SAĞ SÜTUN: UYARI ═══ -->
                                        <Border Grid.Column="1">
                                            <StackPanel Spacing="0">
                                                <!-- UYARI Başlık -->
                                                <Border Background="#3A2E15" Padding="10,6" BorderBrush="#333" BorderThickness="0,0,0,1">
                                                    <StackPanel Spacing="2">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon Glyph="&#xE7BA;" Foreground="#FF9800" FontSize="10"/>
                                                            <TextBlock Text="UYARI (Bilgi Amaçlı)" FontSize="9" FontWeight="Bold" Foreground="#FF9800"/>
                                                        </StackPanel>
                                                        <TextBlock Text="Config: ...\Config\Safety_Warnings.json" FontSize="7" Foreground="#444" FontFamily="Consolas" Margin="16,0,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Sabit: R1 DRIVES -->
                                                <Grid Padding="10,6" BorderBrush="#333" BorderThickness="0,0,0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse x:Name="SafeAutoR1DrivesLed" Grid.Column="0" Width="8" Height="8" Fill="#555" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Spacing="0" Margin="6,0,0,0">
                                                        <TextBlock Text="R1 - $DRIVES_ON" Foreground="#0078D4" FontSize="9" Opacity="0.8"/>
                                                        <TextBlock Text="Robot 1 Sürücüler" Foreground="#BBB" FontSize="10"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="SafeAutoR1DrivesText" Grid.Column="2" Text="---" FontWeight="Bold" FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                </Grid>

                                                <!-- Sabit: R1 USER_SAF -->
                                                <Grid Padding="10,6" BorderBrush="#333" BorderThickness="0,0,0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse x:Name="SafeAutoR1UserSafLed" Grid.Column="0" Width="8" Height="8" Fill="#555" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Spacing="0" Margin="6,0,0,0">
                                                        <TextBlock Text="R1 - $USER_SAF" Foreground="#0078D4" FontSize="9" Opacity="0.8"/>
                                                        <TextBlock Text="Robot 1 User Safety" Foreground="#BBB" FontSize="10"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="SafeAutoR1UserSafText" Grid.Column="2" Text="---" FontWeight="Bold" FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                </Grid>

                                                <!-- Sabit: R1 PERI -->
                                                <Grid Padding="10,6" BorderBrush="#333" BorderThickness="0,0,0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse x:Name="SafeAutoR1PeriLed" Grid.Column="0" Width="8" Height="8" Fill="#555" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Spacing="0" Margin="6,0,0,0">
                                                        <TextBlock Text="R1 - $PERI_RDY" Foreground="#0078D4" FontSize="9" Opacity="0.8"/>
                                                        <TextBlock Text="Robot 1 Peripheral" Foreground="#BBB" FontSize="10"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="SafeAutoR1PeriText" Grid.Column="2" Text="---" FontWeight="Bold" FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                </Grid>

                                                <Border Height="1" Background="#444" Margin="8,1"/>

                                                <!-- Sabit: R2 DRIVES -->
                                                <Grid Padding="10,6" BorderBrush="#333" BorderThickness="0,0,0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse x:Name="SafeAutoR2DrivesLed" Grid.Column="0" Width="8" Height="8" Fill="#555" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Spacing="0" Margin="6,0,0,0">
                                                        <TextBlock Text="R2 - $DRIVES_ON" Foreground="#FF9800" FontSize="9" Opacity="0.8"/>
                                                        <TextBlock Text="Robot 2 Sürücüler" Foreground="#BBB" FontSize="10"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="SafeAutoR2DrivesText" Grid.Column="2" Text="---" FontWeight="Bold" FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                </Grid>

                                                <!-- Sabit: R2 USER_SAF -->
                                                <Grid Padding="10,6" BorderBrush="#333" BorderThickness="0,0,0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse x:Name="SafeAutoR2UserSafLed" Grid.Column="0" Width="8" Height="8" Fill="#555" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Spacing="0" Margin="6,0,0,0">
                                                        <TextBlock Text="R2 - $USER_SAF" Foreground="#FF9800" FontSize="9" Opacity="0.8"/>
                                                        <TextBlock Text="Robot 2 User Safety" Foreground="#BBB" FontSize="10"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="SafeAutoR2UserSafText" Grid.Column="2" Text="---" FontWeight="Bold" FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                </Grid>

                                                <!-- Sabit: R2 PERI -->
                                                <Grid Padding="10,6" BorderBrush="#333" BorderThickness="0,0,0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse x:Name="SafeAutoR2PeriLed" Grid.Column="0" Width="8" Height="8" Fill="#555" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Spacing="0" Margin="6,0,0,0">
                                                        <TextBlock Text="R2 - $PERI_RDY" Foreground="#FF9800" FontSize="9" Opacity="0.8"/>
                                                        <TextBlock Text="Robot 2 Peripheral" Foreground="#BBB" FontSize="10"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="SafeAutoR2PeriText" Grid.Column="2" Text="---" FontWeight="Bold" FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                </Grid>

                                                <!-- Kullanıcı Uyarı Listesi -->
                                                <ListView ItemsSource="{x:Bind SafetyWarningList}" SelectionMode="None" MaxHeight="120">
                                                    <ListView.ItemTemplate>
                                                        <DataTemplate x:DataType="utils:SafetyCheckItem">
                                                            <Grid Padding="8,4" BorderBrush="#333" BorderThickness="0,0,0,1">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0" Spacing="0">
                                                                    <TextBlock Text="{x:Bind TagName}" Foreground="#FF9800" FontSize="9" Opacity="0.8"/>
                                                                    <TextBlock Text="{x:Bind ErrorMessage}" Foreground="#FFB74D" FontWeight="Bold" FontSize="10" TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                                <Button Grid.Column="1" Click="BtnDeleteSafetyWarning_Click" Background="Transparent" BorderThickness="0" Padding="4" VerticalAlignment="Center">
                                                                    <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="#666"/>
                                                                </Button>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListView.ItemTemplate>
                                                </ListView>

                                                <!-- Uyarı Ekleme -->
                                                <StackPanel Background="#222" Padding="8" Spacing="4">
                                                    <ComboBox x:Name="ComboSafetyWarningTag"
                                                        ItemsSource="{Binding AvailableInputPlcTags, ElementName=AutoPageRoot, Mode=OneWay}"
                                                        PlaceholderText="Sinyal Seçiniz..."
                                                        HorizontalAlignment="Stretch" FontSize="10"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox x:Name="TxtSafetyWarningMsg" Grid.Column="0" PlaceholderText="Uyarı Mesajı" FontSize="10" Margin="0,0,4,0"/>
                                                        <Button Grid.Column="1" Content="Ekle" Click="BtnAddSafetyWarning_Click" FontSize="10" FontWeight="Bold" Background="#FF9800" Foreground="White" Padding="10,4"/>
                                                    </Grid>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>