                                            <TextBlock x:Name="SliderSt2PosLabel" Text="0 mm" FontSize="9" Foreground="#FFF3E0" HorizontalAlignment="Center" Opacity="0.9"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="3" Background="#4CAF50" CornerRadius="4" Padding="8,3" HorizontalAlignment="Center">
