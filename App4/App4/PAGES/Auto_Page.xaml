<Page
    x:Class="App4.Auto_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App4"
    xmlns:utils="using:App4.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="AutoPageRoot"
    Loaded="Page_Loaded"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Page.Resources>
        <!-- StationCardTemplate removed as we are inlining it to support WebViews -->

        <DataTemplate x:Key="StationVarTemplate" x:DataType="utils:PlcVariable">
            <StackPanel Spacing="5" Padding="10" BorderBrush="#222" BorderThickness="0,0,0,1">
                <TextBlock Text="{x:Bind Name}" Foreground="#0078D4" FontWeight="Bold" FontSize="11"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableInputPlcTags, ElementName=AutoPageRoot, Mode=OneWay}"
                              SelectedItem="{x:Bind PlcTag, Mode=OneWay}"
                              IsEditable="True" PlaceholderText="Tag Ara..." Background="#202020" BorderBrush="#333" Foreground="White" FontSize="11" Margin="0,0,5,0" Height="28"
                              SelectionChanged="PlcTagComboBox_SelectionChanged"/>
                    <TextBox Grid.Column="1" Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Val" Background="#202020" BorderBrush="#333" Foreground="White" FontSize="11"/>
                </Grid>
                <TextBlock Text="{x:Bind Description}" Foreground="#666" FontSize="10" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="StationOutputVarTemplate" x:DataType="utils:PlcVariable">
            <StackPanel Spacing="4" Padding="10" BorderBrush="#222" BorderThickness="0,0,0,1">
                <TextBlock Text="{x:Bind Name}" Foreground="#E67E22" FontWeight="Bold" FontSize="11"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableOutputPlcTags, ElementName=AutoPageRoot, Mode=OneWay}"
                              SelectedItem="{x:Bind PlcTag, Mode=OneWay}"
                              IsEditable="True" PlaceholderText="Tag 1 Ara..." Background="#202020" BorderBrush="#333" Foreground="White" FontSize="11" Margin="0,0,5,0" Height="28"
                              SelectionChanged="PlcTagComboBox_SelectionChanged"/>
                    <TextBox Grid.Column="1" Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Val" Background="#202020" BorderBrush="#333" Foreground="White" FontSize="11"/>
                </Grid>
                <ComboBox ItemsSource="{Binding AvailableOutputPlcTags, ElementName=AutoPageRoot, Mode=OneWay}"
                          SelectedItem="{x:Bind PlcTag2, Mode=OneWay}"
                          IsEditable="True" PlaceholderText="Tag 2 Ara..." Background="#1A1A1C" BorderBrush="#2A2A2A" Foreground="#AAA" FontSize="10" Height="26"
                          SelectionChanged="PlcTag2ComboBox_SelectionChanged"/>
                <TextBlock Text="{x:Bind Description}" Foreground="#666" FontSize="10" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid Background="#0D0D0D">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1A1A1C" BorderThickness="0,0,0,1" BorderBrush="#333">
            <Grid Padding="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                    <Border Background="#0078D4" CornerRadius="8" Width="40" Height="40">
                        <FontIcon Glyph="&#xE72A;" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Otomatik Üretim" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="İstasyon Kontrolü ve Üretim Takibi" FontSize="11" Foreground="#888"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="10">
                    <Border Background="#1E1E20" CornerRadius="6" Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="#4CAF50"/>
                            <TextBlock Text="Sistem Aktif" Foreground="#888" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="20,10,20,20">
                <!-- ═══════════════════════════════════════════════════════════════════════════ -->
                <!-- İSTASYONLAR, KONTROLLER VE SLIDER BÖLÜMÜ -->
                <!-- ═══════════════════════════════════════════════════════════════════════════ -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ÜST KISIM: İstasyonlar + Kontrol Butonları Yan Yana
                         NOT: KONTROL paneli Visibility="Collapsed" ile GİZLENDİ (silinmedi).
                         START/STOP/RESET/HAT MODU sahadan donanım butonlarıyla yapıldığı için
                         UI'da görünmüyor; ileride tekrar göstermek için KONTROL Border'ının
                         Visibility özelliğini "Visible" yapmak yeterli. -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                    <!-- ═══ İSTASYON 1 ═══ -->
                    <Grid Grid.Column="1" Grid.Row="0" Margin="5">
                        <Border Background="#1A1A1C" CornerRadius="8" BorderThickness="2" BorderBrush="{x:Bind Stations[0].BorderColor, Mode=OneWay}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="50"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="60"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#252526" CornerRadius="6,6,0,0" Padding="15,0" BorderThickness="0,0,0,1" BorderBrush="#333333">
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Stations[0].Name}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{x:Bind Stations[0].Description}" FontSize="10" Foreground="#888888"/>
                                                <FontIcon Glyph="{x:Bind Stations[0].StateGlyph, Mode=OneWay}" FontSize="10" Foreground="{x:Bind Stations[0].StateColor, Mode=OneWay}"/>
                                                <TextBlock Text="{x:Bind Stations[0].StateText, Mode=OneWay}" FontSize="10" FontWeight="SemiBold" Foreground="{x:Bind Stations[0].StateColor, Mode=OneWay}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="10">
                                            <Ellipse Width="12" Height="12" Fill="{x:Bind Stations[0].ModeColor, Mode=OneWay}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Row="1" Background="#151515" Spacing="8" Padding="10">
                                    <!-- Model View -->
                                    <Border CornerRadius="8" BorderBrush="#333" BorderThickness="1" Background="#101010" MinHeight="200">
                                         <WebView2 x:Name="Viewer_Station1" DefaultBackgroundColor="Transparent"/>
                                    </Border>

                                    <!-- Alarm -->
                                    <StackPanel Orientation="Horizontal" Spacing="5" Visibility="{x:Bind Stations[0].AlarmVisibility, Mode=OneWay}" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE7BA;" Foreground="Red" FontSize="14"/>
                                        <TextBlock Text="{x:Bind Stations[0].AlarmText, Mode=OneWay}" Foreground="Red" FontSize="10" FontWeight="Bold"/>
                                    </StackPanel>

                                    <!-- RFID KONTROL -->
                                    <Border Background="#202020" CornerRadius="6" Padding="8" BorderBrush="#333" BorderThickness="1">
                                        <StackPanel Spacing="5">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <FontIcon Glyph="&#xEFA9;" Foreground="#0078D4" FontSize="12"/>
                                                <TextBlock Text="RFID KONTROL" FontSize="10" FontWeight="Bold" Foreground="#DDD"/>
                                            </StackPanel>
                                            <ComboBox ItemsSource="{Binding Stations[0].RfidOpModes}" SelectedItem="{Binding Stations[0].RfidOpMode, Mode=TwoWay}" Foreground="White" FontSize="10" HorizontalAlignment="Stretch" BorderThickness="1" Background="#151515" Height="24"/>
                                            <StackPanel Visibility="{Binding Stations[0].IsSpecificRfidVisible}">
                                                <TextBlock Text="Beklenen ID :" FontSize="9" Foreground="#888" Margin="0,0,0,2"/>
                                                <ComboBox ItemsSource="{Binding Stations[0].RefRfids}" SelectedValue="{Binding Stations[0].TargetRfid, Mode=TwoWay}" SelectedValuePath="Id" DisplayMemberPath="Id" Foreground="White" PlaceholderText="..." FontSize="10" HorizontalAlignment="Stretch" BorderThickness="1" Background="#151515" Height="24"/>
                                            </StackPanel>
                                            <Grid ColumnSpacing="5" Margin="0,2,0,0" Background="#151515" Padding="4" CornerRadius="4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Okunan:" FontSize="8" Foreground="#888"/>
                                                    <TextBlock Text="{x:Bind Stations[0].CurrentRfid, Mode=OneWay}" FontSize="11" Foreground="{x:Bind Stations[0].RfidMatchColor, Mode=OneWay}" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <FontIcon Grid.Column="1" Glyph="{x:Bind Stations[0].RfidMatchIcon, Mode=OneWay}" Foreground="{x:Bind Stations[0].RfidMatchColor, Mode=OneWay}" FontSize="14" VerticalAlignment="Center" Margin="2,0"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- AKTİF NOKTA BİLGİSİ -->
                                    <Border Background="#1A2A1A" CornerRadius="6" Padding="8" BorderBrush="#2E7D32" BorderThickness="1">
                                        <StackPanel Spacing="3">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <FontIcon Glyph="&#xECAD;" Foreground="#4CAF50" FontSize="12"/>
                                                <TextBlock Text="AKTİF NOKTA" FontSize="10" FontWeight="Bold" Foreground="#4CAF50"/>
                                            </StackPanel>
                                            <StackPanel Visibility="{x:Bind Stations[0].R1ActivePointVisibility, Mode=OneWay}">
                                                <TextBlock FontSize="8" Foreground="#888"><Run Text="R1: "/><Run Text="{x:Bind Stations[0].R1ActivePoint, Mode=OneWay}" Foreground="#4CAF50" FontWeight="Bold"/></TextBlock>
                                            </StackPanel>
                                            <StackPanel Visibility="{x:Bind Stations[0].R2ActivePointVisibility, Mode=OneWay}">
                                                <TextBlock FontSize="8" Foreground="#888"><Run Text="R2: "/><Run Text="{x:Bind Stations[0].R2ActivePoint, Mode=OneWay}" Foreground="#FF9800" FontWeight="Bold"/></TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- TABLA KAÇIKLIK DEĞERLERİ -->
                                    <Border Background="#1A1A2E" CornerRadius="6" Padding="8" BorderBrush="#3F51B5" BorderThickness="1">
                                        <StackPanel Spacing="3">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <FontIcon Glyph="&#xE809;" Foreground="#7986CB" FontSize="12"/>
                                                <TextBlock Text="TABLA KAÇIKLIK" FontSize="10" FontWeight="Bold" Foreground="#7986CB"/>
                                                <TextBlock Text="{x:Bind Stations[0].TablaStatusText, Mode=OneWay}" FontSize="9" FontWeight="SemiBold" Foreground="{x:Bind Stations[0].TablaStatusColor, Mode=OneWay}" Margin="8,0,0,0"/>
                                            </StackPanel>
                                            <Grid ColumnSpacing="4" RowSpacing="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="X:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind Stations[0].TablaOffsetX, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                                <TextBlock Grid.Row="0" Grid.Column="2" Text="A:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                <TextBlock Grid.Row="0" Grid.Column="3" Text="{x:Bind Stations[0].TablaOffsetA, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Y:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind Stations[0].TablaOffsetY, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                                <TextBlock Grid.Row="1" Grid.Column="2" Text="B:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                <TextBlock Grid.Row="1" Grid.Column="3" Text="{x:Bind Stations[0].TablaOffsetB, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Z:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind Stations[0].TablaOffsetZ, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                                <TextBlock Grid.Row="2" Grid.Column="2" Text="C:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                <TextBlock Grid.Row="2" Grid.Column="3" Text="{x:Bind Stations[0].TablaOffsetC, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <Border Grid.Row="2" Background="#202020" CornerRadius="0,0,6,6" Padding="15,0">
                                    <Grid VerticalAlignment="Center">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Üretim Adedi" FontSize="10" Foreground="#888888"/>
                                            <TextBlock Text="{x:Bind Stations[0].ProductionCount, Mode=OneWay}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                        </StackPanel>
                                        <StackPanel Spacing="2" HorizontalAlignment="Right">
                                            <TextBlock Text="Verimlilik" FontSize="10" Foreground="#888888" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{x:Bind Stations[0].Efficiency, Mode=OneWay}" FontSize="14" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ═══ İSTASYON 2 ═══ -->
                    <Grid Grid.Column="2" Grid.Row="0" Margin="5">
                        <Border Background="#1A1A1C" CornerRadius="8" BorderThickness="2" BorderBrush="{x:Bind Stations[1].BorderColor, Mode=OneWay}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="50"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="60"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#252526" CornerRadius="6,6,0,0" Padding="15,0" BorderThickness="0,0,0,1" BorderBrush="#333333">
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Stations[1].Name}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{x:Bind Stations[1].Description}" FontSize="10" Foreground="#888888"/>
                                                <FontIcon Glyph="{x:Bind Stations[1].StateGlyph, Mode=OneWay}" FontSize="10" Foreground="{x:Bind Stations[1].StateColor, Mode=OneWay}"/>
                                                <TextBlock Text="{x:Bind Stations[1].StateText, Mode=OneWay}" FontSize="10" FontWeight="SemiBold" Foreground="{x:Bind Stations[1].StateColor, Mode=OneWay}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="10">
                                            <Ellipse Width="12" Height="12" Fill="{x:Bind Stations[1].ModeColor, Mode=OneWay}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Grid Grid.Row="1" Background="#151515">
                                    <StackPanel Margin="10" Spacing="8">
                                        <Border CornerRadius="8" BorderBrush="#333" BorderThickness="1" Background="#101010" MinHeight="200">
                                             <WebView2 x:Name="Viewer_Station2" DefaultBackgroundColor="Transparent"/>
                                        </Border>

                                        <StackPanel Orientation="Horizontal" Spacing="5" Visibility="{x:Bind Stations[1].AlarmVisibility, Mode=OneWay}" HorizontalAlignment="Center">
                                            <FontIcon Glyph="&#xE7BA;" Foreground="Red" FontSize="14"/>
                                            <TextBlock Text="{x:Bind Stations[1].AlarmText, Mode=OneWay}" Foreground="Red" FontSize="10" FontWeight="Bold"/>
                                        </StackPanel>

                                        <Border Background="#202020" CornerRadius="6" Padding="8" BorderBrush="#333" BorderThickness="1">
                                            <StackPanel Spacing="5">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xEFA9;" Foreground="#0078D4" FontSize="12"/>
                                                    <TextBlock Text="RFID KONTROL" FontSize="10" FontWeight="Bold" Foreground="#DDD"/>
                                                </StackPanel>
                                                <ComboBox ItemsSource="{Binding Stations[1].RfidOpModes}" SelectedItem="{Binding Stations[1].RfidOpMode, Mode=TwoWay}" Foreground="White" FontSize="10" HorizontalAlignment="Stretch" BorderThickness="1" Background="#151515" Height="24"/>
                                                <StackPanel Visibility="{Binding Stations[1].IsSpecificRfidVisible}">
                                                    <TextBlock Text="Beklenen ID :" FontSize="9" Foreground="#888" Margin="0,0,0,2"/>
                                                    <ComboBox ItemsSource="{Binding Stations[1].RefRfids}" SelectedValue="{Binding Stations[1].TargetRfid, Mode=TwoWay}" SelectedValuePath="Id" DisplayMemberPath="Id" Foreground="White" PlaceholderText="..." FontSize="10" HorizontalAlignment="Stretch" BorderThickness="1" Background="#151515" Height="24"/>
                                                </StackPanel>
                                                <Grid ColumnSpacing="5" Margin="0,2,0,0" Background="#151515" Padding="4" CornerRadius="4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Okunan:" FontSize="8" Foreground="#888"/>
                                                        <TextBlock Text="{x:Bind Stations[1].CurrentRfid, Mode=OneWay}" FontSize="11" Foreground="{x:Bind Stations[1].RfidMatchColor, Mode=OneWay}" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <FontIcon Grid.Column="1" Glyph="{x:Bind Stations[1].RfidMatchIcon, Mode=OneWay}" Foreground="{x:Bind Stations[1].RfidMatchColor, Mode=OneWay}" FontSize="14" VerticalAlignment="Center" Margin="2,0"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- AKTİF NOKTA BİLGİSİ -->
                                        <Border Background="#1A2A1A" CornerRadius="6" Padding="8" BorderBrush="#2E7D32" BorderThickness="1">
                                            <StackPanel Spacing="3">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xECAD;" Foreground="#4CAF50" FontSize="12"/>
                                                    <TextBlock Text="AKTİF NOKTA" FontSize="10" FontWeight="Bold" Foreground="#4CAF50"/>
                                                </StackPanel>
                                                <StackPanel Visibility="{x:Bind Stations[1].R1ActivePointVisibility, Mode=OneWay}">
                                                    <TextBlock FontSize="8" Foreground="#888"><Run Text="R1: "/><Run Text="{x:Bind Stations[1].R1ActivePoint, Mode=OneWay}" Foreground="#4CAF50" FontWeight="Bold"/></TextBlock>
                                                </StackPanel>
                                                <StackPanel Visibility="{x:Bind Stations[1].R2ActivePointVisibility, Mode=OneWay}">
                                                    <TextBlock FontSize="8" Foreground="#888"><Run Text="R2: "/><Run Text="{x:Bind Stations[1].R2ActivePoint, Mode=OneWay}" Foreground="#FF9800" FontWeight="Bold"/></TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- TABLA KAÇIKLIK DEĞERLERİ -->
                                        <Border Background="#1A1A2E" CornerRadius="6" Padding="8" BorderBrush="#3F51B5" BorderThickness="1">
                                            <StackPanel Spacing="3">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xE809;" Foreground="#7986CB" FontSize="12"/>
                                                    <TextBlock Text="TABLA KAÇIKLIK" FontSize="10" FontWeight="Bold" Foreground="#7986CB"/>
                                                    <TextBlock Text="{x:Bind Stations[1].TablaStatusText, Mode=OneWay}" FontSize="9" FontWeight="SemiBold" Foreground="{x:Bind Stations[1].TablaStatusColor, Mode=OneWay}" Margin="8,0,0,0"/>
                                                </StackPanel>
                                                <Grid ColumnSpacing="4" RowSpacing="1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind Stations[1].TablaOffsetX, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="A:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{x:Bind Stations[1].TablaOffsetA, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Y:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind Stations[1].TablaOffsetY, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="B:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{x:Bind Stations[1].TablaOffsetB, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Z:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind Stations[1].TablaOffsetZ, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="C:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{x:Bind Stations[1].TablaOffsetC, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                                <Border Grid.Row="2" Background="#202020" CornerRadius="0,0,6,6" Padding="15,0">
                                    <Grid VerticalAlignment="Center">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Üretim Adedi" FontSize="10" Foreground="#888888"/>
                                            <TextBlock Text="{x:Bind Stations[1].ProductionCount, Mode=OneWay}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                        </StackPanel>
                                        <StackPanel Spacing="2" HorizontalAlignment="Right">
                                            <TextBlock Text="Verimlilik" FontSize="10" Foreground="#888888" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{x:Bind Stations[1].Efficiency, Mode=OneWay}" FontSize="14" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ═══ İSTASYON 3 ═══ -->
                    <Grid Grid.Column="3" Grid.Row="0" Margin="5">
                        <Border Background="#1A1A1C" CornerRadius="8" BorderThickness="2" BorderBrush="{x:Bind Stations[2].BorderColor, Mode=OneWay}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="50"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="60"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#252526" CornerRadius="6,6,0,0" Padding="15,0" BorderThickness="0,0,0,1" BorderBrush="#333333">
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Stations[2].Name}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{x:Bind Stations[2].Description}" FontSize="10" Foreground="#888888"/>
                                                <FontIcon Glyph="{x:Bind Stations[2].StateGlyph, Mode=OneWay}" FontSize="10" Foreground="{x:Bind Stations[2].StateColor, Mode=OneWay}"/>
                                                <TextBlock Text="{x:Bind Stations[2].StateText, Mode=OneWay}" FontSize="10" FontWeight="SemiBold" Foreground="{x:Bind Stations[2].StateColor, Mode=OneWay}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="10">
                                            <Ellipse Width="12" Height="12" Fill="{x:Bind Stations[2].ModeColor, Mode=OneWay}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Grid Grid.Row="1" Background="#151515">
                                    <StackPanel Margin="10" Spacing="8">
                                        <Border CornerRadius="8" BorderBrush="#333" BorderThickness="1" Background="#101010" MinHeight="200">
                                             <WebView2 x:Name="Viewer_Station3" DefaultBackgroundColor="Transparent"/>
                                        </Border>

                                        <StackPanel Orientation="Horizontal" Spacing="5" Visibility="{x:Bind Stations[2].AlarmVisibility, Mode=OneWay}" HorizontalAlignment="Center">
                                            <FontIcon Glyph="&#xE7BA;" Foreground="Red" FontSize="14"/>
                                            <TextBlock Text="{x:Bind Stations[2].AlarmText, Mode=OneWay}" Foreground="Red" FontSize="10" FontWeight="Bold"/>
                                        </StackPanel>

                                        <Border Background="#202020" CornerRadius="6" Padding="8" BorderBrush="#333" BorderThickness="1">
                                            <StackPanel Spacing="5">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xEFA9;" Foreground="#0078D4" FontSize="12"/>
                                                    <TextBlock Text="RFID KONTROL" FontSize="10" FontWeight="Bold" Foreground="#DDD"/>
                                                </StackPanel>
                                                <ComboBox ItemsSource="{Binding Stations[2].RfidOpModes}" SelectedItem="{Binding Stations[2].RfidOpMode, Mode=TwoWay}" Foreground="White" FontSize="10" HorizontalAlignment="Stretch" BorderThickness="1" Background="#151515" Height="24"/>
                                                <StackPanel Visibility="{Binding Stations[2].IsSpecificRfidVisible}">
                                                    <TextBlock Text="Beklenen ID :" FontSize="9" Foreground="#888" Margin="0,0,0,2"/>
                                                    <ComboBox ItemsSource="{Binding Stations[2].RefRfids}" SelectedValue="{Binding Stations[2].TargetRfid, Mode=TwoWay}" SelectedValuePath="Id" DisplayMemberPath="Id" Foreground="White" PlaceholderText="..." FontSize="10" HorizontalAlignment="Stretch" BorderThickness="1" Background="#151515" Height="24"/>
                                                </StackPanel>
                                                <Grid ColumnSpacing="5" Margin="0,2,0,0" Background="#151515" Padding="4" CornerRadius="4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Okunan:" FontSize="8" Foreground="#888"/>
                                                        <TextBlock Text="{x:Bind Stations[2].CurrentRfid, Mode=OneWay}" FontSize="11" Foreground="{x:Bind Stations[2].RfidMatchColor, Mode=OneWay}" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <FontIcon Grid.Column="1" Glyph="{x:Bind Stations[2].RfidMatchIcon, Mode=OneWay}" Foreground="{x:Bind Stations[2].RfidMatchColor, Mode=OneWay}" FontSize="14" VerticalAlignment="Center" Margin="2,0"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- AKTİF NOKTA BİLGİSİ -->
                                        <Border Background="#1A2A1A" CornerRadius="6" Padding="8" BorderBrush="#2E7D32" BorderThickness="1">
                                            <StackPanel Spacing="3">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xECAD;" Foreground="#4CAF50" FontSize="12"/>
                                                    <TextBlock Text="AKTİF NOKTA" FontSize="10" FontWeight="Bold" Foreground="#4CAF50"/>
                                                </StackPanel>
                                                <StackPanel Visibility="{x:Bind Stations[2].R1ActivePointVisibility, Mode=OneWay}">
                                                    <TextBlock FontSize="8" Foreground="#888"><Run Text="R1: "/><Run Text="{x:Bind Stations[2].R1ActivePoint, Mode=OneWay}" Foreground="#4CAF50" FontWeight="Bold"/></TextBlock>
                                                </StackPanel>
                                                <StackPanel Visibility="{x:Bind Stations[2].R2ActivePointVisibility, Mode=OneWay}">
                                                    <TextBlock FontSize="8" Foreground="#888"><Run Text="R2: "/><Run Text="{x:Bind Stations[2].R2ActivePoint, Mode=OneWay}" Foreground="#FF9800" FontWeight="Bold"/></TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- TABLA KAÇIKLIK DEĞERLERİ -->
                                        <Border Background="#1A1A2E" CornerRadius="6" Padding="8" BorderBrush="#3F51B5" BorderThickness="1">
                                            <StackPanel Spacing="3">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon Glyph="&#xE809;" Foreground="#7986CB" FontSize="12"/>
                                                    <TextBlock Text="TABLA KAÇIKLIK" FontSize="10" FontWeight="Bold" Foreground="#7986CB"/>
                                                    <TextBlock Text="{x:Bind Stations[2].TablaStatusText, Mode=OneWay}" FontSize="9" FontWeight="SemiBold" Foreground="{x:Bind Stations[2].TablaStatusColor, Mode=OneWay}" Margin="8,0,0,0"/>
                                                </StackPanel>
                                                <Grid ColumnSpacing="4" RowSpacing="1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind Stations[2].TablaOffsetX, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="A:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{x:Bind Stations[2].TablaOffsetA, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Y:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind Stations[2].TablaOffsetY, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="B:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{x:Bind Stations[2].TablaOffsetB, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Z:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind Stations[2].TablaOffsetZ, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="C:" FontSize="9" Foreground="#888" FontWeight="Bold"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{x:Bind Stations[2].TablaOffsetC, Mode=OneWay}" FontSize="9" Foreground="#BBDEFB" FontWeight="Bold"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                                <Border Grid.Row="2" Background="#202020" CornerRadius="0,0,6,6" Padding="15,0">
                                    <Grid VerticalAlignment="Center">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Üretim Adedi" FontSize="10" Foreground="#888888"/>
                                            <TextBlock Text="{x:Bind Stations[2].ProductionCount, Mode=OneWay}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                        </StackPanel>
                                        <StackPanel Spacing="2" HorizontalAlignment="Right">
                                            <TextBlock Text="Verimlilik" FontSize="10" Foreground="#888888" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{x:Bind Stations[2].Efficiency, Mode=OneWay}" FontSize="14" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ═══ KONTROL PANELİ (Sol Taraf - Bakım Hizası) ═══
                         GİZLENDİ (Visibility="Collapsed"): START/STOP/RESET ve HAT MODU sahadan
                         donanım butonları/anahtarları ile yapılıyor. Kodlar silinmedi — tekrar
                         göstermek için aşağıdaki Border'da Visibility="Visible" yapın. -->
                    <Border Grid.Column="0" Visibility="Collapsed" Background="#1A1A1C" CornerRadius="8" Margin="5" Padding="15" MinWidth="180" VerticalAlignment="Stretch">
                        <StackPanel Spacing="12">
                            <!-- Başlık -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Background="#333" CornerRadius="6" Width="32" Height="32">
                                    <FontIcon Glyph="&#xE943;" Foreground="#0078D4" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="KONTROL" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Rectangle Height="1" Fill="#333"/>

                            <!-- Sistem Durumu -->
                            <Border x:Name="LineStatusCard" Background="#252528" CornerRadius="6" Padding="10,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon x:Name="LineStatusIcon" Glyph="&#xE71A;" FontSize="14" Foreground="#888"/>
                                    <TextBlock x:Name="LineStatusText" Text="SİSTEM KAPALI" FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                                </StackPanel>
                            </Border>

                            <!-- Safety & Alarm -->
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="CheckSafetyBorder" Grid.Column="0" Background="#252528" CornerRadius="6" Padding="8,6">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="SAFETY" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                            <FontIcon x:Name="CheckSafetyIcon" Glyph="&#xE7BA;" FontSize="10" Foreground="#666"/>
                                            <TextBlock x:Name="CheckSafetyText" Text="OK" FontSize="9" FontWeight="Bold" Foreground="#666"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="CheckAlarmBorder" Grid.Column="1" Background="#252528" CornerRadius="6" Padding="8,6">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="ALARM" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                            <FontIcon x:Name="CheckAlarmIcon" Glyph="&#xE7BA;" FontSize="10" Foreground="#666"/>
                                            <TextBlock x:Name="CheckAlarmText" Text="OK" FontSize="9" FontWeight="Bold" Foreground="#666"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Rectangle Height="1" Fill="#333"/>

                            <!-- Kontrol Butonları -->
                            <Button x:Name="BtnStart" Click="BtnStart_Click" CornerRadius="6" Padding="0" HorizontalAlignment="Stretch" Height="40" Background="#1E5631" BorderBrush="#27AE60" BorderThickness="1" Opacity="0.5" IsEnabled="False">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE768;" FontSize="14" Foreground="#2ECC71"/>
                                    <TextBlock Text="BAŞLAT" FontWeight="Bold" Foreground="White" FontSize="11"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnStop" Click="BtnStop_Click" CornerRadius="6" Padding="0" HorizontalAlignment="Stretch" Height="40" Background="#641E16" BorderBrush="#C0392B" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE71A;" FontSize="14" Foreground="#E74C3C"/>
                                    <TextBlock Text="DURDUR" FontWeight="Bold" Foreground="White" FontSize="11"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnReset" Click="BtnReset_Click" CornerRadius="6" Padding="0" HorizontalAlignment="Stretch" Height="40" Background="#7E5109" BorderBrush="#F39C12" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE72C;" FontSize="14" Foreground="#F1C40F"/>
                                    <TextBlock Text="RESET" FontWeight="Bold" Foreground="White" FontSize="11"/>
                                </StackPanel>
                            </Button>

                            <Rectangle Height="1" Fill="#333"/>

                            <!-- Hat Oto/Manuel Modu -->
                            <Border Background="#252528" CornerRadius="6" Padding="10,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="HAT MODU" FontSize="9" FontWeight="Bold" Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <ToggleSwitch x:Name="KontrolLineAutoManualSwitch" Grid.Row="1"
                                                  OnContent="OTOMATİK" OffContent="MANUEL"
                                                  Toggled="LineAutoManualSwitch_Toggled"
                                                  HorizontalAlignment="Center"
                                                  MinWidth="120"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                    </Grid>
                </Grid>

                <!-- ═══════════════════════════════════════════════════════════════════════════ -->
                <!-- KL100 SLIDER VE ROBOTLAR -->
                <!-- ═══════════════════════════════════════════════════════════════════════════ -->
                <Border Background="#1A1A1C" CornerRadius="8" Padding="20,15" Margin="5,10,5,5">
                    <Grid>
                        <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="140"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Slider Başlık -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="15" Margin="0,0,0,10">
                                    <Border Background="#333" CornerRadius="6" Padding="12,6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE71D;" Foreground="#0078D4" FontSize="14"/>
                                            <TextBlock Text="KL100 LİNEER SLIDER" FontSize="12" FontWeight="Bold" Foreground="#0078D4"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#252528" CornerRadius="6" Padding="12,6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="Aktüel Poz:" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="SliderActualPosText" Text="---" FontSize="12" FontWeight="Bold" Foreground="#FF9800" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#252528" CornerRadius="6" Padding="12,6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="İstasyon:" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="SliderStationText" Text="---" FontSize="12" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#252528" CornerRadius="6" Padding="12,6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE81D;" Foreground="#E91E63" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="Hedef:" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="SliderHedefStationText" Text="---" FontSize="12" FontWeight="Bold" Foreground="#E91E63" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Slider Ray ve Robotlar -->
                                <Grid Grid.Row="1" Background="#151518">
                                    <!-- Slider Ray Arka Plan (Metalik görünüm) -->
                                    <Border Height="20" CornerRadius="10" VerticalAlignment="Center" Margin="80,0" BorderBrush="#666" BorderThickness="1">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#707070" Offset="0"/>
                                                <GradientStop Color="#404040" Offset="0.5"/>
                                                <GradientStop Color="#505050" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>

                                    <!-- Slider Ray Çizgisi (Üstten) -->
                                    <Border Height="4" CornerRadius="2" VerticalAlignment="Center" Margin="80,-8,80,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#888888" Offset="0"/>
                                                <GradientStop Color="#AAAAAA" Offset="0.5"/>
                                                <GradientStop Color="#888888" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>

                                    <!-- İstasyon İşaretleri (Slider üzerinde) -->
                                    <Grid VerticalAlignment="Center" Margin="80,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="8" Height="36" Background="#9E9E9E" CornerRadius="4" HorizontalAlignment="Center" Opacity="0.9"/>
                                        <Border Grid.Column="1" Width="8" Height="36" Background="#FF5722" CornerRadius="4" HorizontalAlignment="Center" Opacity="0.9"/>
                                        <Border Grid.Column="2" Width="8" Height="36" Background="#FF9800" CornerRadius="4" HorizontalAlignment="Center" Opacity="0.9"/>
                                        <Border Grid.Column="3" Width="8" Height="36" Background="#4CAF50" CornerRadius="4" HorizontalAlignment="Center" Opacity="0.9"/>
                                    </Grid>

                                    <!-- Robot Platform Canvas (İki robot yan yana, tek slider) -->
                                    <Canvas x:Name="SliderCanvas" Margin="80,0">
                                        <!-- Robot Platform - İki robot yan yana -->
                                        <Grid x:Name="RobotPlatform" Canvas.Left="20" Canvas.Top="20" Width="140">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- İki Robot Yan Yana -->
                                            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center">
                                                <!-- Robot 1 (Gocator + Helyum) -->
                                                <Grid Width="60">
                                                    <Grid HorizontalAlignment="Center">
                                                        <Ellipse x:Name="R1RobotEllipse" Width="50" Height="50" StrokeThickness="3">
                                                            <Ellipse.Fill>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#2A2A2A" Offset="0"/>
                                                                    <GradientStop Color="#1A1A1A" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Ellipse.Fill>
                                                            <Ellipse.Stroke>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#4CAF50" Offset="0"/>
                                                                    <GradientStop Color="#2E7D32" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Ellipse.Stroke>
                                                        </Ellipse>
                                                        <FontIcon x:Name="R1RobotIcon" Glyph="&#xE99A;" FontSize="20" Foreground="#4CAF50"/>
                                                        <!-- Gocator İkonu -->
                                                        <Border Background="#FF9800" CornerRadius="3" Padding="2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0">
                                                            <FontIcon Glyph="&#xE945;" FontSize="7" Foreground="White"/>
                                                        </Border>
                                                        <!-- Helyum İkonu -->
                                                        <Border Background="#9C27B0" CornerRadius="3" Padding="2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-2,-2,0,0">
                                                            <TextBlock Text="He" FontSize="6" FontWeight="Bold" Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                    <!-- Etiket -->
                                                    <Border Background="#4CAF50" CornerRadius="3" Padding="4,1" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-10,0,0">
                                                        <TextBlock Text="R1" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                    </Border>
                                                </Grid>

                                                <!-- Robot 2 (Sadece Helyum) -->
                                                <Grid Width="60">
                                                    <Grid HorizontalAlignment="Center">
                                                        <Ellipse x:Name="R2RobotEllipse" Width="50" Height="50" StrokeThickness="3">
                                                            <Ellipse.Fill>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#2A2A2A" Offset="0"/>
                                                                    <GradientStop Color="#1A1A1A" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Ellipse.Fill>
                                                            <Ellipse.Stroke>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#0078D4" Offset="0"/>
                                                                    <GradientStop Color="#005A9E" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Ellipse.Stroke>
                                                        </Ellipse>
                                                        <FontIcon x:Name="R2RobotIcon" Glyph="&#xE99A;" FontSize="20" Foreground="#0078D4"/>
                                                        <!-- Helyum İkonu -->
                                                        <Border Background="#9C27B0" CornerRadius="3" Padding="2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0">
                                                            <TextBlock Text="He" FontSize="6" FontWeight="Bold" Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                    <!-- Etiket -->
                                                    <Border Background="#0078D4" CornerRadius="3" Padding="4,1" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-10,0,0">
                                                        <TextBlock Text="R2" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                    </Border>
                                                </Grid>
                                            </StackPanel>

                                            <!-- Platform Bağlantı Çubuğu (Tek parça) -->
                                            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,-3,0,0">
                                                <Border Width="100" Height="6" CornerRadius="3">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#4CAF50" Offset="0"/>
                                                            <GradientStop Color="#0078D4" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <Rectangle Width="8" Height="10" Fill="#555" RadiusX="2" RadiusY="2" HorizontalAlignment="Center"/>
                                                <Border Width="120" Height="10" CornerRadius="5">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#666666" Offset="0"/>
                                                            <GradientStop Color="#444444" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Canvas>
                                </Grid>

                                <!-- ═══ ROBOT DURUM KARTLARI ═══ -->
                                <Grid Grid.Row="2" Margin="10,8,10,0" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Robot 1 Mini Durum Kartı -->
                                    <Border Grid.Column="0" x:Name="Robot1StatusCard" Background="#151518"
                                            CornerRadius="6" Padding="10,6" BorderBrush="#333" BorderThickness="1">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                                                <Border x:Name="Robot1StatusDot" Background="#555" CornerRadius="6"
                                                        Width="12" Height="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="R1" FontSize="11" FontWeight="Bold"
                                                           Foreground="#4CAF50" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                                <TextBlock x:Name="Robot1DurumText" Text="---" FontSize="10"
                                                           FontWeight="SemiBold" Foreground="#888"/>
