<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App4.Pages.MultiRobot_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App4.Pages"
    xmlns:utilities="using:App4.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0A0A0A"
    NavigationCacheMode="Required">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#111111" BorderBrush="#222" BorderThickness="0,0,0,1">
            <Grid Padding="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE99A;" FontSize="28" Foreground="#00FF88"/>
                    <TextBlock Text="ÇOKLU ROBOT KONTROLÜ" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <Border x:Name="RobotCountBadge" Background="#00FF88" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                        <TextBlock x:Name="RobotCountText" Text="2 Robot" FontSize="12" FontWeight="Bold" Foreground="#0A0A0A"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button x:Name="BtnAddRobot" Click="BtnAddRobot_Click"
                            Background="#2D2D30" Foreground="White" CornerRadius="6" Padding="15,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14"/>
                            <TextBlock Text="Robot Ekle" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnStartAll" Click="BtnStartAll_Click"
                            Background="#1B5E20" Foreground="White" CornerRadius="6" Padding="15,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE768;" FontSize="14"/>
                            <TextBlock Text="Tümünü Başlat" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnStopAll" Click="BtnStopAll_Click"
                            Background="#B71C1C" Foreground="White" CornerRadius="6" Padding="15,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE71A;" FontSize="14"/>
                            <TextBlock Text="Tümünü Durdur" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROBOT KARTLARI -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel x:Name="RobotCardsPanel" Spacing="15"/>
        </ScrollViewer>

        <!-- LOG ALANI -->
        <Border Grid.Row="2" Background="#0D0D0D" BorderBrush="#222" BorderThickness="0,1,0,0" Padding="20,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="📋 LOG" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,5"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="LogTextBlock" 
                               Text="[INFO] Çoklu Robot Sistemi Hazır..." 
                               Foreground="#00FF88" 
                               FontSize="10" 
                               FontFamily="Cascadia Mono" 
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
