<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App4.Pages.MultiRobot_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App4.Pages"
    xmlns:utilities="using:App4.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0D0D0D"
    NavigationCacheMode="Required">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1A1A1C" BorderThickness="0,0,0,1" BorderBrush="#333">
            <Grid Padding="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                    <Border Background="#00BCD4" CornerRadius="8" Width="40" Height="40">
                        <FontIcon Glyph="&#xE99A;" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Çoklu Robot Kontrolü" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Robot Durum İzleme ve Komut Yönetimi" FontSize="11" Foreground="#888"/>
                    </StackPanel>
                    <Border Background="#1E1E20" CornerRadius="6" Padding="12,6" Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="RobotCountText" Text="2 Robot" FontSize="11" Foreground="#888"/>
                    </Border>
                </StackPanel>
                <Button x:Name="BtnAddRobot" Click="BtnAddRobot_Click" HorizontalAlignment="Right"
                        Background="#00BCD4" Foreground="White" CornerRadius="4" Padding="15,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                        <TextBlock Text="Robot Ekle"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ROBOT KARTLARI -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,15,20,0">
            <StackPanel x:Name="RobotCardsPanel" Spacing="12"/>
        </ScrollViewer>

        <!-- LOG ALANI -->
        <Border Grid.Row="2" Background="#1E1E20" Margin="20,15,20,20" CornerRadius="8" MaxHeight="140">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#252528" CornerRadius="8,8,0,0" Padding="15,0">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE71E;" Foreground="#00BCD4" FontSize="14"/>
                        <TextBlock Text="ROBOT LOG" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#1A1A1C">
                    <TextBlock x:Name="LogTextBlock" 
                               Text="[INFO] Çoklu Robot Sistemi Hazır..." 
                               Foreground="#4CAF50" 
                               FontSize="10" 
                               FontFamily="Consolas" 
                               TextWrapping="Wrap"
                               Padding="15"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
