<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App4.PAGES.PLC_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#0D0D0D">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- BAŞLIK BÖLÜMÜ -->
        <Border Grid.Row="0" Background="#1A1A1C" BorderThickness="0,0,0,2" BorderBrush="#00A4EF" Padding="25,0">
            <Grid VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="PLC KONTROL PANELİ" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Tag Yönetim ve Monitörleme Sistemi" FontSize="11" Foreground="#00A4EF" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="20" VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center" Spacing="5">
                        <TextBlock Text="SİSTEM DURUMU" FontSize="9" Foreground="#888888" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="PLCStatusLabel" Text="BAĞLI" FontSize="13" FontWeight="Bold" Foreground="#4CAF50"/>
                    </StackPanel>
                    <FontIcon Glyph="&#xE957;" Foreground="#4CAF50" FontSize="24"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- TAG TABLOSU -->
        <Border Grid.Row="1" Background="#1A1A1C" Margin="20" BorderThickness="2" BorderBrush="#00A4EF" CornerRadius="10" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Başlık -->
                <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="15,0" BorderThickness="0,0,0,2" BorderBrush="#00A4EF">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                        <FontIcon Glyph="&#xE71E;" Foreground="#00A4EF" FontSize="20"/>
                        <TextBlock Text="PLC TAG TABLOSU" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Tablo -->
                <Grid Grid.Row="1" Background="#0D0D0D" Padding="15">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                        <StackPanel x:Name="TagsContainer" Spacing="8"/>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="#252526" BorderThickness="0,2,0,0" BorderBrush="#00A4EF" Padding="25,0">
            <Grid VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Left">
                    <Ellipse Width="10" Height="10" Fill="#4CAF50" VerticalAlignment="Center"/>
                    <TextBlock Text="PLC Bağlantı:" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock x:Name="PLCConnectionStatus" Text="AKTIF" FontSize="11" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="© 2025 Simbiosis Mekatronik | PLC Kontrol Sistemi" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Right" 
                           FontSize="10" 
                           Foreground="#555555"/>
            </Grid>
        </Border>
    </Grid>
</Page>
