<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App4.PAGES.PLC_Page"
    xmlns:utils="using:App4.Utilities"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Page.Resources>

        <DataTemplate x:Key="PlcInputVariableTemplate" x:DataType="utils:PlcVariable">
            <Grid Margin="0,2" Background="#1A1A1C" Padding="5" CornerRadius="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="35"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBox Text="{x:Bind Name, Mode=TwoWay}"
                             PlaceholderText="Değişken Adı"
                             LostFocus="Variable_Edited_LostFocus"
                             KeyDown="Variable_TextBox_KeyDown"
                             BorderThickness="0" Background="Transparent" Foreground="White" FontSize="10"/>
                    <TextBlock Text="{x:Bind SourceFile}" FontSize="7" Foreground="#555" Margin="4,-2,0,0"/>
                </StackPanel>

                <TextBox Grid.Column="1"
                         Text="{x:Bind Description, Mode=TwoWay}"
                         PlaceholderText="Adres..."
                         LostFocus="Variable_Edited_LostFocus"
                         KeyDown="Variable_TextBox_KeyDown"
                         BorderThickness="0" Background="Transparent" Foreground="#FF9800" FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" HorizontalContentAlignment="Center"/>

                <TextBox Grid.Column="2"
                         Text="{x:Bind Type, Mode=TwoWay}"
                         LostFocus="Variable_Edited_LostFocus"
                         KeyDown="Variable_TextBox_KeyDown"
                         BorderThickness="0" Background="Transparent" Foreground="#00A4EF" FontSize="10" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="3"
                         Text="{x:Bind Value, Mode=OneWay}"
                         Foreground="#4CAF50" FontWeight="Bold" FontSize="11" FontFamily="Consolas"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <Button Grid.Column="4" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                        Click="DeleteVariable_Click"
                        Background="Transparent" Foreground="#FF5252" BorderThickness="0" Padding="0" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="PlcOutputVariableTemplate" x:DataType="utils:PlcVariable">
            <Grid Margin="0,2" Background="#1A1A1C" Padding="5" CornerRadius="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="35"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBox Text="{x:Bind Name, Mode=TwoWay}"
                             LostFocus="Variable_Edited_LostFocus"
                             KeyDown="Variable_TextBox_KeyDown"
                             BorderThickness="0" Background="Transparent" Foreground="White" FontSize="10"/>
                    <TextBlock Text="{x:Bind SourceFile}" FontSize="7" Foreground="#555" Margin="4,-2,0,0"/>
                </StackPanel>

                <TextBox Grid.Column="1"
                 Text="{x:Bind Description, Mode=TwoWay}"
                 PlaceholderText="Adres..."
                 LostFocus="Variable_Edited_LostFocus"
                 KeyDown="Variable_TextBox_KeyDown"
                 BorderThickness="0" Background="Transparent" Foreground="#FF9800" FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" HorizontalContentAlignment="Center"/>

                <TextBox Grid.Column="2"
                 Text="{x:Bind Type, Mode=TwoWay}"
                 LostFocus="Variable_Edited_LostFocus"
                 KeyDown="Variable_TextBox_KeyDown"
                 BorderThickness="0" Background="Transparent" Foreground="#00A4EF" FontSize="10" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>

                <TextBox Grid.Column="3"
                 Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 KeyDown="ValueTextBox_KeyDown"
                 PlaceholderText="Değer..."
                 BorderThickness="1" BorderBrush="#333" Background="#252526" Foreground="#4CAF50"
                 FontWeight="Bold" FontSize="11" FontFamily="Consolas" HorizontalContentAlignment="Center" VerticalAlignment="Center" CornerRadius="2"/>

                <Button Grid.Column="4" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                Click="DeleteVariable_Click"
                Background="Transparent" Foreground="#FF5252" BorderThickness="0" Padding="0" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
        <Grid Background="#0D0D0D">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="250"/>
                <RowDefinition Height="800"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#252526" BorderThickness="0,0,0,2" BorderBrush="#00A4EF" Padding="20,0">
                <Grid VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                        <FontIcon Glyph="&#xE71A;" Foreground="#00A4EF" FontSize="36"/>
                        <StackPanel VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="Simbiosis Mekatronik Leak Test App" FontSize="14" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="PageTitleLabel" Text="PLC KONTROL" FontSize="10" Foreground="#00A4EF" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="20" VerticalAlignment="Center">
                        <StackPanel VerticalAlignment="Center" Spacing="5">
                            <TextBlock Text="SİSTEM DURUMU" FontSize="9" Foreground="#888888" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="SystemStatusLabel" Text="SENKRON" FontSize="13" FontWeight="Bold" Foreground="#4CAF50"/>
                        </StackPanel>
                        <FontIcon Glyph="&#xE957;" Foreground="#4CAF50" FontSize="24"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="#1A1A1C" Margin="20,0,20,20" BorderThickness="2" BorderBrush="#00A4EF" CornerRadius="10" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="12,0" BorderThickness="0,0,0,2" BorderBrush="#00A4EF">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                <FontIcon Glyph="&#xE71E;" Foreground="#00A4EF" FontSize="16"/>
                                <TextBlock Text="PLC BAĞLANTI AYARLARI" FontSize="12" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                                <TextBlock Text="IP:" FontSize="10" FontWeight="Bold" Foreground="#00A4EF" VerticalAlignment="Center"/>
                                <TextBox x:Name="PLCIPAddressBox" Text="192.168.251.100" Width="120" Height="28" Background="#2D2D30" Foreground="White" BorderBrush="#00A4EF" FontSize="10" Padding="6,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                                <TextBlock Text="Port:" FontSize="10" FontWeight="Bold" Foreground="#00A4EF" VerticalAlignment="Center"/>
                                <TextBox x:Name="PLCPortBox" Text="5007" Width="70" Height="28" Background="#2D2D30" Foreground="White" BorderBrush="#00A4EF" FontSize="10" Padding="6,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="3" x:Name="ConnectPLCBtn" Content="🔗 Bağlan" Background="#4CAF50" Foreground="White" CornerRadius="4" Height="28" FontWeight="Bold" FontSize="9" Padding="10,0" Click="ConnectPLCBtn_Click" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                                <Ellipse x:Name="ConnectionStatusIndicator" Width="12" Height="12" Fill="#FF5252" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ConnectionStatusLabel" Text="Bağlı Değil" FontSize="10" Foreground="#FF5252" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="5" x:Name="ClearLogBtn" Content="🗑️ Logları Temizle" Background="#FF9800" Foreground="White" CornerRadius="4" Height="28" FontWeight="Bold" FontSize="9" Padding="10,0" Click="ClearLogBtn_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1" Background="#0D0D0D" Padding="8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                            <TextBlock x:Name="LogTextBlock" Text="[INFO] Hazır..." Foreground="#00FF88" FontSize="9" FontFamily="Cascadia Mono" TextWrapping="Wrap" Padding="8"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="MainVariablesPanel" Grid.Row="2" Background="#1A1A1C" Margin="20,0,20,20" BorderThickness="2" BorderBrush="#00A4EF" CornerRadius="10" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="12,0" BorderThickness="0,0,0,2" BorderBrush="#00A4EF">
                        <Grid>
                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="&#xE71E;" Foreground="#00A4EF" FontSize="16"/>
                                    <TextBlock Text="PLC DEĞİŞKENLERİ KONTROL" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Mitsubishi PLC - Veri Gönder / Force Et" FontSize="10" Foreground="#888888"/>
                                </StackPanel>
                                <TextBlock Text="Config: C:\Simbiosis\SimbiosisLeakTestApp\Config\PLC_Config.json" FontSize="8" Foreground="#444" FontFamily="Consolas" Margin="28,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="6">
                                <Button x:Name="BtnImportInput" Content="CSV → Input Yukle" Background="#4CAF50" Foreground="White" CornerRadius="4" Height="28" FontWeight="Bold" FontSize="9" Padding="10,0" Click="BtnImportInput_Click"/>
                                <Button x:Name="BtnImportOutput" Content="CSV → Output Yukle" Background="#FF9800" Foreground="White" CornerRadius="4" Height="28" FontWeight="Bold" FontSize="9" Padding="10,0" Click="BtnImportOutput_Click"/>
                                <TextBlock x:Name="TxtImportStatus" Text="" FontSize="9" Foreground="#888" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Background="#0D0D0D" Padding="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#0D0D0D" Margin="0,0,4,0" CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="26"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#1A4D2E" CornerRadius="6,6,0,0" Padding="8" BorderThickness="1" BorderBrush="#4CAF50">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="📥 INPUT VARİABLELERİ (PLC'DEN OKU)" FontSize="10" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                            <Button Content="🗑 Tümünü Sil" Background="#3A1B1B" Foreground="#F44336" CornerRadius="3" Height="20" Padding="6,0" FontSize="9" Click="ClearAllInputs_Click" VerticalAlignment="Center"/>
                                            <Button Content="➕" Background="#4CAF50" Foreground="White" CornerRadius="3" Height="20" Width="25" Padding="0" FontSize="10" Click="AddInputVariableBtn_Click" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1" Background="#1A1A1C" Padding="4,3" BorderThickness="0,0,0,1" BorderBrush="#333333">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="35"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="İsim" FontSize="8" Foreground="#555555" FontWeight="Bold" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Adres" FontSize="8" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Tip" FontSize="8" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="Değer" FontSize="8" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="Sil" FontSize="8" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <ListView Grid.Row="2" 
                                          ItemsSource="{x:Bind InputVariables}"
                                          ItemTemplate="{StaticResource PlcInputVariableTemplate}"
                                          SelectionMode="None"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Background="#0D0D0D" Margin="4,0,0,0" CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="26"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#4D3A1A" CornerRadius="6,6,0,0" Padding="8" BorderThickness="1" BorderBrush="#FF9800">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="📤 OUTPUT VARİABLELERİ (PLC'YE YAZ)" FontSize="10" FontWeight="Bold" Foreground="#FF9800" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                            <Button Content="🗑 Tümünü Sil" Background="#3A1B1B" Foreground="#F44336" CornerRadius="3" Height="20" Padding="6,0" FontSize="9" Click="ClearAllOutputs_Click" VerticalAlignment="Center"/>
                                            <Button Content="➕" Background="#FF9800" Foreground="White" CornerRadius="3" Height="20" Width="25" Padding="0" FontSize="10" Click="AddOutputVariableBtn_Click" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1" Background="#1A1A1C" Padding="4,3" BorderThickness="0,0,0,1" BorderBrush="#333333">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="35"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="İsim" FontSize="8" Foreground="#555555" FontWeight="Bold" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Adres" FontSize="8" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Tip" FontSize="8" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="Değer" FontSize="8" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="Sil" FontSize="8" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <ListView Grid.Row="2"
                                          ItemsSource="{x:Bind OutputVariables}"
                                          ItemTemplate="{StaticResource PlcOutputVariableTemplate}"
                                          SelectionMode="None"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- ═══════════════ FOOTER ═══════════════ -->
            <Border Grid.Row="4" Background="#252526" BorderThickness="0,2,0,0" BorderBrush="#00A4EF" Padding="25,0">
                <Grid VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Left">
                        <Ellipse Width="10" Height="10" Fill="#4CAF50" VerticalAlignment="Center"/>
                        <TextBlock Text="Senkronizasyon:" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock x:Name="SyncStatusLabel" Text="%100 SENKRON" FontSize="11" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="© 2025 Simbiosis Mekatronik | Entegre Sistem Kontrol v2.0" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="10" Foreground="#555555"/>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>