<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App4.PAGES.PLC_Page"
    xmlns:utils="using:App4.Utilities"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <Page.Resources>

        <DataTemplate x:Key="PlcInputVariableTemplate" x:DataType="utils:PlcVariable">
            <Grid Margin="0,2" Background="#1A1A1C" Padding="5" CornerRadius="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <FontIcon Grid.Column="0" Glyph="&#xE9D2;" FontSize="10" Foreground="#555" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <TextBox Grid.Column="1" 
                         Text="{x:Bind Name, Mode=TwoWay}" 
                         PlaceholderText="Adres - Açıklama"
                         LostFocus="Variable_Edited_LostFocus" 
                         KeyDown="Variable_TextBox_KeyDown"
                         BorderThickness="0" Background="Transparent" Foreground="White" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>

                <TextBox Grid.Column="2" 
                         Text="{x:Bind Type, Mode=TwoWay}" 
                         LostFocus="Variable_Edited_LostFocus" 
                         KeyDown="Variable_TextBox_KeyDown"
                         BorderThickness="0" Background="Transparent" Foreground="#00A4EF" FontSize="10" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>

                <TextBox Grid.Column="3" 
                         Text="{x:Bind Value, Mode=TwoWay}" 
                         IsReadOnly="True"
                         BorderThickness="0" Background="Transparent" Foreground="#4CAF50" FontWeight="Bold" FontSize="10" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>

                <Button Grid.Column="4" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" 
                        Click="DeleteVariable_Click" 
                        Background="Transparent" Foreground="#FF5252" BorderThickness="0" Padding="0" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="PlcOutputVariableTemplate" x:DataType="utils:PlcVariable">
            <Grid Margin="0,2" Background="#1A1A1C" Padding="5" CornerRadius="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <FontIcon Grid.Column="0" Glyph="&#xE7E8;" FontSize="10" Foreground="#FF9800" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <TextBox Grid.Column="1" 
                 Text="{x:Bind Name, Mode=TwoWay}" 
                 LostFocus="Variable_Edited_LostFocus" 
                 KeyDown="Variable_TextBox_KeyDown"
                 BorderThickness="0" Background="Transparent" Foreground="White" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>

                <TextBox Grid.Column="2" 
                 Text="{x:Bind Type, Mode=TwoWay}" 
                 LostFocus="Variable_Edited_LostFocus" 
                 KeyDown="Variable_TextBox_KeyDown"
                 BorderThickness="1" BorderBrush="#333" Background="#252526" Foreground="#888" FontSize="10" Height="24" Margin="2,0"/>

                <TextBox Grid.Column="3" 
                 Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                 KeyDown="ValueTextBox_KeyDown"
                 PlaceholderText="Değer..." 
                 BorderThickness="1" BorderBrush="#333" Background="#252526" Foreground="#4CAF50" 
                 FontWeight="Bold" FontSize="10" HorizontalContentAlignment="Center" VerticalAlignment="Center" CornerRadius="2"/>

                <Button Grid.Column="4" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" 
                Click="DeleteVariable_Click" 
                Background="Transparent" Foreground="#FF5252" BorderThickness="0" Padding="0" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
        <Grid Background="#0D0D0D">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="420"/>
                <RowDefinition Height="200"/>
                <RowDefinition Height="280"/>
                <RowDefinition Height="300"/>
                <RowDefinition Height="250"/>
                <RowDefinition Height="800"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#252526" BorderThickness="0,0,0,2" BorderBrush="#00A4EF" Padding="20,0">
                <Grid VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                        <FontIcon Glyph="&#xE71A;" Foreground="#00A4EF" FontSize="36"/>
                        <StackPanel VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="Simbiosis Mekatronik Leak Test App" FontSize="14" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="PageTitleLabel" Text="PLC KONTROL" FontSize="10" Foreground="#00A4EF" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="20" VerticalAlignment="Center">
                        <StackPanel VerticalAlignment="Center" Spacing="5">
                            <TextBlock Text="SİSTEM DURUMU" FontSize="9" Foreground="#888888" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="SystemStatusLabel" Text="SENKRON" FontSize="13" FontWeight="Bold" Foreground="#4CAF50"/>
                        </StackPanel>
                        <FontIcon Glyph="&#xE957;" Foreground="#4CAF50" FontSize="24"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="#1A1A1C" CornerRadius="12" BorderThickness="2" BorderBrush="#00A4EF" Padding="0" Margin="20,20,20,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#252526" CornerRadius="10,10,0,0" Padding="12,0" BorderThickness="0,0,0,2" BorderBrush="#00A4EF">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <FontIcon Glyph="&#xE71C;" Foreground="#00A4EF" FontSize="18"/>
                            <TextBlock Text="TEST İSTATİSTİKLERİ DASHBOARD" FontSize="12" FontWeight="Bold" Foreground="White"/>
                            <Ellipse Width="8" Height="8" Fill="#4CAF50" Margin="0,0,0,0" HorizontalAlignment="Right"/>
                            <TextBlock Text="Aktif" FontSize="9" Foreground="#4CAF50" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1" Background="#0D0D0D" Padding="15">
                        <Grid ColumnSpacing="12" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Column="0" Grid.Row="0" Background="#1A1A1C" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#00A4EF">
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="📊 TOPLAM TEST" FontSize="11" FontWeight="Bold" Foreground="#00A4EF"/>
                                    <TextBlock Grid.Row="1" x:Name="TotalTestsLabel" Text="1,247" FontSize="28" FontWeight="Bold" Foreground="White" FontFamily="Cascadia Mono"/>
                                    <TextBlock Grid.Row="2" Text="Tümü" FontSize="9" Foreground="#888888"/>
                                </Grid>
                            </Border>
                            <Border Grid.Column="1" Grid.Row="0" Background="#1A1A1C" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#4CAF50">
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="✅ BAŞARILI" FontSize="11" FontWeight="Bold" Foreground="#4CAF50"/>
                                    <TextBlock Grid.Row="1" x:Name="SuccessTestsLabel" Text="1,186" FontSize="28" FontWeight="Bold" Foreground="#4CAF50" FontFamily="Cascadia Mono"/>
                                    <TextBlock Grid.Row="2" Text="95.1% Başarı Oranı" FontSize="9" Foreground="#888888"/>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" Grid.Row="0" Background="#1A1A1C" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#FF5252">
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="❌ BAŞARISIZ" FontSize="11" FontWeight="Bold" Foreground="#FF5252"/>
                                    <TextBlock Grid.Row="1" x:Name="FailedTestsLabel" Text="61" FontSize="28" FontWeight="Bold" Foreground="#FF5252" FontFamily="Cascadia Mono"/>
                                    <TextBlock Grid.Row="2" Text="4.9% Hata Oranı" FontSize="9" Foreground="#888888"/>
                                </Grid>
                            </Border>
                            <Border Grid.Column="3" Grid.Row="0" Background="#1A1A1C" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#FFB81C">
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="⏱️ ÇALIŞMA" FontSize="11" FontWeight="Bold" Foreground="#FFB81C"/>
                                    <TextBlock Grid.Row="1" x:Name="UptimeLabel" Text="47.3h" FontSize="28" FontWeight="Bold" Foreground="#FFB81C" FontFamily="Cascadia Mono"/>
                                    <TextBlock Grid.Row="2" Text="Kesintisiz Çalışma" FontSize="9" Foreground="#888888"/>
                                </Grid>
                            </Border>
                            <Border Grid.Column="0" Grid.Row="1" Background="#1A1A1C" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#333333">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="🕐 Son Test" FontSize="11" FontWeight="Bold" Foreground="#00A4EF"/>
                                    <TextBlock x:Name="LastTestLabel" Text="2025-01-14 14:32:45" FontSize="14" Foreground="#00FF88" FontFamily="Cascadia Mono" FontWeight="Bold"/>
                                    <TextBlock Text="5 dakika önce" FontSize="9" Foreground="#888888"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Grid.Row="1" Background="#1A1A1C" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#333333">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="⏲️ Ort. Test Süresi" FontSize="11" FontWeight="Bold" Foreground="#00A4EF"/>
                                    <TextBlock x:Name="AvgDurationLabel" Text="2.36 sn" FontSize="14" Foreground="#00A4EF" FontFamily="Cascadia Mono" FontWeight="Bold"/>
                                    <TextBlock Text="Hedef: 2.50 sn" FontSize="9" Foreground="#4CAF50"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Grid.Row="1" Background="#1A1A1C" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#333333">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="📅 Bugün" FontSize="11" FontWeight="Bold" Foreground="#00A4EF"/>
                                    <TextBlock x:Name="TodayTestsLabel" Text="47 Test" FontSize="14" Foreground="#FFB81C" FontFamily="Cascadia Mono" FontWeight="Bold"/>
                                    <TextBlock Text="45 Başarılı, 2 Başarısız" FontSize="9" Foreground="#888888"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Grid.Row="1" Background="#1A1A1C" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#333333">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="⭐ Sistem Kalitesi" FontSize="11" FontWeight="Bold" Foreground="#00A4EF"/>
                                    <TextBlock x:Name="SystemQualityLabel" Text="A+" FontSize="14" Foreground="#4CAF50" FontFamily="Cascadia Mono" FontWeight="Bold"/>
                                    <TextBlock Text="Mükemmel Performans" FontSize="9" Foreground="#4CAF50"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="#1A1A1C" CornerRadius="12" BorderThickness="2" BorderBrush="#00A4EF" Padding="0" Margin="20,0,20,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#252526" CornerRadius="10,10,0,0" Padding="12,0" BorderThickness="0,0,0,2" BorderBrush="#00A4EF">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <FontIcon Glyph="&#xE71A;" Foreground="#00A4EF" FontSize="18"/>
                            <TextBlock Text="ROBOT KONTROL (KUKA)" FontSize="12" FontWeight="Bold" Foreground="White"/>
                            <Ellipse Width="8" Height="8" Fill="#FFB81C" Margin="0,0,0,0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <TextBlock Text="Bekleme" FontSize="9" Foreground="#FFB81C" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1" Background="#0D0D0D" Padding="15" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#1A1A1C" CornerRadius="8" Padding="12" BorderThickness="1" BorderBrush="#333333">
                            <StackPanel Spacing="6">
                                <TextBlock Text="📍 X KOORDİNATI" FontSize="10" FontWeight="Bold" Foreground="#00A4EF"/>
                                <TextBlock Text="125.5" FontSize="20" FontWeight="Bold" Foreground="#00FF88" FontFamily="Cascadia Mono"/>
                                <TextBlock Text="mm" FontSize="9" Foreground="#888888"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="#1A1A1C" CornerRadius="8" Padding="12" BorderThickness="1" BorderBrush="#333333">
                            <StackPanel Spacing="6">
                                <TextBlock Text="📍 Y KOORDİNATI" FontSize="10" FontWeight="Bold" Foreground="#00A4EF"/>
                                <TextBlock Text="245.3" FontSize="20" FontWeight="Bold" Foreground="#00FF88" FontFamily="Cascadia Mono"/>
                                <TextBlock Text="mm" FontSize="9" Foreground="#888888"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#1A1A1C" CornerRadius="8" Padding="12" BorderThickness="1" BorderBrush="#333333">
                            <StackPanel Spacing="6">
                                <TextBlock Text="📍 Z KOORDİNATI" FontSize="10" FontWeight="Bold" Foreground="#00A4EF"/>
                                <TextBlock Text="450.8" FontSize="20" FontWeight="Bold" Foreground="#00FF88" FontFamily="Cascadia Mono"/>
                                <TextBlock Text="mm" FontSize="9" Foreground="#888888"/>
                            </StackPanel>
                        </Border>
                        <Button Grid.Column="3" Background="#FF5252" CornerRadius="6" FontWeight="Bold" Foreground="White" VerticalAlignment="Stretch">
                            <StackPanel Orientation="Vertical" Spacing="4">
                                <FontIcon Glyph="&#xE71E;" FontSize="18"/>
                                <TextBlock Text="ACİL" TextAlignment="Center" FontSize="10"/>
                                <TextBlock Text="DURDUR" TextAlignment="Center" FontSize="10"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="3" Background="#1A1A1C" Margin="20,0,20,20" BorderThickness="2" BorderBrush="#00A4EF" CornerRadius="10" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="12,0" BorderThickness="0,0,0,2" BorderBrush="#00A4EF">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                            <FontIcon Glyph="&#xE71E;" Foreground="#00A4EF" FontSize="16"/>
                            <TextBlock Text="GERÇEK ZAMANLI I/O MAPPING" FontSize="12" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="PLC ↔ Robot ↔ 3D Kamera Veri Akışı" FontSize="10" Foreground="#888888" Margin="0,0,0,0" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1" Background="#0D0D0D" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                            <StackPanel x:Name="IOMapContainer" Spacing="6"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="4" Background="#1A1A1C" Margin="20,0,20,20" BorderThickness="2" BorderBrush="#00A4EF" CornerRadius="10" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="12,0" BorderThickness="0,0,0,2" BorderBrush="#00A4EF">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                            <FontIcon Glyph="&#xE7F8;" Foreground="#00A4EF" FontSize="16"/>
                            <TextBlock Text="SİSTEM SAĞLIK MONİTÖRÜ" FontSize="12" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1" Background="#0D0D0D" Padding="15">
                        <Grid ColumnSpacing="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="🎛️ PLC SİSTEMİ" FontSize="11" FontWeight="Bold" Foreground="#00A4EF"/>
                                <Border Background="#1A1A1C" CornerRadius="4" Padding="10">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="CPU: 68%" FontSize="10" Foreground="#FFB81C"/>
                                        <TextBlock Text="Hafıza: 45%" FontSize="10" Foreground="#4CAF50"/>
                                        <TextBlock Text="I/O: 12/16 Aktif" FontSize="10" Foreground="#00FF88"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="🤖 ROBOT KONTROL" FontSize="11" FontWeight="Bold" Foreground="#00A4EF"/>
                                <Border Background="#1A1A1C" CornerRadius="4" Padding="10">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Eksen: 6/6 OK" FontSize="10" Foreground="#4CAF50"/>
                                        <TextBlock Text="Sensör: 8/8 Aktif" FontSize="10" Foreground="#00FF88"/>
                                        <TextBlock Text="Hata: Yok" FontSize="10" Foreground="#4CAF50"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="8">
                                <TextBlock Text="📷 3D KAMERA" FontSize="11" FontWeight="Bold" Foreground="#00A4EF"/>
                                <Border Background="#1A1A1C" CornerRadius="4" Padding="10">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="FPS: 30" FontSize="10" Foreground="#4CAF50"/>
                                        <TextBlock Text="Çözünürlük: 2K" FontSize="10" Foreground="#00FF88"/>
                                        <TextBlock Text="Gecikme: 45ms" FontSize="10" Foreground="#FFB81C"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Spacing="8">
                                <TextBlock Text="🌐 İLETİŞİM" FontSize="11" FontWeight="Bold" Foreground="#00A4EF"/>
                                <Border Background="#1A1A1C" CornerRadius="4" Padding="10">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Ethernet: OK" FontSize="10" Foreground="#4CAF50"/>
                                        <TextBlock Text="Protokol: TCP/IP" FontSize="10" Foreground="#00FF88"/>
                                        <TextBlock Text="Ping: 2ms" FontSize="10" Foreground="#4CAF50"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="5" Background="#1A1A1C" Margin="20,0,20,20" BorderThickness="2" BorderBrush="#00A4EF" CornerRadius="10" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="12,0" BorderThickness="0,0,0,2" BorderBrush="#00A4EF">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                <FontIcon Glyph="&#xE71E;" Foreground="#00A4EF" FontSize="16"/>
                                <TextBlock Text="PLC BAĞLANTI AYARLARI" FontSize="12" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                                <TextBlock Text="IP:" FontSize="10" FontWeight="Bold" Foreground="#00A4EF" VerticalAlignment="Center"/>
                                <TextBox x:Name="PLCIPAddressBox" Text="192.168.251.100" Width="120" Height="28" Background="#2D2D30" Foreground="White" BorderBrush="#00A4EF" FontSize="10" Padding="6,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                                <TextBlock Text="Port:" FontSize="10" FontWeight="Bold" Foreground="#00A4EF" VerticalAlignment="Center"/>
                                <TextBox x:Name="PLCPortBox" Text="5007" Width="70" Height="28" Background="#2D2D30" Foreground="White" BorderBrush="#00A4EF" FontSize="10" Padding="6,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="3" x:Name="ConnectPLCBtn" Content="🔗 Bağlan" Background="#4CAF50" Foreground="White" CornerRadius="4" Height="28" FontWeight="Bold" FontSize="9" Padding="10,0" Click="ConnectPLCBtn_Click" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                                <Ellipse x:Name="ConnectionStatusIndicator" Width="12" Height="12" Fill="#FF5252" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ConnectionStatusLabel" Text="Bağlı Değil" FontSize="10" Foreground="#FF5252" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="5" x:Name="ClearLogBtn" Content="🗑️ Logları Temizle" Background="#FF9800" Foreground="White" CornerRadius="4" Height="28" FontWeight="Bold" FontSize="9" Padding="10,0" Click="ClearLogBtn_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1" Background="#0D0D0D" Padding="8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                            <TextBlock x:Name="LogTextBlock" Text="[INFO] Hazır..." Foreground="#00FF88" FontSize="9" FontFamily="Cascadia Mono" TextWrapping="Wrap" Padding="8"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="6" Background="#1A1A1C" Margin="20,0,20,20" BorderThickness="2" BorderBrush="#00A4EF" CornerRadius="10" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="12,0" BorderThickness="0,0,0,2" BorderBrush="#00A4EF">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                            <FontIcon Glyph="&#xE71E;" Foreground="#00A4EF" FontSize="16"/>
                            <TextBlock Text="PLC DEĞİŞKENLERİ KONTROL" FontSize="12" FontWeight="Bold" Foreground="White"/>
