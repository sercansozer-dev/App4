<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App4.Pages.Robot_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App4.Pages"
    xmlns:utilities="using:App4.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Page.Resources>
        <DataTemplate x:Key="RobotInputVariableTemplate" x:DataType="utilities:PlcVariable">
            <Grid Margin="0,2" Background="#1A1A1C" Padding="5" CornerRadius="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <FontIcon Grid.Column="0" Glyph="&#xE9D2;" FontSize="10" Foreground="#555" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <TextBox Grid.Column="1" 
                         Text="{x:Bind Name, Mode=TwoWay}" 
                         PlaceholderText="Değişken Adı"
                         LostFocus="Variable_Edited_LostFocus" 
                         BorderThickness="0" Background="Transparent" Foreground="White" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>

                <TextBox Grid.Column="2" 
                         Text="{x:Bind Type, Mode=TwoWay}" 
                         LostFocus="Variable_Edited_LostFocus" 
                         BorderThickness="0" Background="Transparent" Foreground="#00A4EF" FontSize="10" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>

                 <TextBox Grid.Column="3" 
                         Text="{x:Bind PlcTag, Mode=TwoWay}" 
                         PlaceholderText="KRL Tag ($...)"
                         LostFocus="Variable_Edited_LostFocus" 
                         BorderThickness="0" Background="Transparent" Foreground="#AAAAAA" FontSize="10" VerticalAlignment="Center"/>

                <TextBox Grid.Column="4" 
                         Text="{x:Bind Value, Mode=OneWay}" 
                         IsReadOnly="True"
                         BorderThickness="0" Background="Transparent" Foreground="#4CAF50" FontWeight="Bold" FontSize="10" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>

                <Button Grid.Column="5" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" 
                        Click="BtnDelete_Click" Tag="{x:Bind}"
                        Background="Transparent" Foreground="#FF5252" BorderThickness="0" Padding="0" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="RobotOutputVariableTemplate" x:DataType="utilities:PlcVariable">
            <Grid Margin="0,2" Background="#1A1A1C" Padding="5" CornerRadius="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <FontIcon Grid.Column="0" Glyph="&#xE7E8;" FontSize="10" Foreground="#FF9800" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <TextBox Grid.Column="1" 
                 Text="{x:Bind Name, Mode=TwoWay}" 
                 LostFocus="Variable_Edited_LostFocus" 
                 PlaceholderText="Değişken Adı"
                 BorderThickness="0" Background="Transparent" Foreground="White" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>

                <TextBox Grid.Column="2" 
                 Text="{x:Bind Type, Mode=TwoWay}" 
                 LostFocus="Variable_Edited_LostFocus" 
                 BorderThickness="1" BorderBrush="#333" Background="#252526" Foreground="#888" FontSize="10" Height="24" Margin="2,0"/>
                
                <TextBox Grid.Column="3" 
                         Text="{x:Bind PlcTag, Mode=TwoWay}" 
                         PlaceholderText="KRL Tag ($...)"
                         LostFocus="Variable_Edited_LostFocus" 
                         BorderThickness="0" Background="Transparent" Foreground="#AAAAAA" FontSize="10" VerticalAlignment="Center"/>

                <TextBox Grid.Column="4" 
                 Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                 KeyDown="ValueTextBox_KeyDown"
                 Tag="{x:Bind}"
                 PlaceholderText="Değer..." 
                 BorderThickness="1" BorderBrush="#333" Background="#252526" Foreground="#4CAF50" 
                 FontWeight="Bold" FontSize="10" HorizontalContentAlignment="Center" VerticalAlignment="Center" CornerRadius="2"/>

                <Button Grid.Column="5" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" 
                Click="BtnDelete_Click" Tag="{x:Bind}"
                Background="Transparent" Foreground="#FF5252" BorderThickness="0" Padding="0" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
        <Grid Background="#0D0D0D">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/> <!-- Header -->
                <RowDefinition Height="*"/>  <!-- Dinamik Robot Panelleri -->
                <RowDefinition Height="Auto"/> <!-- Log -->
            </Grid.RowDefinitions>

            <!-- HEADER / STATUS -->
            <Border Grid.Row="0" Background="#111" BorderBrush="#222" BorderThickness="0,0,0,1">
                <Grid Padding="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE99A;" FontSize="24" Foreground="#00A4EF"/>
                        <TextBlock Text="ROBOT ENTEGRASYON KONTROLÜ" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <Border x:Name="RobotCountBadge" Background="#00FF88" CornerRadius="4" Padding="10,4">
                            <TextBlock x:Name="RobotCountText" Text="0 Robot" FontSize="11" FontWeight="Bold" Foreground="#0A0A0A"/>
                        </Border>
                    </StackPanel>
                    <Button Grid.Column="2" x:Name="BtnAddRobot" Click="BtnAddRobot_Click"
                            Background="#2D2D30" Foreground="White" CornerRadius="6" Padding="15,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14"/>
                            <TextBlock Text="Robot Ekle" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- DİNAMİK ROBOT PANELLERİ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,15,20,0">
                <StackPanel x:Name="RobotPanelsContainer" Spacing="15"/>
            </ScrollViewer>

            <!-- LOG PANEL -->
            <Border Grid.Row="2" Background="#1A1A1C" Margin="20,15,20,20" BorderThickness="2" BorderBrush="#00A4EF" CornerRadius="10" Padding="0" MaxHeight="150">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="12,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                            <FontIcon Glyph="&#xE71E;" Foreground="#00A4EF" FontSize="14"/>
                            <TextBlock Text="📋 LOG" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden" Background="#0D0D0D">
                        <TextBlock x:Name="RobotLogTextBlock" Text="[INFO] Robot Entegrasyonu Hazır..." Foreground="#00FF88" FontSize="9" FontFamily="Cascadia Mono" TextWrapping="Wrap" Padding="10"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>

</Page>
