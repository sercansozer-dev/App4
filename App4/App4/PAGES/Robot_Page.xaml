<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App4.Pages.Robot_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App4.Pages"
    xmlns:utilities="using:App4.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Page.Resources>
        <DataTemplate x:Key="RobotInputVariableTemplate" x:DataType="utilities:PlcVariable">
            <Grid Margin="0,2" Background="#1A1A1C" Padding="5" CornerRadius="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <FontIcon Grid.Column="0" Glyph="&#xE9D2;" FontSize="10" Foreground="#555" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <TextBox Grid.Column="1" 
                         Text="{x:Bind Name, Mode=TwoWay}" 
                         PlaceholderText="Değişken Adı"
                         LostFocus="Variable_Edited_LostFocus" 
                         BorderThickness="0" Background="Transparent" Foreground="White" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>

                <TextBox Grid.Column="2" 
                         Text="{x:Bind Type, Mode=TwoWay}" 
                         LostFocus="Variable_Edited_LostFocus" 
                         BorderThickness="0" Background="Transparent" Foreground="#00A4EF" FontSize="10" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>

                 <TextBox Grid.Column="3" 
                         Text="{x:Bind PlcTag, Mode=TwoWay}" 
                         PlaceholderText="KRL Tag ($...)"
                         LostFocus="Variable_Edited_LostFocus" 
                         BorderThickness="0" Background="Transparent" Foreground="#AAAAAA" FontSize="10" VerticalAlignment="Center"/>

                <TextBox Grid.Column="4" 
                         Text="{x:Bind Value, Mode=OneWay}" 
                         IsReadOnly="True"
                         BorderThickness="0" Background="Transparent" Foreground="#4CAF50" FontWeight="Bold" FontSize="10" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>

                <Button Grid.Column="5" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" 
                        Click="BtnDelete_Click" Tag="{x:Bind}"
                        Background="Transparent" Foreground="#FF5252" BorderThickness="0" Padding="0" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="RobotOutputVariableTemplate" x:DataType="utilities:PlcVariable">
            <Grid Margin="0,2" Background="#1A1A1C" Padding="5" CornerRadius="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <FontIcon Grid.Column="0" Glyph="&#xE7E8;" FontSize="10" Foreground="#FF9800" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <TextBox Grid.Column="1" 
                 Text="{x:Bind Name, Mode=TwoWay}" 
                 LostFocus="Variable_Edited_LostFocus" 
                 PlaceholderText="Değişken Adı"
                 BorderThickness="0" Background="Transparent" Foreground="White" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>

                <TextBox Grid.Column="2" 
                 Text="{x:Bind Type, Mode=TwoWay}" 
                 LostFocus="Variable_Edited_LostFocus" 
                 BorderThickness="1" BorderBrush="#333" Background="#252526" Foreground="#888" FontSize="10" Height="24" Margin="2,0"/>
                
                <TextBox Grid.Column="3" 
                         Text="{x:Bind PlcTag, Mode=TwoWay}" 
                         PlaceholderText="KRL Tag ($...)"
                         LostFocus="Variable_Edited_LostFocus" 
                         BorderThickness="0" Background="Transparent" Foreground="#AAAAAA" FontSize="10" VerticalAlignment="Center"/>

                <TextBox Grid.Column="4" 
                 Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                 KeyDown="ValueTextBox_KeyDown"
                 Tag="{x:Bind}"
                 PlaceholderText="Değer..." 
                 BorderThickness="1" BorderBrush="#333" Background="#252526" Foreground="#4CAF50" 
                 FontWeight="Bold" FontSize="10" HorizontalContentAlignment="Center" VerticalAlignment="Center" CornerRadius="2"/>

                <Button Grid.Column="5" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" 
                Click="BtnDelete_Click" Tag="{x:Bind}"
                Background="Transparent" Foreground="#FF5252" BorderThickness="0" Padding="0" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
        <Grid Background="#0D0D0D">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Variable Control -->
                <RowDefinition Height="Auto"/> <!-- Connection and Log -->
            </Grid.RowDefinitions>

            <!-- HEADER / STATUS -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="20" Margin="20,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="ROBOT ENTEGRASYON KONTROLÜ" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <Border x:Name="ConnectionBadge" Background="#333" CornerRadius="4" Padding="10,5">
                    <TextBlock x:Name="ConnectionText" Text="BAĞLANTI BEKLENİYOR..." Foreground="Gray" FontSize="12"/>
                </Border>
            </StackPanel>

            <Border Grid.Row="1" Background="#1A1A1C" Margin="20,0,20,20" BorderThickness="2" BorderBrush="#00A4EF" CornerRadius="10" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="12,0" BorderThickness="0,0,0,2" BorderBrush="#00A4EF">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                            <FontIcon Glyph="&#xE71E;" Foreground="#00A4EF" FontSize="16"/>
                            <TextBlock Text="ROBOT DEĞİŞKENLERİ KONTROL" FontSize="12" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="KUKA Robot - Veri Gönder / Al" FontSize="10" Foreground="#888888"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" Background="#0D0D0D" Padding="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- INPUT SECTION -->
                        <Border Grid.Column="0" Background="#0D0D0D" Margin="0,0,4,0" CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="26"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#1A4D2E" CornerRadius="6,6,0,0" Padding="8" BorderThickness="1" BorderBrush="#4CAF50">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="📥 ROBOT INPUT (OKUNAN VERİLER)" FontSize="10" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="➕" Background="#4CAF50" Foreground="White" CornerRadius="3" Height="20" Width="25" Padding="0" FontSize="10" Click="BtnAddInput_Click" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1" Background="#1A1A1C" Padding="4,3" BorderThickness="0,0,0,1" BorderBrush="#333333">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="#" FontSize="7" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="İsim" FontSize="7" Foreground="#555555" FontWeight="Bold" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Tip" FontSize="7" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="KRL Tag" FontSize="7" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="Değer" FontSize="7" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="Sil" FontSize="7" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <ListView Grid.Row="2" 
                                          ItemsSource="{x:Bind RobotInputVars}"
                                          ItemTemplate="{StaticResource RobotInputVariableTemplate}"
                                          SelectionMode="None"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </Border>

                        <!-- OUTPUT SECTION -->
                        <Border Grid.Column="1" Background="#0D0D0D" Margin="4,0,0,0" CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="26"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#4D3A1A" CornerRadius="6,6,0,0" Padding="8" BorderThickness="1" BorderBrush="#FF9800">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="📤 ROBOT OUTPUT (YAZILAN VERİLER)" FontSize="10" FontWeight="Bold" Foreground="#FF9800" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="➕" Background="#FF9800" Foreground="White" CornerRadius="3" Height="20" Width="25" Padding="0" FontSize="10" Click="BtnAddOutput_Click" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1" Background="#1A1A1C" Padding="4,3" BorderThickness="0,0,0,1" BorderBrush="#333333">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="#" FontSize="7" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="İsim" FontSize="7" Foreground="#555555" FontWeight="Bold" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Tip" FontSize="7" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="KRL Tag" FontSize="7" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="Yazılacak Değer" FontSize="7" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="Sil" FontSize="7" Foreground="#555555" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <ListView Grid.Row="2" 
                                          ItemsSource="{x:Bind RobotOutputVars}"
                                          ItemTemplate="{StaticResource RobotOutputVariableTemplate}"
                                          SelectionMode="None"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
            <Border Grid.Row="2" Background="#1A1A1C" Margin="20,0,20,20" BorderThickness="2" BorderBrush="#00A4EF" CornerRadius="10" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Padding="12,0" BorderThickness="0,0,0,2" BorderBrush="#00A4EF">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                <FontIcon Glyph="&#xE71E;" Foreground="#00A4EF" FontSize="16"/>
                                <TextBlock Text="ROBOT BAĞLANTI AYARLARI" FontSize="12" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                                <TextBlock Text="IP:" FontSize="10" FontWeight="Bold" Foreground="#00A4EF" VerticalAlignment="Center"/>
                                <TextBox x:Name="RobotIPAddressBox" PlaceholderText="192.168.251.71" Width="120" Height="28" Background="#2D2D30" Foreground="White" BorderBrush="#00A4EF" FontSize="10" Padding="6,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                                <TextBlock Text="Port:" FontSize="10" FontWeight="Bold" Foreground="#00A4EF" VerticalAlignment="Center"/>
                                <TextBox x:Name="RobotPortBox" PlaceholderText="7000" Width="70" Height="28" Background="#2D2D30" Foreground="White" BorderBrush="#00A4EF" FontSize="10" Padding="6,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="3" x:Name="ConnectRobotBtn" Content="💾 Kaydet ve Bağlan" Background="#4CAF50" Foreground="White" CornerRadius="4" Height="28" FontWeight="Bold" FontSize="9" Padding="10,0" Click="ConnectRobotBtn_Click" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                                <Ellipse x:Name="RobotConnectionStatusIndicator" Width="12" Height="12" Fill="#FF5252" VerticalAlignment="Center"/>
                                <TextBlock x:Name="RobotConnectionStatusLabel" Text="Bağlı Değil" FontSize="10" Foreground="#FF5252" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1" Background="#0D0D0D" Padding="8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden" Height="60">
                            <TextBlock x:Name="RobotLogTextBlock" Text="[INFO] KUKA Aracı Hazır..." Foreground="#00FF88" FontSize="9" FontFamily="Cascadia Mono" TextWrapping="Wrap" Padding="8"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>

</Page>
