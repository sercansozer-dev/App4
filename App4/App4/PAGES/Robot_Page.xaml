                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE71A;" FontSize="20"/>
                                    <TextBlock Text="DURAKLAT / DEVAM" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Test Başlatma -->
                            <Button Grid.Column="1" Grid.Row="1" Background="#2ECC71" CornerRadius="8" Foreground="White" Height="60" FontWeight="Bold" FontSize="11" Click="StartTest_Click">
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE768;" FontSize="20"/>
                                    <TextBlock Text="TEST BAŞLAT" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Oto Tekrar -->
                            <Button Grid.Column="2" Grid.Row="1" Background="#333333" CornerRadius="8" Foreground="White" Height="60" FontWeight="Bold" FontSize="11" Click="AutoRepeat_Click">
