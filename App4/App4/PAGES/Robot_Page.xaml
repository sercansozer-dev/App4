<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App4.Pages.Robot_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App4.Pages"
    xmlns:utilities="using:App4.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Page.Resources>
        <DataTemplate x:Key="RobotInputVariableTemplate" x:DataType="utilities:PlcVariable">
            <Grid Margin="0,2" Background="#1A1A1C" Padding="5" CornerRadius="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <FontIcon Grid.Column="0" Glyph="&#xE9D2;" FontSize="10" Foreground="#555" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <TextBox Grid.Column="1" 
                         Text="{x:Bind Name, Mode=TwoWay}" 
                         PlaceholderText="Değişken Adı"
                         LostFocus="Variable_Edited_LostFocus" 
                         BorderThickness="0" Background="Transparent" Foreground="White" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>

                <TextBox Grid.Column="2" 
                         Text="{x:Bind Type, Mode=TwoWay}" 
                         LostFocus="Variable_Edited_LostFocus" 
                         BorderThickness="0" Background="Transparent" Foreground="#00A4EF" FontSize="10" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>

                 <TextBox Grid.Column="3" 
                         Text="{x:Bind PlcTag, Mode=TwoWay}" 
                         PlaceholderText="KRL Tag ($...)"
                         LostFocus="Variable_Edited_LostFocus" 
                         BorderThickness="0" Background="Transparent" Foreground="#AAAAAA" FontSize="10" VerticalAlignment="Center"/>

                <TextBox Grid.Column="4" 
                         Text="{x:Bind Value, Mode=OneWay}" 
                         IsReadOnly="True"
                         BorderThickness="0" Background="Transparent" Foreground="#4CAF50" FontWeight="Bold" FontSize="10" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>

                <Button Grid.Column="5" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" 
                        Click="BtnDelete_Click" Tag="{x:Bind}"
                        Background="Transparent" Foreground="#FF5252" BorderThickness="0" Padding="0" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="RobotOutputVariableTemplate" x:DataType="utilities:PlcVariable">
            <Grid Margin="0,2" Background="#1A1A1C" Padding="5" CornerRadius="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <FontIcon Grid.Column="0" Glyph="&#xE7E8;" FontSize="10" Foreground="#FF9800" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <TextBox Grid.Column="1" 
                 Text="{x:Bind Name, Mode=TwoWay}" 
                 LostFocus="Variable_Edited_LostFocus" 
                 PlaceholderText="Değişken Adı"
                 BorderThickness="0" Background="Transparent" Foreground="White" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>

                <TextBox Grid.Column="2" 
                 Text="{x:Bind Type, Mode=TwoWay}" 
                 LostFocus="Variable_Edited_LostFocus" 
                 BorderThickness="1" BorderBrush="#333" Background="#252526" Foreground="#888" FontSize="10" Height="24" Margin="2,0"/>
                
                <TextBox Grid.Column="3" 
                         Text="{x:Bind PlcTag, Mode=TwoWay}" 
                         PlaceholderText="KRL Tag ($...)"
                         LostFocus="Variable_Edited_LostFocus" 
                         BorderThickness="0" Background="Transparent" Foreground="#AAAAAA" FontSize="10" VerticalAlignment="Center"/>

                <TextBox Grid.Column="4" 
                 Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                 KeyDown="ValueTextBox_KeyDown"
                 Tag="{x:Bind}"
                 PlaceholderText="Değer..." 
                 BorderThickness="1" BorderBrush="#333" Background="#252526" Foreground="#4CAF50" 
                 FontWeight="Bold" FontSize="10" HorizontalContentAlignment="Center" VerticalAlignment="Center" CornerRadius="2"/>

                <Button Grid.Column="5" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" 
                Click="BtnDelete_Click" Tag="{x:Bind}"
                Background="Transparent" Foreground="#FF5252" BorderThickness="0" Padding="0" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Background="#0D0D0D">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1A1A1C" BorderThickness="0,0,0,1" BorderBrush="#333">
            <Grid Padding="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                    <Border Background="#0078D4" CornerRadius="8" Width="40" Height="40">
                        <FontIcon Glyph="&#xE99A;" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Robot Entegrasyonu" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="KUKA Robot Değişken Yönetimi" FontSize="11" Foreground="#888"/>
                    </StackPanel>
                    <Border Background="#1E1E20" CornerRadius="6" Padding="12,6" Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="RobotCountText" Text="0 Robot" FontSize="11" Foreground="#888"/>
                    </Border>
                </StackPanel>
                <Button x:Name="BtnAddRobot" Click="BtnAddRobot_Click" HorizontalAlignment="Right"
                        Background="#0078D4" Foreground="White" CornerRadius="4" Padding="15,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                        <TextBlock Text="Robot Ekle"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ROBOT PANELLERİ -->
		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,15,20,0">
			<StackPanel Spacing="12">
				<StackPanel x:Name="RobotPanelsContainer" Spacing="12"/>

				<!-- ═══ ROBOT ↔ PLC KÖPRÜ TABLOLARI (Her Robot İçin Ayrı Input/Output) ═══ -->
				<StackPanel x:Name="BridgeTablesContainer" Spacing="12" Margin="0,15,0,5">
					<TextBlock x:Name="MappingCountText" Visibility="Collapsed"/>
				</StackPanel>

				<!-- ═══ ROBOT ↔ ROBOT HABERLEŞME TABLOSU ═══ -->
				<Border Background="#1E1E20" Margin="0,5,0,20" CornerRadius="8" MaxHeight="350">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="40"/>
							<RowDefinition Height="28"/>
							<RowDefinition Height="*"/>
						</Grid.RowDefinitions>

						<Border Grid.Row="0" Background="#252528" CornerRadius="8,8,0,0" Padding="15,0">
							<Grid>
								<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
									<FontIcon Glyph="&#xE8F4;" Foreground="#FF5722" FontSize="14"/>
									<TextBlock Text="ROBOT ↔ ROBOT HABERLEŞME" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
									<Border Background="#FF5722" CornerRadius="4" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
										<TextBlock x:Name="RobotRobotCountText" Text="0 Eşleşme" FontSize="9" FontWeight="Bold" Foreground="White"/>
									</Border>
								</StackPanel>
								<Button x:Name="BtnAddRobotRobotMapping" Click="BtnAddRobotRobotMapping_Click" HorizontalAlignment="Right"
										Background="#FF5722" Foreground="White" CornerRadius="4" Height="28" Padding="12,0" VerticalAlignment="Center">
									<StackPanel Orientation="Horizontal" Spacing="6">
										<FontIcon Glyph="&#xE710;" FontSize="11"/>
										<TextBlock Text="Yeni Eşleşme" FontSize="10"/>
									</StackPanel>
								</Button>
							</Grid>
						</Border>

						<Border Grid.Row="1" Background="#1A1A1C" Padding="8,4">
							<Grid ColumnDefinitions="30, 1*, 1*, 40, 1*, 1*, 80, 60, 40">
								<TextBlock Grid.Column="0" Text="#" FontSize="9" Foreground="#555" FontWeight="Bold" HorizontalAlignment="Center"/>
								<TextBlock Grid.Column="1" Text="Kaynak Robot" FontSize="9" Foreground="#555" FontWeight="Bold" Margin="4,0"/>
								<TextBlock Grid.Column="2" Text="Kaynak Tag" FontSize="9" Foreground="#555" FontWeight="Bold" Margin="4,0"/>
								<TextBlock Grid.Column="3" Text="→" FontSize="11" Foreground="#FF5722" FontWeight="Bold" HorizontalAlignment="Center"/>
								<TextBlock Grid.Column="4" Text="Hedef Robot" FontSize="9" Foreground="#555" FontWeight="Bold" Margin="4,0"/>
								<TextBlock Grid.Column="5" Text="Hedef Tag" FontSize="9" Foreground="#555" FontWeight="Bold" Margin="4,0"/>
								<TextBlock Grid.Column="6" Text="Değer" FontSize="9" Foreground="#555" FontWeight="Bold" HorizontalAlignment="Center"/>
								<TextBlock Grid.Column="7" Text="Durum" FontSize="9" Foreground="#555" FontWeight="Bold" HorizontalAlignment="Center"/>
								<TextBlock Grid.Column="8" Text="Sil" FontSize="9" Foreground="#555" FontWeight="Bold" HorizontalAlignment="Center"/>
							</Grid>
						</Border>

						<ScrollViewer Grid.Row="2" MaxHeight="250" VerticalScrollBarVisibility="Auto" Background="#0D0D0D">
							<StackPanel x:Name="RobotRobotRowsContainer" Spacing="2" Padding="4"/>
						</ScrollViewer>
					</Grid>
				</Border>

				<!-- ═══ ROBOT STATUS KOD REFERANS TABLOSU ═══ -->
