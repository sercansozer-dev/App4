                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE74C;" FontSize="20"/>
                                    <TextBlock Text="OFSET KOMPENSASYONU" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Manuel Koordinat Girişi -->
                            <Button Grid.Column="1" Grid.Row="0" Background="#333333" CornerRadius="8" Foreground="White" Height="60" FontWeight="Bold" FontSize="11" Click="ManualPosition_Click">
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE71E;" FontSize="20"/>
                                    <TextBlock Text="MANUEL KONUM" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Kalibrasyonu -->
                            <Button Grid.Column="2" Grid.Row="0" Background="#333333" CornerRadius="8" Foreground="White" Height="60" FontWeight="Bold" FontSize="11" Click="Calibration_Click">
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE895;" FontSize="20"/>
                                    <TextBlock Text="KALİBRASYON" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Duraklatma / Devam Butonu -->
