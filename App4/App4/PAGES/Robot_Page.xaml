            <!-- ROBOT MODÜL KONTROL VE PLC KOMUTLARI -->
            <!-- ═══════════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="5" Background="#1A1A1C" CornerRadius="12" BorderThickness="2" BorderBrush="#333333" Padding="0" Margin="20,0,20,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#252526" CornerRadius="10,10,0,0" Padding="12,0" BorderThickness="0,0,0,2" BorderBrush="#333333">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <FontIcon Glyph="&#xE8EE;" Foreground="#0078D4" FontSize="18"/>
                            <TextBlock Text="ROBOT MODÜL KONTROL" FontSize="12" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Gocator Ofset Tabanlı Hareket" FontSize="10" Foreground="#0078D4" Margin="8,0,0,0"/>
