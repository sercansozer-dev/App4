<Page
    x:Class="App4.PAGES.Trend_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App4.PAGES"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0D0D0D"
    Loaded="Page_Loaded">

    <Page.Resources>
        <local:ResultBackgroundConverter x:Key="ResultBgConverter"/>
        <local:ResultForegroundConverter x:Key="ResultFgConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- BASLIK -->
        <Border Grid.Row="0" Background="#161616" Padding="20,14" BorderBrush="#222" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE9D2;" FontSize="22" Foreground="#00A4EF"/>
                    <TextBlock Text="TREND ve RAPORLAMA" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <Border Background="#1E1E1E" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtRecordCount" Text="0 kayit" FontSize="11" Foreground="Gray"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnExport" Click="BtnExport_Click" Background="#1E6F3E" Foreground="White"
                            CornerRadius="6" Padding="12,6" FontSize="12">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xEDE1;" FontSize="14"/>
                            <TextBlock Text="CSV Disa Aktar"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnPrint" Click="BtnPrint_Click" Background="#2D2D2D" Foreground="White"
                            CornerRadius="6" Padding="12,6" FontSize="12">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE749;" FontSize="14"/>
                            <TextBlock Text="Yazdir"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnLeakLibrary" Click="BtnLeakLibrary_Click" Background="#1E2A38" BorderBrush="#00A4EF" BorderThickness="1" Foreground="White"
                            CornerRadius="6" Padding="12,6" FontSize="12" ToolTipService.ToolTip="16 tip için nokta→INT eşlemesini önceden ayarla">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8F1;" FontSize="14" Foreground="#00A4EF"/>
                            <TextBlock Text="Nokta Kütüphanesi" Foreground="#00A4EF"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnClearTrend" Click="BtnClearTrend_Click" Background="#3A1212" BorderBrush="#E74C3C" BorderThickness="1" Foreground="White"
                            CornerRadius="6" Padding="12,6" FontSize="12" ToolTipService.ToolTip="Tüm trend üretim kayıtlarını siler (geri alınamaz)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#E74C3C"/>
                            <TextBlock Text="Kayıtları Temizle" Foreground="#E74C3C"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- FILTRELER -->
        <Border Grid.Row="1" Background="#1A1A1A" Padding="16,12" BorderBrush="#222" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <StackPanel Spacing="2">
                    <TextBlock Text="Baslangic" FontSize="10" Foreground="Gray"/>
                    <CalendarDatePicker x:Name="DpStart" DateChanged="Filter_Changed"
                                        PlaceholderText="Baslangic" Width="150" RequestedTheme="Dark"/>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="Bitis" FontSize="10" Foreground="Gray"/>
                    <CalendarDatePicker x:Name="DpEnd" DateChanged="Filter_Changed"
                                        PlaceholderText="Bitis" Width="150" RequestedTheme="Dark"/>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="Istasyon" FontSize="10" Foreground="Gray"/>
                    <ComboBox x:Name="CmbStation" SelectionChanged="Filter_Changed" Width="140"
                              RequestedTheme="Dark" SelectedIndex="0">
                        <ComboBoxItem Content="Tumu" Tag="0"/>
                        <ComboBoxItem Content="ISTASYON 1" Tag="1"/>
                        <ComboBoxItem Content="ISTASYON 2" Tag="2"/>
                        <ComboBoxItem Content="ISTASYON 3" Tag="3"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="Sonuc" FontSize="10" Foreground="Gray"/>
                    <ComboBox x:Name="CmbResult" SelectionChanged="Filter_Changed" Width="120"
                              RequestedTheme="Dark" SelectedIndex="0">
                        <ComboBoxItem Content="Tumu"/>
                        <ComboBoxItem Content="OK"/>
                        <ComboBoxItem Content="NOK"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="RFID" FontSize="10" Foreground="Gray"/>
                    <TextBox x:Name="TxtRfidFilter" PlaceholderText="RFID filtre..." Width="140"
                             RequestedTheme="Dark" TextChanged="TxtRfidFilter_TextChanged"/>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="Hizli" FontSize="10" Foreground="Gray"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Content="Bugun" Click="QuickFilter_Click" Tag="today"
                                Background="#2D2D2D" Foreground="White" CornerRadius="4" Padding="10,5" FontSize="11"/>
                        <Button Content="Bu Hafta" Click="QuickFilter_Click" Tag="week"
                                Background="#2D2D2D" Foreground="White" CornerRadius="4" Padding="10,5" FontSize="11"/>
                        <Button Content="Bu Ay" Click="QuickFilter_Click" Tag="month"
                                Background="#2D2D2D" Foreground="White" CornerRadius="4" Padding="10,5" FontSize="11"/>
                        <Button Content="12 Ay" Click="QuickFilter_Click" Tag="year"
                                Background="#2D2D2D" Foreground="White" CornerRadius="4" Padding="10,5" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ISTATISTIK KARTLARI -->
        <Border Grid.Row="2" Background="#111" Padding="16,10" BorderBrush="#222" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1A1A2E" CornerRadius="8" Padding="14,10" Margin="4">
                    <StackPanel>
                        <TextBlock Text="TOPLAM" FontSize="9" Foreground="Gray" FontWeight="Bold"/>
                        <TextBlock x:Name="StatTotal" Text="0" FontSize="26" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="test kaydi" FontSize="10" Foreground="#666"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#0D2818" CornerRadius="8" Padding="14,10" Margin="4">
                    <StackPanel>
                        <TextBlock Text="OK" FontSize="9" Foreground="#4CAF50" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="StatOk" Text="0" FontSize="26" FontWeight="Bold" Foreground="#4CAF50"/>
                            <TextBlock x:Name="StatOkPct" Text="(%0)" FontSize="12" Foreground="#4CAF50" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                        </StackPanel>
                        <TextBlock Text="basarili" FontSize="10" Foreground="#666"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#2D0A0A" CornerRadius="8" Padding="14,10" Margin="4">
                    <StackPanel>
                        <TextBlock Text="NOK" FontSize="9" Foreground="#E74C3C" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="StatNok" Text="0" FontSize="26" FontWeight="Bold" Foreground="#E74C3C"/>
                            <TextBlock x:Name="StatNokPct" Text="(%0)" FontSize="12" Foreground="#E74C3C" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                        </StackPanel>
                        <TextBlock Text="basarisiz" FontSize="10" Foreground="#666"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="#1A1A2E" CornerRadius="8" Padding="14,10" Margin="4">
                    <StackPanel>
                        <TextBlock Text="ORT. SURE" FontSize="9" Foreground="Gray" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock x:Name="StatAvgTime" Text="0" FontSize="26" FontWeight="Bold" Foreground="#00A4EF"/>
                            <TextBlock Text="sn" FontSize="12" Foreground="#00A4EF" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                        </StackPanel>
                        <TextBlock Text="cevrim suresi" FontSize="10" Foreground="#666"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Background="#2D1F0A" CornerRadius="8" Padding="14,10" Margin="4">
                    <StackPanel>
                        <TextBlock Text="NOK NOKTALAR" FontSize="9" Foreground="#F39C12" FontWeight="Bold"/>
                        <TextBlock x:Name="StatNokPoints" Text="0" FontSize="26" FontWeight="Bold" Foreground="#F39C12"/>
                        <TextBlock Text="toplam hatali nokta" FontSize="10" Foreground="#666"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="5" Background="#1A1A2E" CornerRadius="8" Padding="14,10" Margin="4">
                    <StackPanel>
                        <TextBlock Text="ORT. OFFSET" FontSize="9" Foreground="Gray" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock x:Name="StatOffsetX" Text="X:0" FontSize="11" Foreground="#00A4EF"/>
                            <TextBlock x:Name="StatOffsetY" Text="Y:0" FontSize="11" Foreground="#4CAF50"/>
                            <TextBlock x:Name="StatOffsetZ" Text="Z:0" FontSize="11" Foreground="#F39C12"/>
                        </StackPanel>
                        <TextBlock Text="mm sapma" FontSize="10" Foreground="#666"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- RFID BAZINDA DETAYLI RAPOR (her zaman görünür — popup yok) -->
        <Border Grid.Row="3" Background="#141414" Padding="12,8" BorderBrush="#222" BorderThickness="0,0,0,1">
            <Expander IsExpanded="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                      Background="#161616" BorderBrush="#2A2A2A" CornerRadius="8">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE8FD;" FontSize="14" Foreground="#BA68C8"/>
                        <TextBlock Text="RFID BAZINDA DETAYLI RAPOR" FontSize="12" FontWeight="Bold" Foreground="#BA68C8" VerticalAlignment="Center"/>
                        <Border Background="#241A2E" CornerRadius="4" Padding="8,2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock x:Name="StatProductCount" Text="0" FontSize="12" FontWeight="Bold" Foreground="#BA68C8"/>
                                <TextBlock Text="çeşit" FontSize="11" Foreground="#9E7BB5"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Expander.Header>
                <Grid Margin="0,6,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- SOL: RFID bazında üretim kırılımı -->
                    <Border Grid.Column="0" Background="#111" CornerRadius="8" Padding="10,8" Margin="0,0,6,0" BorderBrush="#222" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <TextBlock Text="RFID BAZINDA ÜRETİM (filtrelenen gruba göre)" FontSize="10" FontWeight="Bold" Foreground="#888"/>
                            <ScrollViewer MaxHeight="210" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="ProductBreakdownPanel" Spacing="2"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                    <!-- SAĞ: En sık kaçak noktalar -->
                    <Border Grid.Column="1" Background="#111" CornerRadius="8" Padding="10,8" Margin="6,0,0,0" BorderBrush="#222" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE7BA;" FontSize="12" Foreground="#E74C3C"/>
                                <TextBlock Text="EN SIK KAÇAK NOKTALAR" FontSize="10" FontWeight="Bold" Foreground="#E74C3C" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ScrollViewer MaxHeight="210" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="TopNgPointsPanel" Spacing="2"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                    <!-- ALT: Model bazında tespit edilen kaçak noktaları (R1/R2 + adet) -->
                    <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#111" CornerRadius="8" Padding="10,8" Margin="0,8,0,0" BorderBrush="#222" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE9D2;" FontSize="12" Foreground="#F39C12"/>
                                <TextBlock Text="MODEL BAZINDA TESPİT EDİLEN KAÇAK NOKTALARI" FontSize="10" FontWeight="Bold" Foreground="#F39C12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="ModelNgBreakdownPanel" Spacing="3"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>
            </Expander>
        </Border>

        <!-- ANA VERI TABLOSU -->
        <Border Grid.Row="4" Margin="10" Background="#161616" CornerRadius="10" BorderBrush="#252525" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="10,10,0,0" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" FontSize="10" Foreground="#E67E22" FontWeight="Bold" HorizontalTextAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="TARIH / SAAT" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="SONUC" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="ISTASYON" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                        <TextBlock Grid.Column="4" Text="RFID" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                        <TextBlock Grid.Column="5" Text="URUN" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                        <TextBlock Grid.Column="6" Text="OK" FontSize="10" Foreground="#4CAF50" FontWeight="Bold" HorizontalTextAlignment="Center"/>
                        <TextBlock Grid.Column="7" Text="NOK" FontSize="10" Foreground="#E74C3C" FontWeight="Bold" HorizontalTextAlignment="Center"/>
                        <TextBlock Grid.Column="8" Text="BASARI" FontSize="10" Foreground="Gray" FontWeight="Bold" HorizontalTextAlignment="Center"/>
                        <TextBlock Grid.Column="9" Text="OFS X" FontSize="10" Foreground="Gray" FontWeight="Bold" HorizontalTextAlignment="Center"/>
                        <TextBlock Grid.Column="10" Text="OFS Y" FontSize="10" Foreground="Gray" FontWeight="Bold" HorizontalTextAlignment="Center"/>
                        <TextBlock Grid.Column="11" Text="OFS Z" FontSize="10" Foreground="Gray" FontWeight="Bold" HorizontalTextAlignment="Center"/>
                        <TextBlock Grid.Column="12" Text="SURE" FontSize="10" Foreground="Gray" FontWeight="Bold" HorizontalTextAlignment="Center"/>
                        <TextBlock Grid.Column="13" Text="SİL" FontSize="10" Foreground="Gray" FontWeight="Bold" HorizontalTextAlignment="Center"/>
                    </Grid>
                </Border>

                <ListView x:Name="TrendListView" Grid.Row="1"
                          SelectionMode="Single" IsItemClickEnabled="True" ItemClick="TrendListView_ItemClick"
                          Background="Transparent">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,6" Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="45"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding SiraNo}" FontSize="12" FontWeight="Bold" Foreground="#E67E22" VerticalAlignment="Center" HorizontalTextAlignment="Center"/>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding DateStr}" FontSize="11" Foreground="White"/>
                                    <TextBlock Text="{Binding TimeStr}" FontSize="10" Foreground="Gray"/>
                                </StackPanel>

                                <Border Grid.Column="2" CornerRadius="4" Padding="8,2" HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Background="{Binding OverallResult, Converter={StaticResource ResultBgConverter}}">
                                    <TextBlock Text="{Binding OverallResult}" FontSize="11" FontWeight="Bold"
                                               Foreground="{Binding OverallResult, Converter={StaticResource ResultFgConverter}}"/>
                                </Border>

                                <TextBlock Grid.Column="3" Text="{Binding StationName}" FontSize="11" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{Binding RfidTag}" FontSize="11" Foreground="#00A4EF" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="{Binding ProductName}" FontSize="11" Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="6" Text="{Binding OkCount}" FontSize="11" Foreground="#4CAF50" VerticalAlignment="Center" HorizontalTextAlignment="Center"/>
                                <Grid Grid.Column="7" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <!-- OK ürün: düz sayı -->
                                    <TextBlock Text="{Binding NokCount}" Visibility="{Binding NokTextVisibility}" FontSize="11" Foreground="#E74C3C" HorizontalTextAlignment="Center"/>
                                    <!-- NG ürün: tıklanınca kaçak noktaları popup'ı -->
                                    <Button Visibility="{Binding NgButtonVisibility}" Background="#3A1212" BorderBrush="#E74C3C" BorderThickness="1"
                                            CornerRadius="4" Padding="6,1" MinWidth="0" MinHeight="0"
                                            ToolTipService.ToolTip="Kaçak tespit noktalarını göster">
                                        <TextBlock Text="{Binding NgPointsCountText}" FontSize="10" FontWeight="Bold" Foreground="#E74C3C"/>
                                        <Button.Flyout>
                                            <Flyout>
                                                <StackPanel MinWidth="200" Spacing="8">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="#E74C3C"/>
                                                        <TextBlock Text="KAÇAK TESPİT NOKTALARI" FontSize="11" FontWeight="Bold" Foreground="#E74C3C" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <!-- ROBOT 1 -->
                                                    <StackPanel Spacing="3">
                                                        <TextBlock Text="ROBOT 1" FontSize="10" FontWeight="Bold" Foreground="#00A4EF"/>
                                                        <Border Background="#101A2A" CornerRadius="4" Padding="10,6" BorderBrush="#00A4EF" BorderThickness="1">
                                                            <TextBlock Text="{Binding NgPointsR1Text}" FontSize="14" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <!-- ROBOT 2 -->
                                                    <StackPanel Spacing="3">
                                                        <TextBlock Text="ROBOT 2" FontSize="10" FontWeight="Bold" Foreground="#FF9800"/>
                                                        <Border Background="#2A1F10" CornerRadius="4" Padding="10,6" BorderBrush="#FF9800" BorderThickness="1">
                                                            <TextBlock Text="{Binding NgPointsR2Text}" FontSize="14" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="NG olarak işaretlenen nokta numaraları" FontSize="9" Foreground="Gray"/>
                                                </StackPanel>
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>
                                </Grid>
                                <TextBlock Grid.Column="8" Text="{Binding SuccessRate}" FontSize="11" Foreground="White" VerticalAlignment="Center" HorizontalTextAlignment="Center"/>
                                <TextBlock Grid.Column="9" Text="{Binding OffsetX}" FontSize="10" Foreground="Gray" VerticalAlignment="Center" HorizontalTextAlignment="Center"/>
                                <TextBlock Grid.Column="10" Text="{Binding OffsetY}" FontSize="10" Foreground="Gray" VerticalAlignment="Center" HorizontalTextAlignment="Center"/>
                                <TextBlock Grid.Column="11" Text="{Binding OffsetZ}" FontSize="10" Foreground="Gray" VerticalAlignment="Center" HorizontalTextAlignment="Center"/>
                                <TextBlock Grid.Column="12" Text="{Binding CycleTime}" FontSize="10" Foreground="Gray" VerticalAlignment="Center" HorizontalTextAlignment="Center"/>
                                <Button Grid.Column="13" Click="DeleteTrendRecord_Click" Tag="{Binding}"
                                        Background="Transparent" BorderThickness="0" Padding="2"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        ToolTipService.ToolTip="Bu kaydı sil (yanlış/manuel veri)">
                                    <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="#FF5252"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel x:Name="EmptyState" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed" Spacing="8">
                    <FontIcon Glyph="&#xE9D2;" FontSize="48" Foreground="#333"/>
                    <TextBlock Text="Kayit Bulunamadi" FontSize="14" Foreground="#555" HorizontalAlignment="Center"/>
                    <TextBlock Text="Filtreleri degistirin veya farkli tarih araligi secin" FontSize="11" Foreground="#444" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ALT BAR -->
        <Border Grid.Row="5" Background="#161616" Padding="16,8" BorderBrush="#222" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <TextBlock x:Name="TxtStatusInfo" Text="Hazir" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtDateRange" Text="" FontSize="11" Foreground="#555" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <TextBlock x:Name="TxtStorageInfo" Text="" FontSize="10" Foreground="#444" VerticalAlignment="Center"/>
                    <Button Content="Yenile" Click="BtnRefresh_Click" Background="#2D2D2D" Foreground="White"
                            CornerRadius="4" Padding="10,4" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════ KAÇAK HARİTASI OVERLAY (seçili ürünün kaçak noktaları) ═══════════ -->
        <Border x:Name="LeakMapOverlay" Grid.RowSpan="6" Background="#D8000000" Visibility="Collapsed"
                Tapped="LeakMapOverlay_Tapped">
            <Border Background="#161616" CornerRadius="14" BorderBrush="#333" BorderThickness="1"
                    MaxWidth="1850" MaxHeight="1060" Margin="16" Tapped="LeakMapCard_Tapped">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Başlık -->
                    <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="14,14,0,0" Padding="18,12" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE707;" FontSize="18" Foreground="#00A4EF"/>
                                <TextBlock Text="KAÇAK HARİTASI" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                <Border x:Name="LeakMapResultBadge" Background="#2D0A0A" CornerRadius="4" Padding="10,3" VerticalAlignment="Center">
                                    <TextBlock x:Name="LeakMapResult" Text="NOK" FontSize="12" FontWeight="Bold" Foreground="#E74C3C"/>
                                </Border>
                                <TextBlock x:Name="LeakMapSubTitle" Text="" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <Button Click="ToggleLeakEdit_Click" Background="#1E2A38" BorderBrush="#00A4EF" BorderThickness="1" Padding="10,5" CornerRadius="6"
                                        ToolTipService.ToolTip="Her noktaya robottan gelen INT değerini ata">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon x:Name="LeakEditBtnIcon" Glyph="&#xE70F;" FontSize="13" Foreground="#00A4EF"/>
                                        <TextBlock x:Name="LeakEditBtnText" Text="INT Düzenle" FontSize="12" Foreground="#00A4EF"/>
                                    </StackPanel>
                                </Button>
                                <Button Click="CloseLeakMap_Click" Background="Transparent" BorderThickness="0" Padding="8" CornerRadius="6">
                                    <FontIcon Glyph="&#xE711;" FontSize="15" Foreground="#BBB"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- İçerik: sol = diyagram, sağ = bilgi + lejant -->
                    <Grid Grid.Row="1" Padding="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="320"/>
                        </Grid.ColumnDefinitions>

                        <!-- Diyagram parçaları — eşit kolonlara bölünür, hepsi ekrana sığar -->
                        <Border Grid.Column="0" Background="#0D0D0D" CornerRadius="10" Padding="8" BorderBrush="#222" BorderThickness="1">
                            <Grid x:Name="LeakPartsGrid"/>
                        </Border>

                        <!-- Bilgi + lejant -->
                        <Grid Grid.Column="1" Margin="14,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#111" CornerRadius="10" Padding="12" BorderBrush="#222" BorderThickness="1">
                                <StackPanel x:Name="LeakMapInfoPanel" Spacing="4"/>
                            </Border>

                            <!-- Lejant açıklama -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16" Margin="2,10,0,8">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="13" Height="13" Stroke="#4CAF50" StrokeThickness="3" Fill="#1A2E1A"/>
                                    <TextBlock Text="OK nokta" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="13" Height="13" Stroke="#E74C3C" StrokeThickness="3" Fill="#2D0A0A"/>
                                    <TextBlock Text="KAÇAK" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Nokta listesi -->
                            <Border Grid.Row="2" Background="#111" CornerRadius="10" Padding="10" BorderBrush="#222" BorderThickness="1">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="LeakPointLegendPanel" Spacing="3"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Page>
