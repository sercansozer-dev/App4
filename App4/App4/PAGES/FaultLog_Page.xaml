<Page
    x:Class="App4.PAGES.FaultLog_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App4.PAGES"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0D0D0D"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- BAŞLIK -->
        <Border Grid.Row="0" Background="#161616" Padding="20,14" BorderBrush="#222" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE7BA;" FontSize="22" Foreground="#E74C3C"/>
                    <TextBlock Text="ALARM KAYITLARI" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <Border Background="#1E1E1E" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtRecordCount" Text="0 kayıt" FontSize="11" Foreground="Gray"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Click="BtnRefresh_Click" Background="#2D2D2D" Foreground="White" CornerRadius="6" Padding="12,6" FontSize="12">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                            <TextBlock Text="Yenile"/>
                        </StackPanel>
                    </Button>
                    <Button Click="BtnExport_Click" Background="#1E6F3E" Foreground="White" CornerRadius="6" Padding="12,6" FontSize="12">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xEDE1;" FontSize="14"/>
                            <TextBlock Text="CSV Dışa Aktar"/>
                        </StackPanel>
                    </Button>
                    <Button Click="BtnClear_Click" Background="#3A1212" BorderBrush="#E74C3C" BorderThickness="1" Foreground="White"
                            CornerRadius="6" Padding="12,6" FontSize="12" ToolTipService.ToolTip="Tüm arıza kayıtlarını siler (geri alınamaz)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#E74C3C"/>
                            <TextBlock Text="Kayıtları Temizle" Foreground="#E74C3C"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- FİLTRELER -->
        <Border Grid.Row="1" Background="#1A1A1A" Padding="16,12" BorderBrush="#222" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <StackPanel Spacing="2">
                    <TextBlock Text="Başlangıç" FontSize="10" Foreground="Gray"/>
                    <CalendarDatePicker x:Name="DpStart" DateChanged="Filter_Changed" PlaceholderText="Başlangıç" Width="150" RequestedTheme="Dark"/>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="Bitiş" FontSize="10" Foreground="Gray"/>
                    <CalendarDatePicker x:Name="DpEnd" DateChanged="Filter_Changed" PlaceholderText="Bitiş" Width="150" RequestedTheme="Dark"/>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="Kaynak" FontSize="10" Foreground="Gray"/>
                    <ComboBox x:Name="CmbKaynak" SelectionChanged="Filter_Changed" Width="120" RequestedTheme="Dark" SelectedIndex="0">
                        <ComboBoxItem Content="Tümü"/>
                        <ComboBoxItem Content="R1"/>
                        <ComboBoxItem Content="R2"/>
                        <ComboBoxItem Content="PLC"/>
                        <ComboBoxItem Content="Sistem"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="Önem" FontSize="10" Foreground="Gray"/>
                    <ComboBox x:Name="CmbSeverity" SelectionChanged="Filter_Changed" Width="120" RequestedTheme="Dark" SelectedIndex="0">
                        <ComboBoxItem Content="Tümü"/>
                        <ComboBoxItem Content="Arıza"/>
                        <ComboBoxItem Content="Uyarı"/>
                        <ComboBoxItem Content="Bilgi"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="Durum" FontSize="10" Foreground="Gray"/>
                    <ComboBox x:Name="CmbDurum" SelectionChanged="Filter_Changed" Width="120" RequestedTheme="Dark" SelectedIndex="0">
                        <ComboBoxItem Content="Tümü"/>
                        <ComboBoxItem Content="Aktif"/>
                        <ComboBoxItem Content="Geçmiş"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="Hızlı" FontSize="10" Foreground="Gray"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Content="Bugün" Click="QuickFilter_Click" Tag="today" Background="#2D2D2D" Foreground="White" CornerRadius="4" Padding="10,5" FontSize="11"/>
                        <Button Content="Bu Hafta" Click="QuickFilter_Click" Tag="week" Background="#2D2D2D" Foreground="White" CornerRadius="4" Padding="10,5" FontSize="11"/>
                        <Button Content="Bu Ay" Click="QuickFilter_Click" Tag="month" Background="#2D2D2D" Foreground="White" CornerRadius="4" Padding="10,5" FontSize="11"/>
                        <Button Content="12 Ay" Click="QuickFilter_Click" Tag="year" Background="#2D2D2D" Foreground="White" CornerRadius="4" Padding="10,5" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ADMİN: PLC INPUT → ALARM EŞLEŞTİRME (yalnız admin görür/düzenler) -->
        <Expander x:Name="AlarmDefPanel" Grid.Row="2" Margin="10,6,10,0" HorizontalAlignment="Stretch"
                  Background="#141414" BorderBrush="#2A2A2A" BorderThickness="1" Visibility="Collapsed"
                  HorizontalContentAlignment="Stretch">
            <Expander.Header>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE713;" FontSize="16" Foreground="#00A4EF"/>
                    <TextBlock Text="SİNYAL EŞLEŞTİRME TABLOSU" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <Border Background="#1E2A38" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                        <TextBlock Text="Admin" FontSize="10" Foreground="#00A4EF"/>
                    </Border>
                </StackPanel>
            </Expander.Header>
            <StackPanel Spacing="10" Margin="4,8,4,8">
                <!-- Yeni tanım ekleme formu -->
                <Border Background="#1A1A1A" CornerRadius="8" Padding="12" BorderBrush="#222" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom">
                        <StackPanel Spacing="2">
                            <TextBlock Text="PLC Input" FontSize="10" Foreground="Gray"/>
                            <ComboBox x:Name="CmbNewInput" Width="200" RequestedTheme="Dark" PlaceholderText="Input seç..."/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Tetik" FontSize="10" Foreground="Gray"/>
                            <ComboBox x:Name="CmbNewTrigger" Width="160" RequestedTheme="Dark" SelectedIndex="0">
                                <ComboBoxItem Content="ON (1) → Alarm"/>
                                <ComboBoxItem Content="OFF (0) → Alarm"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Mesaj" FontSize="10" Foreground="Gray"/>
                            <TextBox x:Name="TxtNewMsg" Width="220" RequestedTheme="Dark" PlaceholderText="Alarm mesajı..."/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Önem" FontSize="10" Foreground="Gray"/>
                            <ComboBox x:Name="CmbNewSeverity" Width="110" RequestedTheme="Dark" SelectedIndex="0">
                                <ComboBoxItem Content="Arıza"/>
                                <ComboBoxItem Content="Uyarı"/>
                                <ComboBoxItem Content="Bilgi"/>
                            </ComboBox>
                        </StackPanel>
                        <Button Click="BtnAddAlarmDef_Click" Background="#1E6F3E" Foreground="White" CornerRadius="6" Padding="14,8" VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE710;" FontSize="14"/>
                                <TextBlock Text="Ekle"/>
                            </StackPanel>
                        </Button>
                        <Button Click="BtnRefreshInputs_Click" Background="#2D2D2D" Foreground="White" CornerRadius="6" Padding="12,8" VerticalAlignment="Bottom" ToolTipService.ToolTip="PLC input listesini yenile">
                            <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Tanım listesi başlık -->
                <Grid Padding="12,4,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="190"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="PLC INPUT" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="TETİK" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                    <TextBlock Grid.Column="2" Text="MESAJ" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                    <TextBlock Grid.Column="3" Text="ÖNEM" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                    <TextBlock Grid.Column="4" Text="AKTİF" FontSize="10" Foreground="Gray" FontWeight="Bold" HorizontalTextAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="SİL" FontSize="10" Foreground="Gray" FontWeight="Bold" HorizontalTextAlignment="Center"/>
                </Grid>

                <ItemsControl x:Name="AlarmDefList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,4" Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding PlcInputName}" FontSize="12" Foreground="#00A4EF" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <ComboBox Grid.Column="1" Width="175" RequestedTheme="Dark" SelectedIndex="{Binding TetikIndex, Mode=TwoWay}" SelectionChanged="AlarmDef_Changed">
                                    <ComboBoxItem Content="ON (1) → Alarm"/>
                                    <ComboBoxItem Content="OFF (0) → Alarm"/>
                                </ComboBox>
                                <TextBox Grid.Column="2" Margin="0,0,8,0" RequestedTheme="Dark" Text="{Binding Mesaj, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" LostFocus="AlarmDef_Changed"/>
                                <ComboBox Grid.Column="3" Width="105" RequestedTheme="Dark" SelectedIndex="{Binding SeverityIndex, Mode=TwoWay}" SelectionChanged="AlarmDef_Changed">
                                    <ComboBoxItem Content="Arıza"/>
                                    <ComboBoxItem Content="Uyarı"/>
                                    <ComboBoxItem Content="Bilgi"/>
                                </ComboBox>
                                <ToggleSwitch Grid.Column="4" IsOn="{Binding Enabled, Mode=TwoWay}" OnContent="" OffContent="" MinWidth="0" HorizontalAlignment="Center" Toggled="AlarmDef_Changed"/>
                                <Button Grid.Column="5" Click="DeleteAlarmDef_Click" Tag="{Binding}" Background="Transparent" BorderThickness="0" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTipService.ToolTip="Tanımı sil">
                                    <FontIcon Glyph="&#xE74D;" FontSize="13" Foreground="#E74C3C"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Expander>

        <!-- TABLO -->
        <Border Grid.Row="3" Margin="10" Background="#161616" CornerRadius="10" BorderBrush="#252525" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="10,10,0,0" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" FontSize="10" Foreground="#E67E22" FontWeight="Bold" HorizontalTextAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="TARİH / SAAT" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="KAYNAK" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="KOD" FontSize="10" Foreground="Gray" FontWeight="Bold" HorizontalTextAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="MESAJ" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                        <TextBlock Grid.Column="5" Text="ÖNEM" FontSize="10" Foreground="Gray" FontWeight="Bold" HorizontalTextAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="DURUM" FontSize="10" Foreground="Gray" FontWeight="Bold" HorizontalTextAlignment="Center"/>
                        <TextBlock Grid.Column="7" Text="SÜRE" FontSize="10" Foreground="Gray" FontWeight="Bold" HorizontalTextAlignment="Center"/>
                        <TextBlock Grid.Column="8" Text="SİL" FontSize="10" Foreground="Gray" FontWeight="Bold" HorizontalTextAlignment="Center"/>
                    </Grid>
                </Border>

                <ListView x:Name="FaultListView" Grid.Row="1" SelectionMode="None" Background="Transparent">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,6" Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="45"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding SiraNo}" FontSize="12" FontWeight="Bold" Foreground="#E67E22" VerticalAlignment="Center" HorizontalTextAlignment="Center"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DateStr}" FontSize="11" Foreground="White"/>
                                    <TextBlock Text="{Binding TimeStr}" FontSize="10" Foreground="Gray"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{Binding Kaynak}" FontSize="11" FontWeight="Bold" Foreground="#00A4EF" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding KodStr}" FontSize="11" Foreground="White" VerticalAlignment="Center" HorizontalTextAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{Binding Mesaj}" FontSize="11" Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                                <Border Grid.Column="5" CornerRadius="4" Padding="8,2" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#1E1E1E">
                                    <TextBlock Text="{Binding Severity}" FontSize="11" FontWeight="Bold" Foreground="{Binding SeverityBrush}"/>
                                </Border>

                                <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DurumIcon}" FontSize="11"/>
                                    <TextBlock Text="{Binding DurumStr}" FontSize="11" Foreground="White"/>
                                </StackPanel>

                                <TextBlock Grid.Column="7" Text="{Binding SureStr}" FontSize="11" Foreground="#DDDDDD" VerticalAlignment="Center" HorizontalTextAlignment="Center"/>

                                <Button Grid.Column="8" Click="DeleteRow_Click" Tag="{Binding}" Background="Transparent" BorderThickness="0"
                                        Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTipService.ToolTip="Bu kaydı sil">
                                    <FontIcon Glyph="&#xE74D;" FontSize="13" Foreground="#E74C3C"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel x:Name="EmptyState" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8" Visibility="Collapsed">
                    <FontIcon Glyph="&#xE73E;" FontSize="40" Foreground="#2E7D32"/>
                    <TextBlock Text="Seçilen aralıkta arıza kaydı yok" FontSize="14" Foreground="Gray"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ALT BİLGİ -->
        <Border Grid.Row="4" Background="#161616" Padding="16,8" BorderBrush="#222" BorderThickness="0,1,0,0">
            <TextBlock x:Name="TxtStatusInfo" Text="" FontSize="11" Foreground="Gray"/>
        </Border>
    </Grid>
</Page>
