<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App4.Pages.Recipes_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0D0D0D"
    Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1A1A1C" BorderThickness="0,0,0,1" BorderBrush="#333">
            <Grid Padding="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                    <Border Background="#4CAF50" CornerRadius="8" Width="40" Height="40">
                        <FontIcon Glyph="&#xE8A5;" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Reçete Yönetimi" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Model Konfigürasyonu ve Test Noktaları" FontSize="11" Foreground="#888"/>
                    </StackPanel>
                    <Border Background="#1E1E20" CornerRadius="6" Padding="12,6" Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="RecipeCountLabel" Text="0 Reçete" FontSize="11" Foreground="#888"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- İÇERİK -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sol Panel -->
            <Border Grid.Column="0" Background="#151515" BorderThickness="0,0,1,0" BorderBrush="#333">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1E1E20" Padding="15,0">
                        <TextBlock Text="KAYITLI REÇETELER" FontSize="11" FontWeight="SemiBold" Foreground="#888" VerticalAlignment="Center"/>
                    </Border>

                    <ListView x:Name="RecipesList" Grid.Row="1" SelectionChanged="RecipesList_SelectionChanged" Padding="10">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E20" CornerRadius="6" Padding="12" Margin="0,4">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border Background="#252528" CornerRadius="6" Width="36" Height="36">
                                            <FontIcon Glyph="&#xE8A5;" Foreground="#4CAF50" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding RecipeName}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding LastModified}" Foreground="#666" FontSize="10"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Rectangle Grid.Row="2" Height="1" Fill="#333" Margin="10,5"/>

                    <Border Grid.Row="3" Background="#1E1E20" Padding="15,0">
                        <Grid>
                            <TextBlock Text="MODEL KÜTÜPHANESİ" FontSize="11" FontWeight="SemiBold" Foreground="#888" VerticalAlignment="Center"/>
                            <Button x:Name="BtnGlobalScan" Click="BtnBrowseFolder_Click" HorizontalAlignment="Right"
                                    Background="#333" Padding="10,6" CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xED25;" FontSize="12" Foreground="#888"/>
                                    <TextBlock Text="Tara" FontSize="11" Foreground="White"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <ListView x:Name="LibraryModelList" Grid.Row="4" Padding="10" SelectionChanged="LibraryModelList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E20" CornerRadius="6" Padding="10" Margin="0,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" CornerRadius="6" Background="#252528">
                                            <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding ModelName}" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        <Button Grid.Column="2" Click="BtnDeleteLibraryModel_Click" Background="Transparent" Padding="6">
                                            <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="#666"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button Grid.Row="5" Click="BtnNew_Click" HorizontalAlignment="Stretch" Margin="10,10,10,15" 
                            Background="#4CAF50" Foreground="White" CornerRadius="4" Height="40">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE710;" FontSize="12"/>
                            <TextBlock Text="Yeni Reçete"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Sağ Panel - Detaylar -->
            <ScrollViewer Grid.Column="1" Padding="25">
                <StackPanel x:Name="DetailPanel" Visibility="Collapsed" Spacing="20">

                    <!-- Başlık -->
                    <StackPanel Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                        <Border Background="#333" CornerRadius="6" Width="40" Height="40">
                            <FontIcon Glyph="&#xE70F;" FontSize="18" Foreground="#4CAF50" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Model Detayları" FontSize="18" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="#333"/>

                    <!-- Form Alanları -->
                    <Border Background="#1E1E20" CornerRadius="8" Padding="20">
                        <Grid RowSpacing="15" ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBox x:Name="TxtName" Header="Model Adı" PlaceholderText="Model adı girin" Background="#252528" BorderBrush="#333" Foreground="White" CornerRadius="4"/>
                            <NumberBox x:Name="NumPlcCode" Header="PLC Model Kodu" Grid.Column="1" SpinButtonPlacementMode="Inline"/>
                            <TextBox x:Name="TxtJob" Header="Gocator Job Dosyası" Grid.Row="1" Grid.Column="0" Background="#252528" BorderBrush="#333" Foreground="White" CornerRadius="4"/>
                            <TextBox x:Name="TxtStepPath" Header="Model Dosya Yolu" Grid.Row="1" Grid.Column="1" IsReadOnly="True" PlaceholderText="Kütüphaneden seçim yapın..." Background="#252528" BorderBrush="#333" Foreground="#888" CornerRadius="4"/>
                        </Grid>
                    </Border>

                    <!-- 3D Önizleme -->
                    <Grid Height="500" Background="#111" CornerRadius="8" BorderBrush="#333" BorderThickness="1">
                        <WebView2 x:Name="PreviewWebView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="15">
                            <Button x:Name="BtnTransfer" Click="BtnTransferPoints_Click" Background="#4CAF50" Margin="0,0,10,0" Padding="12,8" CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE72D;" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="Reçeteye Ekle" Foreground="White" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnShow" Click="BtnShowHidden_Click" Background="#333" Padding="12,8" CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE7B3;" FontSize="14" Foreground="#888"/>
                                    <TextBlock Text="Parçaları Göster" Foreground="White" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Border Background="#1E1E20" Padding="12,8" CornerRadius="4" Margin="10,0,0,0">
                                <TextBlock x:Name="TxtPreviewName" Text="Model Seçilmedi" Foreground="#888" FontSize="12"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Referans Noktaları -->
                    <Border Background="#1E1E20" CornerRadius="8" Padding="20">
                        <StackPanel Spacing="15">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="REFERANS NOKTALARI" FontSize="12" FontWeight="SemiBold" Foreground="#4CAF50"/>
                                    <TextBlock Text="CAD verisinden alınan test noktaları" FontSize="11" Foreground="#888" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Button Click="BtnOpen3DEditor_Click" HorizontalAlignment="Right" Background="#333" CornerRadius="4" Padding="12,8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE774;" FontSize="14" Foreground="#888"/>
                                        <TextBlock Text="3D Modelden Seç" Foreground="White" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <ListView x:Name="PointsList" Background="#252528" CornerRadius="6" Height="250" SelectionChanged="PointsList_SelectionChanged">
                                <ListView.Header>
                                    <Grid Padding="12" Background="#1A1A1C">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="0.6*"/>
                                            <ColumnDefinition Width="0.6*"/>
                                            <ColumnDefinition Width="0.6*"/>
                                            <ColumnDefinition Width="0.6*"/>
                                    <ColumnDefinition Width="0.6*"/>
                                    <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Ad" Foreground="#666" FontSize="10"/>
                            <TextBlock Grid.Column="1" Text="Tanım" Foreground="#666" FontSize="10"/>
                            <TextBlock Grid.Column="2" Text="X" Foreground="#666" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Y" Foreground="#666" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="Z" Foreground="#666" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="V%" Foreground="#666" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="Sn" Foreground="#666" FontSize="10" HorizontalAlignment="Center"/>
                        </Grid>
                    </ListView.Header>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="0.6*"/>
                                    <ColumnDefinition Width="0.6*"/>
                                    <ColumnDefinition Width="0.6*"/>
                                    <ColumnDefinition Width="0.6*"/>
                                    <ColumnDefinition Width="0.6*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding PointName, Mode=TwoWay}" Margin="2" FontSize="11" Background="#1E1E20" BorderBrush="#333"/>
                                <TextBox Grid.Column="1" Text="{Binding Description, Mode=TwoWay}" PlaceholderText="Tanım" Margin="2" FontSize="11" Background="#1E1E20" BorderBrush="#333"/>
                                <NumberBox Grid.Column="2" Value="{Binding RefX, Mode=TwoWay}" Margin="2" SmallChange="0.1" SpinButtonPlacementMode="Hidden"/>
                                <NumberBox Grid.Column="3" Value="{Binding RefY, Mode=TwoWay}" Margin="2" SmallChange="0.1" SpinButtonPlacementMode="Hidden"/>
                                <NumberBox Grid.Column="4" Value="{Binding RefZ, Mode=TwoWay}" Margin="2" SmallChange="0.1" SpinButtonPlacementMode="Hidden"/>
                                <NumberBox Grid.Column="5" Value="{Binding Speed, Mode=TwoWay}" Margin="2" SpinButtonPlacementMode="Hidden"/>
                                <NumberBox Grid.Column="6" Value="{Binding WaitTime, Mode=TwoWay}" Margin="2" SpinButtonPlacementMode="Hidden"/>
                                <Button Grid.Column="7" Click="BtnDeletePoint_Click" Background="Transparent" Padding="4">
                                    <FontIcon Glyph="&#xE74D;" FontSize="10" Foreground="#666"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                                                <Button Click="BtnAddPoint_Click" HorizontalAlignment="Left" Background="#333" CornerRadius="4" Padding="12,8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="#4CAF50"/>
                                                        <TextBlock Text="Nokta Ekle" Foreground="White"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Border>

                                        <!-- Kaydet Butonları -->
                                        <Border Background="#1E1E20" CornerRadius="8" Padding="15">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                                                <Button Click="BtnDelete_Click" Background="#333" CornerRadius="4" Padding="20,10">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#FF5252"/>
                                                        <TextBlock Text="Reçeteyi Sil" Foreground="#FF5252"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Click="BtnSave_Click" Background="#4CAF50" CornerRadius="4" Padding="25,10">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon Glyph="&#xE74E;" FontSize="14" Foreground="White"/>
                                                        <TextBlock Text="KAYDET" Foreground="White" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Border>

                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Page>