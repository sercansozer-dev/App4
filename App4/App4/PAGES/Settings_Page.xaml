<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App4.Settings_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App4"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0D0D0D">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1A1A1C" BorderThickness="0,0,0,1" BorderBrush="#333">
            <Grid Padding="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                    <Border Background="#9C27B0" CornerRadius="8" Width="40" Height="40">
                        <FontIcon Glyph="&#xE713;" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Ayarlar" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Sistem Yapılandırma ve Tercihler" FontSize="11" Foreground="#888"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock Text="v1.0.0" Foreground="#666" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- İÇERİK -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="20" Spacing="15" MaxWidth="800" HorizontalAlignment="Left">

                <!-- PLC Bağlantı -->
                <Border Background="#1E1E20" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Background="#4CAF50" CornerRadius="6" Width="36" Height="36">
                                <FontIcon Glyph="&#xE968;" Foreground="White" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="PLC Bağlantı Ayarları" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Rectangle Height="1" Fill="#333"/>

                        <Grid ColumnSpacing="20" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="250"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IP Adresi" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtPlcIp" PlaceholderText="192.168.251.100" Background="#252528" BorderBrush="#333" Foreground="White" CornerRadius="4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Port" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtPlcPort" PlaceholderText="5007" Background="#252528" BorderBrush="#333" Foreground="White" CornerRadius="4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Protokol" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Background="#252528" Foreground="White" CornerRadius="4" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Mitsubishi MC Protocol" IsSelected="True"/>
                                <ComboBoxItem Content="Modbus TCP"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Robot Ayarları -->
                <Border Background="#1E1E20" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Background="#0078D4" CornerRadius="6" Width="36" Height="36">
                                <FontIcon Glyph="&#xE99A;" Foreground="White" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Robot Ayarları" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Rectangle Height="1" Fill="#333"/>

                        <Grid ColumnSpacing="20" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="250"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Varsayılan Port" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtRobotPort" Background="#252528" BorderBrush="#333" Foreground="White" CornerRadius="4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Okuma Hızı (ms)" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            <Slider Grid.Row="1" Grid.Column="1" Minimum="50" Maximum="500" Value="100"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Kamera Ayarları -->
                <Border Background="#1E1E20" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Background="#9C27B0" CornerRadius="6" Width="36" Height="36">
                                <FontIcon Glyph="&#xE722;" Foreground="White" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Kamera (Gocator 3D) Ayarları" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Rectangle Height="1" Fill="#333"/>

                        <Grid ColumnSpacing="20" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="250"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Gocator IP" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtGocatorIp" PlaceholderText="192.168.251.30" Background="#252528" BorderBrush="#333" Foreground="White" CornerRadius="4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Control Port" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtGocatorPort" PlaceholderText="3600" Background="#252528" BorderBrush="#333" Foreground="White" CornerRadius="4"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Genel Ayarlar -->
                <Border Background="#1E1E20" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Background="#FF9800" CornerRadius="6" Width="36" Height="36">
                                <FontIcon Glyph="&#xE770;" Foreground="White" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Genel Ayarlar" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Rectangle Height="1" Fill="#333"/>

                        <Grid ColumnSpacing="20" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Bildirimler" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Row="0" Grid.Column="1" IsOn="True"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Log Kaydet" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Row="1" Grid.Column="1" IsOn="True"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Kaydet Butonları -->
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button x:Name="BtnResetDefaults" Click="BtnResetDefaults_Click" Content="Varsayılana Dön" Background="#333" Foreground="White" Padding="20,10" CornerRadius="4"/>
                    <Button x:Name="BtnSaveSettings" Click="BtnSaveSettings_Click" Content="Ayarları Kaydet" Background="#0078D4" Foreground="White" Padding="20,10" CornerRadius="4"/>
                </StackPanel>
                <TextBlock x:Name="TxtSaveStatus" Text="" Foreground="#4CAF50" FontSize="11"/>

                <!-- Ayar Yedekleme / İçe Aktarma -->
                <Border Background="#1E1E20" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Background="#00BCD4" CornerRadius="6" Width="36" Height="36">
                                <FontIcon Glyph="&#xE8F1;" Foreground="White" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Yapılandırma Yedekleme" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="Tüm ayarları yedekle ve başka bilgisayara aktar" FontSize="11" Foreground="#888"/>
                            </StackPanel>
                        </StackPanel>
                        <Rectangle Height="1" Fill="#333"/>

                        <TextBlock Text="PLC tag eşleşmeleri, otomasyon ayarları, reçeteler, robot konfigürasyonu ve transfer tablosu tek dosyada yedeklenir." 
                                   Foreground="#888" FontSize="11" TextWrapping="Wrap"/>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BtnExportConfig" Click="BtnExportConfig_Click" 
                                    HorizontalAlignment="Stretch" Padding="0,14" CornerRadius="4"
                                    Background="#00BCD4" Foreground="White">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE898;" FontSize="16"/>
                                    <TextBlock Text="Ayarları Dışa Aktar" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnImportConfig" Click="BtnImportConfig_Click" Grid.Column="1"
                                    HorizontalAlignment="Stretch" Padding="0,14" CornerRadius="4"
                                    Background="#FF9800" Foreground="White">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE896;" FontSize="16"/>
                                    <TextBlock Text="Ayarları İçe Aktar" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock x:Name="TxtConfigStatus" Text="" Foreground="#4CAF50" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
