<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App4.Settings_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App4"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0D0D0D">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1A1A1C" BorderThickness="0,0,0,1" BorderBrush="#333">
            <Grid Padding="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                    <Border Background="#9C27B0" CornerRadius="8" Width="40" Height="40">
                        <FontIcon Glyph="&#xE713;" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Ayarlar" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Sistem Yapılandırma ve Tercihler" FontSize="11" Foreground="#888"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock Text="v1.0.0" Foreground="#666" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- İÇERİK -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="20" Spacing="15" MaxWidth="800" HorizontalAlignment="Left">

                <!-- PLC Bağlantı -->
                <Border Background="#1E1E20" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Background="#4CAF50" CornerRadius="6" Width="36" Height="36">
                                <FontIcon Glyph="&#xE968;" Foreground="White" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="PLC Bağlantı Ayarları" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Rectangle Height="1" Fill="#333"/>

                        <Grid ColumnSpacing="20" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="250"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IP Adresi" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtPlcIp" PlaceholderText="192.168.251.100" Background="#252528" BorderBrush="#333" Foreground="White" CornerRadius="4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Port" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtPlcPort" PlaceholderText="5007" Background="#252528" BorderBrush="#333" Foreground="White" CornerRadius="4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Protokol" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Background="#252528" Foreground="White" CornerRadius="4" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Mitsubishi MC Protocol" IsSelected="True"/>
                                <ComboBoxItem Content="Modbus TCP"/>
                            </ComboBox>
                        </Grid>

                        <Rectangle Height="1" Fill="#333" Margin="0,5,0,0"/>
                        <TextBlock Text="Zamanlama" FontSize="11" Foreground="#4CAF50" FontWeight="SemiBold" Margin="0,5,0,0"/>

                        <Grid ColumnSpacing="10" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="PLC Okuma Hızı" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="SliderPlcReadInterval" Minimum="20" Maximum="500" StepFrequency="10" SnapsTo="StepValues" Value="50"
                                    ValueChanged="SliderPlcReadInterval_ValueChanged"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" x:Name="TxtPlcReadInterval" Text="50 ms" Foreground="#4CAF50" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Tüm PLC değişken okuma" Foreground="#555" FontSize="9" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Tetik İzleme Hızı" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Row="1" Grid.Column="1" x:Name="SliderTriggerMonitor" Minimum="200" Maximum="2000" StepFrequency="50" SnapsTo="StepValues" Value="500"
                                    ValueChanged="SliderTriggerMonitor_ValueChanged"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="TxtTriggerMonitor" Text="500 ms" Foreground="#4CAF50" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="Otomasyon trigger izleme" Foreground="#555" FontSize="9" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Robot Ayarları -->
                <Border Background="#1E1E20" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Background="#0078D4" CornerRadius="6" Width="36" Height="36">
                                <FontIcon Glyph="&#xE99A;" Foreground="White" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Robot Ayarları" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Rectangle Height="1" Fill="#333"/>

                        <Grid ColumnSpacing="20" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="250"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Varsayılan Port" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtRobotPort" Background="#252528" BorderBrush="#333" Foreground="White" CornerRadius="4"/>

                        </Grid>

                        <Rectangle Height="1" Fill="#333" Margin="0,5,0,0"/>
                        <TextBlock Text="Zamanlama" FontSize="11" Foreground="#0078D4" FontWeight="SemiBold" Margin="0,5,0,0"/>

                        <Grid ColumnSpacing="10" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Okuma Hızı" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="SliderRobotReadSpeed" Minimum="50" Maximum="500" StepFrequency="10" SnapsTo="StepValues" Value="100"
                                    ValueChanged="SliderRobotReadSpeed_ValueChanged"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" x:Name="TxtRobotReadSpeedValue" Text="100 ms" Foreground="#4CAF50" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="KUKA TCP loop hızı" Foreground="#555" FontSize="9" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="TCP Timeout" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Row="1" Grid.Column="1" x:Name="SliderRobotTcpTimeout" Minimum="1000" Maximum="30000" StepFrequency="500" SnapsTo="StepValues" Value="5000"
                                    ValueChanged="SliderRobotTcpTimeout_ValueChanged"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="TxtRobotTcpTimeout" Text="5000 ms" Foreground="#4CAF50" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="Bağlantı zaman aşımı" Foreground="#555" FontSize="9" VerticalAlignment="Center"/>
                        </Grid>

                        <Rectangle Height="1" Fill="#333" Margin="0,5,0,0"/>
                        <TextBlock Text="Öncelik Sistemi" FontSize="11" Foreground="#FF9800" FontWeight="SemiBold" Margin="0,5,0,0"/>
                        <Border Background="#1A1A1C" CornerRadius="4" Padding="10,8">
                            <StackPanel Spacing="4">
                                <TextBlock Foreground="#888" FontSize="9" TextWrapping="Wrap"
                                           Text="Yüksek: G_OLCUM_TETIK, G_ROBOT_HAZIR, G_IS_BITTI, G_HATA_VAR (3ms aralık)"/>
                                <TextBlock Foreground="#888" FontSize="9" TextWrapping="Wrap"
                                           Text="Otomatik: OLCUM/TETIK/TAMAM/SAPMA/NOKTA keyword → öncelikli"/>
                                <TextBlock Foreground="#888" FontSize="9" TextWrapping="Wrap"
                                           Text="Adaptif: Öncelikli tag varken loop hızı 2x artar (min 30ms)"/>
                                <TextBlock Foreground="#555" FontSize="9" TextWrapping="Wrap"
                                           Text="Yavaş: $TORQUE_AXIS, $VEL_AXIS → her 5 döngüde 1 okunur"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Kamera Ayarları -->
                <Border Background="#1E1E20" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Background="#9C27B0" CornerRadius="6" Width="36" Height="36">
                                <FontIcon Glyph="&#xE722;" Foreground="White" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Kamera (Gocator 3D) Ayarları" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Rectangle Height="1" Fill="#333"/>

                        <Grid ColumnSpacing="20" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="250"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Gocator IP" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtGocatorIp" PlaceholderText="192.168.251.30" Background="#252528" BorderBrush="#333" Foreground="White" CornerRadius="4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Control Port" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtGocatorPort" PlaceholderText="3600" Background="#252528" BorderBrush="#333" Foreground="White" CornerRadius="4"/>
                        </Grid>

                        <Rectangle Height="1" Fill="#333" Margin="0,5,0,0"/>
                        <TextBlock Text="Zamanlama" FontSize="11" Foreground="#9C27B0" FontWeight="SemiBold" Margin="0,5,0,0"/>

                        <Grid ColumnSpacing="10" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="REST API Timeout" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" x:Name="SliderGocatorTimeout" Minimum="5000" Maximum="120000" StepFrequency="1000" SnapsTo="StepValues" Value="30000"
                                    ValueChanged="SliderGocatorTimeout_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="TxtGocatorTimeout" Text="30000 ms" Foreground="#4CAF50" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Gocator API zaman aşımı" Foreground="#555" FontSize="9" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Inficon Sniffer Ayarları -->
                <Border Background="#1E1E20" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Background="#00BCD4" CornerRadius="6" Width="36" Height="36">
                                <FontIcon Glyph="&#xE9CE;" Foreground="White" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Inficon Sniffer Ayarları" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Rectangle Height="1" Fill="#333"/>

                        <TextBlock Text="Zamanlama" FontSize="11" Foreground="#00BCD4" FontWeight="SemiBold"/>

                        <Grid ColumnSpacing="10" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Panel Güncelleme" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="SliderInficonRefresh" Minimum="100" Maximum="1000" StepFrequency="50" SnapsTo="StepValues" Value="200"
                                    ValueChanged="SliderInficonRefresh_ValueChanged"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" x:Name="TxtInficonRefresh" Text="200 ms" Foreground="#4CAF50" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="LED/değer okuma hızı" Foreground="#555" FontSize="9" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Trend Grafik" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Row="1" Grid.Column="1" x:Name="SliderInficonTrend" Minimum="500" Maximum="5000" StepFrequency="100" SnapsTo="StepValues" Value="1000"
                                    ValueChanged="SliderInficonTrend_ValueChanged"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="TxtInficonTrend" Text="1000 ms" Foreground="#4CAF50" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="Chart.js güncelleme" Foreground="#555" FontSize="9" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Güvenlik Kontrol" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Row="2" Grid.Column="1" x:Name="SliderSafetyCheck" Minimum="500" Maximum="5000" StepFrequency="100" SnapsTo="StepValues" Value="1000"
                                    ValueChanged="SliderSafetyCheck_ValueChanged"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="TxtSafetyCheck" Text="1000 ms" Foreground="#4CAF50" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="Safety alarm kontrolü" Foreground="#555" FontSize="9" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Genel Ayarlar -->
                <Border Background="#1E1E20" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Background="#FF9800" CornerRadius="6" Width="36" Height="36">
                                <FontIcon Glyph="&#xE770;" Foreground="White" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Genel Ayarlar" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Rectangle Height="1" Fill="#333"/>

                        <Grid ColumnSpacing="20" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Bildirimler" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Row="0" Grid.Column="1" IsOn="True"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Log Kaydet" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Row="1" Grid.Column="1" IsOn="True"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Kaydet Butonları -->
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button x:Name="BtnResetDefaults" Click="BtnResetDefaults_Click" Content="Varsayılana Dön" Background="#333" Foreground="White" Padding="20,10" CornerRadius="4"/>
                    <Button x:Name="BtnSaveSettings" Click="BtnSaveSettings_Click" Content="Ayarları Kaydet" Background="#0078D4" Foreground="White" Padding="20,10" CornerRadius="4"/>
                </StackPanel>
                <TextBlock x:Name="TxtSaveStatus" Text="" Foreground="#4CAF50" FontSize="11"/>

                <!-- Ayar Yedekleme / İçe Aktarma -->
                <Border Background="#1E1E20" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Background="#00BCD4" CornerRadius="6" Width="36" Height="36">
                                <FontIcon Glyph="&#xE8F1;" Foreground="White" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Yapılandırma Yedekleme" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="Tüm ayarları yedekle ve başka bilgisayara aktar" FontSize="11" Foreground="#888"/>
                            </StackPanel>
                        </StackPanel>
                        <Rectangle Height="1" Fill="#333"/>

                        <TextBlock Text="PLC tag eşleşmeleri, otomasyon ayarları, reçeteler, robot konfigürasyonu ve transfer tablosu tek dosyada yedeklenir." 
                                   Foreground="#888" FontSize="11" TextWrapping="Wrap"/>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BtnExportConfig" Click="BtnExportConfig_Click" 
                                    HorizontalAlignment="Stretch" Padding="0,14" CornerRadius="4"
                                    Background="#00BCD4" Foreground="White">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE898;" FontSize="16"/>
                                    <TextBlock Text="Ayarları Dışa Aktar" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnImportConfig" Click="BtnImportConfig_Click" Grid.Column="1"
                                    HorizontalAlignment="Stretch" Padding="0,14" CornerRadius="4"
                                    Background="#FF9800" Foreground="White">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE896;" FontSize="16"/>
                                    <TextBlock Text="Ayarları İçe Aktar" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock x:Name="TxtConfigStatus" Text="" Foreground="#4CAF50" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
