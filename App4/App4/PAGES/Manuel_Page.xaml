<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App4.Manuel_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App4"
    xmlns:utils="using:App4.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0D0D0D"
    NavigationCacheMode="Required">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1A1A1C" BorderThickness="0,0,0,1" BorderBrush="#333">
            <Grid Padding="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                    <Border Background="#FF9800" CornerRadius="8" Width="40" Height="40">
                        <FontIcon Glyph="&#xE8B3;" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Manuel Kontrol" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Manuel Kontrol &#x2014; &#x0130;stasyon Test &amp; &#xC7;evrim" FontSize="11" Foreground="#888"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Padding="15" RowSpacing="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ROW 0: Control Panel + 3 Station Cards -->
                <Grid Grid.Row="0" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- CONTROL PANEL (Left) -->
                    <Border Grid.Column="0" Background="#1A1A1C" CornerRadius="8" Padding="15" VerticalAlignment="Stretch">
                        <StackPanel Spacing="12">
                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Background="#333" CornerRadius="6" Width="32" Height="32">
                                    <FontIcon Glyph="&#xE943;" Foreground="#0078D4" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="KONTROL" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Rectangle Height="1" Fill="#333"/>

                            <!-- System Status -->
                            <Border x:Name="ManuelLineStatusCard" Background="#252528" CornerRadius="6" Padding="10,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon x:Name="ManuelLineStatusIcon" Glyph="&#xE71A;" FontSize="14" Foreground="#888"/>
                                    <TextBlock x:Name="ManuelLineStatusText" Text="SISTEM KAPALI" FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                                </StackPanel>
                            </Border>

                            <!-- Safety & Alarm -->
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="ManuelSafetyBorder" Grid.Column="0" Background="#252528" CornerRadius="6" Padding="8,6">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="SAFETY" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                            <FontIcon x:Name="ManuelSafetyIcon" Glyph="&#xE7BA;" FontSize="10" Foreground="#666"/>
                                            <TextBlock x:Name="ManuelSafetyText" Text="OK" FontSize="9" FontWeight="Bold" Foreground="#666"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="ManuelAlarmBorder" Grid.Column="1" Background="#252528" CornerRadius="6" Padding="8,6">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="ALARM" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                            <FontIcon x:Name="ManuelAlarmIcon" Glyph="&#xE7BA;" FontSize="10" Foreground="#666"/>
                                            <TextBlock x:Name="ManuelAlarmText" Text="OK" FontSize="9" FontWeight="Bold" Foreground="#666"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Rectangle Height="1" Fill="#333"/>

                            <!-- BASLAT Button -->
                            <Button x:Name="BtnManuelBaslat" Click="BtnManuelBaslat_Click" CornerRadius="6" Padding="0" HorizontalAlignment="Stretch" Height="40" Background="#1E5631" BorderBrush="#27AE60" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE768;" FontSize="14" Foreground="#2ECC71"/>
                                    <TextBlock Text="BASLAT" FontWeight="Bold" Foreground="White" FontSize="11"/>
                                </StackPanel>
                            </Button>

                            <!-- DURDUR Button -->
                            <Button x:Name="BtnManuelDurdur" Click="BtnManuelDurdur_Click" CornerRadius="6" Padding="0" HorizontalAlignment="Stretch" Height="40" Background="#641E16" BorderBrush="#C0392B" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE71A;" FontSize="14" Foreground="#E74C3C"/>
                                    <TextBlock Text="DURDUR" FontWeight="Bold" Foreground="White" FontSize="11"/>
                                </StackPanel>
                            </Button>

                            <!-- RESET Button -->
                            <Button x:Name="BtnManuelReset" Click="BtnManuelReset_Click" CornerRadius="6" Padding="0" HorizontalAlignment="Stretch" Height="40" Background="#7E5109" BorderBrush="#F39C12" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE72C;" FontSize="14" Foreground="#F1C40F"/>
                                    <TextBlock Text="RESET" FontWeight="Bold" Foreground="White" FontSize="11"/>
                                </StackPanel>
                            </Button>

                            <Rectangle Height="1" Fill="#333" Margin="0,4"/>

                            <!-- 3 ISTASYON CALIS Button -->
                            <Button x:Name="BtnTumIstasyonCalis" Click="BtnTumIstasyonCalis_Click" CornerRadius="6" Padding="0" HorizontalAlignment="Stretch" Height="44" Background="#1565C0" BorderBrush="#42A5F5" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="14" Foreground="#42A5F5"/>
                                    <TextBlock Text="3 IST ÇALIŞ" FontWeight="Bold" Foreground="White" FontSize="10"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- ISTASYON 1 CARD -->
                    <Border Grid.Column="1" Background="#1A1A1C" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Padding="12">
                        <StackPanel Spacing="8">
                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="10" Height="10" Fill="#FF5722" VerticalAlignment="Center"/>
                                <TextBlock Text="ISTASYON 1" FontSize="13" FontWeight="Bold" Foreground="#FF5722"/>
                            </StackPanel>
                            <Rectangle Height="1" Fill="#333"/>

                            <!-- LED Panel -->
                            <Grid ColumnSpacing="8" RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- HAZIR -->
                                <Ellipse x:Name="Led_IST1_Hazir" Grid.Row="0" Grid.Column="0" Width="12" Height="12" Fill="#555"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="HAZIR" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtLed_IST1_Hazir_Val" Grid.Row="0" Grid.Column="2" Text="---" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <!-- IS BITTI -->
                                <Ellipse x:Name="Led_IST1_IsBitti" Grid.Row="1" Grid.Column="0" Width="12" Height="12" Fill="#555"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="IS BITTI" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtLed_IST1_IsBitti_Val" Grid.Row="1" Grid.Column="2" Text="---" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <!-- HEDEF IST -->
                                <Ellipse x:Name="Led_IST1_HedefIst" Grid.Row="2" Grid.Column="0" Width="12" Height="12" Fill="#555"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="HEDEF IST" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtLed_IST1_HedefIst_Val" Grid.Row="2" Grid.Column="2" Text="---" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <!-- TABLA OK -->
                                <Ellipse x:Name="Led_IST1_TablaOk" Grid.Row="3" Grid.Column="0" Width="12" Height="12" Fill="#555"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="TABLA OK" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtLed_IST1_TablaOk_Val" Grid.Row="3" Grid.Column="2" Text="---" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <!-- BORU OK -->
                                <Ellipse x:Name="Led_IST1_BoruOk" Grid.Row="4" Grid.Column="0" Width="12" Height="12" Fill="#555"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="BORU OK" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtLed_IST1_BoruOk_Val" Grid.Row="4" Grid.Column="2" Text="---" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#333"/>

                            <!-- Klima Dropdown -->
                            <TextBlock Text="Klima Tipi:" Foreground="#888" FontSize="10"/>
                            <ComboBox x:Name="CmbKlima_IST1" HorizontalAlignment="Stretch" Background="#252528" FontSize="11" Height="30" BorderBrush="#333"/>
                            <TextBlock x:Name="TxtKlima_IST1_Info" Text="Tip: - | Case: -" Foreground="#666" FontSize="10"/>

                            <Rectangle Height="1" Fill="#333"/>

                            <!-- Action Buttons -->
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Tag="1" Click="BtnIstasyonCalis_Click" CornerRadius="6" HorizontalAlignment="Stretch" Height="36" Background="#1E5631" BorderBrush="#27AE60" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE768;" FontSize="12" Foreground="White"/>
                                        <TextBlock Text="CALIS" FontWeight="Bold" Foreground="White" FontSize="10"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Tag="1" Click="BtnIstasyonDurdur_Click" CornerRadius="6" HorizontalAlignment="Stretch" Height="36" Background="#641E16" BorderBrush="#C0392B" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE71A;" FontSize="12" Foreground="White"/>
                                        <TextBlock Text="DURDUR" FontWeight="Bold" Foreground="White" FontSize="10"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <ToggleButton x:Name="BtnTekrarla_IST1" Tag="1" Click="BtnTekrarla_Click" CornerRadius="6" HorizontalAlignment="Stretch" Height="36" Background="#4A148C" BorderBrush="#7B1FA2" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE1CD;" FontSize="12" Foreground="White"/>
                                    <TextBlock x:Name="TxtTekrarla_IST1" Text="TEKRARLA" FontWeight="Bold" Foreground="White" FontSize="10"/>
                                </StackPanel>
                            </ToggleButton>
                        </StackPanel>
                    </Border>

                    <!-- ISTASYON 2 CARD -->
                    <Border Grid.Column="2" Background="#1A1A1C" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Padding="12">
                        <StackPanel Spacing="8">
                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="10" Height="10" Fill="#FF9800" VerticalAlignment="Center"/>
                                <TextBlock Text="ISTASYON 2" FontSize="13" FontWeight="Bold" Foreground="#FF9800"/>
                            </StackPanel>
                            <Rectangle Height="1" Fill="#333"/>

                            <!-- LED Panel -->
                            <Grid ColumnSpacing="8" RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- HAZIR -->
                                <Ellipse x:Name="Led_IST2_Hazir" Grid.Row="0" Grid.Column="0" Width="12" Height="12" Fill="#555"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="HAZIR" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtLed_IST2_Hazir_Val" Grid.Row="0" Grid.Column="2" Text="---" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <!-- IS BITTI -->
                                <Ellipse x:Name="Led_IST2_IsBitti" Grid.Row="1" Grid.Column="0" Width="12" Height="12" Fill="#555"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="IS BITTI" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtLed_IST2_IsBitti_Val" Grid.Row="1" Grid.Column="2" Text="---" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <!-- HEDEF IST -->
                                <Ellipse x:Name="Led_IST2_HedefIst" Grid.Row="2" Grid.Column="0" Width="12" Height="12" Fill="#555"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="HEDEF IST" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtLed_IST2_HedefIst_Val" Grid.Row="2" Grid.Column="2" Text="---" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <!-- TABLA OK -->
                                <Ellipse x:Name="Led_IST2_TablaOk" Grid.Row="3" Grid.Column="0" Width="12" Height="12" Fill="#555"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="TABLA OK" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtLed_IST2_TablaOk_Val" Grid.Row="3" Grid.Column="2" Text="---" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <!-- BORU OK -->
                                <Ellipse x:Name="Led_IST2_BoruOk" Grid.Row="4" Grid.Column="0" Width="12" Height="12" Fill="#555"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="BORU OK" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtLed_IST2_BoruOk_Val" Grid.Row="4" Grid.Column="2" Text="---" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#333"/>

                            <!-- Klima Dropdown -->
                            <TextBlock Text="Klima Tipi:" Foreground="#888" FontSize="10"/>
                            <ComboBox x:Name="CmbKlima_IST2" HorizontalAlignment="Stretch" Background="#252528" FontSize="11" Height="30" BorderBrush="#333"/>
                            <TextBlock x:Name="TxtKlima_IST2_Info" Text="Tip: - | Case: -" Foreground="#666" FontSize="10"/>

                            <Rectangle Height="1" Fill="#333"/>

                            <!-- Action Buttons -->
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Tag="2" Click="BtnIstasyonCalis_Click" CornerRadius="6" HorizontalAlignment="Stretch" Height="36" Background="#1E5631" BorderBrush="#27AE60" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE768;" FontSize="12" Foreground="White"/>
                                        <TextBlock Text="CALIS" FontWeight="Bold" Foreground="White" FontSize="10"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Tag="2" Click="BtnIstasyonDurdur_Click" CornerRadius="6" HorizontalAlignment="Stretch" Height="36" Background="#641E16" BorderBrush="#C0392B" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE71A;" FontSize="12" Foreground="White"/>
                                        <TextBlock Text="DURDUR" FontWeight="Bold" Foreground="White" FontSize="10"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <ToggleButton x:Name="BtnTekrarla_IST2" Tag="2" Click="BtnTekrarla_Click" CornerRadius="6" HorizontalAlignment="Stretch" Height="36" Background="#4A148C" BorderBrush="#7B1FA2" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE1CD;" FontSize="12" Foreground="White"/>
                                    <TextBlock x:Name="TxtTekrarla_IST2" Text="TEKRARLA" FontWeight="Bold" Foreground="White" FontSize="10"/>
                                </StackPanel>
                            </ToggleButton>
                        </StackPanel>
                    </Border>

                    <!-- ISTASYON 3 CARD -->
                    <Border Grid.Column="3" Background="#1A1A1C" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Padding="12">
                        <StackPanel Spacing="8">
                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="10" Height="10" Fill="#4CAF50" VerticalAlignment="Center"/>
                                <TextBlock Text="ISTASYON 3" FontSize="13" FontWeight="Bold" Foreground="#4CAF50"/>
                            </StackPanel>
                            <Rectangle Height="1" Fill="#333"/>

                            <!-- LED Panel -->
                            <Grid ColumnSpacing="8" RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- HAZIR -->
                                <Ellipse x:Name="Led_IST3_Hazir" Grid.Row="0" Grid.Column="0" Width="12" Height="12" Fill="#555"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="HAZIR" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtLed_IST3_Hazir_Val" Grid.Row="0" Grid.Column="2" Text="---" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <!-- IS BITTI -->
                                <Ellipse x:Name="Led_IST3_IsBitti" Grid.Row="1" Grid.Column="0" Width="12" Height="12" Fill="#555"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="IS BITTI" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtLed_IST3_IsBitti_Val" Grid.Row="1" Grid.Column="2" Text="---" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <!-- HEDEF IST -->
                                <Ellipse x:Name="Led_IST3_HedefIst" Grid.Row="2" Grid.Column="0" Width="12" Height="12" Fill="#555"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="HEDEF IST" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtLed_IST3_HedefIst_Val" Grid.Row="2" Grid.Column="2" Text="---" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <!-- TABLA OK -->
                                <Ellipse x:Name="Led_IST3_TablaOk" Grid.Row="3" Grid.Column="0" Width="12" Height="12" Fill="#555"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="TABLA OK" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtLed_IST3_TablaOk_Val" Grid.Row="3" Grid.Column="2" Text="---" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <!-- BORU OK -->
                                <Ellipse x:Name="Led_IST3_BoruOk" Grid.Row="4" Grid.Column="0" Width="12" Height="12" Fill="#555"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="BORU OK" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtLed_IST3_BoruOk_Val" Grid.Row="4" Grid.Column="2" Text="---" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#333"/>

                            <!-- Klima Dropdown -->
                            <TextBlock Text="Klima Tipi:" Foreground="#888" FontSize="10"/>
                            <ComboBox x:Name="CmbKlima_IST3" HorizontalAlignment="Stretch" Background="#252528" FontSize="11" Height="30" BorderBrush="#333"/>
                            <TextBlock x:Name="TxtKlima_IST3_Info" Text="Tip: - | Case: -" Foreground="#666" FontSize="10"/>

                            <Rectangle Height="1" Fill="#333"/>

                            <!-- Action Buttons -->
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Tag="3" Click="BtnIstasyonCalis_Click" CornerRadius="6" HorizontalAlignment="Stretch" Height="36" Background="#1E5631" BorderBrush="#27AE60" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE768;" FontSize="12" Foreground="White"/>
                                        <TextBlock Text="CALIS" FontWeight="Bold" Foreground="White" FontSize="10"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Tag="3" Click="BtnIstasyonDurdur_Click" CornerRadius="6" HorizontalAlignment="Stretch" Height="36" Background="#641E16" BorderBrush="#C0392B" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE71A;" FontSize="12" Foreground="White"/>
                                        <TextBlock Text="DURDUR" FontWeight="Bold" Foreground="White" FontSize="10"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <ToggleButton x:Name="BtnTekrarla_IST3" Tag="3" Click="BtnTekrarla_Click" CornerRadius="6" HorizontalAlignment="Stretch" Height="36" Background="#4A148C" BorderBrush="#7B1FA2" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE1CD;" FontSize="12" Foreground="White"/>
                                    <TextBlock x:Name="TxtTekrarla_IST3" Text="TEKRARLA" FontWeight="Bold" Foreground="White" FontSize="10"/>
                                </StackPanel>
                            </ToggleButton>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ROW 1: KL100 SLIDER VISUAL -->
                <Border Grid.Row="1" Background="#1A1A1C" CornerRadius="8" Padding="20,15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="140"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Slider Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="15" Margin="0,0,0,10">
                            <Border Background="#333" CornerRadius="6" Padding="12,6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE71D;" Foreground="#0078D4" FontSize="14"/>
                                    <TextBlock Text="KL100 LINEER SLIDER" FontSize="12" FontWeight="Bold" Foreground="#0078D4"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#252528" CornerRadius="6" Padding="12,6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Aktuel Poz:" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ManuelSliderActualPosText" Text="---" FontSize="12" FontWeight="Bold" Foreground="#FF9800" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#252528" CornerRadius="6" Padding="12,6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Istasyon:" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ManuelSliderStationText" Text="---" FontSize="12" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#252528" CornerRadius="6" Padding="12,6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE81D;" Foreground="#E91E63" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="Hedef:" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ManuelSliderHedefStationText" Text="---" FontSize="12" FontWeight="Bold" Foreground="#E91E63" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Slider Rail and Robots -->
                        <Grid Grid.Row="1" Background="#151518">
                            <!-- Slider Rail Background (Metallic) -->
                            <Border Height="20" CornerRadius="10" VerticalAlignment="Center" Margin="80,0" BorderBrush="#666" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#707070" Offset="0"/>
                                        <GradientStop Color="#404040" Offset="0.5"/>
                                        <GradientStop Color="#505050" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- Slider Rail Line (Top) -->
                            <Border Height="4" CornerRadius="2" VerticalAlignment="Center" Margin="80,-8,80,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#888888" Offset="0"/>
                                        <GradientStop Color="#AAAAAA" Offset="0.5"/>
                                        <GradientStop Color="#888888" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- Station Markers on Slider -->
                            <Grid VerticalAlignment="Center" Margin="80,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="8" Height="36" Background="#9E9E9E" CornerRadius="4" HorizontalAlignment="Center" Opacity="0.9"/>
                                <Border Grid.Column="1" Width="8" Height="36" Background="#FF5722" CornerRadius="4" HorizontalAlignment="Center" Opacity="0.9"/>
                                <Border Grid.Column="2" Width="8" Height="36" Background="#FF9800" CornerRadius="4" HorizontalAlignment="Center" Opacity="0.9"/>
                                <Border Grid.Column="3" Width="8" Height="36" Background="#4CAF50" CornerRadius="4" HorizontalAlignment="Center" Opacity="0.9"/>
                            </Grid>

                            <!-- Robot Platform Canvas -->
                            <Canvas x:Name="ManuelSliderCanvas" Margin="80,0">
                                <Grid x:Name="ManuelRobotPlatform" Canvas.Left="20" Canvas.Top="20" Width="140">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Two Robots Side by Side -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center">
                                        <!-- Robot 1 (Gocator + Helyum) -->
                                        <Grid Width="60">
                                            <Grid HorizontalAlignment="Center">
                                                <Ellipse x:Name="ManuelR1RobotEllipse" Width="50" Height="50" StrokeThickness="3">
                                                    <Ellipse.Fill>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#2A2A2A" Offset="0"/>
                                                            <GradientStop Color="#1A1A1A" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Ellipse.Fill>
                                                    <Ellipse.Stroke>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#4CAF50" Offset="0"/>
                                                            <GradientStop Color="#2E7D32" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Ellipse.Stroke>
                                                </Ellipse>
                                                <FontIcon x:Name="ManuelR1RobotIcon" Glyph="&#xE99A;" FontSize="20" Foreground="#4CAF50"/>
                                                <!-- Gocator Icon -->
                                                <Border Background="#FF9800" CornerRadius="3" Padding="2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0">
                                                    <FontIcon Glyph="&#xE945;" FontSize="7" Foreground="White"/>
                                                </Border>
                                                <!-- Helyum Icon -->
                                                <Border Background="#9C27B0" CornerRadius="3" Padding="2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-2,-2,0,0">
                                                    <TextBlock Text="He" FontSize="6" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </Grid>
                                            <Border Background="#4CAF50" CornerRadius="3" Padding="4,1" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-10,0,0">
                                                <TextBlock Text="R1" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                        </Grid>

                                        <!-- Robot 2 (Helyum only) -->
                                        <Grid Width="60">
                                            <Grid HorizontalAlignment="Center">
                                                <Ellipse x:Name="ManuelR2RobotEllipse" Width="50" Height="50" StrokeThickness="3">
                                                    <Ellipse.Fill>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#2A2A2A" Offset="0"/>
                                                            <GradientStop Color="#1A1A1A" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Ellipse.Fill>
                                                    <Ellipse.Stroke>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#0078D4" Offset="0"/>
                                                            <GradientStop Color="#005A9E" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Ellipse.Stroke>
                                                </Ellipse>
                                                <FontIcon x:Name="ManuelR2RobotIcon" Glyph="&#xE99A;" FontSize="20" Foreground="#0078D4"/>
                                                <!-- Helyum Icon -->
                                                <Border Background="#9C27B0" CornerRadius="3" Padding="2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0">
                                                    <TextBlock Text="He" FontSize="6" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </Grid>
                                            <Border Background="#0078D4" CornerRadius="3" Padding="4,1" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-10,0,0">
                                                <TextBlock Text="R2" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Platform Connection Bar -->
                                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,-3,0,0">
                                        <Border Width="100" Height="6" CornerRadius="3">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#4CAF50" Offset="0"/>
                                                    <GradientStop Color="#0078D4" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <Rectangle Width="8" Height="10" Fill="#555" RadiusX="2" RadiusY="2" HorizontalAlignment="Center"/>
                                        <Border Width="120" Height="10" CornerRadius="5">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#666666" Offset="0"/>
                                                    <GradientStop Color="#444444" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Canvas>
                        </Grid>

                        <!-- Robot Status Cards -->
                        <Grid Grid.Row="2" Margin="10,8,10,0" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Robot 1 Mini Status Card -->
                            <Border Grid.Column="0" x:Name="ManuelRobot1StatusCard" Background="#151518"
                                    CornerRadius="6" Padding="10,6" BorderBrush="#333" BorderThickness="1">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                                        <Border x:Name="ManuelRobot1StatusDot" Background="#555" CornerRadius="6"
                                                Width="12" Height="12" VerticalAlignment="Center"/>
                                        <TextBlock Text="R1" FontSize="11" FontWeight="Bold"
                                                   Foreground="#4CAF50" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock x:Name="ManuelRobot1DurumText" Text="---" FontSize="10"
                                                   FontWeight="SemiBold" Foreground="#888"/>
                                        <TextBlock x:Name="ManuelRobot1MesajText" Text="---" FontSize="9"
                                                   Foreground="#666" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" x:Name="ManuelRobot1HataBadge" Background="#1A2A1A"
                                            CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                        <TextBlock x:Name="ManuelRobot1HataText" Text="Hata: Yok" FontSize="9"
                                                   FontWeight="Bold" Foreground="#4CAF50"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Robot 2 Mini Status Card -->
                            <Border Grid.Column="1" x:Name="ManuelRobot2StatusCard" Background="#151518"
                                    CornerRadius="6" Padding="10,6" BorderBrush="#333" BorderThickness="1">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                                        <Border x:Name="ManuelRobot2StatusDot" Background="#555" CornerRadius="6"
                                                Width="12" Height="12" VerticalAlignment="Center"/>
                                        <TextBlock Text="R2" FontSize="11" FontWeight="Bold"
                                                   Foreground="#0078D4" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock x:Name="ManuelRobot2DurumText" Text="---" FontSize="10"
                                                   FontWeight="SemiBold" Foreground="#888"/>
                                        <TextBlock x:Name="ManuelRobot2MesajText" Text="---" FontSize="9"
                                                   Foreground="#666" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" x:Name="ManuelRobot2HataBadge" Background="#1A1A2A"
                                            CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                        <TextBlock x:Name="ManuelRobot2HataText" Text="Hata: Yok" FontSize="9"
                                                   FontWeight="Bold" Foreground="#4CAF50"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Station Labels -->
                        <Grid Grid.Row="3" Margin="80,10,80,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#9E9E9E" CornerRadius="4" Padding="8,3" HorizontalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="BAKIM" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="0 mm" FontSize="9" Foreground="#DDD" HorizontalAlignment="Center" Opacity="0.7"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="#FF5722" CornerRadius="4" Padding="8,3" HorizontalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="ISTASYON 1" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="ManuelSliderSt1PosLabel" Text="0 mm" FontSize="9" Foreground="#FFE0B2" HorizontalAlignment="Center" Opacity="0.9"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="#FF9800" CornerRadius="4" Padding="8,3" HorizontalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="ISTASYON 2" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="ManuelSliderSt2PosLabel" Text="0 mm" FontSize="9" Foreground="#FFF3E0" HorizontalAlignment="Center" Opacity="0.9"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Background="#4CAF50" CornerRadius="4" Padding="8,3" HorizontalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="ISTASYON 3" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="ManuelSliderSt3PosLabel" Text="0 mm" FontSize="9" Foreground="#C8E6C9" HorizontalAlignment="Center" Opacity="0.9"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ROW 2: KL100 SLIDER KONTROL (existing expander kept) -->
                <Border Grid.Row="2" Background="#1A1A1C" CornerRadius="8" Padding="15">
                    <StackPanel Spacing="10">
                        <!-- Title + Status -->
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE71D;" Foreground="#E91E63" FontSize="14"/>
                                <TextBlock Text="KL100 SLIDER KONTROL" FontWeight="Bold" Foreground="#E91E63"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="Aktuel:" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="KL100AktuelIstasyon" Text="---" FontSize="12" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border x:Name="KL100HatModBorder" Background="#333" CornerRadius="4" Padding="8,3">
                                    <TextBlock x:Name="KL100HatModText" Text="---" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <Rectangle Height="1" Fill="#333" Margin="0,0,0,2"/>

                        <!-- Warnings -->
                        <Border x:Name="KL100AutoWarning" Background="#331E16" CornerRadius="4" Padding="10,6" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE7BA;" Foreground="#FF9800" FontSize="12"/>
                                <TextBlock Text="Hat OTOMATIK moddayken slider manuel kontrol edilemez!" Foreground="#FF9800" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="KL100HomeWarning" Background="#2D1616" CornerRadius="4" Padding="10,6" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE7BA;" Foreground="#F44336" FontSize="12"/>
                                <TextBlock Text="Robot HOME pozisyonunda degil! Slider hareket ettirilemez." Foreground="#F44336" FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <!-- MAIN CONTROL AREA -->
                        <Grid ColumnSpacing="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- LEFT: Robot Home Status -->
                            <Border Grid.Column="0" Background="#202020" CornerRadius="6" Padding="10,8">
                                <Grid RowSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="ROBOT HOME DURUMU" FontSize="9" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Center"/>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="R1:" Foreground="#888" FontSize="10" VerticalAlignment="Center" Width="22"/>
                                        <ComboBox x:Name="CmbR1HomeSignal" Width="120" Background="#252528" Foreground="White" FontSize="10" Height="26"
                                                  PlaceholderText="Sinyal Sec..." SelectionChanged="CmbR1HomeSignal_SelectionChanged"/>
                                        <Ellipse x:Name="LedR1Home" Width="10" Height="10" Fill="Gray" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtR1HomeStatus" Text="---" FontSize="10" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Width="65"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="R2:" Foreground="#888" FontSize="10" VerticalAlignment="Center" Width="22"/>
                                        <ComboBox x:Name="CmbR2HomeSignal" Width="120" Background="#252528" Foreground="White" FontSize="10" Height="26"
                                                  PlaceholderText="Sinyal Sec..." SelectionChanged="CmbR2HomeSignal_SelectionChanged"/>
                                        <Ellipse x:Name="LedR2Home" Width="10" Height="10" Fill="Gray" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtR2HomeStatus" Text="---" FontSize="10" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Width="65"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- CENTER: Station Position Settings -->
                            <Border Grid.Column="1" Background="#202020" CornerRadius="6" Padding="10,8">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="ISTASYON POZISYONLARI (mm)" FontSize="9" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Center"/>
                                    <Grid ColumnSpacing="8" RowSpacing="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="BAKIM:" Foreground="#E91E63" FontSize="10" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBox x:Name="TxtKL100StBakimPos" Grid.Row="0" Grid.Column="1" PlaceholderText="0.0"
                                                 Background="#252528" Foreground="#E91E63" FontSize="11" Height="26" FontWeight="Bold"
                                                 LostFocus="KL100StationPos_LostFocus" BorderBrush="#333"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="ISTASYON 1:" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBox x:Name="TxtKL100St1Pos" Grid.Row="1" Grid.Column="1" PlaceholderText="0.0"
                                                 Background="#252528" Foreground="#4CAF50" FontSize="11" Height="26" FontWeight="Bold"
                                                 LostFocus="KL100StationPos_LostFocus" BorderBrush="#333"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="ISTASYON 2:" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBox x:Name="TxtKL100St2Pos" Grid.Row="2" Grid.Column="1" PlaceholderText="0.0"
                                                 Background="#252528" Foreground="#4CAF50" FontSize="11" Height="26" FontWeight="Bold"
                                                 LostFocus="KL100StationPos_LostFocus" BorderBrush="#333"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="ISTASYON 3:" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBox x:Name="TxtKL100St3Pos" Grid.Row="3" Grid.Column="1" PlaceholderText="0.0"
                                                 Background="#252528" Foreground="#4CAF50" FontSize="11" Height="26" FontWeight="Bold"
                                                 LostFocus="KL100StationPos_LostFocus" BorderBrush="#333"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- RIGHT: Movement Control -->
                            <Border Grid.Column="2" Background="#202020" CornerRadius="6" Padding="12,8">
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Mode Selection -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="HAREKET MODU:" FontSize="9" FontWeight="Bold" Foreground="#666" VerticalAlignment="Center"/>
                                        <RadioButton x:Name="RbKL100StationMode" Content="ISTASYONA GIT" GroupName="KL100Mode" IsChecked="True"
                                                     Foreground="White" FontSize="11" FontWeight="SemiBold" Checked="KL100Mode_Changed"/>
                                        <RadioButton x:Name="RbKL100PositionMode" Content="POZISYONA GIT" GroupName="KL100Mode"
                                                     Foreground="White" FontSize="11" FontWeight="SemiBold" Checked="KL100Mode_Changed"/>
                                    </StackPanel>

                                    <!-- Station Go Panel -->
                                    <Border x:Name="KL100StationPanel" Grid.Row="1" Background="#252528" CornerRadius="4" Padding="10,8">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="Hedef Istasyon:" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="KL100HedefCombo" Width="140" Background="#1A1A1C" Foreground="White" FontSize="12" Height="32" IsEnabled="False">
                                                <ComboBoxItem Content="ISTASYON 1" Tag="1"/>
                                                <ComboBoxItem Content="ISTASYON 2" Tag="2"/>
                                                <ComboBoxItem Content="ISTASYON 3" Tag="3"/>
                                            </ComboBox>
                                            <StackPanel Spacing="1">
                                                <TextBlock Text="Kayitli Poz:" Foreground="#666" FontSize="9"/>
                                                <TextBlock x:Name="TxtKL100SelectedStationPos" Text="---" FontSize="12" FontWeight="Bold" Foreground="#FF9800"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Position Go Panel -->
                                    <Border x:Name="KL100PositionPanel" Grid.Row="1" Background="#252528" CornerRadius="4" Padding="10,8" Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="Hedef Pozisyon (mm):" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBox x:Name="TxtKL100ManualPos" PlaceholderText="Pozisyon gir..." Width="130"
                                                     Background="#1A1A1C" Foreground="#FF9800" FontSize="13" FontWeight="Bold" Height="32" BorderBrush="#555"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Go Button -->
                                    <Button x:Name="BtnKL100HedefGit" Grid.Row="2" Click="BtnKL100HedefGit_Click"
                                            HorizontalAlignment="Stretch" Height="38" IsEnabled="False"
                                            Background="#E91E63" CornerRadius="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE768;" Foreground="White" FontSize="14"/>
                                            <TextBlock x:Name="TxtKL100GoButtonLabel" Text="ISTASYONA GIT" FontWeight="Bold" Foreground="White" FontSize="12"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Slider HOME Button -->
                                    <Button x:Name="BtnKL100SliderHome" Grid.Row="3" Click="BtnKL100SliderHome_Click"
                                            HorizontalAlignment="Stretch" Height="38"
                                            Background="#0078D4" CornerRadius="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE80F;" Foreground="White" FontSize="14"/>
                                            <TextBlock Text="SLIDER HOME" FontWeight="Bold" Foreground="White" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
