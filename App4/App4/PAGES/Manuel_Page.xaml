<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App4.Manuel_Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App4"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0D0D0D"
    NavigationCacheMode="Required">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <!-- Sinyal tablosu altta -->
            <RowDefinition Height="250"/> 
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1A1A1C" BorderThickness="0,0,0,1" BorderBrush="#333">
            <Grid Padding="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                    <Border Background="#FF9800" CornerRadius="8" Width="40" Height="40">
                        <FontIcon Glyph="&#xE8B3;" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Manuel Kontrol" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Robot ve PLC Manuel Kontrol Paneli" FontSize="11" Foreground="#888"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- KONTROLLER -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Padding="20" ColumnSpacing="15" RowSpacing="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 1. SÜTUN: ROBOT KONTROL -->
                <Border Grid.Column="0" Background="#1A1A1C" CornerRadius="8" Padding="15">
                    <StackPanel Spacing="10">
                        <TextBlock Text="ROBOT KONTROL" FontWeight="Bold" Foreground="#0078D4"/>
                        <Rectangle Height="1" Fill="#333" Margin="0,0,0,5"/>

                        <Button x:Name="BtnBaslat" Content="BAŞLAT" Background="#1E5631" Foreground="White" HorizontalAlignment="Stretch" Click="BtnBaslat_Click"/>
                        <Button x:Name="BtnDur" Content="DUR" Background="#641E16" Foreground="White" HorizontalAlignment="Stretch" Click="BtnDur_Click"/>
                        <Button x:Name="BtnReset" Content="RESET" Background="#7E5109" Foreground="White" HorizontalAlignment="Stretch" Click="BtnReset_Click"/>
                        <Button x:Name="BtnHome" Content="HOME POZİSYONU" Background="#005A9E" Foreground="White" HorizontalAlignment="Stretch" Click="BtnHome_Click"/>

                        <TextBlock Text="Klima Tipi:" Foreground="#888" Margin="0,10,0,0"/>
                        <ComboBox x:Name="ComboKlimaTipi" HorizontalAlignment="Stretch" SelectionChanged="ComboKlimaTipi_SelectionChanged">
                            <ComboBoxItem Content="Klima 1"/>
                            <ComboBoxItem Content="Klima 2"/>
                            <ComboBoxItem Content="Klima 3"/>
                        </ComboBox>

                        <TextBlock Text="Override PRO (%):" Foreground="#888" Margin="0,10,0,0"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Slider x:Name="SliderOverridePro" Minimum="1" Maximum="100" Value="100" Width="180" ValueChanged="SliderOverridePro_ValueChanged"/>
                            <TextBlock x:Name="OverrideProValueText" Text="100%" VerticalAlignment="Center" Foreground="White"/>
                        </StackPanel>

                        <TextBlock Text="Override JOG (%):" Foreground="#888" Margin="0,5,0,0"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Slider x:Name="SliderOverrideJog" Minimum="1" Maximum="100" Value="50" Width="180" ValueChanged="SliderOverrideJog_ValueChanged"/>
                            <TextBlock x:Name="OverrideJogValueText" Text="50%" VerticalAlignment="Center" Foreground="White"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 2. SÜTUN: GOCATOR OFFSET (BORU + TABLA) -->
                <Border Grid.Column="1" Background="#1A1A1C" CornerRadius="8" Padding="15">
                    <StackPanel Spacing="8">
                        <TextBlock Text="GOCATOR OFFSET" FontWeight="Bold" Foreground="#4CAF50"/>
                        <Rectangle Height="1" Fill="#333" Margin="0,0,0,2"/>

                        <!-- BORU OFFSET -->
                        <TextBlock Text="BORU" FontSize="11" FontWeight="SemiBold" Foreground="#4CAF50" Opacity="0.7"/>
                        <Grid ColumnSpacing="10" RowSpacing="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="X:" Foreground="#888"/><TextBlock x:Name="TxtBoruX" Grid.Row="0" Grid.Column="1" Text="0.0" Foreground="White"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Y:" Foreground="#888"/><TextBlock x:Name="TxtBoruY" Grid.Row="1" Grid.Column="1" Text="0.0" Foreground="White"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Z:" Foreground="#888"/><TextBlock x:Name="TxtBoruZ" Grid.Row="2" Grid.Column="1" Text="0.0" Foreground="White"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="A:" Foreground="#888"/><TextBlock x:Name="TxtBoruA" Grid.Row="3" Grid.Column="1" Text="0.0" Foreground="White"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="B:" Foreground="#888"/><TextBlock x:Name="TxtBoruB" Grid.Row="4" Grid.Column="1" Text="0.0" Foreground="White"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="C:" Foreground="#888"/><TextBlock x:Name="TxtBoruC" Grid.Row="5" Grid.Column="1" Text="0.0" Foreground="White"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="StatusBoruTara" Text="TARA: Kapalı" Foreground="White" FontSize="11"/>
                            <TextBlock x:Name="StatusBoruTamam" Text="TAMAM: Kapalı" Foreground="White" FontSize="11"/>
                            <TextBlock x:Name="StatusBoruHazir" Text="HAZIR: Kapalı" Foreground="White" FontSize="11"/>
                        </StackPanel>

                        <Rectangle Height="1" Fill="#333" Margin="0,2"/>

                        <!-- TABLA OFFSET -->
                        <TextBlock Text="TABLA" FontSize="11" FontWeight="SemiBold" Foreground="#E67E22" Opacity="0.7"/>
                        <Grid ColumnSpacing="10" RowSpacing="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="X:" Foreground="#888"/><TextBlock x:Name="TxtTablaX" Grid.Row="0" Grid.Column="1" Text="0.0" Foreground="White"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Y:" Foreground="#888"/><TextBlock x:Name="TxtTablaY" Grid.Row="1" Grid.Column="1" Text="0.0" Foreground="White"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Z:" Foreground="#888"/><TextBlock x:Name="TxtTablaZ" Grid.Row="2" Grid.Column="1" Text="0.0" Foreground="White"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="A:" Foreground="#888"/><TextBlock x:Name="TxtTablaA" Grid.Row="3" Grid.Column="1" Text="0.0" Foreground="White"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="B:" Foreground="#888"/><TextBlock x:Name="TxtTablaB" Grid.Row="4" Grid.Column="1" Text="0.0" Foreground="White"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="C:" Foreground="#888"/><TextBlock x:Name="TxtTablaC" Grid.Row="5" Grid.Column="1" Text="0.0" Foreground="White"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="StatusTablaTara" Text="TARA: Kapalı" Foreground="#888" FontSize="11"/>
                            <TextBlock x:Name="StatusTablaTamam" Text="TAMAM: Kapalı" Foreground="#888" FontSize="11"/>
                        </StackPanel>

                        <Rectangle Height="1" Fill="#333" Margin="0,2"/>

                        <!-- Butonlar -->
                        <Button x:Name="BtnOffsetHazir" Content="OFFSET HAZIR BİLDİR" Background="#4CAF50" Foreground="White" HorizontalAlignment="Stretch" Margin="0,2,0,0" Click="BtnOffsetHazir_Click"/>
                        <Button x:Name="BtnGocatorTamam" Content="GOCATOR TAMAM" Background="#0078D4" Foreground="White" HorizontalAlignment="Stretch" Click="BtnGocatorTamam_Click"/>
                        <Button x:Name="BtnTablaTamam" Content="TABLA TAMAM" Background="#E67E22" Foreground="White" HorizontalAlignment="Stretch" Click="BtnTablaTamam_Click"/>
                    </StackPanel>
                </Border>

                <!-- 3. SÜTUN: INFICON ÖLÇÜM -->
                <Border Grid.Column="2" Background="#1A1A1C" CornerRadius="8" Padding="15">
                    <StackPanel Spacing="10">
                        <TextBlock Text="INFICON ÖLÇÜM" FontWeight="Bold" Foreground="#9C27B0"/>
                        <Rectangle Height="1" Fill="#333" Margin="0,0,0,5"/>

                        <TextBlock Text="Ölçüm Değeri:" Foreground="#888"/>
                        <TextBlock x:Name="TxtInficonDeger" Text="0.0" FontSize="20" FontWeight="Bold" Foreground="White"/>

                        <Rectangle Height="1" Fill="#333" Margin="0,5"/>
                        <TextBlock Text="Durumlar:" Foreground="#888"/>
                        <TextBlock x:Name="StatusInficonTamam" Text="TAMAM: Kapalı" Foreground="White"/>
                        <TextBlock x:Name="StatusInficonOk" Text="OK (Sonuç): Bekleniyor" Foreground="White"/>

                        <Button x:Name="BtnInficonOlcum" Content="ÖLÇÜM YAP" Background="#7B1FA2" Foreground="White" HorizontalAlignment="Stretch" Margin="0,10,0,0" Click="BtnInficonOlcum_Click"/>
                        <Button x:Name="BtnInficonReset" Content="RESETLEME YAP" Background="#6A1B9A" Foreground="White" HorizontalAlignment="Stretch" Margin="0,0,0,0" Click="BtnInficonReset_Click"/>
                        <Button x:Name="BtnInficonTamam" Content="INFICON TAMAM BİLDİR" Background="#9C27B0" Foreground="White" HorizontalAlignment="Stretch" Margin="0,0,0,0" Click="BtnInficonTamam_Click"/>
                    </StackPanel>
                </Border>

                <!-- 4. KAMERA ÖLÇÜM PANELİ (Sadeleştirilmiş) -->
                <Border Grid.Row="1" Grid.ColumnSpan="3" Background="#1A1A1C" CornerRadius="8" Padding="15">
                    <StackPanel Spacing="10">
                        <TextBlock Text="KAMERA ÖLÇÜM (MANUEL)" FontWeight="Bold" Foreground="#00BCD4"/>
                        <Rectangle Height="1" Fill="#333" Margin="0,0,0,5"/>

                        <Grid ColumnSpacing="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- RFID Değeri -->
                            <TextBlock Grid.Column="0" Text="RFID:" Foreground="#888" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtManuelRfid" Grid.Column="1" PlaceholderText="RFID değeri girin..."
                                     Background="#252528" Foreground="White" FontSize="12" Height="32"/>

                            <!-- Index Değeri -->
                            <TextBlock Grid.Column="2" Text="Index:" Foreground="#888" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtManuelIndex" Grid.Column="3" PlaceholderText="Job Index"
                                     Background="#252528" Foreground="White" FontSize="12" Height="32"/>

                            <!-- Ölçüm Başlat Butonu -->
                            <Button x:Name="BtnManuelOlcumBaslat" Grid.Column="4"
                                    Content="ÖLÇÜM AL" Background="#00BCD4" Foreground="White"
                                    FontWeight="Bold" Padding="20,6" Click="BtnManuelOlcumBaslat_Click"/>

                            <!-- Son Ölçüm Durumu -->
                            <TextBlock x:Name="TxtOlcumDurum" Grid.Column="5" Text="Bekleniyor..."
                                       Foreground="#888" VerticalAlignment="Center" FontSize="12"/>
                        </Grid>

                        <!-- Ölçüm Sonuçları -->
                        <ItemsControl x:Name="OlcumSonuclariList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="8,4" Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Id}" Foreground="#555" FontSize="11"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="#00BCD4" FontWeight="SemiBold" FontSize="12"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Value}" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- 5. KL100 SLIDER KONTROL (Manuel) -->
                <Border Grid.Row="2" Grid.ColumnSpan="3" Background="#1A1A1C" CornerRadius="8" Padding="15">
                    <StackPanel Spacing="10">
                        <!-- Başlık + Durum -->
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE71D;" Foreground="#E91E63" FontSize="14"/>
                                <TextBlock Text="KL100 SLIDER KONTROL" FontWeight="Bold" Foreground="#E91E63"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="Aktüel:" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="KL100AktuelIstasyon" Text="---" FontSize="12" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border x:Name="KL100HatModBorder" Background="#333" CornerRadius="4" Padding="8,3">
                                    <TextBlock x:Name="KL100HatModText" Text="---" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <Rectangle Height="1" Fill="#333" Margin="0,0,0,2"/>

                        <!-- Uyarılar -->
                        <Border x:Name="KL100AutoWarning" Background="#331E16" CornerRadius="4" Padding="10,6" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE7BA;" Foreground="#FF9800" FontSize="12"/>
                                <TextBlock Text="Hat OTOMATİK moddayken slider manuel kontrol edilemez!" Foreground="#FF9800" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="KL100HomeWarning" Background="#2D1616" CornerRadius="4" Padding="10,6" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE7BA;" Foreground="#F44336" FontSize="12"/>
                                <TextBlock Text="Robot HOME pozisyonunda değil! Slider hareket ettirilemez." Foreground="#F44336" FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <!-- ANA KONTROL ALANI -->
                        <Grid ColumnSpacing="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- SOL: Robot Home Durumu -->
                            <Border Grid.Column="0" Background="#202020" CornerRadius="6" Padding="10,8">
                                <Grid RowSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="ROBOT HOME DURUMU" FontSize="9" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Center"/>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="R1:" Foreground="#888" FontSize="10" VerticalAlignment="Center" Width="22"/>
                                        <ComboBox x:Name="CmbR1HomeSignal" Width="120" Background="#252528" Foreground="White" FontSize="10" Height="26"
                                                  PlaceholderText="Sinyal Seç..." SelectionChanged="CmbR1HomeSignal_SelectionChanged"/>
                                        <Ellipse x:Name="LedR1Home" Width="10" Height="10" Fill="Gray" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtR1HomeStatus" Text="---" FontSize="10" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Width="65"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="R2:" Foreground="#888" FontSize="10" VerticalAlignment="Center" Width="22"/>
                                        <ComboBox x:Name="CmbR2HomeSignal" Width="120" Background="#252528" Foreground="White" FontSize="10" Height="26"
                                                  PlaceholderText="Sinyal Seç..." SelectionChanged="CmbR2HomeSignal_SelectionChanged"/>
                                        <Ellipse x:Name="LedR2Home" Width="10" Height="10" Fill="Gray" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtR2HomeStatus" Text="---" FontSize="10" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Width="65"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- ORTA: İstasyon Pozisyon Ayarları -->
                            <Border Grid.Column="1" Background="#202020" CornerRadius="6" Padding="10,8">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="İSTASYON POZİSYONLARI (mm)" FontSize="9" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Center"/>
                                    <Grid ColumnSpacing="8" RowSpacing="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="BAKIM:" Foreground="#E91E63" FontSize="10" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBox x:Name="TxtKL100StBakimPos" Grid.Row="0" Grid.Column="1" PlaceholderText="0.0"
                                                 Background="#252528" Foreground="#E91E63" FontSize="11" Height="26" FontWeight="Bold"
                                                 LostFocus="KL100StationPos_LostFocus" BorderBrush="#333"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="İSTASYON 1:" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBox x:Name="TxtKL100St1Pos" Grid.Row="1" Grid.Column="1" PlaceholderText="0.0"
                                                 Background="#252528" Foreground="#4CAF50" FontSize="11" Height="26" FontWeight="Bold"
                                                 LostFocus="KL100StationPos_LostFocus" BorderBrush="#333"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="İSTASYON 2:" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBox x:Name="TxtKL100St2Pos" Grid.Row="2" Grid.Column="1" PlaceholderText="0.0"
                                                 Background="#252528" Foreground="#4CAF50" FontSize="11" Height="26" FontWeight="Bold"
                                                 LostFocus="KL100StationPos_LostFocus" BorderBrush="#333"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="İSTASYON 3:" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBox x:Name="TxtKL100St3Pos" Grid.Row="3" Grid.Column="1" PlaceholderText="0.0"
                                                 Background="#252528" Foreground="#4CAF50" FontSize="11" Height="26" FontWeight="Bold"
                                                 LostFocus="KL100StationPos_LostFocus" BorderBrush="#333"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- SAĞ: Hareket Kontrol -->
                            <Border Grid.Column="2" Background="#202020" CornerRadius="6" Padding="12,8">
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Mod Seçimi -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="HAREKET MODU:" FontSize="9" FontWeight="Bold" Foreground="#666" VerticalAlignment="Center"/>
                                        <RadioButton x:Name="RbKL100StationMode" Content="İSTASYONA GİT" GroupName="KL100Mode" IsChecked="True"
                                                     Foreground="White" FontSize="11" FontWeight="SemiBold" Checked="KL100Mode_Changed"/>
                                        <RadioButton x:Name="RbKL100PositionMode" Content="POZİSYONA GİT" GroupName="KL100Mode"
                                                     Foreground="White" FontSize="11" FontWeight="SemiBold" Checked="KL100Mode_Changed"/>
                                    </StackPanel>

                                    <!-- İstasyona Git Paneli -->
                                    <Border x:Name="KL100StationPanel" Grid.Row="1" Background="#252528" CornerRadius="4" Padding="10,8">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="Hedef İstasyon:" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="KL100HedefCombo" Width="140" Background="#1A1A1C" Foreground="White" FontSize="12" Height="32" IsEnabled="False">
                                                <ComboBoxItem Content="İSTASYON 1" Tag="1"/>
                                                <ComboBoxItem Content="İSTASYON 2" Tag="2"/>
                                                <ComboBoxItem Content="İSTASYON 3" Tag="3"/>
                                            </ComboBox>
                                            <StackPanel Spacing="1">
                                                <TextBlock Text="Kayıtlı Poz:" Foreground="#666" FontSize="9"/>
                                                <TextBlock x:Name="TxtKL100SelectedStationPos" Text="---" FontSize="12" FontWeight="Bold" Foreground="#FF9800"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Pozisyona Git Paneli -->
                                    <Border x:Name="KL100PositionPanel" Grid.Row="1" Background="#252528" CornerRadius="4" Padding="10,8" Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="Hedef Pozisyon (mm):" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBox x:Name="TxtKL100ManualPos" PlaceholderText="Pozisyon gir..." Width="130"
                                                     Background="#1A1A1C" Foreground="#FF9800" FontSize="13" FontWeight="Bold" Height="32" BorderBrush="#555"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Git Butonu -->
                                    <Button x:Name="BtnKL100HedefGit" Grid.Row="2" Click="BtnKL100HedefGit_Click"
                                            HorizontalAlignment="Stretch" Height="38" IsEnabled="False"
                                            Background="#E91E63" CornerRadius="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE768;" Foreground="White" FontSize="14"/>
                                            <TextBlock x:Name="TxtKL100GoButtonLabel" Text="İSTASYONA GİT" FontWeight="Bold" Foreground="White" FontSize="12"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Slider HOME Butonu -->
                                    <Button x:Name="BtnKL100SliderHome" Grid.Row="3" Click="BtnKL100SliderHome_Click"
                                            HorizontalAlignment="Stretch" Height="38"
                                            Background="#0078D4" CornerRadius="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE80F;" Foreground="White" FontSize="14"/>
                                            <TextBlock Text="SLIDER HOME" FontWeight="Bold" Foreground="White" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- SİNYAL TABLOSU (DETAYLI) -->
        <Border Grid.Row="2" Background="#141414" BorderThickness="0,2,0,0" BorderBrush="#333">
            <ListView x:Name="SignalListView" SelectionMode="None">
                <ListView.Header>
                    <Grid Padding="15,12" Background="#1E1E20" BorderBrush="#333" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="HEDEF ROBOT" Foreground="#AAA" FontWeight="Bold" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="VERİ YÖNÜ / KAYNAK" Foreground="#AAA" FontWeight="Bold" FontSize="11"/>
                        <TextBlock Grid.Column="2" Text="SİNYAL ADI" Foreground="#AAA" FontWeight="Bold" FontSize="11"/>
                        <TextBlock Grid.Column="3" Text="PLC TAG" Foreground="#AAA" FontWeight="Bold" FontSize="11"/>
                        <TextBlock Grid.Column="4" Text="BİLGİ TİPİ" Foreground="#AAA" FontWeight="Bold" FontSize="11"/>
                        <TextBlock Grid.Column="5" Text="ANLIK DEĞER" Foreground="#AAA" FontWeight="Bold" FontSize="11"/>
                    </Grid>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="15,10" BorderThickness="0,0,0,1" BorderBrush="#222">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2.5*"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Hedef Robot -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="🤖" FontSize="14" Foreground="#FF9800"/>
                                <TextBlock Text="{Binding RobotName}" Foreground="#E0E0E0" FontWeight="SemiBold"/>
                            </StackPanel>

                            <!-- Yön -->
                            <Border Grid.Column="1" Background="#222" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DirectionTarget}" Foreground="#4CAF50" FontSize="11" FontWeight="Bold"/>
                            </Border>

                            <!-- Sinyal Adı -->
                            <TextBlock Grid.Column="2" Text="{Binding VarName}" Foreground="#5AA4FF" FontWeight="Bold" VerticalAlignment="Center" FontSize="14"/>

                            <!-- PLC Tag -->
                            <TextBlock Grid.Column="3" Text="{Binding PlcTagName}" Foreground="#888" VerticalAlignment="Center"/>

                            <!-- Veri Tipi -->
                            <Border Grid.Column="4" Background="#333" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="{Binding PlcType}" Foreground="#BDBDBD" FontSize="11"/>
                            </Border>

                            <!-- Değer -->
                            <TextBlock Grid.Column="5" Text="{Binding ValueStr}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" FontSize="16"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>
