                                    <FontIcon Glyph="&#xE943;" Foreground="#0078D4" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="KONTROL" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Rectangle Height="1" Fill="#333"/>

                            <!-- System Status -->
                            <Border x:Name="ManuelLineStatusCard" Background="#252528" CornerRadius="6" Padding="10,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon x:Name="ManuelLineStatusIcon" Glyph="&#xE71A;" FontSize="14" Foreground="#888"/>
                                    <TextBlock x:Name="ManuelLineStatusText" Text="SISTEM KAPALI" FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                                </StackPanel>
                            </Border>

                            <!-- Safety & Alarm -->
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="ManuelSafetyBorder" Grid.Column="0" Background="#252528" CornerRadius="6" Padding="8,6">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="SAFETY" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                            <FontIcon x:Name="ManuelSafetyIcon" Glyph="&#xE7BA;" FontSize="10" Foreground="#666"/>
                                            <TextBlock x:Name="ManuelSafetyText" Text="OK" FontSize="9" FontWeight="Bold" Foreground="#666"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="ManuelAlarmBorder" Grid.Column="1" Background="#252528" CornerRadius="6" Padding="8,6">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="ALARM" FontSize="8" Foreground="#666" HorizontalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                            <FontIcon x:Name="ManuelAlarmIcon" Glyph="&#xE7BA;" FontSize="10" Foreground="#666"/>
                                            <TextBlock x:Name="ManuelAlarmText" Text="OK" FontSize="9" FontWeight="Bold" Foreground="#666"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Rectangle Height="1" Fill="#333"/>

                            <!-- BASLAT Button -->
                            <Button x:Name="BtnManuelBaslat" Click="BtnManuelBaslat_Click" CornerRadius="6" Padding="0" HorizontalAlignment="Stretch" Height="40" Background="#1E5631" BorderBrush="#27AE60" BorderThickness="1">
