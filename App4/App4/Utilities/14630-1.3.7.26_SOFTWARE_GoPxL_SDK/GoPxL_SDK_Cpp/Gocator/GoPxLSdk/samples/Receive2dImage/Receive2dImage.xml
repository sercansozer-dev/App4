<?xml version="1.0" encoding="UTF-8"?>
<Project>
  <Variables>
    <Variable name="Root">../../../..</Variable>
    <Variable name="Gocator">../../..</Variable>
    <Variable name="Platform">../../../../Platform</Variable>
  </Variables>
  <Sources>
    <SourceGroup name="Common">
      <Source>../Common/src/SampleUtils.h</Source>
      <Source>../Common/src/SampleUtils.cpp</Source>
    </SourceGroup>
    <Source>src/Receive2dImage.cpp</Source>
    <Source>src/ImageUtils.h</Source>
    <Source>src/ImageUtils.cpp</Source>
  </Sources>
  <Configurations>
    <Configuration>
      <Name>Debug</Name>
      <Platform>Win64</Platform>
      <Type>Executable</Type>
      <Template value="Symbols|Console|Unicode|Win64|MultiProcessorCompile|FastRuntimeChecks" />
      <BinDir>#[Root]/bin/win64d</BinDir>
      <LibDir>#[Root]/lib/win64d</LibDir>
      <TempDir>#[Root]/build</TempDir>
      <Target>Receive2dImage.exe</Target>
      <IncludeDirs>
        <IncludeDir>.</IncludeDir>
        <IncludeDir>#[Platform]/kApi</IncludeDir>
        <IncludeDir>#[Gocator]/GoApi</IncludeDir>
        <IncludeDir>#[Gocator]/GoPxLSdk</IncludeDir>
      </IncludeDirs>
      <Defines>
        <Define>WIN64</Define>
        <Define>_WINDOWS</Define>
        <Define>_USRDLL</Define>
        <Define>_CRT_SECURE_NO_WARNINGS=0</Define>
      </Defines>
      <LibraryDirs>
        <LibraryDir>#[Platform]/lib/win64d</LibraryDir>
        <LibraryDir>#[Root]/lib/win64d</LibraryDir>
      </LibraryDirs>
      <Libs>
        <Lib>kApi.lib</Lib>
        <Lib>GoApi.lib</Lib>
        <Lib>GoPxLSdk.lib</Lib>
      </Libs>
    </Configuration>
    <Configuration>
      <Name>Release</Name>
      <Platform>Win64</Platform>
      <Type>Executable</Type>
      <Template value="Optimize|Win64|MultiProcessorCompile|Console" />
      <BinDir>#[Root]/bin/win64</BinDir>
      <LibDir>#[Root]/lib/win64</LibDir>
      <TempDir>#[Root]/build</TempDir>
      <Target>Receive2dImage.exe</Target>
      <IncludeDirs>
        <IncludeDir>.</IncludeDir>
        <IncludeDir>#[Platform]/kApi</IncludeDir>
        <IncludeDir>#[Gocator]/GoApi</IncludeDir>
        <IncludeDir>#[Gocator]/GoPxLSdk</IncludeDir>
      </IncludeDirs>
      <Defines>
        <Define>WIN64</Define>
        <Define>NDEBUG</Define>
        <Define>_WINDOWS</Define>
        <Define>_USRDLL</Define>
        <Define>_CRT_SECURE_NO_WARNINGS=0</Define>
      </Defines>
      <LibraryDirs>
        <LibraryDir>#[Platform]/lib/win64</LibraryDir>
        <LibraryDir>#[Root]/lib/win64</LibraryDir>
      </LibraryDirs>
      <Libs>
        <Lib>kApi.lib</Lib>
        <Lib>GoApi.lib</Lib>
        <Lib>GoPxLSdk.lib</Lib>
      </Libs>
    </Configuration>
    <Configuration>
      <Name>Debug</Name>
      <Platform>Linux_X64</Platform>
      <Type>Executable</Type>
      <Template value="Symbols" />
      <BinDir>#[Root]/bin/linux_x64d</BinDir>
      <LibDir>#[Root]/lib/linux_x64d</LibDir>
      <TempDir>#[Root]/build</TempDir>
      <Target>Receive2dImage</Target>
      <IncludeDirs>
        <IncludeDir>.</IncludeDir>
        <IncludeDir>#[Platform]/kApi</IncludeDir>
        <IncludeDir>#[Gocator]/GoApi</IncludeDir>
        <IncludeDir>#[Gocator]/GoPxLSdk</IncludeDir>
      </IncludeDirs>
      <Defines>
        <Define>K_DEBUG</Define>
      </Defines>
      <LibraryDirs>
        <LibraryDir>#[Platform]/lib/linux_x64d</LibraryDir>
        <LibraryDir>#[Root]/lib/linux_x64d</LibraryDir>
      </LibraryDirs>
      <Libs>
        <Lib>pthread</Lib>
        <Lib>kApi</Lib>
        <Lib>GoApi</Lib>
        <Lib>GoPxLSdk</Lib>
      </Libs>
    </Configuration>
    <Configuration>
      <Name>Release</Name>
      <Platform>Linux_X64</Platform>
      <Type>Executable</Type>
      <Template value="Optimize" />
      <BinDir>#[Root]/bin/linux_x64</BinDir>
      <LibDir>#[Root]/lib/linux_x64</LibDir>
      <TempDir>#[Root]/build</TempDir>
      <Target>Receive2dImage</Target>
      <IncludeDirs>
        <IncludeDir>.</IncludeDir>
        <IncludeDir>#[Platform]/kApi</IncludeDir>
        <IncludeDir>#[Gocator]/GoApi</IncludeDir>
        <IncludeDir>#[Gocator]/GoPxLSdk</IncludeDir>
      </IncludeDirs>
      <LibraryDirs>
        <LibraryDir>#[Platform]/lib/linux_x64</LibraryDir>
        <LibraryDir>#[Root]/lib/linux_x64</LibraryDir>
      </LibraryDirs>
      <Libs>
        <Lib>pthread</Lib>
        <Lib>kApi</Lib>
        <Lib>GoApi</Lib>
        <Lib>GoPxLSdk</Lib>
      </Libs>
    </Configuration>
  </Configurations>
</Project>
